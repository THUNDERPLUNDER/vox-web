<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VOX – Det Visuelle Målbildet</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;600;700&family=Inter:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* DESIGN SYSTEM TOKENS */
        :root {
            --bg: #FDFDFC;          /* Warm Paper */
            --text: #0F172A;        /* Midnight Navy Text */
            --primary: #1E3A8A;     /* Navy - Tillit */
            --nerve: #FB7185;       /* Electric Coral - Innovasjon */
            --muted: #64748B;       /* Slate 500 */
            --surface: #FFFFFF;
            --radius-lg: 32px;
            --radius-md: 16px;
            --max-width: 1100px;
        }

        /* RESET & SCROLL BEHAVIOR */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        html {
            scroll-snap-type: y mandatory;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg);
            font-family: 'Inter', sans-serif;
            color: var(--text);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* SLIDE WRAPPER */
        section {
            height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            scroll-snap-align: start;
            padding: 40px;
            position: relative;
            overflow: hidden;
        }

        .container {
            max-width: var(--max-width);
            width: 100%;
            z-index: 10;
        }

        /* "NERVEN" - Den røde tråden */
        .the-pulse {
            position: fixed;
            left: 50%;
            bottom: 40px;
            transform: translateX(-50%);
            width: 200px;
            height: 2px;
            background: rgba(15, 23, 42, 0.1);
            z-index: 100;
        }
        .the-pulse-active {
            width: 30%;
            height: 100%;
            background: var(--nerve);
            box-shadow: 0 0 10px var(--nerve);
        }

        /* TYPOGRAPHY */
        h1, h2, h3 {
            font-family: 'Figtree', sans-serif;
            font-weight: 700;
            line-height: 1.1;
        }

        .title-large { font-size: clamp(3rem, 8vw, 6rem); letter-spacing: -0.04em; margin-bottom: 0.5em; }
        .title-medium { font-size: clamp(2rem, 5vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 0.6em; }
        
        .eyebrow {
            color: var(--nerve);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            display: block;
        }

        .lead { font-size: 1.4rem; color: var(--muted); font-weight: 300; max-width: 700px; }

        /* LAYOUT COMPONENTS */
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
        
        .card {
            background: var(--surface);
            padding: 48px;
            border-radius: var(--radius-md);
            border: 1px solid rgba(15, 23, 42, 0.05);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
            position: relative;
        }

        .image-frame {
            border-radius: var(--radius-lg);
            overflow: hidden;
            height: 500px;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.1);
        }

        .image-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* Justert fokus for å vise øret bedre */
            object-position: 80% center; 
        }

        /* BACKGROUND DECOR */
        .blob {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(251, 113, 133, 0.03) 0%, transparent 70%);
            border-radius: 50%;
            z-index: 1;
        }

        /* SLIDE SPECIFICS */
        #hero { background-color: #FDFDFC; }
        #identity { background-color: var(--text); color: white; }
        #identity h2, #identity .lead { color: white; }
        #identity .eyebrow { color: var(--nerve); }

        .tag {
            display: inline-block;
            padding: 8px 16px;
            background: rgba(251, 113, 133, 0.1);
            color: var(--nerve);
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.8rem;
            margin-bottom: 1rem;
        }

        /* ANIMATION */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .container { animation: fadeIn 1s ease-out forwards; }

        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; gap: 40px; }
            section { padding: 20px; }
            .image-frame { height: 300px; }
        }
    </style>
</head>
<body>

    <div class="the-pulse"><div class="the-pulse-active"></div></div>

    <!-- SLIDE 1: INTRO -->
    <section id="hero">
        <div class="blob" style="top: -200px; right: -200px;"></div>
        <div class="container">
            <span class="eyebrow">Etablering av Merkevare</span>
            <h1 class="title-large">VOX –<br>Hørehjelpen</h1>
            <p class="lead">Fra internetts pionerånd i 1993 til Kirkens SOS i 2025. En reise i trygg innovasjon og menneskelig omsorg.</p>
        </div>
    </section>

    <!-- SLIDE 2: IDENTITETEN -->
    <section id="identity">
        <div class="container">
            <div class="grid">
                <div>
                    <span class="eyebrow">Kjernen</span>
                    <h2 class="title-medium">En Nerve av<br>Innovasjon</h2>
                    <p class="lead" style="margin-bottom: 2rem; opacity: 0.9;">Vi opererer i paradokset mellom det tekniske modemet og den varme samtalen.</p>
                    <div style="border-left: 4px solid var(--nerve); padding-left: 2rem; margin-top: 3rem;">
                        <p style="font-style: italic; font-weight: 300; font-size: 1.2rem;">"Målet er ikke å bare vise vei, men å være tryggheten i rommet mens teknologien mestres."</p>
                    </div>
                </div>
                <div style="display: flex; flex-direction: column; gap: 20px;">
                    <div class="card" style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); color: white;">
                        <h3 style="color: var(--nerve); margin-bottom: 10px;">Midnight Navy</h3>
                        <p style="font-size: 0.9rem; opacity: 0.8;">Autoritet, Soliditet, Kirkens SOS.</p>
                    </div>
                    <div class="card" style="background: rgba(251, 113, 133, 0.1); border-color: var(--nerve); color: white;">
                        <h3 style="color: var(--nerve); margin-bottom: 10px;">Electric Coral</h3>
                        <p style="font-size: 0.9rem; opacity: 0.8;">Innovasjon, Puls, Menneskemøtet.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SLIDE 3: ERFARING -->
    <section>
        <div class="blob" style="bottom: -200px; left: -200px;"></div>
        <div class="container">
            <div class="grid">
                <div style="text-align: center;">
                    <div style="font-size: 12rem; font-family: 'Figtree'; font-weight: 800; color: var(--primary); opacity: 0.05; position: absolute; top: 10%; left: 0;">30 ÅR</div>
                    <div class="card" style="display: inline-block; padding: 60px;">
                        <i class="fa-solid fa-bolt-lightning" style="font-size: 80px; color: var(--nerve);"></i>
                        <p style="margin-top: 20px; font-weight: 600; color: var(--primary);">EST. 1993</p>
                    </div>
                </div>
                <div>
                    <span class="eyebrow">Erfaring</span>
                    <h2 class="title-medium">Fundamentet</h2>
                    <p style="margin-bottom: 1.5rem;">Vår autoritet bygger på en unik tidslinje:</p>
                    <ul style="list-style: none;">
                        <li style="margin-bottom: 1rem; display: flex; gap: 15px; align-items: center;"><i class="fa-solid fa-circle-check" style="color: var(--nerve);"></i> Pionerånd (IRC, BBS, HTML '96)</li>
                        <li style="margin-bottom: 1rem; display: flex; gap: 15px; align-items: center;"><i class="fa-solid fa-circle-check" style="color: var(--nerve);"></i> Menneskelig dybde (Kirkens SOS)</li>
                        <li style="margin-bottom: 1rem; display: flex; gap: 15px; align-items: center;"><i class="fa-solid fa-circle-check" style="color: var(--nerve);"></i> Systemforståelse (Designsystem Lead)</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- SLIDE 4: VISUELT UTTRYKK -->
    <section>
        <div class="container">
            <div class="grid">
                <div>
                    <span class="tag">Design Tokens</span>
                    <h2 class="title-medium">Form & Følelse</h2>
                    <p class="lead">Vi bruker moderne geometri kombinert med klassisk typografi for å skape en følelse av "Ekspertise med Empati".</p>
                    <div style="margin-top: 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div>
                            <p style="font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">Typografi</p>
                            <p>Figtree / Inter</p>
                        </div>
                        <div>
                            <p style="font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">Radius</p>
                            <p>32px (rounded-3xl)</p>
                        </div>
                    </div>
                </div>
                <div class="image-frame">
                    <!-- Bildet er nå sentrert mer mot høyre i CSS for å vise øret/detaljene -->
                    <img src="http://googleusercontent.com/image_collection/image_retrieval/15185958262209202660" alt="Høreapparat detaljfoto">
                </div>
            </div>
        </div>
    </section>

    <!-- SLIDE 5: NESTE SKRITT -->
    <section style="background: var(--primary); color: white;">
        <div class="container" style="text-align: center;">
            <span class="eyebrow" style="color: var(--nerve);">Fremtiden</span>
            <h2 class="title-large" style="color: white;">Neste Skritt</h2>
            <p class="lead" style="color: rgba(255,255,255,0.8); margin: 0 auto 3rem;">Fra den første koden i 1996 til en revolusjon for hverdagsmestring i 2026.</p>
            <div style="display: flex; gap: 20px; justify-content: center;">
                <div style="padding: 20px 40px; border: 2px solid var(--nerve); border-radius: 100px; font-weight: 700; letter-spacing: 0.1em;">PROTOTYPE</div>
                <div style="padding: 20px 40px; background: white; color: var(--primary); border-radius: 100px; font-weight: 700; letter-spacing: 0.1em;">VOX.RADDUM.NO</div>
            </div>
        </div>
    </section>

</body>
</html>