---
import "../styles/global.css";

const { title = "VOX" } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen antialiased">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <slot />
    </div>
  </body>
</html>