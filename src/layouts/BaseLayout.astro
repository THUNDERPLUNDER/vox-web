---
import "../styles/global.css";

const { title = "VOX" } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script defer src="https://www.gstatic.com/ces-console/fast/chat-messenger/prod/v1.15/chat-messenger.js"></script>
    <link rel="stylesheet" href="https://www.gstatic.com/ces-console/fast/chat-messenger/prod/v1.15/themes/chat-messenger.css">
  </head>

  <body class="min-h-screen antialiased">
    <div class="fixed inset-0 -z-10 overflow-hidden">
      <!-- base wash -->
      <div class="absolute inset-0" style="background: rgb(var(--bg));"></div>
  
      <!-- orb 1: primary, top-left -->
      <div
        class="absolute -top-[12%] -left-[12%] h-[520px] w-[520px] rounded-full blur-[120px]"
        style="background: rgb(var(--primary) / 0.06);"
      ></div>
  
      <!-- orb 2: coral/focus, mid-right -->
      <div
        class="absolute top-[35%] -right-[8%] h-[420px] w-[420px] rounded-full blur-[110px]"
        style="background: rgb(var(--focus) / 0.10);"
      ></div>
  
      <!-- orb 3: primary, bottom-center -->
      <div
        class="absolute -bottom-[22%] left-[18%] h-[640px] w-[640px] rounded-full blur-[150px]"
        style="background: rgb(var(--primary) / 0.04);"
      ></div>
    </div>
  
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <slot />
    </div>

    <script>
      console.log("CES Widget: Initializing script...");

      window.addEventListener('chat-messenger-loaded', () => {
        try {
          chatSdk.registerContext(
            chatSdk.prebuilts.ces.createContext({
              deploymentName: 'projects/1088102295663/locations/eu/apps/1741e68d-0528-4625-8b83-99a0dbb5298f/deployments/dc1619d0-44a1-401b-92a6-1357c29274ea',
              tokenBroker: { enableTokenBroker: true, enableRecaptcha: false }
            })
          );
        } catch (error) {
          console.error('CES Widget Error', error);
        }
      });

      window.addEventListener("chat-messenger-error", (e) => {
        console.error("CES Widget: chat-messenger-error event fired.", e.detail || e);
      });

      document.addEventListener('DOMContentLoaded', () => {
        const widget = document.querySelector('chat-messenger');
        if(widget) {
            console.log("CES Widget: Found widget element.", widget);
            widget.addEventListener('open', (e) => console.log('CES Widget: open event', e.detail || e));
            widget.addEventListener('close', (e) => console.log('CES Widget: close event', e.detail || e));

            if (window.location.pathname.startsWith('/no')) {
                console.log("CES Widget: /no page detected, making widget launcher visible for debug.");
                widget.show?.();
                widget.style.display = 'block';
            }
        } else {
            console.error("CES Widget: Could not find chat-messenger element");
        }
      });
    </script>
    
    <chat-messenger url-allowlist="*">
      <chat-messenger-container
        chat-title="Hørehjelpen"
        chat-title-icon="https://gstatic.com/dialogflow-console/common/assets/ccai-favicons/conversational_agents.png"
        enable-file-upload
        enable-audio-input
      >
        <chat-reset-session-button slot="titlebar-actions" title-text="Start new chat"></chat-reset-session-button>
      </chat-messenger-container>
    </chat-messenger>
  </body>
</html>