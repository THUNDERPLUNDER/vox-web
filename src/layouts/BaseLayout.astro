---
/* CONTRACT: Shared application shell with global header, background mood layer, and CES bootstrapping. */
import "../styles/global.css";
import Header from "../components/nav/Header.astro";
import MobileMenuSheet from "../components/nav/MobileMenuSheet.astro";

const { title = "VOX", currentPath = "" } = Astro.props;
---

<!doctype html>
<html lang="no" data-theme="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        var STORAGE_KEY = "vox-theme";
        var v = null;
        try {
          v = localStorage.getItem(STORAGE_KEY);
        } catch (_) {}
        var mode =
          v === "light" || v === "dark" || v === "system" ? v : "system";
        document.documentElement.setAttribute("data-theme", mode);
        function resolvedColorScheme(m) {
          if (m === "light") return "light";
          if (m === "dark") return "dark";
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.style.colorScheme = resolvedColorScheme(mode);
      })();
    </script>
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
    />
    <slot name="head" />
    <script defer src="https://www.gstatic.com/ces-console/fast/chat-messenger/prod/v1.15/chat-messenger.js"></script>
    <link rel="stylesheet" href="https://www.gstatic.com/ces-console/fast/chat-messenger/prod/v1.15/themes/chat-messenger.css">
    <style is:global>
      /* Sonic gradient blob: light ~5%; dark / system→dark ~17% for glass depth */
      .vox-sonic-blob {
        background: linear-gradient(
          135deg,
          rgb(var(--accent-gradient-start) / 0.05),
          rgb(var(--accent-gradient-end) / 0.05)
        );
      }
      html[data-theme="dark"] .vox-sonic-blob {
        background: linear-gradient(
          135deg,
          rgb(var(--accent-gradient-start) / 0.17),
          rgb(var(--accent-gradient-end) / 0.17)
        );
      }
      @media (prefers-color-scheme: dark) {
        html[data-theme="system"] .vox-sonic-blob {
          background: linear-gradient(
            135deg,
            rgb(var(--accent-gradient-start) / 0.17),
            rgb(var(--accent-gradient-end) / 0.17)
          );
        }
      }
    </style>
  </head>

  <body class="min-h-screen antialiased">
    <div class="fixed inset-0 -z-10 overflow-hidden">
      <!-- base wash -->
      <div class="absolute inset-0" style="background: rgb(var(--bg));"></div>

      <!-- Sonic gradient blob: tonal depth (opacity via .vox-sonic-blob) -->
      <div
        class="vox-sonic-blob pointer-events-none absolute left-1/2 top-[30%] h-[min(100vh,900px)] w-[min(130vw,1100px)] -translate-x-1/2 rounded-full blur-[160px]"
        aria-hidden="true"
      ></div>
  
      <!-- orb 1: primary, top-left -->
      <div
        class="absolute -top-[12%] -left-[12%] h-[520px] w-[520px] rounded-full blur-[120px]"
        style="background: rgb(var(--primary) / var(--orb-a));"
      ></div>
  
      <!-- orb 2: focus accent, mid-right -->
      <div
        class="absolute top-[35%] -right-[8%] h-[420px] w-[420px] rounded-full blur-[110px]"
        style="background: rgb(var(--focus) / var(--orb-b));"
      ></div>
  
      <!-- orb 3: primary, bottom-center -->
      <div
        class="absolute -bottom-[22%] left-[18%] h-[640px] w-[640px] rounded-full blur-[150px]"
        style="background: rgb(var(--primary) / var(--orb-c));"
      ></div>
    </div>

    <header class="fixed inset-x-0 top-0 z-40">
      <div
        class="bg-[rgb(var(--surface-elevated))/0.88] backdrop-blur-xl"
        style="box-shadow: var(--shadow-header);"
      >
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
          <Header currentPath={currentPath} />
        </div>
      </div>
    </header>

    <MobileMenuSheet currentPath={currentPath} />

    <div class="mx-auto max-w-6xl px-4 pt-28 sm:px-6 sm:pt-30 lg:px-8">
      <slot />
    </div>

    <script is:inline>
      const deploymentName =
        "projects/1088102295663/locations/eu/apps/1741e68d-0528-4625-8b83-99a0dbb5298f/deployments/dc1619d0-44a1-401b-92a6-1357c29274ea";

      const register = (widget) => {
        if (!widget) return false;
        if (!window.chatSdk) return false;
        try {
          chatSdk.registerContext(
            chatSdk.prebuilts.ces.createContext({
              deploymentName,
              tokenBroker: { enableTokenBroker: true, enableRecaptcha: false },
            }),
          );
          return true;
        } catch (e) {
          console.error("chat-messenger-error", e?.detail || e);
          return false;
        }
      };

      function syncCesWidgetTheme() {
        const widget = document.getElementById("ces-widget");
        if (!widget) return;
        const mode = document.documentElement.getAttribute("data-theme") || "system";
        let dark = false;
        if (mode === "dark") dark = true;
        else if (mode === "light") dark = false;
        else
          dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        widget.setAttribute("theme-id", dark ? "dark" : "light");

        // Force CES host variables inline (widget defaults can win over external CSS).
        const root = getComputedStyle(document.documentElement);
        const token = (name) => root.getPropertyValue(name).trim();
        const asRgb = (name) => {
          const raw = token(name);
          return raw ? `rgb(${raw})` : "";
        };
        const set = (name, value) => {
          if (value) widget.style.setProperty(name, value);
        };

        const surfaceTone = dark
          ? "rgb(var(--surface-subtle))"
          : "color-mix(in srgb, rgb(var(--surface-subtle)) 95%, rgb(var(--accent-gradient-start)) 5%)";
        const containerTone = dark
          ? "rgb(var(--surface-elevated))"
          : "color-mix(in srgb, rgb(var(--surface-elevated)) 97%, rgb(var(--accent-gradient-start)) 3%)";
        const composerTone = dark
          ? "rgb(var(--surface-elevated))"
          : "color-mix(in srgb, rgb(var(--surface-elevated)) 90%, rgb(var(--accent-gradient-start)) 10%)";
        const inputBoxTone = composerTone;

        set("--chat-messenger-color--primary", asRgb("--primary"));
        set("--chat-messenger-color--on-primary", asRgb("--on-sonic"));
        set("--chat-messenger-color--surface", surfaceTone);
        set("--chat-messenger-color--surface-container", containerTone);
        set("--chat-messenger-color--on-surface", asRgb("--text"));
        set("--chat-messenger-color--on-surface-variant", asRgb("--text-secondary"));
        set("--chat-messenger-color--outline", asRgb("--border"));
        set("--chat-messenger-color--surface-container-low", surfaceTone);
        set("--chat-messenger-color--surface-container-high", containerTone);
        set("--chat-messenger-internal-input-background-color", composerTone);
        set("--chat-messenger-internal-input-background", composerTone);
        set("--chat-messenger-internal-chat-border-radius", token("--radius-lg"));
        set("--chat-messenger-internal-chat-padding", "8px 12px 0 12px");
        set("--chat-messenger-internal-input-gutter", "8px");
        set("--chat-messenger-internal-input-inner-padding", "16px 18px");
        set("--chat-messenger-internal-input-font-size", "15px");
        set("--chat-messenger-internal-input-box-background-color", inputBoxTone);
        set("--chat-messenger-internal-input-box-border", "1px solid rgb(var(--border) / 0.1)");
        set("--chat-messenger-internal-input-box-focus-border", "1px solid rgb(var(--focus-ring) / 0.55)");
        set("--chat-messenger-internal-input-box-border-radius", "1rem");
        set("--chat-messenger-internal-input-border-top", "none");
        set("--chat-messenger-internal-input-border-bottom", "none");
        set("--chat-messenger-internal-input-max-width", "100%");
        set("--chat-messenger-internal-input-box-min-height", "62px");
        set("--chat-messenger-internal-chat-messagelist-border", "none");
        set(
          "--chat-messenger-internal-chat-messagelist-scroll-shadow-background",
          "linear-gradient(180deg, rgb(var(--surface-elevated) / 0) 0%, rgb(var(--surface-elevated) / 0.78) 58%, rgb(var(--surface-elevated)) 100%)",
        );
        set("--chat-messenger-internal-send-icon-background", composerTone);
        set("--chat-messenger-internal-send-icon-color", asRgb("--primary"));
        set("--chat-messenger-internal-send-icon-border-radius", "1rem");
        set("--chat-messenger-internal-send-icon-offset-x", "0px");
        set("--chat-messenger-color--state-layer-on-surface", "rgb(var(--text) / 0.05)");
        set(
          "--chat-messenger-elevation",
          dark
            ? "0 20px 46px -18px rgba(0,0,0,0.62), 0 8px 24px -12px rgba(0,0,0,0.42)"
            : "0 18px 42px -20px rgba(28,32,38,0.18), 0 8px 20px -12px rgba(28,32,38,0.12)",
        );
      }

      window.addEventListener("chat-messenger-loaded", () => {
        const widget = document.getElementById("ces-widget");
        if (!widget) return;
        syncCesWidgetTheme();
        if (register(widget)) return;
        let tries = 0;
        const t = setInterval(() => {
          tries++;
          if (register(widget) || tries > 10) clearInterval(t);
        }, 200);
      });

      window.addEventListener("chat-messenger-error", (e) => {
        console.error("chat-messenger-error", e?.detail || e);
      });

      document.addEventListener("DOMContentLoaded", () => {
        syncCesWidgetTheme();
        new MutationObserver(syncCesWidgetTheme).observe(
          document.documentElement,
          { attributes: true, attributeFilter: ["data-theme"] },
        );
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", () => {
            if (document.documentElement.getAttribute("data-theme") === "system") {
              syncCesWidgetTheme();
            }
          });
      });
    </script>
  </body>
</html>