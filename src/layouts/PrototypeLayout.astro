---
/* CONTRACT: Isolated backstage wireframe shell for /vis; no VOX app shell, nav, or theme coupling. */
import "../styles/global.css";
import { slugFromHtmlFilename } from "../lib/vis-wireframes";

interface Props {
  title: string;
  activePage: "forside" | "hub" | "artikkel" | "wireframe";
  /** When set (e.g. on /vis/[slug]), compact pager in the main top bar; mobile uses position + dialog list, desktop uses select. Hidden in ?preview=1. */
  wireframeFileNav?: {
    allFiles: string[];
    currentSlug: string;
  };
}

const { title, activePage, wireframeFileNav } = Astro.props;

const base = import.meta.env.BASE_URL;

const fileNavIndex =
  wireframeFileNav?.allFiles.findIndex((f) => slugFromHtmlFilename(f) === wireframeFileNav.currentSlug) ?? -1;
const prevFileNavHref =
  wireframeFileNav && fileNavIndex > 0
    ? `${base}vis/${encodeURIComponent(slugFromHtmlFilename(wireframeFileNav.allFiles[fileNavIndex - 1]!))}`
    : null;
const nextFileNavHref =
  wireframeFileNav && fileNavIndex >= 0 && fileNavIndex < wireframeFileNav.allFiles.length - 1
    ? `${base}vis/${encodeURIComponent(slugFromHtmlFilename(wireframeFileNav.allFiles[fileNavIndex + 1]!))}`
    : null;

const fileNavPosition =
  wireframeFileNav && fileNavIndex >= 0 ? fileNavIndex + 1 : 0;
const fileNavTotal = wireframeFileNav?.allFiles.length ?? 0;

/**
 * Exit preview: same path without `preview` (build-time path is correct per page).
 * With static output, runtime `?preview=1` is toggled via `html.vis-preview` + CSS + head script.
 */
const exitPreviewHref = (() => {
  const u = new URL(Astro.url.href);
  u.searchParams.delete("preview");
  const q = u.searchParams.toString();
  return q ? `${u.pathname}?${q}` : u.pathname;
})();
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>VIS Wireframe - {title}</title>
    <script is:inline>
      (function () {
        try {
          if (new URLSearchParams(window.location.search).get("preview") === "1") {
            document.documentElement.classList.add("vis-preview");
          }
        } catch (_) {}
      })();
    </script>
    <style is:global>
      /* Clean preview: chrome hidden, near-fullscreen content; toggled only when ?preview=1 (see script above). */
      html.vis-preview .vis-prototype-topbar,
      html.vis-preview .vis-prototype-bottombar,
      html.vis-preview .vis-wireframe-filetools,
      html.vis-preview #vis-file-picker-dialog {
        display: none !important;
      }
      .vis-prototype-exit {
        display: none;
      }
      html.vis-preview .vis-prototype-exit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      html.vis-preview .vis-prototype-body {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        min-height: 100dvh !important;
      }
      html.vis-preview .vis-prototype-main {
        min-height: 100dvh !important;
      }
      html.vis-preview .vis-wireframe-iframe {
        min-height: 100dvh !important;
        height: 100dvh !important;
      }
      #vis-file-picker-dialog::backdrop {
        background: rgb(0 0 0 / 0.45);
      }
    </style>
  </head>
  <body class="vis-prototype-body bg-gray-100 antialiased pt-10 pb-20 sm:pb-0">
    <div
      class:list={[
        "vis-prototype-topbar fixed top-0 left-0 z-[9999] w-full border-b border-gray-950 bg-gray-900 font-mono text-xs text-white shadow-md",
        wireframeFileNav
          ? "grid h-10 grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-x-1.5 px-2 sm:gap-x-3 sm:px-4"
          : "flex h-10 items-center justify-between px-4",
      ]}
    >
      <div class:list={["flex min-w-0 items-center", wireframeFileNav ? "space-x-3 sm:space-x-6" : "space-x-6"]}>
        <div class="flex shrink-0 items-baseline gap-2">
          <span class="text-sm font-bold uppercase tracking-widest text-purple-400">VIS</span>
          <span class="text-[10px] font-medium text-gray-500">v0.1</span>
        </div>

        <nav class="hidden min-w-0 border-l border-gray-700 pl-3 sm:flex sm:space-x-1 sm:pl-6">
          <a
            href={`${base}vis/`}
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "forside"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            Forside
          </a>
          <a
            href={`${base}vis/hub`}
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "hub"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            Hub
          </a>
          <a
            href={`${base}vis/artikkel`}
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "artikkel"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            Artikkel
          </a>
        </nav>
      </div>

      {
        wireframeFileNav && (
          <div class="vis-wireframe-filetools flex max-w-[100vw] shrink-0 items-center justify-center gap-0.5 sm:gap-1">
            {prevFileNavHref ? (
              <a
                href={prevFileNavHref}
                class="inline-flex h-7 min-w-[1.75rem] shrink-0 items-center justify-center rounded border border-gray-700 bg-gray-900 text-sm leading-none text-gray-300 hover:border-gray-600 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                aria-label="Forrige wireframe"
              >
                ‹
              </a>
            ) : (
              <span
                class="inline-flex h-7 min-w-[1.75rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-sm text-gray-600"
                aria-hidden="true"
              >
                ‹
              </span>
            )}

            <button
              type="button"
              id="vis-file-picker-open"
              class="inline-flex h-7 shrink-0 items-center gap-0.5 rounded border border-gray-700 bg-gray-900 px-1.5 py-0.5 text-[11px] tabular-nums text-gray-300 hover:border-gray-600 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500 md:hidden"
              aria-haspopup="dialog"
              aria-controls="vis-file-picker-dialog"
              aria-label={`Velg wireframe, viser ${fileNavPosition} av ${fileNavTotal}`}
            >
              {fileNavPosition} / {fileNavTotal}
              <span aria-hidden="true" class="text-[10px]">
                ▾
              </span>
            </button>

            <label class="sr-only" for="vis-wireframe-jump-desktop">
              Velg wireframe-fil
            </label>
            <select
              id="vis-wireframe-jump-desktop"
              class="hidden h-7 max-w-[min(14rem,calc(100vw-12rem))] shrink truncate rounded border border-gray-700 bg-gray-900 py-0 pl-2 pr-7 text-[11px] text-gray-200 focus:border-gray-600 focus:outline-none focus:ring-1 focus:ring-gray-600 md:block"
              aria-label="Velg wireframe-fil"
            >
              {wireframeFileNav.allFiles.map((name) => {
                const s = slugFromHtmlFilename(name);
                const optHref = `${base}vis/${encodeURIComponent(s)}`;
                const sel = s === wireframeFileNav.currentSlug;
                return (
                  <option value={optHref} selected={sel}>
                    {name}
                  </option>
                );
              })}
            </select>

            {nextFileNavHref ? (
              <a
                href={nextFileNavHref}
                class="inline-flex h-7 min-w-[1.75rem] shrink-0 items-center justify-center rounded border border-gray-700 bg-gray-900 text-sm leading-none text-gray-300 hover:border-gray-600 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                aria-label="Neste wireframe"
              >
                ›
              </a>
            ) : (
              <span
                class="inline-flex h-7 min-w-[1.75rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-sm text-gray-600"
                aria-hidden="true"
              >
                ›
              </span>
            )}
          </div>
        )
      }

      <div class="flex items-center justify-end space-x-2 text-gray-500 sm:space-x-4">
        <span class="hidden md:inline">Visning for: Vibeke</span>
        <div class="h-2 w-2 shrink-0 rounded-full bg-green-500" title="Live"></div>
      </div>
    </div>

    {
      wireframeFileNav && (
        <dialog
          id="vis-file-picker-dialog"
          class="z-[10001] w-[min(100vw-2rem,20rem)] max-w-[calc(100vw-2rem)] overflow-hidden rounded-lg border border-gray-700 bg-gray-900 p-0 text-gray-200 shadow-2xl"
          aria-labelledby="vis-file-picker-title"
        >
          <div class="border-b border-gray-800 px-3 py-2">
            <p id="vis-file-picker-title" class="text-[10px] font-medium uppercase tracking-wide text-gray-500">
              Velg wireframe
            </p>
          </div>
          <ul class="max-h-[min(60dvh,22rem)] overflow-y-auto p-2">
            {wireframeFileNav.allFiles.map((name) => {
              const s = slugFromHtmlFilename(name);
              const href = `${base}vis/${encodeURIComponent(s)}`;
              const current = s === wireframeFileNav.currentSlug;
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      "block truncate rounded px-2 py-2 text-xs hover:bg-gray-800",
                      current ? "bg-gray-800 text-white" : "text-gray-300",
                    ]}
                  >
                    {name}
                  </a>
                </li>
              );
            })}
          </ul>
          <div class="border-t border-gray-800 p-2">
            <button
              type="button"
              class="w-full rounded border border-gray-700 bg-gray-900 py-1.5 text-[11px] text-gray-400 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
              id="vis-file-picker-close"
            >
              Lukk
            </button>
          </div>
        </dialog>
      )
    }

    <script is:inline>
      (function () {
        var sel = document.getElementById("vis-wireframe-jump-desktop");
        if (sel)
          sel.addEventListener("change", function () {
            var v = sel.value;
            if (v) window.location.href = v;
          });
        var openBtn = document.getElementById("vis-file-picker-open");
        var dlg = document.getElementById("vis-file-picker-dialog");
        var closeBtn = document.getElementById("vis-file-picker-close");
        if (openBtn && dlg) {
          openBtn.addEventListener("click", function () {
            if (typeof dlg.showModal === "function") dlg.showModal();
          });
        }
        if (closeBtn && dlg) {
          closeBtn.addEventListener("click", function () {
            dlg.close();
          });
        }
      })();
    </script>

    <div
      class="vis-prototype-bottombar fixed bottom-0 left-0 z-[9999] flex w-full justify-around border-t border-gray-800 bg-gray-900 py-3 font-mono text-xs text-white sm:hidden"
      style="padding-bottom: env(safe-area-inset-bottom);"
    >
      <a
        href={`${base}vis/`}
        class:list={[activePage === "forside" ? "text-gray-300" : "text-gray-500"]}
      >
        Forside
      </a>
      <a
        href={`${base}vis/hub`}
        class:list={[activePage === "hub" ? "text-gray-300" : "text-gray-500"]}
      >
        Hub
      </a>
      <a
        href={`${base}vis/artikkel`}
        class:list={[activePage === "artikkel" ? "text-gray-300" : "text-gray-500"]}
      >
        Artikkel
      </a>
    </div>

    <a
      href={exitPreviewHref}
      class="vis-prototype-exit fixed z-[10000] max-w-[calc(100vw-1.5rem)] items-center justify-center rounded-full bg-gray-900/95 px-3.5 py-2.5 font-mono text-xs font-medium text-white shadow-lg backdrop-blur-sm transition hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/80"
      style="top: calc(env(safe-area-inset-top, 0px) + 12px); right: calc(env(safe-area-inset-right, 0px) + 12px);"
      aria-label="Tilbake til prototype-meny"
    >
      ← Tilbake
    </a>

    <div class="vis-prototype-main relative min-h-screen w-full bg-white">
      <slot />
    </div>
  </body>
</html>
