---
/* CONTRACT: Isolated wireframe shell for /klarlyd prototypes; no VOX app shell, nav, or theme coupling. */
import "../styles/global.css";

interface Props {
  title: string;
  activePage: "forside" | "hub" | "artikkel";
}

const { title, activePage } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>KlarLyd Wireframe - {title}</title>
  </head>
  <body class="bg-gray-100 antialiased pt-10 pb-20 sm:pb-0">
    <div
      class="fixed top-0 left-0 z-[9999] flex h-10 w-full items-center justify-between border-b border-gray-950 bg-gray-900 px-4 font-mono text-xs text-white shadow-md"
    >
      <div class="flex items-center space-x-6">
        <span class="font-bold uppercase tracking-widest text-purple-400">KlarLyd v0.1</span>

        <nav class="hidden border-l border-gray-700 pl-6 sm:flex sm:space-x-1">
          <a
            href="/klarlyd/"
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "forside"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            Forside
          </a>
          <a
            href="/klarlyd/hub"
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "hub"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            NAV-Hub
          </a>
          <a
            href="/klarlyd/artikkel"
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "artikkel"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            Artikkel
          </a>
        </nav>
      </div>

      <div class="flex items-center space-x-4 text-gray-500">
        <span class="hidden md:inline">Visning for: Vibeke</span>
        <div class="h-2 w-2 rounded-full bg-green-500" title="Live"></div>
      </div>
    </div>

    <div
      class="fixed bottom-0 left-0 z-[9999] flex w-full justify-around border-t border-gray-800 bg-gray-900 py-3 font-mono text-xs text-white sm:hidden"
      style="padding-bottom: env(safe-area-inset-bottom);"
    >
      <a
        href="/klarlyd/"
        class:list={[activePage === "forside" ? "text-purple-400" : "text-gray-400"]}
      >
        Forside
      </a>
      <a
        href="/klarlyd/hub"
        class:list={[activePage === "hub" ? "text-purple-400" : "text-gray-400"]}
      >
        Hub
      </a>
      <a
        href="/klarlyd/artikkel"
        class:list={[activePage === "artikkel" ? "text-purple-400" : "text-gray-400"]}
      >
        Artikkel
      </a>
    </div>

    <div class="relative min-h-screen w-full bg-white">
      <slot />
    </div>
  </body>
</html>
