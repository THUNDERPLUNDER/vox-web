---
/* CONTRACT: Isolated backstage wireframe shell for /vis; no VOX app shell, nav, or theme coupling. */
import "../styles/global.css";
import { slugFromHtmlFilename } from "../lib/vis-wireframes";

interface Props {
  title: string;
  /** When set (e.g. on /vis/[slug]), compact pager in the main top bar; mobile uses position + dialog list, desktop uses select. */
  wireframeFileNav?: {
    allFiles: string[];
    currentSlug: string;
  };
  /** Parsed head metadata from the raw HTML file (wireframe viewer only). */
  wireframeMeta?: {
    displayTitle: string;
    description?: string;
    /** `<meta name="vis:delta">` — endring fra forrige iterasjon. */
    delta?: string;
    /** Rå HTML under `public/vis/raw/` (samme som «Direkte fil» på `/vis`). */
    rawHref: string;
  };
}

const { title, wireframeFileNav, wireframeMeta } = Astro.props;

const base = import.meta.env.BASE_URL;

const hasInfobar = !!wireframeMeta;

const fileNavIndex =
  wireframeFileNav?.allFiles.findIndex((f) => slugFromHtmlFilename(f) === wireframeFileNav.currentSlug) ?? -1;
const prevFileNavHref =
  wireframeFileNav && fileNavIndex > 0
    ? `${base}vis/${encodeURIComponent(slugFromHtmlFilename(wireframeFileNav.allFiles[fileNavIndex - 1]!))}`
    : null;
const nextFileNavHref =
  wireframeFileNav && fileNavIndex >= 0 && fileNavIndex < wireframeFileNav.allFiles.length - 1
    ? `${base}vis/${encodeURIComponent(slugFromHtmlFilename(wireframeFileNav.allFiles[fileNavIndex + 1]!))}`
    : null;

const fileNavPosition =
  wireframeFileNav && fileNavIndex >= 0 ? fileNavIndex + 1 : 0;
const fileNavTotal = wireframeFileNav?.allFiles.length ?? 0;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>VIS Wireframe - {title}</title>
    <style is:global>
      #vis-file-picker-dialog::backdrop {
        background: rgb(0 0 0 / 0.45);
      }
    </style>
  </head>
  <body
    class:list={[
      "bg-gray-100 antialiased pb-0",
      hasInfobar ? "flex min-h-screen flex-col pt-0" : "vis-prototype-body pt-10",
    ]}
  >
    {
      hasInfobar && wireframeFileNav && wireframeMeta ? (
        <header
          id="vis-chrome-infobar"
          class="sticky top-0 z-[9999] w-full border-b border-gray-950/60 bg-gray-900/80 font-mono text-xs text-white shadow-sm backdrop-blur-md"
        >
          <div
            class:list={[
              "grid h-10 grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-x-1.5 px-2 sm:gap-x-3 sm:px-4",
            ]}
          >
            <div class="flex min-w-0 shrink-0 items-center gap-2">
              <a
                href={`${base}vis/`}
                class="text-sm font-bold uppercase tracking-widest text-purple-400 transition hover:text-purple-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/60 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900"
              >
                VIS
              </a>
              <span class="text-[10px] font-medium text-gray-500">v0.1</span>
            </div>

            <div class="vis-wireframe-filetools flex max-w-[100vw] shrink-0 items-center justify-center gap-0.5 sm:gap-1">
              {prevFileNavHref ? (
                <a
                  href={prevFileNavHref}
                  class="inline-flex h-7 min-w-[2.25rem] shrink-0 items-center justify-center rounded border border-gray-500/90 bg-gray-900/90 text-[1.5rem] font-light leading-none text-gray-100 hover:border-gray-400 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                  aria-label="Forrige wireframe"
                >
                  ‹
                </a>
              ) : (
                <span
                  class="inline-flex h-7 min-w-[2.25rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-[1.5rem] font-light leading-none text-gray-600"
                  aria-hidden="true"
                >
                  ‹
                </span>
              )}

              <button
                type="button"
                id="vis-file-picker-open"
                class="inline-flex h-7 shrink-0 items-center gap-0.5 rounded border border-gray-700 bg-gray-900/90 px-1.5 py-0.5 text-[11px] tabular-nums text-gray-300 hover:border-gray-600 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500 md:hidden"
                aria-haspopup="dialog"
                aria-controls="vis-file-picker-dialog"
                aria-label={`Velg wireframe, viser ${fileNavPosition} av ${fileNavTotal}`}
              >
                {fileNavPosition} / {fileNavTotal}
                <span aria-hidden="true" class="text-[10px]">
                  ▾
                </span>
              </button>

              <label class="sr-only" for="vis-wireframe-jump-desktop">
                Velg wireframe-fil
              </label>
              <select
                id="vis-wireframe-jump-desktop"
                class="hidden h-7 max-w-[min(14rem,calc(100vw-12rem))] shrink truncate rounded border border-gray-700 bg-gray-900/90 py-0 pl-2 pr-7 text-[11px] text-gray-200 focus:border-gray-600 focus:outline-none focus:ring-1 focus:ring-gray-600 md:block"
                aria-label="Velg wireframe-fil"
              >
                {wireframeFileNav.allFiles.map((name) => {
                  const s = slugFromHtmlFilename(name);
                  const optHref = `${base}vis/${encodeURIComponent(s)}`;
                  const sel = s === wireframeFileNav.currentSlug;
                  return (
                    <option value={optHref} selected={sel}>
                      {name}
                    </option>
                  );
                })}
              </select>

              {nextFileNavHref ? (
                <a
                  href={nextFileNavHref}
                  class="inline-flex h-7 min-w-[2.25rem] shrink-0 items-center justify-center rounded border border-gray-500/90 bg-gray-900/90 text-[1.5rem] font-light leading-none text-gray-100 hover:border-gray-400 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                  aria-label="Neste wireframe"
                >
                  ›
                </a>
              ) : (
                <span
                  class="inline-flex h-7 min-w-[2.25rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-[1.5rem] font-light leading-none text-gray-600"
                  aria-hidden="true"
                >
                  ›
                </span>
              )}
            </div>

            <div class="flex min-w-0 items-center justify-end gap-2 text-gray-500 sm:gap-3">
              <button
                type="button"
                id="vis-meta-toggle"
                class="vis-meta-toggle inline-flex h-7 shrink-0 items-center gap-1 rounded-md border border-purple-500/45 bg-gray-800 px-2 text-gray-200 ring-1 ring-purple-400/35 transition hover:border-purple-400/55 hover:bg-gray-800/90 focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/50"
                aria-expanded="true"
                aria-controls="vis-infobar-expand"
                aria-label="Vis eller skjul informasjon om wireframen"
              >
                <span class="hidden text-[10px] font-semibold uppercase tracking-wide text-purple-200/90 sm:inline">
                  Info
                </span>
                <svg
                  class="vis-infobar-chevron h-4 w-4 shrink-0 rotate-180 text-purple-200 transition-transform duration-300 ease-out"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                    clip-rule="evenodd"
                  />
                </svg>
              </button>
              <span class="hidden md:inline">Visning for: Vibeke</span>
              <div class="h-2 w-2 shrink-0 rounded-full bg-green-500" title="Live" />
            </div>
          </div>

          <div
            id="vis-infobar-expand"
            class="grid overflow-hidden transition-[grid-template-rows] duration-300 ease-in-out"
            style="grid-template-rows: 1fr;"
          >
            <div class="min-h-0">
              <div class="max-h-[min(50vh,28rem)] overflow-y-auto border-t border-gray-600/25 bg-gray-900/25 px-3 py-3 backdrop-blur-[1px] sm:px-6 sm:py-4">
                <div
                  class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-x-10 md:gap-y-3 md:items-start"
                  role="region"
                  aria-labelledby="vis-meta-title"
                >
                  <div>
                    <p class="text-[10px] font-medium uppercase tracking-[0.14em] text-gray-500">Wireframe</p>
                    <h2
                      id="vis-meta-title"
                      class="mt-1.5 text-base font-semibold leading-snug tracking-tight text-white sm:text-lg"
                    >
                      {wireframeMeta.displayTitle}
                    </h2>
                    <div class="mt-2">
                      {wireframeMeta.description ? (
                        <p class="text-sm font-medium leading-relaxed text-gray-100/95">{wireframeMeta.description}</p>
                      ) : (
                        <p class="text-sm text-gray-500">Ingen beskrivelse i HTML-filen.</p>
                      )}
                    </div>
                  </div>
                  <div class="flex flex-col gap-3 md:pt-0.5">
                    {wireframeMeta.delta ? (
                      <div>
                        <h3 class="text-[11px] font-semibold uppercase tracking-wide text-gray-400">
                          Endret i denne varianten
                        </h3>
                        <p class="mt-1.5 text-sm font-medium leading-relaxed text-gray-100/95">{wireframeMeta.delta}</p>
                      </div>
                    ) : null}
                    <a
                      href={wireframeMeta.rawHref}
                      class="inline-flex w-full items-center justify-center rounded-md border border-gray-500/60 bg-gray-800/35 px-3 py-2 font-mono text-xs font-medium text-gray-200 transition hover:border-gray-400 hover:bg-gray-800/80 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500 sm:mt-1 sm:w-auto sm:self-start"
                    >
                      Direkte fil
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </header>
      ) : (
        <div
          class:list={[
            "vis-prototype-topbar fixed top-0 left-0 z-[9999] w-full border-b border-gray-950 bg-gray-900 font-mono text-xs text-white shadow-md",
            wireframeFileNav
              ? "grid h-10 grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-x-1.5 px-2 sm:gap-x-3 sm:px-4"
              : "flex h-10 items-center justify-between px-4",
          ]}
        >
          <div class="flex min-w-0 shrink-0 items-center gap-2">
            <a
              href={`${base}vis/`}
              class="text-sm font-bold uppercase tracking-widest text-purple-400 transition hover:text-purple-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/60 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900"
            >
              VIS
            </a>
            <span class="text-[10px] font-medium text-gray-500">v0.1</span>
          </div>

          {
            wireframeFileNav && (
              <div class="vis-wireframe-filetools flex max-w-[100vw] shrink-0 items-center justify-center gap-0.5 sm:gap-1">
                {prevFileNavHref ? (
                  <a
                    href={prevFileNavHref}
                    class="inline-flex h-7 min-w-[2.25rem] shrink-0 items-center justify-center rounded border border-gray-600 bg-gray-900 text-[1.5rem] font-light leading-none text-gray-200 hover:border-gray-500 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                    aria-label="Forrige wireframe"
                  >
                    ‹
                  </a>
                ) : (
                  <span
                    class="inline-flex h-7 min-w-[2.25rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-[1.5rem] font-light leading-none text-gray-600"
                    aria-hidden="true"
                  >
                    ‹
                  </span>
                )}

                <button
                  type="button"
                  id="vis-file-picker-open"
                  class="inline-flex h-7 shrink-0 items-center gap-0.5 rounded border border-gray-700 bg-gray-900 px-1.5 py-0.5 text-[11px] tabular-nums text-gray-300 hover:border-gray-600 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500 md:hidden"
                  aria-haspopup="dialog"
                  aria-controls="vis-file-picker-dialog"
                  aria-label={`Velg wireframe, viser ${fileNavPosition} av ${fileNavTotal}`}
                >
                  {fileNavPosition} / {fileNavTotal}
                  <span aria-hidden="true" class="text-[10px]">
                    ▾
                  </span>
                </button>

                <label class="sr-only" for="vis-wireframe-jump-desktop">
                  Velg wireframe-fil
                </label>
                <select
                  id="vis-wireframe-jump-desktop"
                  class="hidden h-7 max-w-[min(14rem,calc(100vw-12rem))] shrink truncate rounded border border-gray-700 bg-gray-900 py-0 pl-2 pr-7 text-[11px] text-gray-200 focus:border-gray-600 focus:outline-none focus:ring-1 focus:ring-gray-600 md:block"
                  aria-label="Velg wireframe-fil"
                >
                  {wireframeFileNav.allFiles.map((name) => {
                    const s = slugFromHtmlFilename(name);
                    const optHref = `${base}vis/${encodeURIComponent(s)}`;
                    const sel = s === wireframeFileNav.currentSlug;
                    return (
                      <option value={optHref} selected={sel}>
                        {name}
                      </option>
                    );
                  })}
                </select>

                {nextFileNavHref ? (
                  <a
                    href={nextFileNavHref}
                    class="inline-flex h-7 min-w-[2.25rem] shrink-0 items-center justify-center rounded border border-gray-600 bg-gray-900 text-[1.5rem] font-light leading-none text-gray-200 hover:border-gray-500 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                    aria-label="Neste wireframe"
                  >
                    ›
                  </a>
                ) : (
                  <span
                    class="inline-flex h-7 min-w-[2.25rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-[1.5rem] font-light leading-none text-gray-600"
                    aria-hidden="true"
                  >
                    ›
                  </span>
                )}
              </div>
            )
          }

          <div class="flex min-w-0 items-center justify-end gap-2 text-gray-500 sm:gap-4">
            <span class="hidden md:inline">Visning for: Vibeke</span>
            <div class="h-2 w-2 shrink-0 rounded-full bg-green-500" title="Live" />
          </div>
        </div>
      )
    }

    {
      wireframeFileNav && (
        <dialog
          id="vis-file-picker-dialog"
          class="z-[10001] w-[min(100vw-2rem,20rem)] max-w-[calc(100vw-2rem)] overflow-hidden rounded-lg border border-gray-700 bg-gray-900 p-0 text-gray-200 shadow-2xl"
          aria-labelledby="vis-file-picker-title"
        >
          <div class="border-b border-gray-800 px-3 py-2">
            <p id="vis-file-picker-title" class="text-[10px] font-medium uppercase tracking-wide text-gray-500">
              Velg wireframe
            </p>
          </div>
          <ul class="max-h-[min(60dvh,22rem)] overflow-y-auto p-2">
            {wireframeFileNav.allFiles.map((name) => {
              const s = slugFromHtmlFilename(name);
              const href = `${base}vis/${encodeURIComponent(s)}`;
              const current = s === wireframeFileNav.currentSlug;
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      "block truncate rounded px-2 py-2 text-xs hover:bg-gray-800",
                      current ? "bg-gray-800 text-white" : "text-gray-300",
                    ]}
                  >
                    {name}
                  </a>
                </li>
              );
            })}
          </ul>
          <div class="border-t border-gray-800 p-2">
            <button
              type="button"
              class="w-full rounded border border-gray-700 bg-gray-900 py-1.5 text-[11px] text-gray-400 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
              id="vis-file-picker-close"
            >
              Lukk
            </button>
          </div>
        </dialog>
      )
    }

    {
      hasInfobar ? (
        <script is:inline>
          (function () {
            try {
              if (sessionStorage.getItem("vox.vis.wireframeMetaOpen") === "false") {
                var exp = document.getElementById("vis-infobar-expand");
                var t = document.getElementById("vis-meta-toggle");
                var chev = document.querySelector(".vis-infobar-chevron");
                if (exp) exp.style.gridTemplateRows = "0fr";
                if (chev) chev.classList.remove("rotate-180");
                if (t) {
                  t.setAttribute("aria-expanded", "false");
                  ["border-purple-500/45", "bg-gray-800", "text-gray-200", "ring-1", "ring-purple-400/35"].forEach(function (c) {
                    t.classList.remove(c);
                  });
                  ["border-gray-700", "bg-gray-900", "text-gray-400"].forEach(function (c) {
                    t.classList.add(c);
                  });
                }
              }
            } catch (e) {}
          })();
        </script>
      ) : null
    }

    <script is:inline>
      (function () {
        var sel = document.getElementById("vis-wireframe-jump-desktop");
        if (sel)
          sel.addEventListener("change", function () {
            var v = sel.value;
            if (v) window.location.href = v;
          });
        var openBtn = document.getElementById("vis-file-picker-open");
        var dlg = document.getElementById("vis-file-picker-dialog");
        var closeBtn = document.getElementById("vis-file-picker-close");
        if (openBtn && dlg) {
          openBtn.addEventListener("click", function () {
            if (typeof dlg.showModal === "function") dlg.showModal();
          });
        }
        if (closeBtn && dlg) {
          closeBtn.addEventListener("click", function () {
            dlg.close();
          });
        }
        var META_OPEN_KEY = "vox.vis.wireframeMetaOpen";
        var metaToggle = document.getElementById("vis-meta-toggle");
        var infobarExpand = document.getElementById("vis-infobar-expand");
        var chev = document.querySelector(".vis-infobar-chevron");
        var META_ON = ["border-purple-500/45", "bg-gray-800", "text-gray-200", "ring-1", "ring-purple-400/35"];
        var META_OFF = ["border-gray-700", "bg-gray-900", "text-gray-400"];
        function syncMetaToggleStyles(open) {
          if (!metaToggle) return;
          META_ON.forEach(function (c) {
            metaToggle.classList.toggle(c, !!open);
          });
          META_OFF.forEach(function (c) {
            metaToggle.classList.toggle(c, !open);
          });
        }
        function setMetaClosedInSession() {
          try {
            sessionStorage.setItem(META_OPEN_KEY, "false");
          } catch (e) {}
        }
        function setMetaOpenInSession() {
          try {
            sessionStorage.setItem(META_OPEN_KEY, "true");
          } catch (e) {}
        }
        function infobarIsOpen() {
          return metaToggle && metaToggle.getAttribute("aria-expanded") === "true";
        }
        function setInfobarOpen(open) {
          if (infobarExpand) infobarExpand.style.gridTemplateRows = open ? "1fr" : "0fr";
          if (chev) chev.classList.toggle("rotate-180", !!open);
          if (metaToggle) metaToggle.setAttribute("aria-expanded", open ? "true" : "false");
          syncMetaToggleStyles(open);
        }
        if (metaToggle && infobarExpand) {
          metaToggle.addEventListener("click", function () {
            var next = !infobarIsOpen();
            if (next) setMetaOpenInSession();
            else setMetaClosedInSession();
            setInfobarOpen(next);
          });
        }
      })();
    </script>

    {
      hasInfobar ? (
        <div class="flex min-h-0 flex-1 flex-col">
          <div class="vis-prototype-main flex min-h-0 flex-1 flex-col bg-white">
            <slot />
          </div>
        </div>
      ) : (
        <div class="vis-prototype-main relative min-h-screen w-full bg-white">
          <slot />
        </div>
      )
    }
  </body>
</html>
