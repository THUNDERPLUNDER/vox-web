---
/* CONTRACT: Isolated backstage wireframe shell for /vis; no VOX app shell, nav, or theme coupling. */
import "../styles/global.css";

interface Props {
  title: string;
  activePage: "forside" | "hub" | "artikkel" | "wireframe";
}

const { title, activePage } = Astro.props;

const base = import.meta.env.BASE_URL;

/**
 * Exit preview: same path without `preview` (build-time path is correct per page).
 * With static output, runtime `?preview=1` is toggled via `html.vis-preview` + CSS + head script.
 */
const exitPreviewHref = (() => {
  const u = new URL(Astro.url.href);
  u.searchParams.delete("preview");
  const q = u.searchParams.toString();
  return q ? `${u.pathname}?${q}` : u.pathname;
})();
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>VIS Wireframe - {title}</title>
    <script is:inline>
      (function () {
        try {
          if (new URLSearchParams(window.location.search).get("preview") === "1") {
            document.documentElement.classList.add("vis-preview");
          }
        } catch (_) {}
      })();
    </script>
    <style is:global>
      /* Clean preview: chrome hidden, near-fullscreen content; toggled only when ?preview=1 (see script above). */
      html.vis-preview .vis-prototype-topbar,
      html.vis-preview .vis-prototype-bottombar {
        display: none !important;
      }
      .vis-prototype-exit {
        display: none;
      }
      html.vis-preview .vis-prototype-exit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      html.vis-preview .vis-prototype-body {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        min-height: 100dvh !important;
      }
      html.vis-preview .vis-prototype-main {
        min-height: 100dvh !important;
      }
      html.vis-preview .vis-wireframe-iframe {
        min-height: 100dvh !important;
        height: 100dvh !important;
      }
    </style>
  </head>
  <body class="vis-prototype-body bg-gray-100 antialiased pt-10 pb-20 sm:pb-0">
    <div
      class="vis-prototype-topbar fixed top-0 left-0 z-[9999] flex h-10 w-full items-center justify-between border-b border-gray-950 bg-gray-900 px-4 font-mono text-xs text-white shadow-md"
    >
      <div class="flex items-center space-x-6">
        <div class="flex items-baseline gap-2">
          <span class="text-sm font-bold uppercase tracking-widest text-purple-400">VIS</span>
          <span class="text-[10px] font-medium text-gray-500">v0.1</span>
        </div>

        <nav class="hidden border-l border-gray-700 pl-6 sm:flex sm:space-x-1">
          <a
            href={`${base}vis/`}
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "forside"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            Forside
          </a>
          <a
            href={`${base}vis/hub`}
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "hub"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            NAV-Hub
          </a>
          <a
            href={`${base}vis/artikkel`}
            class:list={[
              "rounded px-3 py-1 transition",
              activePage === "artikkel"
                ? "bg-gray-700 text-white"
                : "text-gray-400 hover:bg-gray-800 hover:text-white",
            ]}
          >
            Artikkel
          </a>
        </nav>
      </div>

      <div class="flex items-center space-x-4 text-gray-500">
        <span class="hidden md:inline">Visning for: Vibeke</span>
        <div class="h-2 w-2 shrink-0 rounded-full bg-green-500" title="Live"></div>
      </div>
    </div>

    <div
      class="vis-prototype-bottombar fixed bottom-0 left-0 z-[9999] flex w-full justify-around border-t border-gray-800 bg-gray-900 py-3 font-mono text-xs text-white sm:hidden"
      style="padding-bottom: env(safe-area-inset-bottom);"
    >
      <a
        href={`${base}vis/`}
        class:list={[activePage === "forside" ? "text-gray-300" : "text-gray-500"]}
      >
        Forside
      </a>
      <a
        href={`${base}vis/hub`}
        class:list={[activePage === "hub" ? "text-gray-300" : "text-gray-500"]}
      >
        Hub
      </a>
      <a
        href={`${base}vis/artikkel`}
        class:list={[activePage === "artikkel" ? "text-gray-300" : "text-gray-500"]}
      >
        Artikkel
      </a>
    </div>

    <a
      href={exitPreviewHref}
      class="vis-prototype-exit fixed z-[10000] max-w-[calc(100vw-1.5rem)] items-center justify-center rounded-full bg-gray-900/95 px-3.5 py-2.5 font-mono text-xs font-medium text-white shadow-lg backdrop-blur-sm transition hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/80"
      style="top: calc(env(safe-area-inset-top, 0px) + 12px); right: calc(env(safe-area-inset-right, 0px) + 12px);"
      aria-label="Tilbake til prototype-meny"
    >
      ← Tilbake
    </a>

    <div class="vis-prototype-main relative min-h-screen w-full bg-white">
      <slot />
    </div>
  </body>
</html>
