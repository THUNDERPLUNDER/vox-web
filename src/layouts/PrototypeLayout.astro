---
/* CONTRACT: Isolated backstage wireframe shell for /vis; no VOX app shell, nav, or theme coupling. */
import "../styles/global.css";
import { slugFromHtmlFilename } from "../lib/vis-wireframes";

interface Props {
  title: string;
  /** When set (e.g. on /vis/[slug]), compact pager in the main top bar; mobile uses position + dialog list, desktop uses select. */
  wireframeFileNav?: {
    allFiles: string[];
    currentSlug: string;
  };
  /** Parsed head metadata from the raw HTML file (wireframe viewer only). */
  wireframeMeta?: {
    displayTitle: string;
    description?: string;
    /** `<meta name="vis:delta">` — endring fra forrige iterasjon. */
    delta?: string;
  };
}

const { title, wireframeFileNav, wireframeMeta } = Astro.props;

const base = import.meta.env.BASE_URL;

const fileNavIndex =
  wireframeFileNav?.allFiles.findIndex((f) => slugFromHtmlFilename(f) === wireframeFileNav.currentSlug) ?? -1;
const prevFileNavHref =
  wireframeFileNav && fileNavIndex > 0
    ? `${base}vis/${encodeURIComponent(slugFromHtmlFilename(wireframeFileNav.allFiles[fileNavIndex - 1]!))}`
    : null;
const nextFileNavHref =
  wireframeFileNav && fileNavIndex >= 0 && fileNavIndex < wireframeFileNav.allFiles.length - 1
    ? `${base}vis/${encodeURIComponent(slugFromHtmlFilename(wireframeFileNav.allFiles[fileNavIndex + 1]!))}`
    : null;

const fileNavPosition =
  wireframeFileNav && fileNavIndex >= 0 ? fileNavIndex + 1 : 0;
const fileNavTotal = wireframeFileNav?.allFiles.length ?? 0;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>VIS Wireframe - {title}</title>
    <style is:global>
      #vis-file-picker-dialog::backdrop {
        background: rgb(0 0 0 / 0.45);
      }
    </style>
  </head>
  <body class="vis-prototype-body bg-gray-100 antialiased pt-10 pb-0">
    <div
      class:list={[
        "vis-prototype-topbar fixed top-0 left-0 z-[9999] w-full border-b border-gray-950 bg-gray-900 font-mono text-xs text-white shadow-md",
        wireframeFileNav
          ? "grid h-10 grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-x-1.5 px-2 sm:gap-x-3 sm:px-4"
          : "flex h-10 items-center justify-between px-4",
      ]}
    >
      <div class="flex min-w-0 shrink-0 items-center gap-2">
        <a
          href={`${base}vis/`}
          class="text-sm font-bold uppercase tracking-widest text-purple-400 transition hover:text-purple-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/60 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900"
        >
          VIS
        </a>
        <span class="text-[10px] font-medium text-gray-500">v0.1</span>
      </div>

      {
        wireframeFileNav && (
          <div class="vis-wireframe-filetools flex max-w-[100vw] shrink-0 items-center justify-center gap-0.5 sm:gap-1">
            {prevFileNavHref ? (
              <a
                href={prevFileNavHref}
                class="inline-flex h-7 min-w-[2rem] shrink-0 items-center justify-center rounded border border-gray-600 bg-gray-900 text-[1.35rem] font-light leading-none text-gray-200 hover:border-gray-500 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                aria-label="Forrige wireframe"
              >
                ‹
              </a>
            ) : (
              <span
                class="inline-flex h-7 min-w-[2rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-[1.35rem] font-light leading-none text-gray-600"
                aria-hidden="true"
              >
                ‹
              </span>
            )}

            <button
              type="button"
              id="vis-file-picker-open"
              class="inline-flex h-7 shrink-0 items-center gap-0.5 rounded border border-gray-700 bg-gray-900 px-1.5 py-0.5 text-[11px] tabular-nums text-gray-300 hover:border-gray-600 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500 md:hidden"
              aria-haspopup="dialog"
              aria-controls="vis-file-picker-dialog"
              aria-label={`Velg wireframe, viser ${fileNavPosition} av ${fileNavTotal}`}
            >
              {fileNavPosition} / {fileNavTotal}
              <span aria-hidden="true" class="text-[10px]">
                ▾
              </span>
            </button>

            <label class="sr-only" for="vis-wireframe-jump-desktop">
              Velg wireframe-fil
            </label>
            <select
              id="vis-wireframe-jump-desktop"
              class="hidden h-7 max-w-[min(14rem,calc(100vw-12rem))] shrink truncate rounded border border-gray-700 bg-gray-900 py-0 pl-2 pr-7 text-[11px] text-gray-200 focus:border-gray-600 focus:outline-none focus:ring-1 focus:ring-gray-600 md:block"
              aria-label="Velg wireframe-fil"
            >
              {wireframeFileNav.allFiles.map((name) => {
                const s = slugFromHtmlFilename(name);
                const optHref = `${base}vis/${encodeURIComponent(s)}`;
                const sel = s === wireframeFileNav.currentSlug;
                return (
                  <option value={optHref} selected={sel}>
                    {name}
                  </option>
                );
              })}
            </select>

            {nextFileNavHref ? (
              <a
                href={nextFileNavHref}
                class="inline-flex h-7 min-w-[2rem] shrink-0 items-center justify-center rounded border border-gray-600 bg-gray-900 text-[1.35rem] font-light leading-none text-gray-200 hover:border-gray-500 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                aria-label="Neste wireframe"
              >
                ›
              </a>
            ) : (
              <span
                class="inline-flex h-7 min-w-[2rem] shrink-0 cursor-not-allowed items-center justify-center rounded border border-gray-800 bg-gray-900/50 text-[1.35rem] font-light leading-none text-gray-600"
                aria-hidden="true"
              >
                ›
              </span>
            )}
          </div>
        )
      }

      <div class="flex min-w-0 items-center justify-end gap-2 text-gray-500 sm:gap-4">
        {
          wireframeMeta && (
            <button
              type="button"
              id="vis-meta-toggle"
              class="vis-meta-toggle inline-flex h-7 w-7 shrink-0 items-center justify-center rounded border border-purple-500/45 bg-gray-800 text-[11px] font-semibold text-purple-300 ring-1 ring-purple-400/35 transition hover:border-purple-400/60 hover:bg-gray-800/90 focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/50"
              aria-expanded="true"
              aria-controls="vis-wireframe-meta-panel"
              aria-label="Vis eller skjul informasjon om wireframen"
            >
              i
            </button>
          )
        }
        <span class="hidden md:inline">Visning for: Vibeke</span>
        <div class="h-2 w-2 shrink-0 rounded-full bg-green-500" title="Live"></div>
      </div>
    </div>

    {
      wireframeFileNav && (
        <dialog
          id="vis-file-picker-dialog"
          class="z-[10001] w-[min(100vw-2rem,20rem)] max-w-[calc(100vw-2rem)] overflow-hidden rounded-lg border border-gray-700 bg-gray-900 p-0 text-gray-200 shadow-2xl"
          aria-labelledby="vis-file-picker-title"
        >
          <div class="border-b border-gray-800 px-3 py-2">
            <p id="vis-file-picker-title" class="text-[10px] font-medium uppercase tracking-wide text-gray-500">
              Velg wireframe
            </p>
          </div>
          <ul class="max-h-[min(60dvh,22rem)] overflow-y-auto p-2">
            {wireframeFileNav.allFiles.map((name) => {
              const s = slugFromHtmlFilename(name);
              const href = `${base}vis/${encodeURIComponent(s)}`;
              const current = s === wireframeFileNav.currentSlug;
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      "block truncate rounded px-2 py-2 text-xs hover:bg-gray-800",
                      current ? "bg-gray-800 text-white" : "text-gray-300",
                    ]}
                  >
                    {name}
                  </a>
                </li>
              );
            })}
          </ul>
          <div class="border-t border-gray-800 p-2">
            <button
              type="button"
              class="w-full rounded border border-gray-700 bg-gray-900 py-1.5 text-[11px] text-gray-400 hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
              id="vis-file-picker-close"
            >
              Lukk
            </button>
          </div>
        </dialog>
      )
    }

    {
      wireframeMeta && (
        <>
          <div
            id="vis-meta-scrim"
            class="pointer-events-none fixed inset-0 top-10 z-[9997] bg-slate-950/[0.07] transition-opacity duration-150"
            aria-hidden="true"
          >
          </div>
          <div
            id="vis-wireframe-meta-root"
            class="fixed left-0 right-0 top-10 z-[9998] flex justify-center px-3 pb-2 pt-0 sm:px-4"
          >
            <div
              id="vis-wireframe-meta-panel"
              class="vis-wireframe-meta-panel pointer-events-auto relative w-full max-w-xl overflow-hidden rounded-b-xl border border-gray-600/70 border-t-0 bg-gray-900/98 text-left text-gray-200 shadow-[0_12px_40px_-8px_rgba(0,0,0,0.45)] backdrop-blur-sm"
              role="region"
              aria-labelledby="vis-meta-title"
            >
              <button
                type="button"
                id="vis-meta-close"
                class="absolute right-2 top-2 inline-flex h-7 min-w-[1.75rem] items-center justify-center rounded text-lg leading-none text-gray-500 hover:bg-gray-800 hover:text-gray-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-500"
                aria-label="Skjul informasjonspanel"
              >
                ×
              </button>
              <div class="border-b border-gray-700/70 px-8 pb-5 pr-12 pt-7 sm:px-10 sm:pb-6 sm:pr-14 sm:pt-9">
                <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-gray-500">Wireframe</p>
                <h2
                  id="vis-meta-title"
                  class="mt-2 text-lg font-semibold leading-snug tracking-tight text-white sm:text-xl"
                >
                  {wireframeMeta.displayTitle}
                </h2>
              </div>
              <div class="max-h-[min(52dvh,22rem)] space-y-6 overflow-y-auto px-8 py-5 sm:px-10 sm:py-7">
                <div>
                  {
                    wireframeMeta.description ? (
                      <p class="text-sm leading-relaxed text-gray-300">{wireframeMeta.description}</p>
                    ) : (
                      <p class="text-sm text-gray-500">Ingen beskrivelse i HTML-filen.</p>
                    )
                  }
                </div>
                {
                  wireframeMeta.delta ? (
                    <div class="border-t border-gray-700/60 pt-5">
                      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400">
                        Endret i denne varianten
                      </h3>
                      <p class="mt-2 text-sm leading-relaxed text-gray-200">{wireframeMeta.delta}</p>
                    </div>
                  ) : null
                }
              </div>
            </div>
          </div>
        </>
      )
    }

    {
      wireframeMeta ? (
        <script is:inline>
          (function () {
            try {
              if (sessionStorage.getItem("vox.vis.wireframeMetaOpen") === "false") {
                var r = document.getElementById("vis-wireframe-meta-root");
                var s = document.getElementById("vis-meta-scrim");
                var t = document.getElementById("vis-meta-toggle");
                if (r) r.classList.add("hidden");
                if (s) s.classList.add("hidden");
                if (t) {
                  t.setAttribute("aria-expanded", "false");
                  ["border-purple-500/45", "bg-gray-800", "text-purple-300", "ring-1", "ring-purple-400/35"].forEach(
                    function (c) {
                      t.classList.remove(c);
                    },
                  );
                  ["border-gray-700", "bg-gray-900", "text-gray-400"].forEach(function (c) {
                    t.classList.add(c);
                  });
                }
              }
            } catch (e) {}
          })();
        </script>
      ) : null
    }

    <script is:inline>
      (function () {
        var sel = document.getElementById("vis-wireframe-jump-desktop");
        if (sel)
          sel.addEventListener("change", function () {
            var v = sel.value;
            if (v) window.location.href = v;
          });
        var openBtn = document.getElementById("vis-file-picker-open");
        var dlg = document.getElementById("vis-file-picker-dialog");
        var closeBtn = document.getElementById("vis-file-picker-close");
        if (openBtn && dlg) {
          openBtn.addEventListener("click", function () {
            if (typeof dlg.showModal === "function") dlg.showModal();
          });
        }
        if (closeBtn && dlg) {
          closeBtn.addEventListener("click", function () {
            dlg.close();
          });
        }
        var META_OPEN_KEY = "vox.vis.wireframeMetaOpen";
        var metaRoot = document.getElementById("vis-wireframe-meta-root");
        var metaScrim = document.getElementById("vis-meta-scrim");
        var metaToggle = document.getElementById("vis-meta-toggle");
        var metaClose = document.getElementById("vis-meta-close");
        var META_ON = ["border-purple-500/45", "bg-gray-800", "text-purple-300", "ring-1", "ring-purple-400/35"];
        var META_OFF = ["border-gray-700", "bg-gray-900", "text-gray-400"];
        function syncMetaToggleStyles(open) {
          if (!metaToggle) return;
          META_ON.forEach(function (c) {
            metaToggle.classList.toggle(c, !!open);
          });
          META_OFF.forEach(function (c) {
            metaToggle.classList.toggle(c, !open);
          });
        }
        function setMetaClosedInSession() {
          try {
            sessionStorage.setItem(META_OPEN_KEY, "false");
          } catch (e) {}
        }
        function setMetaOpenInSession() {
          try {
            sessionStorage.setItem(META_OPEN_KEY, "true");
          } catch (e) {}
        }
        function metaPanelIsOpen() {
          return metaRoot && !metaRoot.classList.contains("hidden");
        }
        function setMetaPanelOpen(open) {
          if (metaRoot) metaRoot.classList.toggle("hidden", !open);
          if (metaScrim) metaScrim.classList.toggle("hidden", !open);
          if (metaToggle) metaToggle.setAttribute("aria-expanded", open ? "true" : "false");
          syncMetaToggleStyles(open);
        }
        if (metaToggle && metaRoot) {
          metaToggle.addEventListener("click", function () {
            var next = !metaPanelIsOpen();
            if (next) setMetaOpenInSession();
            else setMetaClosedInSession();
            setMetaPanelOpen(next);
          });
        }
        if (metaClose && metaRoot) {
          metaClose.addEventListener("click", function () {
            setMetaClosedInSession();
            setMetaPanelOpen(false);
          });
        }
      })();
    </script>

    <div class="vis-prototype-main relative min-h-screen w-full bg-white">
      <slot />
    </div>
  </body>
</html>
