---
/* CONTRACT: Reusable product article template skeleton for v0.1 presets and minimum field contract. */
export type ArticlePreset = "standard" | "faglig-fokus" | "minimal";

export interface Props {
  title: string;
  ingress: string;
  preset: ArticlePreset;
  articleType: string;
  hub: string;
  sourceTrustType: string;
  relatedTopics?: string[];
  aiSeedGroup?: string;
  aiMode?: boolean;
  body: string[];
  footerTitle?: string;
  footerText?: string;
}

const {
  title,
  ingress,
  preset,
  articleType,
  hub,
  sourceTrustType,
  relatedTopics = [],
  aiSeedGroup,
  aiMode = false,
  body,
  footerTitle = "Kort oppsummert",
  footerText = "Dette er en første versjon av templateskjelettet. Innhold og koblinger kan utvides senere.",
} = Astro.props;

const presetLabel = preset === "faglig-fokus" ? "Faglig Fokus" : preset === "minimal" ? "Minimal" : "Standard";
const wrapperClass =
  preset === "minimal"
    ? "mx-auto max-w-3xl"
    : preset === "faglig-fokus"
      ? "mx-auto max-w-6xl lg:grid lg:grid-cols-[minmax(0,1fr)_18rem] lg:gap-8"
      : "mx-auto max-w-4xl";
const articleClass = preset === "minimal" ? "space-y-6" : "space-y-8";
const bodyClass = preset === "minimal" ? "space-y-3 text-base leading-relaxed" : "space-y-4 text-[1.0625rem] leading-relaxed";
---

<section class={`rounded-lg border border-gray-300 bg-white p-4 sm:p-6 ${wrapperClass}`.trim()}>
  <article class={articleClass}>
    <header class="space-y-3 border-b border-gray-200 pb-4">
      <div class="flex flex-wrap items-center gap-2 text-xs">
        <span class="rounded border border-gray-300 bg-gray-100 px-2 py-0.5 font-medium text-gray-800">{presetLabel}</span>
        <span class="rounded border border-gray-300 bg-white px-2 py-0.5 text-gray-700">Type: {articleType}</span>
        <span class="rounded border border-gray-300 bg-white px-2 py-0.5 text-gray-700">Hub: {hub}</span>
      </div>
      <h2 class="text-2xl font-semibold leading-tight text-gray-900 sm:text-3xl">{title}</h2>
      <p class="max-w-2xl text-base leading-relaxed text-gray-700">{ingress}</p>
    </header>

    <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-600">Trygghetslag</p>
      <p class="mt-1">Kilde/trygghet: {sourceTrustType}</p>
    </div>

    <section class="space-y-3">
      <h3 class="text-lg font-semibold text-gray-900">Brodtekst</h3>
      <div class={bodyClass}>
        {body.map((paragraph) => (
          <p class="text-gray-700">{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="rounded border border-dashed border-gray-300 bg-gray-50 px-3 py-2 text-sm text-gray-600">
      <p class="font-medium text-gray-700">Plassholder: figur / illustrasjon</p>
      <p class="mt-1">Kobles inn ved behov i senere iterasjon.</p>
    </section>

    <footer class="rounded border border-gray-200 bg-gray-50 p-3">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-700">{footerTitle}</h3>
      <p class="mt-2 text-sm leading-relaxed text-gray-700">{footerText}</p>
      {relatedTopics.length > 0 ? (
        <div class="mt-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-600">Relaterte tema</p>
          <ul class="mt-1 flex flex-wrap gap-1.5">
            {relatedTopics.map((topic) => (
              <li class="rounded border border-gray-300 bg-white px-2 py-0.5 text-xs text-gray-700">{topic}</li>
            ))}
          </ul>
        </div>
      ) : null}
      {aiMode ? (
        <p class="mt-3 rounded border border-violet-200 bg-violet-50 px-2 py-1 text-xs text-violet-900">
          AI-hjelp aktivert som lag over valgt preset{aiSeedGroup ? ` (seed: ${aiSeedGroup})` : ""}.
        </p>
      ) : null}
    </footer>
  </article>

  {preset === "faglig-fokus" ? (
    <aside class="mt-6 rounded border border-gray-200 bg-gray-50 p-3 lg:mt-0">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-600">Sidespalte / rail</p>
      <p class="mt-2 text-sm text-gray-700">
        Stotteomraade for faglig kontekst, definisjoner og videre lesning. Vises tydelig i Faglig Fokus.
      </p>
    </aside>
  ) : null}
</section>
