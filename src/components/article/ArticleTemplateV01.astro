---
/* CONTRACT: Reusable product article template skeleton for v0.1 presets and minimum field contract. */
import ArticleRail from "./ArticleRail.astro";
export type ArticlePreset = "standard" | "faglig-fokus" | "minimal";

export interface Props {
  title: string;
  ingress: string;
  preset: ArticlePreset;
  articleType: string;
  hub: string;
  sourceTrustType: string;
  relatedTopics?: string[];
  aiSeedGroup?: string;
  aiMode?: boolean;
  body: string[];
  footerTitle?: string;
  footerText?: string;
  railItems?: Array<{ eyebrow: string; title: string; body: string }>;
  trustAuthors?: Array<{ name: string; role?: string; href?: string }>;
  trustPublished?: string;
  trustUpdated?: string;
  trustShowActions?: boolean;
  trustAvatarSrc?: string;
  trustAvatarAlt?: string;
  figureImage?: { src: string; alt: string; caption?: string };
  figureAfterTrust?: boolean;
}

const {
  title,
  ingress,
  preset,
  articleType,
  hub,
  sourceTrustType,
  relatedTopics = [],
  aiSeedGroup,
  aiMode = false,
  body,
  footerTitle = "Kort oppsummert",
  footerText = "Dette er en første versjon av templateskjelettet. Innhold og koblinger kan utvides senere.",
  railItems = [
    {
      eyebrow: "Sidespalte",
      title: "Faglig stotte",
      body: "Stotteomraade for faglig kontekst, definisjoner og videre lesning. Vises tydelig i Faglig Fokus.",
    },
    {
      eyebrow: "Relasjon",
      title: "Hub-kobling",
      body: `Denne artikkelen er koblet til hub: ${hub}.`,
    },
  ],
  trustAuthors = [],
  trustPublished,
  trustUpdated,
  trustShowActions = false,
  trustAvatarSrc,
  trustAvatarAlt = "Forfatterbilde",
  figureImage,
  figureAfterTrust = false,
} = Astro.props;

const presetLabel = preset === "faglig-fokus" ? "Faglig Fokus" : preset === "minimal" ? "Minimal" : "Standard";
const wrapperClass =
  preset === "minimal"
    ? "mx-auto max-w-[min(100%,42rem)]"
    : preset === "faglig-fokus"
      ? "mx-auto max-w-6xl lg:grid lg:grid-cols-[minmax(0,1fr)_16.5rem] lg:gap-x-10"
      : "mx-auto max-w-[min(100%,46rem)]";
const articleClass = preset === "minimal" ? "space-y-8" : "space-y-10";
const bodyClass = preset === "minimal" ? "space-y-3 text-base leading-relaxed" : "space-y-4 text-[1.0625rem] leading-[1.66]";
const inspectLabelClass =
  "article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950";
---

<section class={`ams ${wrapperClass}`.trim()} data-article-system data-component="ArticleTemplate">
  <article class={articleClass} data-component="ArticleContent">
    <header class="ams-zone ams-zone--lead pb-6" data-component="ArticleHeader">
      <span class={inspectLabelClass} data-component-label>ArticleHeader</span>
      <div class="flex flex-wrap items-center gap-2 text-[11px]">
        <span class="ams-kicker ams-kicker--spread">{presetLabel}</span>
        <span class="text-[rgb(var(--reading-ink-secondary))]">Type: {articleType}</span>
        <span class="text-[rgb(var(--reading-ink-secondary))]">Hub: {hub}</span>
      </div>
      <h2 class="mt-2 text-[2rem] font-semibold leading-[1.12] text-balance text-[rgb(var(--reading-ink))] sm:text-[2.35rem]">{title}</h2>
      <p class="ams-lead mt-4 max-w-2xl text-lg">{ingress}</p>
    </header>

    <section class="ams-plate px-5 py-5 sm:px-7" data-component="ArticleTrustBlock">
      <span class={inspectLabelClass} data-component-label>ArticleTrustBlock</span>
      {trustAuthors.length > 0 ? (
        <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--reading-ink-secondary))]">
          {trustAvatarSrc ? (
            <img
              src={trustAvatarSrc}
              alt={trustAvatarAlt}
              class="mr-2 inline-block h-5 w-5 rounded-full bg-black object-cover align-[-0.2em]"
              loading="lazy"
            />
          ) : (
            <span class="mr-2 inline-block h-5 w-5 rounded-full bg-black align-[-0.2em]" aria-hidden="true"></span>
          )}
          By{" "}
          {trustAuthors.map((author, index) => (
            <>
              <a
                href={author.href || "#"}
                class="font-medium text-[rgb(var(--reading-ink))] underline underline-offset-2"
              >
                {author.name}
              </a>
              {author.role ? `, ${author.role}` : ""}
              {index < trustAuthors.length - 1 ? ", " : ""}
            </>
          ))}
          <span>, {sourceTrustType}</span>
        </p>
      ) : (
        <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--reading-ink-secondary))]">{sourceTrustType}</p>
      )}
      {trustPublished || trustUpdated ? (
        <p class="mt-1.5 text-xs leading-relaxed text-[rgb(var(--reading-ink-secondary))]">
          {trustPublished ? `Publisert ${trustPublished}` : ""}
          {trustPublished && trustUpdated ? ", " : ""}
          {trustUpdated ? `Oppdatert ${trustUpdated}` : ""}
        </p>
      ) : null}
      {trustShowActions ? (
        <>
          <hr class="mt-3 border-0 border-t border-[rgb(var(--border))/0.35]" />
          <div class="mt-2.5 flex items-center gap-3 text-[rgb(var(--reading-ink-secondary))]">
            <button type="button" class="inline-flex h-8 w-8 items-center justify-center text-current" aria-label="Del artikkel">
              <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="none" aria-hidden="true">
                <path d="M8.59 13.51 15.42 17.5M15.41 6.5 8.59 10.49M18 22a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm12-7a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button type="button" class="inline-flex h-8 w-8 items-center justify-center text-current" aria-label="Lagre artikkel">
              <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="none" aria-hidden="true">
                <path d="M19 21 12 16 5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </>
      ) : null}
    </section>

    {figureImage && figureAfterTrust ? (
      <section class="ams-zone ams-zone--inline-visual ams-plate px-5 py-4 sm:px-6" data-component="ArticleFigurePlaceholder">
        <span class={inspectLabelClass} data-component-label>ArticleFigurePlaceholder</span>
        <figure>
          <img src={figureImage.src} alt={figureImage.alt} class="h-auto w-full" loading="lazy" />
          {figureImage.caption ? (
            <figcaption class="mt-2 text-xs leading-relaxed text-[rgb(var(--reading-ink-secondary))]">{figureImage.caption}</figcaption>
          ) : null}
        </figure>
      </section>
    ) : null}

    <section class="ams-zone ams-zone--article-body space-y-3" data-component="ArticleBody">
      <span class={inspectLabelClass} data-component-label>ArticleBody</span>
      <h3 class="text-xl font-semibold leading-snug text-[rgb(var(--reading-ink))]">Brødtekst</h3>
      <div class={bodyClass}>
        {body.map((paragraph) => (
          <p class="ams-body-p">{paragraph}</p>
        ))}
      </div>
    </section>

    {!figureAfterTrust ? (
      <section class="ams-zone ams-zone--inline-visual ams-plate px-5 py-4 sm:px-6" data-component="ArticleFigurePlaceholder">
      <span class={inspectLabelClass} data-component-label>ArticleFigurePlaceholder</span>
      {figureImage ? (
        <figure>
          <img src={figureImage.src} alt={figureImage.alt} class="h-auto w-full" loading="lazy" />
          {figureImage.caption ? (
            <figcaption class="mt-2 text-xs leading-relaxed text-[rgb(var(--reading-ink-secondary))]">{figureImage.caption}</figcaption>
          ) : null}
        </figure>
      ) : (
        <>
          <p class="text-sm font-medium text-[rgb(var(--reading-ink))]">Plassholder: figur / illustrasjon</p>
          <p class="mt-1 text-sm text-[rgb(var(--reading-ink-secondary))]">Kobles inn ved behov i senere iterasjon.</p>
        </>
      )}
      </section>
    ) : null}

    <footer class="ams-zone ams-zone--summary ams-plate space-y-4 px-5 py-5 sm:px-6" data-component="ArticleSummary">
      <span class={inspectLabelClass} data-component-label>ArticleSummary</span>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-[rgb(var(--reading-ink-secondary))]">{footerTitle}</h3>
      <p class="text-sm leading-relaxed text-[rgb(var(--reading-ink-secondary))]">{footerText}</p>
      {relatedTopics.length > 0 ? (
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--reading-ink-secondary))]">Relaterte tema</p>
          <ul class="mt-1 flex flex-wrap gap-1.5">
            {relatedTopics.map((topic) => (
              <li class="rounded-full border border-[rgb(var(--reading-ink-secondary))/0.24] px-2.5 py-0.5 text-xs text-[rgb(var(--reading-ink-secondary))]">{topic}</li>
            ))}
          </ul>
        </div>
      ) : null}
      {aiMode ? (
        <p class="rounded border border-[rgb(var(--reading-accent-iris))/0.3] bg-[rgb(var(--reading-inline))] px-2.5 py-1.5 text-xs text-[rgb(var(--reading-ink))]">
          AI-hjelp aktivert som lag over valgt preset{aiSeedGroup ? ` (seed: ${aiSeedGroup})` : ""}.
        </p>
      ) : null}
    </footer>
  </article>

  {preset === "faglig-fokus" ? (
    <ArticleRail class="mt-7 lg:mt-0" dataComponent="ArticleRail">
      <span class={inspectLabelClass} data-component-label>ArticleRail</span>
      {railItems.map((item) => (
        <div class="ams-rail__block">
          <p class="ams-rail__eyebrow">{item.eyebrow}</p>
          <h3 class="ams-rail__title">{item.title}</h3>
          <p class="text-sm leading-relaxed text-[rgb(var(--reading-ink-secondary))]">{item.body}</p>
        </div>
      ))}
    </ArticleRail>
  ) : null}
</section>
