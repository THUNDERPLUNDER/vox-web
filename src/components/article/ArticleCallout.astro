---
/* CONTRACT: Reusable article callout block with kicker, heading, and body slot on shared plate surface. */
export interface Props {
  kicker: string;
  title: string;
  class?: string;
}

const { kicker, title, class: className = "" } = Astro.props;
---

<section class={`ams-plate space-y-4 px-5 py-8 sm:px-7 sm:py-9 ${className}`.trim()}>
  <p class="ams-kicker">{kicker}</p>
  <h3 class="text-lg font-semibold leading-snug text-[rgb(var(--reading-ink))] sm:text-xl">
    {title}
  </h3>
  <slot />
</section>
