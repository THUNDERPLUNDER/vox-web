---
/* CONTRACT: Inline article chat shell with seed starters and in-place CES conversation. */
export interface PromptItem {
  question: string;
}

export interface Props {
  title: string;
  intro: string;
  headingId: string;
  items: PromptItem[];
  sourceLabel?: string;
  mode?: "inline" | "progressive";
  freeChatLabel?: string;
}

const {
  title,
  intro,
  headingId,
  items,
  sourceLabel = "artikkel",
  mode = "inline",
  freeChatLabel = "Start fri samtale",
} = Astro.props;
---

<section
  class="inline-chat-shell ams-zone"
  aria-labelledby={headingId}
  data-component="ArticleInlineChatShell"
  data-inline-chat-mode={mode}
  data-inline-chat-state={mode === "progressive" ? "idle" : "active"}
>
  <header class="inline-chat-shell__header">
    <h2 id={headingId} class="inline-chat-shell__title">{title}</h2>
    <p class="inline-chat-shell__intro">{intro}</p>
  </header>

  {mode === "progressive" ? (
    <p
      class="inline-chat-shell__affordance text-xs font-medium uppercase tracking-[0.12em] text-[rgb(var(--reading-ink-secondary))]"
      data-inline-chat-affordance
    >
      Dialog med Hørehjelpen
    </p>
  ) : null}

  <ul
    class:list={[
      "inline-chat-shell__seed-list",
      mode === "progressive" && "inline-chat-shell__seed-list--rows",
    ]}
    role="list"
  >
    {
      items.map((item) => (
        <li class={mode === "progressive" ? "inline-chat-shell__seed-item" : undefined}>
          <button
            type="button"
            class:list={[
              "inline-chat-shell__seed-btn",
              mode === "progressive" && "inline-chat-shell__seed-row",
            ]}
            data-inline-chat-seed={item.question}
          >
            <span class={mode === "progressive" ? "inline-chat-shell__seed-question" : undefined}>{item.question}</span>
            {mode === "progressive" ? (
              <span class="inline-chat-shell__seed-icon" aria-hidden="true">
                <svg class="inline-chat-shell__seed-icon-svg" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            ) : null}
          </button>
        </li>
      ))
    }
  </ul>

  {mode === "progressive" ? (
    <button type="button" class="prompt-group__cta inline-chat-shell__free-chat" data-inline-chat-free-trigger>
      {freeChatLabel}
    </button>
  ) : null}

  <p class="inline-chat-shell__source text-[11px] text-[rgb(var(--muted))]">
    Kontekst: {sourceLabel}. Velg et startspørsmål{mode === "progressive" ? " for å åpne samtalen." : " eller skriv fritt i feltet under."}
  </p>

  <div class="inline-chat-shell__dialog-thread mt-3 hidden" data-inline-chat-selected>
    <div class="inline-chat-shell__transcript" data-inline-chat-transcript></div>
    <p class="inline-chat-shell__status" data-inline-chat-status aria-live="polite">
      Vi bruker chatmotoren i bakgrunnen.
    </p>
  </div>

  <div
    class:list={[
      "vox-surface-embedded-app mt-3",
      mode === "progressive" && "pointer-events-none absolute h-px w-px overflow-hidden opacity-0",
    ]}
    data-kl-surface="embedded-app"
    data-inline-chat-surface
  >
    <chat-messenger
      id="article-inline-chat-widget"
      url-allowlist="*"
      class:list={[
        "block w-full overflow-hidden rounded-none bg-[rgb(var(--surface-subtle))]",
        mode === "progressive" ? "h-[min(34vh,360px)] sm:h-[min(42vh,420px)]" : "h-[min(54vh,520px)]",
      ]}
    >
      <chat-messenger-container
        chat-title="Hørehjelpen"
        enable-file-upload
        enable-audio-input
      ></chat-messenger-container>
    </chat-messenger>
  </div>
</section>

<script is:inline define:vars={{ mode }}>
  (() => {
    const shell = document.querySelector('[data-component="ArticleInlineChatShell"][data-inline-chat-mode]');
    const widget = shell?.querySelector("#article-inline-chat-widget");
    if (!widget) return;
    const progressive = mode === "progressive";
    const selectedBox = shell?.querySelector("[data-inline-chat-selected]");
    const transcriptEl = shell?.querySelector("[data-inline-chat-transcript]");
    const statusText = shell?.querySelector("[data-inline-chat-status]");
    const surface = shell?.querySelector("[data-inline-chat-surface]");
    const seedButtons = Array.from(shell?.querySelectorAll("[data-inline-chat-seed]") || []);
    let bridgeReady = false;
    let responseTimer = null;
    let retryTimer = null;
    let slowTimer = null;
    let controlsTimer = null;
    let activeTurn = null;
    let turnId = 0;
    const responseTimeoutMs = 120000;
    const slowStatusDelayMs = 10000;
    const controlsDelayMs = 7000;
    const retryDelayMs = 6000;

    const setState = (next) => {
      if (!shell) return;
      shell.setAttribute("data-inline-chat-state", next);
    };
    const setStatus = (text) => {
      if (statusText) statusText.textContent = text;
    };
    const setSeedsBusy = (busy) => {
      seedButtons.forEach((btn) => {
        btn.setAttribute("aria-disabled", String(busy));
        btn.toggleAttribute("data-inline-chat-seed-busy", busy);
      });
    };
    const clearResponseTimer = () => {
      if (!responseTimer) return;
      clearTimeout(responseTimer);
      responseTimer = null;
    };
    const clearRetryTimer = () => {
      if (!retryTimer) return;
      clearTimeout(retryTimer);
      retryTimer = null;
    };
    const clearSlowTimer = () => {
      if (!slowTimer) return;
      clearTimeout(slowTimer);
      slowTimer = null;
    };
    const clearControlsTimer = () => {
      if (!controlsTimer) return;
      clearTimeout(controlsTimer);
      controlsTimer = null;
    };
    const clearTurnTimers = () => {
      clearResponseTimer();
      clearRetryTimer();
      clearSlowTimer();
      clearControlsTimer();
    };
    const escapeHtml = (value) =>
      String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    const renderInlineMarkdown = (text) =>
      escapeHtml(text).replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
    const renderFormattedText = (text) => {
      const normalized = String(text || "").replace(/\r\n/g, "\n").trim();
      if (!normalized) return "";
      const lines = normalized.split("\n");
      const html = [];
      let listType = "";
      const closeList = () => {
        if (!listType) return;
        html.push(`</${listType}>`);
        listType = "";
      };
      for (const rawLine of lines) {
        const line = rawLine.trim();
        if (!line) {
          closeList();
          continue;
        }
        const bullet = line.match(/^[-*]\s+(.+)$/);
        const numbered = line.match(/^(\d+)[.)]\s+(.+)$/);
        if (bullet) {
          if (listType !== "ul") {
            closeList();
            html.push("<ul>");
            listType = "ul";
          }
          html.push(`<li>${renderInlineMarkdown(bullet[1])}</li>`);
          continue;
        }
        if (numbered) {
          if (listType !== "ol") {
            closeList();
            html.push("<ol>");
            listType = "ol";
          }
          html.push(`<li value="${escapeHtml(numbered[1])}">${renderInlineMarkdown(numbered[2])}</li>`);
          continue;
        }
        closeList();
        html.push(`<p>${renderInlineMarkdown(line)}</p>`);
      }
      closeList();
      return html.join("");
    };
    const scrollToElement = (element) => {
      if (!element) return;
      requestAnimationFrame(() => {
        element.scrollIntoView({ behavior: "smooth", block: "end" });
      });
    };
    const revealDialog = () => {
      if (selectedBox) selectedBox.classList.remove("hidden");
    };
    const revealSurface = () => {
      revealDialog();
      if (surface) surface.classList.remove("hidden");
    };
    const getFallbackHref = (query) => {
      const params = new URLSearchParams();
      if (query) params.set("seed", query);
      params.set("from", "article-r1");
      return `/no/chat?${params.toString()}`;
    };
    const renderPending = (turn, label = "Henter svaret ...") => {
      if (!turn?.assistantText) return;
      turn.assistantText.innerHTML = `
        <span class="inline-chat-shell__typing" aria-live="polite">
          <span>${escapeHtml(label)}</span>
          <span class="inline-chat-shell__typing-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
        </span>
      `;
    };
    const createTurn = (query) => {
      if (!transcriptEl) return null;
      turnId += 1;
      const turn = {
        id: turnId,
        query,
        state: "pending",
        responseReceived: false,
        retryUsed: false,
        manualRetryCount: 0,
        createdAt: Date.now(),
        element: document.createElement("div"),
        assistantText: document.createElement("div"),
      };
      turn.element.className = "inline-chat-shell__turn";
      turn.element.dataset.inlineChatTurn = String(turn.id);
      turn.element.innerHTML = `
        <div class="inline-chat-shell__message inline-chat-shell__message--user">
          <p class="inline-chat-shell__message-eyebrow">Du valgte</p>
          <p class="inline-chat-shell__message-text">${escapeHtml(query)}</p>
        </div>
        <div class="inline-chat-shell__message inline-chat-shell__message--assistant">
          <p class="inline-chat-shell__message-eyebrow">Hørehjelpen</p>
        </div>
      `;
      turn.assistantText.className = "inline-chat-shell__message-text";
      turn.element.querySelector(".inline-chat-shell__message--assistant")?.append(turn.assistantText);
      transcriptEl.append(turn.element);
      renderPending(turn);
      return turn;
    };
    const finishActiveTurn = (state) => {
      if (activeTurn) activeTurn.state = state;
      clearTurnTimers();
      setSeedsBusy(false);
      setState(state);
    };
    const renderTurnActions = (turn, { includeAbort = true } = {}) => {
      if (!turn || turn.state !== "pending") return;
      const href = getFallbackHref(turn.query);
      const actionHtml = `
        <p class="inline-chat-shell__turn-actions" data-inline-chat-turn-actions>
          <button type="button" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2" data-inline-chat-retry>Prøv igjen</button>
          ${includeAbort ? '<span aria-hidden="true"> · </span><button type="button" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2" data-inline-chat-abort>Avbryt</button>' : ""}
          <span aria-hidden="true"> · </span>
          <a href="${href}" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2">Åpne fri samtale</a>
        </p>
      `;
      const existingActions = turn.assistantText.querySelector("[data-inline-chat-turn-actions]");
      if (existingActions) existingActions.remove();
      turn.assistantText.insertAdjacentHTML("beforeend", actionHtml);
      turn.assistantText
        .querySelector("[data-inline-chat-retry]")
        ?.addEventListener("click", () => retryTurn(turn), { once: true });
      turn.assistantText
        .querySelector("[data-inline-chat-abort]")
        ?.addEventListener("click", () => abortTurn(turn), { once: true });
    };
    const scheduleManualControls = (turn) => {
      clearControlsTimer();
      controlsTimer = setTimeout(() => {
        if (activeTurn?.id !== turn.id || turn.responseReceived || turn.state !== "pending") return;
        renderTurnActions(turn);
        setStatus("Du kan prøve igjen, avbryte eller åpne fri samtale.");
      }, controlsDelayMs);
    };
    const renderFallback = (turn) => {
      if (!turn) return;
      turn.state = "fallback";
      finishActiveTurn("fallback");
      const href = getFallbackHref(turn.query);
      turn.assistantText.innerHTML = `
        ${renderFormattedText("Svaret kom ikke helt inn her. Du kan prøve igjen, eller åpne fri samtale.")}
        <p class="inline-chat-shell__turn-actions">
          <button type="button" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2" data-inline-chat-retry>Prøv igjen</button>
          <span aria-hidden="true"> · </span>
          <a href="${href}" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2">Åpne fri samtale</a>
        </p>
      `;
      const retryButton = turn.assistantText.querySelector("[data-inline-chat-retry]");
      retryButton?.addEventListener("click", () => retryTurn(turn), { once: true });
      setStatus("");
      scrollToElement(turn.assistantText);
    };
    const startResponseTimer = (turn) => {
      clearResponseTimer();
      responseTimer = setTimeout(() => {
        if (activeTurn?.id !== turn.id || turn.responseReceived) return;
        renderFallback(turn);
      }, responseTimeoutMs);
    };
    const startSlowTimer = (turn) => {
      clearSlowTimer();
      slowTimer = setTimeout(() => {
        if (activeTurn?.id !== turn.id || turn.responseReceived) return;
        renderPending(turn, "Henter fortsatt svaret ...");
        renderTurnActions(turn);
        setStatus("Dette tar litt lenger tid enn vanlig ...");
      }, slowStatusDelayMs);
    };

    const asText = (payload) => {
      if (!payload) return "";
      if (typeof payload === "string") return payload.trim();
      if (Array.isArray(payload)) {
        return payload.map((item) => asText(item)).filter(Boolean).join("\n\n").trim();
      }
      if (typeof payload === "object") {
        const candidates = [
          payload.text,
          payload.transcript,
          payload.outputText,
          payload.message,
          payload.content,
          payload.payload,
          payload.raw,
          payload.data,
          payload.messages,
          payload.outputs,
        ];
        for (const candidate of candidates) {
          const parsed = asText(candidate);
          if (parsed) return parsed;
        }
      }
      return "";
    };
    const normalizeQuery = (value) => String(value || "").replace(/\s+/g, " ").trim().toLowerCase();
    const getResponseQuery = (payload) => {
      const messages = payload?.raw?.diagnosticInfo?.messages || payload?.diagnosticInfo?.messages || [];
      if (!Array.isArray(messages)) return "";
      const userTexts = [];
      for (const message of messages) {
        if (!String(message?.role || "").toLowerCase().includes("user")) continue;
        const chunks = Array.isArray(message?.chunks) ? message.chunks : [];
        for (const chunk of chunks) {
          if (typeof chunk?.text === "string" && chunk.text.trim()) userTexts.push(chunk.text.trim());
        }
      }
      return userTexts.at(-1) || "";
    };

    const handleBotReply = (event) => {
      if (!progressive || !activeTurn) return;
      if (activeTurn.state !== "pending") return;
      if (activeTurn.responseReceived) return;
      const responseQuery = getResponseQuery(event?.detail);
      if (responseQuery && normalizeQuery(responseQuery) !== normalizeQuery(activeTurn.query)) return;
      const text = asText(event?.detail);
      if (!text) return;
      const turn = activeTurn;
      turn.responseReceived = true;
      turn.state = "answered";
      turn.assistantText.innerHTML = renderFormattedText(text);
      finishActiveTurn("answered");
      setStatus("Svar mottatt.");
      scrollToElement(turn.assistantText);
    };

    const pushToWidget = (prompt, turn = activeTurn) => {
      const seed = (prompt || "").trim();
      if (!seed || typeof widget.sendQuery !== "function") return false;
      widget.sendQuery(seed).catch(() => {
        if (!progressive || !turn || activeTurn?.id !== turn.id || turn.responseReceived) return;
        renderFallback(turn);
      });
      return true;
    };

    const scheduleTransientRetry = (turn) => {
      if (!turn || turn.retryUsed || turn.responseReceived || retryTimer) return;
      turn.retryUsed = true;
      retryTimer = setTimeout(() => {
        retryTimer = null;
        if (activeTurn?.id !== turn.id || turn.responseReceived) return;
        setStatus("Vi prøver én gang til i bakgrunnen ...");
        pushToWidget(turn.query, turn);
      }, retryDelayMs);
    };

    const handleBridgeError = (event) => {
      if (!progressive || !activeTurn || activeTurn.state !== "pending" || activeTurn.responseReceived) return;
      const detail = event?.detail || {};
      const status = String(detail.status ?? detail?.error?.status ?? "");
      const message = String(detail.message || detail?.error?.message || "");
      if (status === "429" || /fetch error/i.test(message)) {
        renderPending(activeTurn, "Henter fortsatt svaret ...");
        renderTurnActions(activeTurn);
        setStatus("Dette tar litt lenger tid enn vanlig ...");
        scheduleTransientRetry(activeTurn);
        return;
      }
      setStatus("Dette tar litt lenger tid enn vanlig ...");
    };

    const markBridgeReady = () => {
      if (!widget || typeof widget.sendQuery !== "function") return false;
      bridgeReady = true;
      return true;
    };

    const observeReady = () => {
      if (markBridgeReady()) return;
      let tries = 0;
      const timer = setInterval(() => {
        tries += 1;
        if (markBridgeReady() || tries > 40) clearInterval(timer);
      }, 250);
    };

    const startTurn = (seed, options = {}) => {
      const query = (seed || "").trim();
      if (!query) return;
      if (activeTurn?.state === "pending") {
        renderTurnActions(activeTurn);
        setStatus("Et svar hentes allerede. Prøv igjen, avbryt eller åpne fri samtale.");
        return;
      }
      revealDialog();
      const turn = options.turn || createTurn(query);
      if (!turn) return;
      activeTurn = turn;
      turn.query = query;
      turn.state = "pending";
      turn.responseReceived = false;
      turn.retryUsed = Boolean(options.isManualRetry);
      if (options.isManualRetry) turn.manualRetryCount = (turn.manualRetryCount || 0) + 1;
      clearTurnTimers();
      setSeedsBusy(true);
      renderPending(turn, options.isManualRetry ? "Prøver igjen ..." : "Henter svaret ...");
      setStatus(bridgeReady ? "Sendt til Hørehjelpen. Venter på svar ..." : "Kobler til Hørehjelpen ...");
      setState("started");
      scrollToElement(turn.element);
      if (pushToWidget(query, turn)) {
        scheduleManualControls(turn);
        startSlowTimer(turn);
        startResponseTimer(turn);
        setState("active");
        return;
      }
      let tries = 0;
      const readyTimer = setInterval(() => {
        tries += 1;
        const pushed = pushToWidget(query, turn);
        if (pushed || tries > 20) {
          if (pushed) {
            setStatus("Sendt til Hørehjelpen. Venter på svar ...");
            scheduleManualControls(turn);
            startSlowTimer(turn);
            startResponseTimer(turn);
            setState("active");
          }
          if (!pushed && tries > 20) renderFallback(turn);
          clearInterval(readyTimer);
        }
      }, 250);
    };

    const retryTurn = (turn) => {
      if (!turn) return;
      if (activeTurn?.state === "pending" && activeTurn.id !== turn.id) return;
      activeTurn = turn;
      turn.state = "pending";
      turn.responseReceived = false;
      turn.retryUsed = true;
      turn.manualRetryCount = (turn.manualRetryCount || 0) + 1;
      clearTurnTimers();
      setSeedsBusy(true);
      renderPending(turn, "Prøver igjen ...");
      setStatus("Prøver igjen med samme spørsmål ...");
      setState("active");
      scrollToElement(turn.assistantText);
      if (pushToWidget(turn.query, turn)) {
        scheduleManualControls(turn);
        startSlowTimer(turn);
        startResponseTimer(turn);
        return;
      }
      renderFallback(turn);
    };

    const abortTurn = (turn) => {
      if (!turn || activeTurn?.id !== turn.id || turn.state !== "pending") return;
      turn.state = "cancelled";
      clearTurnTimers();
      setSeedsBusy(false);
      activeTurn = null;
      setState("cancelled");
      turn.assistantText.innerHTML = renderFormattedText(
        "Vi stoppet ventingen her. Du kan velge et nytt spørsmål eller åpne fri samtale."
      );
      setStatus("Avbrutt lokalt. Eventuelle sene svar fra chatmotoren ignoreres her.");
      scrollToElement(turn.assistantText);
    };

    const startFreeChat = () => {
      revealSurface();
      setStatus("Fri samtale bruker den synlige chatflaten.");
      setState("started");
      if (surface) surface.classList.remove("pointer-events-none", "absolute", "h-px", "w-px", "overflow-hidden", "opacity-0");
      if (typeof widget.sendQuery === "function") {
        setState("active");
        return;
      }
      let tries = 0;
      const freeRetryTimer = setInterval(() => {
        tries += 1;
        if (typeof widget.sendQuery === "function" || tries > 20) {
          if (typeof widget.sendQuery === "function") setState("active");
          clearInterval(freeRetryTimer);
        }
      }, 250);
    };

    let readinessTries = 0;
    const timer = setInterval(() => {
      readinessTries += 1;
      bridgeReady = typeof widget.sendQuery === "function";
      if (bridgeReady || readinessTries > 40) clearInterval(timer);
    }, 250);

    seedButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const seed = btn.getAttribute("data-inline-chat-seed") || "";
        if (progressive) {
          startTurn(seed);
          return;
        }
        if (pushToWidget(seed)) setStatus("Sendt til Hørehjelpen.");
      });
    });

    const freeTrigger = shell?.querySelector("[data-inline-chat-free-trigger]");
    if (freeTrigger) {
      freeTrigger.addEventListener("click", startFreeChat);
    }

    widget.addEventListener("chat-messenger-response-received", handleBotReply);
    widget.addEventListener("chat-messenger-error-v2", handleBridgeError);
    window.addEventListener("chat-messenger-response-received", handleBotReply);
    window.addEventListener("chat-messenger-error-v2", handleBridgeError);

    window.addEventListener("vox-ces-register", (event) => {
      const detail = event?.detail || {};
      if (detail.widgetId !== "article-inline-chat-widget") return;
      if (detail.success) {
        observeReady();
        return;
      }
      if (progressive) setStatus("Chatmotoren er ikke klar ennå.");
    });
    window.addEventListener("chat-messenger-loaded", observeReady, { once: true });
    window.addEventListener("ces-messenger-connected", observeReady, { once: true });
    observeReady();
  })();
</script>

<style is:global>
  .inline-chat-shell__transcript {
    display: grid;
    gap: 0.9rem;
  }

  .inline-chat-shell__turn {
    display: grid;
    gap: 0.55rem;
  }

  .inline-chat-shell__message-text p {
    margin: 0 0 0.75rem;
  }

  .inline-chat-shell__message-text p:last-child,
  .inline-chat-shell__message-text ul:last-child,
  .inline-chat-shell__message-text ol:last-child {
    margin-bottom: 0;
  }

  .inline-chat-shell__message-text ul,
  .inline-chat-shell__message-text ol {
    margin: 0 0 0.75rem 1.15rem;
    padding: 0;
  }

  .inline-chat-shell__message-text ul {
    list-style: disc;
  }

  .inline-chat-shell__message-text ol {
    list-style: decimal;
  }

  .inline-chat-shell__message-text li + li {
    margin-top: 0.25rem;
  }

  .inline-chat-shell__turn-actions {
    margin-top: 0.85rem;
  }

  .inline-chat-shell__seed-btn:disabled {
    cursor: wait;
    opacity: 0.62;
  }

  .inline-chat-shell__typing {
    align-items: center;
    display: inline-flex;
    gap: 0.55rem;
  }

  .inline-chat-shell__typing-dots {
    align-items: center;
    display: inline-flex;
    gap: 0.18rem;
  }

  .inline-chat-shell__typing-dots span {
    animation: inline-chat-shell-typing 1.1s ease-in-out infinite;
    background: currentColor;
    border-radius: 999px;
    display: block;
    height: 0.3rem;
    opacity: 0.35;
    width: 0.3rem;
  }

  .inline-chat-shell__typing-dots span:nth-child(2) {
    animation-delay: 0.16s;
  }

  .inline-chat-shell__typing-dots span:nth-child(3) {
    animation-delay: 0.32s;
  }

  @keyframes inline-chat-shell-typing {
    0%,
    80%,
    100% {
      opacity: 0.3;
      transform: translateY(0);
    }

    40% {
      opacity: 0.9;
      transform: translateY(-0.12rem);
