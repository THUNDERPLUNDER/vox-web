---
/* CONTRACT: Inline article chat shell. #77 progressive: composer-from-start + active fixed chrome. #257 transition-v01. */
export interface PromptItem {
  question: string;
}

export interface Props {
  title: string;
  /** Når utelatt eller tom, vises ingen undertekst under tittelen (f.eks. rett til seed-liste). */
  intro?: string;
  headingId: string;
  items: PromptItem[];
  sourceLabel?: string;
  mode?: "inline" | "progressive";
  /** #257: kort artikkel → chat med sticky composer og to seeds. */
  layout?: "default" | "transition-v01";
  articleTitle?: string;
  composePlaceholder?: string;
}

const {
  title,
  intro,
  headingId,
  items,
  sourceLabel = "artikkel",
  mode = "inline",
  layout = "default",
  articleTitle,
  composePlaceholder = layout === "transition-v01" ? "Hva lurer du på?" : "Spør videre om dette",
} = Astro.props;

const conversationAttr = mode === "progressive" ? "idle" : "off";
const shellItems = layout === "transition-v01" ? items.slice(0, 2) : items;
const resolvedArticleTitle = articleTitle || title;

const inspectLabelClass =
  "article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950";
---

<section
  class="inline-chat-shell ams-zone"
  aria-labelledby={headingId}
  data-component="ArticleInlineChatShell"
  data-inline-chat-mode={mode}
  data-inline-chat-conversation={conversationAttr}
  data-inline-chat-state={mode === "progressive" ? "idle" : "active"}
  data-inline-chat-layout={layout}
  data-article-title={resolvedArticleTitle}
>
  <span class={inspectLabelClass} data-component-label>ArticleInlineChatShell</span>
  <header
    class:list={["inline-chat-shell__header", layout === "transition-v01" && "hidden"]}
    data-inline-chat-header
    aria-hidden={layout === "transition-v01" ? "true" : undefined}
  >
    <h2 id={headingId} class:list={[layout === "transition-v01" && "sr-only", "inline-chat-shell__title"]}>{title}</h2>
    {intro ? <p class="inline-chat-shell__intro">{intro}</p> : null}
  </header>

  <div class="inline-chat-shell__seed-suggestions" data-component="SeedSuggestions" data-inline-chat-seed-suggestions>
    <span class={inspectLabelClass} data-component-label>SeedSuggestions</span>
    <ul
      class:list={[
        "inline-chat-shell__seed-list",
        mode === "progressive" && "inline-chat-shell__seed-list--rows",
      ]}
      role="list"
    >
      {
        shellItems.map((item) => (
          <li class={mode === "progressive" ? "inline-chat-shell__seed-item" : undefined}>
            <button
              type="button"
              class:list={[
                "inline-chat-shell__seed-btn",
                mode === "progressive" && "inline-chat-shell__seed-row",
              ]}
              data-inline-chat-seed={item.question}
              data-viddel-track="article_ai_seed_clicked"
              data-viddel-entry-surface="article_inline_shell"
              data-viddel-seed-label={item.question}
            >
              <span class={mode === "progressive" ? "inline-chat-shell__seed-question" : undefined}>{item.question}</span>
            </button>
          </li>
        ))
      }
    </ul>
  </div>

  <p
    class:list={[
      "inline-chat-shell__source text-[11px] text-[rgb(var(--muted))]",
      layout === "transition-v01" && "hidden",
    ]}
    data-inline-chat-source
    aria-hidden={layout === "transition-v01" ? "true" : undefined}
  >
    Kontekst: {sourceLabel}. Velg et startspørsmål{mode === "progressive" ? " for å åpne samtalen." : " eller skriv fritt i feltet under."}
  </p>

  {
    mode === "progressive" ? (
      <>
        <div class="inline-chat-shell__dialog-thread mt-3 hidden" data-inline-chat-selected>
          <div class="inline-chat-shell__transcript-divider" data-component="TranscriptDivider" data-inline-chat-transcript-divider>
            <span class={inspectLabelClass} data-component-label>TranscriptDivider</span>
            <span class="inline-chat-shell__transcript-divider-line" aria-hidden="true" />
            <span
              class="inline-chat-shell__transcript-divider-label"
              id={`${headingId}-dialog-landmark`}>Dialog med Viddel</span>
          </div>
          <div class="inline-chat-shell__transcript" data-component="Transcript" data-inline-chat-transcript>
            <span class={inspectLabelClass} data-component-label>Transcript</span>
          </div>
          <button type="button" class="inline-chat-shell__latest hidden" data-inline-chat-latest>
            Til siste svar
          </button>
          <div class="inline-chat-shell__bottom-anchor" data-inline-chat-bottom aria-hidden="true" />
        </div>
        <div class="inline-chat-shell__compose-stack mt-3" data-inline-chat-compose-stack>
          <p class="inline-chat-shell__status inline-chat-shell__status--dock" data-inline-chat-status aria-live="polite"></p>
          <form class="inline-chat-shell__compose" data-component="Compose" data-inline-chat-compose>
            <span class={inspectLabelClass} data-component-label>Compose</span>
            <label class="sr-only" for="article-inline-chat-compose">Spør videre om dette</label>
            <div class="inline-chat-shell__compose-input-wrap" data-inline-chat-compose-input-wrap>
              <textarea
                id="article-inline-chat-compose"
                class="inline-chat-shell__compose-input"
                    data-inline-chat-compose-input
                    placeholder={composePlaceholder}
                    rows="1"
                    enterkeyhint="send"
                  ></textarea>
              <div class="inline-chat-shell__compose-fetch-overlay" data-inline-chat-compose-fetch-overlay aria-hidden="true">
                <span class="inline-chat-shell__compose-fetch-dots">
                  <span></span><span></span><span></span>
                </span>
                <span class="inline-chat-shell__compose-fetch-hint" data-inline-chat-compose-fetch-hint hidden></span>
              </div>
            </div>
            <button
              type="submit"
              class="inline-chat-shell__compose-send"
              data-inline-chat-compose-send
              aria-label="Send spørsmål"
              disabled
            >
              <span aria-hidden="true">↑</span>
            </button>
          </form>
        </div>
      </>
    ) : (
      <div class="inline-chat-shell__dialog-thread mt-3 hidden" data-inline-chat-selected>
        <div class="inline-chat-shell__transcript" data-component="Transcript" data-inline-chat-transcript>
          <span class={inspectLabelClass} data-component-label>Transcript</span>
        </div>
        <p class="inline-chat-shell__status" data-inline-chat-status aria-live="polite"></p>
        <button type="button" class="inline-chat-shell__latest hidden" data-inline-chat-latest>
          Til siste svar
        </button>
        <div class="inline-chat-shell__bottom-anchor" data-inline-chat-bottom aria-hidden="true" />
        <form class="inline-chat-shell__compose hidden" data-component="Compose" data-inline-chat-compose>
          <span class={inspectLabelClass} data-component-label>Compose</span>
          <label class="sr-only" for="article-inline-chat-compose">Spør videre om dette</label>
          <div class="inline-chat-shell__compose-input-wrap" data-inline-chat-compose-input-wrap>
            <textarea
              id="article-inline-chat-compose"
              class="inline-chat-shell__compose-input"
                    data-inline-chat-compose-input
                    placeholder={composePlaceholder}
                    rows="1"
                    enterkeyhint="send"
                  ></textarea>
            <div class="inline-chat-shell__compose-fetch-overlay" data-inline-chat-compose-fetch-overlay aria-hidden="true">
              <span class="inline-chat-shell__compose-fetch-dots">
                <span></span><span></span><span></span>
              </span>
              <span class="inline-chat-shell__compose-fetch-hint" data-inline-chat-compose-fetch-hint hidden></span>
            </div>
          </div>
          <button type="submit" class="inline-chat-shell__compose-send" data-inline-chat-compose-send aria-label="Send spørsmål">
            <span aria-hidden="true">↑</span>
          </button>
        </form>
      </div>
    )
  }

  <div
    class:list={[
      "vox-surface-embedded-app mt-3 inline-chat-shell__ces-bridge",
      mode === "progressive" && "inline-chat-shell__ces-bridge--hidden",
    ]}
    data-kl-surface="embedded-app"
    data-component="CESBridgeHidden"
    data-inline-chat-surface
    aria-hidden={mode === "progressive" ? "true" : undefined}
  >
    <span class={inspectLabelClass} data-component-label>CESBridgeHidden</span>
    <chat-messenger
      id="article-inline-chat-widget"
      url-allowlist="*"
      class:list={[
        "block w-full overflow-hidden rounded-none bg-[rgb(var(--surface-subtle))]",
        mode === "progressive" ? "h-[min(34vh,360px)] sm:h-[min(42vh,420px)]" : "h-[min(54vh,520px)]",
      ]}
    >
      <chat-messenger-container
        chat-title="Hørehjelpen"
        enable-file-upload
        enable-audio-input
      ></chat-messenger-container>
    </chat-messenger>
  </div>
</section>

<script is:inline define:vars={{ mode, layout }}>
  (() => {
    const shell = document.querySelector('[data-component="ArticleInlineChatShell"][data-inline-chat-mode]');
    if (!shell) return;
    const isTransitionV01 = layout === "transition-v01";
    const widget = shell.querySelector("#article-inline-chat-widget");
    const progressive = mode === "progressive";
    const selectedBox = shell?.querySelector("[data-inline-chat-selected]");
    const seedSuggestions = shell?.querySelector("[data-inline-chat-seed-suggestions]");
    const transcriptEl = shell?.querySelector("[data-inline-chat-transcript]");
    const sourceLine = shell?.querySelector("[data-inline-chat-source]");
    const statusText = shell?.querySelector("[data-inline-chat-status]");
    const latestButton = shell?.querySelector("[data-inline-chat-latest]");
    const bottomAnchor = shell?.querySelector("[data-inline-chat-bottom]");
    const composeStack = progressive ? shell?.querySelector("[data-inline-chat-compose-stack]") : null;
    const composeForm = shell?.querySelector("[data-inline-chat-compose]");
    const composeInput = shell?.querySelector("[data-inline-chat-compose-input]");
    const composeSend = shell?.querySelector("[data-inline-chat-compose-send]");
    const composeFetchHint = composeForm?.querySelector("[data-inline-chat-compose-fetch-hint]");
    const defaultComposePlaceholder = isTransitionV01 ? "Hva lurer du på?" : "Spør videre om dette";
    const seedButtons = Array.from(shell?.querySelectorAll("[data-inline-chat-seed]") || []);
    const SESSION_KEY = "viddel-article-chat-session";
    const SESSION_PATTERN = /^[a-zA-Z0-9][a-zA-Z0-9-_]{4,62}$/;
    let bridgeReady = false;
    let responseTimer = null;
    let retryTimer = null;
    let slowTimer = null;
    let controlsTimer = null;
    let autoRetryTimer = null;
    let countdownTimer = null;
    let revealTimers = [];
    let activeTurn = null;
    let turnId = 0;
    let userNearBottom = true;
    let composeVisible = false;
    const responseTimeoutMs = 24000;
    const autoRetryDelayMs = 15000;
    const countdownStartDelayMs = 5000;
    const slowStatusDelayMs = 17000;
    const controlsDelayMs = 17000;
    const retryDelayMs = 6000;

    const ensureSessionId = () => {
      try {
        const existing = sessionStorage.getItem(SESSION_KEY);
        if (existing && SESSION_PATTERN.test(existing)) return existing;
      } catch (_) {}
      const created = `viddel-${crypto.randomUUID().replace(/-/g, "").slice(0, 24)}`;
      try {
        sessionStorage.setItem(SESSION_KEY, created);
      } catch (_) {}
      return created;
    };

    const setState = (next) => {
      if (!shell) return;
      shell.setAttribute("data-inline-chat-state", next);
    };
    const setStatus = (text) => {
      if (!statusText) return;
      statusText.removeAttribute("data-inline-chat-dock-pending");
      statusText.textContent = String(text || "").trim();
    };
    const isFetchPending = () =>
      Boolean(progressive && activeTurn?.state === "pending" && !activeTurn?.responseReceived);
    const setComposeWaitHint = (text) => {
      if (!composeFetchHint) return;
      const t = String(text || "").trim();
      composeFetchHint.textContent = t;
      composeFetchHint.toggleAttribute("hidden", !t);
    };
    const syncComposeFetchOverlay = () => {
      if (!composeForm || !composeInput) return;
      const wait = isFetchPending();
      composeForm.toggleAttribute("data-inline-chat-compose-fetch-wait", wait);
      if (wait) {
        composeInput.setAttribute("placeholder", "");
      } else if (!composeInput.value.trim()) {
        composeInput.setAttribute("placeholder", defaultComposePlaceholder);
        setComposeWaitHint("");
      }
    };
    const isTurnBusy = (turn = activeTurn) => turn?.state === "pending" || turn?.state === "revealing";
    const setSeedsBusy = (busy) => {
      seedButtons.forEach((btn) => {
        if (!btn.isConnected) return;
        btn.setAttribute("aria-disabled", String(busy));
        btn.toggleAttribute("data-inline-chat-seed-busy", busy);
      });
    };
    const ensureActiveConversation = () => {
      if (!progressive || !shell) return;
      if (shell.getAttribute("data-inline-chat-conversation") === "active") return;
      shell.setAttribute("data-inline-chat-conversation", "active");
      const headerEl = shell.querySelector("[data-inline-chat-header]");
      headerEl?.classList.add("hidden");
      headerEl?.setAttribute("aria-hidden", "true");
    const landmarkId = shell.querySelector(".inline-chat-shell__transcript-divider-label")?.id;
      if (landmarkId) shell.setAttribute("aria-labelledby", landmarkId);
      const prevDivider = shell.previousElementSibling;
      if (prevDivider?.hasAttribute?.("data-inline-chat-seed-bridge-divider")) {
        prevDivider.classList.add("hidden");
        prevDivider.setAttribute("aria-hidden", "true");
      }
      seedSuggestions?.classList.add("hidden");
      seedSuggestions?.setAttribute("aria-hidden", "true");
      sourceLine?.classList.add("hidden");
      sourceLine?.setAttribute("aria-hidden", "true");
      if (isTransitionV01) {
        document.documentElement.style.setProperty("--article-chat-compose-reserve", "0px");
      }
      syncBottomReserve();
    };
    const syncComposeState = () => {
      if (!composeForm || !composeInput || !composeSend) return;
      const pending = isTurnBusy();
      composeInput.disabled = pending;
      composeSend.disabled = pending || !composeInput.value.trim();
      composeForm.toggleAttribute("data-inline-chat-compose-pending", pending);
      if (pending) composeInput.setAttribute("aria-busy", "true");
      else composeInput.removeAttribute("aria-busy");
      syncComposeFetchOverlay();
    };
    const revealBreathingGapPx = () =>
      window.matchMedia?.("(max-width: 768px)")?.matches ? 108 : 72;
    /** JS → --inline-chat-bottom-reserve. Inline: dialog-thread + sticky compose. Progressive aktiv: én måling av compose-stack (status + compose). */
    const rootRemPx = () => {
      const fs = parseFloat(getComputedStyle(document.documentElement).fontSize);
      return Number.isFinite(fs) && fs > 0 ? fs : 16;
    };
    const minBottomReservePx = () => Math.ceil(6.5 * rootRemPx());
    const stickyComposerBottomInsetPx = () => Math.max(Math.ceil(0.75 * rootRemPx()), 12);
    /** Liten luft under fixed stack i dokument-padding (ikke stor Phase A-reserve). */
    const activeStackDocumentTailPx = () => 10;
    const measuredComposeHeightPx = () =>
      composeVisible && composeForm ? composeForm.getBoundingClientRect().height : 0;
    const measuredProgressiveStackHeightPx = () => {
      if (!progressive || !composeStack || shell?.getAttribute("data-inline-chat-conversation") !== "active") return 0;
      return composeStack.getBoundingClientRect().height;
    };
    const measuredIdleStickyStackPx = () => (composeStack ? composeStack.getBoundingClientRect().height : 0);
    const syncBottomReserve = () => {
      if (!shell) return;
      if (!progressive) {
        const h = measuredComposeHeightPx();
        const gap = revealBreathingGapPx();
        const stickyBottom = stickyComposerBottomInsetPx();
        const composed = Math.ceil(h + gap + stickyBottom);
        const reserve = Math.max(minBottomReservePx(), composed);
        shell.style.setProperty("--inline-chat-bottom-reserve", `${reserve}px`);
        return;
      }
      if (shell.getAttribute("data-inline-chat-conversation") !== "active") {
        if (isTransitionV01) {
          const h = measuredIdleStickyStackPx();
          const reserve = Math.max(
            minBottomReservePx(),
            Math.ceil(h + stickyComposerBottomInsetPx() + activeStackDocumentTailPx()),
          );
          shell.style.setProperty("--inline-chat-bottom-reserve", `${reserve}px`);
          document.documentElement.style.setProperty("--article-chat-compose-reserve", `${reserve}px`);
          return;
        }
        shell.style.setProperty("--inline-chat-bottom-reserve", "0px");
        return;
      }
      const h = measuredProgressiveStackHeightPx();
      if (!h) {
        shell.style.setProperty("--inline-chat-bottom-reserve", "12px");
        return;
      }
      if (isTransitionV01 && composeStack) {
        const rect = composeStack.getBoundingClientRect();
        const blockedBottom = Math.max(0, Math.ceil(window.innerHeight - rect.top)) + 20;
        shell.style.setProperty("--inline-chat-bottom-reserve", `${blockedBottom}px`);
        document.documentElement.style.setProperty("--article-chat-compose-reserve", "0px");
        return;
      }
      const tail = activeStackDocumentTailPx();
      shell.style.setProperty("--inline-chat-bottom-reserve", `${Math.ceil(h + tail)}px`);
    };
    const getChromeTopForLayout = () => {
      if (progressive && shell?.getAttribute("data-inline-chat-conversation") === "active" && composeStack) {
        return composeStack.getBoundingClientRect().top;
      }
      if (!progressive && composeVisible && composeForm) return composeForm.getBoundingClientRect().top;
      if (progressive && composeForm && shell?.getAttribute("data-inline-chat-conversation") !== "active") {
        return composeStack ? composeStack.getBoundingClientRect().top : composeForm.getBoundingClientRect().top;
      }
      return null;
    };
    const getVisibleRevealBottom = () => {
      const chromeTop = getChromeTopForLayout();
      if (chromeTop != null) return chromeTop - revealBreathingGapPx();
      if (!composeVisible || !composeForm) return window.innerHeight - revealBreathingGapPx();
      return composeForm.getBoundingClientRect().top - revealBreathingGapPx();
    };
    /** Synlig «bunnlinje» for innhold: over compose-stack (progressive aktiv) / inline compose / vindu. */
    const getVisibleContentBottom = () => {
      if (activeTurn?.state === "revealing") return getVisibleRevealBottom();
      const chromeTop = getChromeTopForLayout();
      if (chromeTop != null) return chromeTop - 10;
      if (composeVisible && composeForm) {
        return composeForm.getBoundingClientRect().top - 10;
      }
      return window.innerHeight - revealBreathingGapPx();
    };
    const revealCompose = () => {
      if (!composeForm) return;
      if (progressive) {
        syncComposeState();
        syncBottomReserve();
        return;
      }
      if (composeVisible) return;
      composeVisible = true;
      composeForm.classList.remove("hidden");
      syncComposeState();
      syncBottomReserve();
    };
    const resizeComposeInput = () => {
      if (!composeInput) return;
      composeInput.style.height = "auto";
      composeInput.style.height = `${composeInput.scrollHeight}px`;
      syncBottomReserve();
    };
    const clearResponseTimer = () => {
      if (!responseTimer) return;
      clearTimeout(responseTimer);
      responseTimer = null;
    };
    const clearRetryTimer = () => {
      if (!retryTimer) return;
      clearTimeout(retryTimer);
      retryTimer = null;
    };
    const clearSlowTimer = () => {
      if (!slowTimer) return;
      clearTimeout(slowTimer);
      slowTimer = null;
    };
    const clearControlsTimer = () => {
      if (!controlsTimer) return;
      clearTimeout(controlsTimer);
      controlsTimer = null;
    };
    const clearAutoRetryTimer = () => {
      if (!autoRetryTimer) return;
      clearTimeout(autoRetryTimer);
      autoRetryTimer = null;
    };
    const clearCountdownTimer = () => {
      if (!countdownTimer) return;
      clearInterval(countdownTimer);
      countdownTimer = null;
      setComposeWaitHint("");
    };
    const clearRevealTimers = () => {
      revealTimers.forEach((timer) => clearTimeout(timer));
      revealTimers = [];
    };
    const clearTurnTimers = () => {
      clearResponseTimer();
      clearRetryTimer();
      clearSlowTimer();
      clearControlsTimer();
      clearAutoRetryTimer();
      clearCountdownTimer();
      clearRevealTimers();
    };
    const escapeHtml = (value) =>
      String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    const renderInlineMarkdown = (text) =>
      escapeHtml(text).replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
    const renderFormattedBlocks = (text) => {
      const normalized = String(text || "").replace(/\r\n/g, "\n").trim();
      if (!normalized) return [];
      const lines = normalized.split("\n");
      const blocks = [];
      let listType = "";
      let listItems = [];
      const closeList = () => {
        if (!listType) return;
        blocks.push(`<${listType}>${listItems.join("")}</${listType}>`);
        listType = "";
        listItems = [];
      };
      for (const rawLine of lines) {
        const line = rawLine.trim();
        if (!line) {
          closeList();
          continue;
        }
        const bullet = line.match(/^[-*]\s+(.+)$/);
        const numbered = line.match(/^(\d+)[.)]\s+(.+)$/);
        if (bullet) {
          if (listType !== "ul") {
            closeList();
            listType = "ul";
          }
          listItems.push(`<li>${renderInlineMarkdown(bullet[1])}</li>`);
          continue;
        }
        if (numbered) {
          if (listType !== "ol") {
            closeList();
            listType = "ol";
          }
          listItems.push(`<li value="${escapeHtml(numbered[1])}">${renderInlineMarkdown(numbered[2])}</li>`);
          continue;
        }
        closeList();
        blocks.push(`<p>${renderInlineMarkdown(line)}</p>`);
      }
      closeList();
      return blocks;
    };
    const renderFormattedText = (text) => renderFormattedBlocks(text).join("");
    const revealFormattedText = (turn, text, onComplete) => {
      const blocks = renderFormattedBlocks(text);
      const attemptId = turn?.attemptId;
      const prefersReducedMotion = window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches;
      clearRevealTimers();
      if (!turn?.assistantText) return;
      ensureAssistantEyebrow(turn);
      turn.assistantText.innerHTML = "";
      if (!blocks.length || prefersReducedMotion) {
        turn.assistantText.innerHTML = blocks.join("");
        onComplete?.();
        return;
      }
      const tail = document.createElement("span");
      tail.className = "inline-chat-shell__reveal-tail";
      tail.setAttribute("aria-hidden", "true");
      turn.revealTail = tail;
      turn.assistantText.append(tail);
      turn.assistantText.setAttribute("data-inline-chat-revealing", "true");
      turn.revealShouldFollow = true;
      const delayMs = Math.max(90, Math.min(220, Math.floor(1400 / Math.max(blocks.length, 1))));
      const revealNext = (index) => {
        if (activeTurn?.id !== turn.id || turn.attemptId !== attemptId || turn.state !== "revealing") return;
        tail.insertAdjacentHTML("beforebegin", blocks[index]);
        scrollRevealIntoView(turn);
        if (index >= blocks.length - 1) {
          turn.assistantText.removeAttribute("data-inline-chat-revealing");
          tail.remove();
          turn.revealTail = null;
          onComplete?.();
          return;
        }
        const timer = window.setTimeout(() => revealNext(index + 1), delayMs);
        revealTimers.push(timer);
      };
      revealNext(0);
    };
    const hideLatestButton = () => latestButton?.classList.add("hidden");
    const showLatestButton = () => latestButton?.classList.remove("hidden");
    const getLatestRevealBlock = (turn) => {
      if (!turn?.revealTail) return turn?.assistantText;
      const prev = turn.revealTail.previousElementSibling;
      return prev || turn.assistantText;
    };
    const keepAboveCompose = (target, { behavior = "auto" } = {}) => {
      if (!target) return;
      const visibleBottom = getVisibleContentBottom();
      const rect = target.getBoundingClientRect();
      const delta = rect.bottom - visibleBottom;
      if (delta <= 0) return;
      window.scrollBy({ top: Math.ceil(delta), behavior });
      hideLatestButton();
    };
    const scrollRevealIntoView = (turn) => {
      if (!turn?.revealShouldFollow || !turn.revealTail) {
        showLatestButton();
        return;
      }
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            if (activeTurn?.id !== turn.id || turn.state !== "revealing" || !turn.revealTail) return;
            keepAboveCompose(getLatestRevealBlock(turn));
          });
        });
      });
    };
    const getDefaultScrollTarget = () => {
      if (activeTurn?.state === "revealing") return activeTurn?.assistantText;
      const composeShown = progressive || composeVisible;
      if (composeShown && activeTurn?.assistantText) return activeTurn.assistantText;
      if (composeShown && bottomAnchor) return bottomAnchor;
      if (activeTurn?.assistantText) return activeTurn.assistantText;
      return bottomAnchor || transcriptEl;
    };
    const scrollToLatest = ({ force = false, target: explicitTarget = null } = {}) => {
      const target = explicitTarget || getDefaultScrollTarget();
      if (!target) return;
      const shouldFollowReveal = activeTurn?.state === "revealing" && activeTurn?.revealShouldFollow;
      if (!force && !userNearBottom && !shouldFollowReveal) {
        showLatestButton();
        return;
      }
      const behavior = force || userNearBottom || shouldFollowReveal ? "smooth" : "auto";
      requestAnimationFrame(() => {
        window.setTimeout(() => {
          if (activeTurn?.state === "revealing") {
            keepAboveCompose(
              getLatestRevealBlock(activeTurn) || activeTurn.revealTail || activeTurn.assistantText,
              { behavior: shouldFollowReveal ? "auto" : behavior }
            );
            return;
          }
          keepAboveCompose(target, { behavior });
          requestAnimationFrame(() => keepAboveCompose(target, { behavior: "auto" }));
          hideLatestButton();
        }, 40);
      });
    };
    const revealDialog = () => {
      if (selectedBox) selectedBox.classList.remove("hidden");
      syncBottomReserve();
    };
    const getFallbackHref = (query) => {
      const params = new URLSearchParams();
      if (query) params.set("seed", query);
      params.set("from", "article-r1");
      return `/no/chat?${params.toString()}`;
    };
    const ensureAssistantEyebrow = (turn) => {
      const assistant = turn?.element?.querySelector(".inline-chat-shell__message--assistant");
      if (!assistant || !turn?.assistantText) return;
      if (assistant.querySelector(".inline-chat-shell__message-eyebrow")) return;
      const p = document.createElement("p");
      p.className = "inline-chat-shell__message-eyebrow";
      p.textContent = progressive ? "Viddel" : "Hørehjelpen";
      assistant.insertBefore(p, turn.assistantText);
    };
    const createTurn = (query, { source = "seed" } = {}) => {
      if (!transcriptEl) return null;
      turnId += 1;
      const turn = {
        id: turnId,
        query,
        state: "pending",
        responseReceived: false,
        autoRetryUsed: false,
        manualRetryCount: 0,
        manualRetryInFlight: false,
        attemptId: 0,
        createdAt: Date.now(),
        element: document.createElement("div"),
        assistantText: document.createElement("div"),
      };
      turn.element.className = "inline-chat-shell__turn";
      turn.element.dataset.inlineChatTurn = String(turn.id);
      turn.element.dataset.inlineChatTurnSource = source;
      turn.element.innerHTML = `
        <div class="inline-chat-shell__message inline-chat-shell__message--user" data-component="UserMessage">
          <span class="article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950" data-component-label>UserMessage</span>
          <p class="inline-chat-shell__message-text">${escapeHtml(query)}</p>
        </div>
        <div class="inline-chat-shell__message inline-chat-shell__message--assistant" data-component="AssistantMessage">
          <span class="article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950" data-component-label>AssistantMessage</span>
        </div>
      `;
      turn.assistantText.className = "inline-chat-shell__message-text";
      turn.element.querySelector(".inline-chat-shell__message--assistant")?.append(turn.assistantText);
      transcriptEl.append(turn.element);
      return turn;
    };
    const finishActiveTurn = (state) => {
      if (activeTurn) activeTurn.state = state;
      if (activeTurn) activeTurn.manualRetryInFlight = false;
      clearTurnTimers();
      setSeedsBusy(false);
      setState(state);
      syncComposeState();
    };
    const renderTurnActions = (turn, { includeAbort = true } = {}) => {
      if (!turn || turn.state !== "pending") return;
      const href = getFallbackHref(turn.query);
      const actionHtml = `
        <p class="inline-chat-shell__turn-actions" data-inline-chat-turn-actions>
          <button type="button" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2" data-inline-chat-retry>Prøv igjen</button>
          ${includeAbort ? '<span aria-hidden="true"> · </span><button type="button" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2" data-inline-chat-abort>Avbryt</button>' : ""}
          <span aria-hidden="true"> · </span>
          <a href="${href}" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2">Åpne fri samtale</a>
        </p>
      `;
      const existingActions = turn.assistantText.querySelector("[data-inline-chat-turn-actions]");
      if (existingActions) existingActions.remove();
      turn.assistantText.insertAdjacentHTML("beforeend", actionHtml);
      turn.assistantText
        .querySelector("[data-inline-chat-retry]")
        ?.addEventListener("click", () => retryTurn(turn), { once: true });
      turn.assistantText
        .querySelector("[data-inline-chat-abort]")
        ?.addEventListener("click", () => abortTurn(turn), { once: true });
      requestAnimationFrame(() => {
        if (turn?.assistantText) keepAboveCompose(turn.assistantText, { behavior: "smooth" });
      });
    };
    const scheduleManualControls = (turn) => {
      clearControlsTimer();
      const attemptId = turn.attemptId;
      controlsTimer = setTimeout(() => {
        if (!isCurrentAttempt(turn, attemptId)) return;
        renderTurnActions(turn);
        setStatus("Du kan prøve igjen, avbryte eller åpne fri samtale.");
      }, controlsDelayMs);
    };
    const renderFallback = (turn) => {
      if (!turn) return;
      turn.state = "fallback";
      finishActiveTurn("fallback");
      ensureAssistantEyebrow(turn);
      const href = getFallbackHref(turn.query);
      turn.assistantText.innerHTML = `
        ${renderFormattedText("Svaret kom ikke helt inn her. Du kan prøve igjen, eller åpne fri samtale.")}
        <p class="inline-chat-shell__turn-actions">
          <button type="button" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2" data-inline-chat-retry>Prøv igjen</button>
          <span aria-hidden="true"> · </span>
          <a href="${href}" class="underline decoration-[rgb(var(--reading-ink-secondary))/0.55] underline-offset-2">Åpne fri samtale</a>
        </p>
      `;
      const retryButton = turn.assistantText.querySelector("[data-inline-chat-retry]");
      retryButton?.addEventListener("click", () => retryTurn(turn), { once: true });
      setStatus("");
      scrollToLatest();
    };
    const startResponseTimer = (turn) => {
      clearResponseTimer();
      const attemptId = turn.attemptId;
      responseTimer = setTimeout(() => {
        if (!isCurrentAttempt(turn, attemptId)) return;
        renderFallback(turn);
      }, responseTimeoutMs);
    };
    const startSlowTimer = (turn) => {
      clearSlowTimer();
      const attemptId = turn.attemptId;
      slowTimer = setTimeout(() => {
        if (!isCurrentAttempt(turn, attemptId)) return;
        renderTurnActions(turn);
        setStatus("Vent litt lenger …");
      }, slowStatusDelayMs);
    };
    const scheduleSilentAutoRetry = (turn) => {
      clearAutoRetryTimer();
      clearCountdownTimer();
      const attemptId = turn.attemptId;
      const retryScheduledAt = Date.now();
      countdownTimer = setInterval(() => {
        if (!isCurrentAttempt(turn, attemptId) || turn.autoRetryUsed) {
          clearCountdownTimer();
          return;
        }
        const elapsed = Date.now() - retryScheduledAt;
        if (elapsed < countdownStartDelayMs) return;
        const remainingSeconds = Math.max(1, Math.ceil((autoRetryDelayMs - elapsed) / 1000));
        setComposeWaitHint(`Nytt forsøk om ${remainingSeconds} s`);
      }, 1000);
      autoRetryTimer = setTimeout(() => {
        autoRetryTimer = null;
        if (!isCurrentAttempt(turn, attemptId) || turn.autoRetryUsed) return;
        turn.autoRetryUsed = true;
        clearCountdownTimer();
        setComposeWaitHint("");
        sendTurnQuery(turn.query, turn);
      }, autoRetryDelayMs);
    };

    const asText = (payload) => {
      if (!payload) return "";
      if (typeof payload === "string") return payload.trim();
      if (Array.isArray(payload)) {
        return payload.map((item) => asText(item)).filter(Boolean).join("\n\n").trim();
      }
      if (typeof payload === "object") {
        const candidates = [
          payload.text,
          payload.transcript,
          payload.outputText,
          payload.message,
          payload.content,
          payload.payload,
          payload.raw,
          payload.data,
          payload.messages,
          payload.outputs,
        ];
        for (const candidate of candidates) {
          const parsed = asText(candidate);
          if (parsed) return parsed;
        }
      }
      return "";
    };
    const normalizeQuery = (value) => String(value || "").replace(/\s+/g, " ").trim().toLowerCase();
    const getResponseQuery = (payload) => {
      const messages = payload?.raw?.diagnosticInfo?.messages || payload?.diagnosticInfo?.messages || [];
      if (!Array.isArray(messages)) return "";
      const userTexts = [];
      for (const message of messages) {
        if (!String(message?.role || "").toLowerCase().includes("user")) continue;
        const chunks = Array.isArray(message?.chunks) ? message.chunks : [];
        for (const chunk of chunks) {
          if (typeof chunk?.text === "string" && chunk.text.trim()) userTexts.push(chunk.text.trim());
        }
      }
      return userTexts.at(-1) || "";
    };

    const handleBotReply = (event) => {
      if (progressive || !activeTurn) return;
      if (activeTurn.state !== "pending") return;
      if (activeTurn.responseReceived) return;
      const responseQuery = getResponseQuery(event?.detail);
      if (responseQuery && normalizeQuery(responseQuery) !== normalizeQuery(activeTurn.query)) return;
      const text = asText(event?.detail);
      if (!text) return;
      deliverBotReply(activeTurn, text);
    };

    const deliverBotReply = (turn, text) => {
      if (!turn || turn.state !== "pending" || turn.responseReceived) return;
      const trimmed = String(text || "").trim();
      if (!trimmed) return;
      turn.responseReceived = true;
      turn.state = "revealing";
      clearTurnTimers();
      setSeedsBusy(false);
      setState("answered");
      syncComposeState();
      setStatus("");
      revealFormattedText(turn, trimmed, () => {
        if (activeTurn?.id !== turn.id || turn.state !== "revealing") return;
        finishActiveTurn("answered");
        revealCompose();
        setStatus("");
        scrollToLatest();
      });
    };

    const handleApiError = (turn, payload, status) => {
      if (!turn || !isCurrentAttempt(turn)) return;
      const errorCode = String(payload?.error || "");
      if (status === 429 || errorCode === "rate_limited") {
        renderTurnActions(turn);
        setStatus("Vent litt. Vi prøver igjen …");
        scheduleTransientRetry(turn);
        return;
      }
      renderTurnActions(turn);
      setStatus("Noe nølte. Vent litt, eller prøv igjen.");
    };

    const wrapArticleContext = (message) => {
      const seed = String(message || "").trim();
      if (!seed || !isTransitionV01) return seed;
      const articleLabel = shell?.dataset.articleTitle || "artikkelen";
      return `Jeg leser artikkelen «${articleLabel}». ${seed}`;
    };

    const requestChatAnswer = async (prompt, turn = activeTurn) => {
      const seed = (prompt || "").trim();
      if (!seed || !turn) return;
      const attemptId = turn.attemptId;
      try {
        const response = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({
            message: wrapArticleContext(seed),
            sessionId: ensureSessionId(),
          }),
        });
        const payload = await response.json().catch(() => ({}));
        if (!isCurrentAttempt(turn, attemptId)) return;
        if (!response.ok) {
          handleApiError(turn, payload, response.status);
          return;
        }
        const text = typeof payload.text === "string" ? payload.text.trim() : "";
        if (!text) {
          handleApiError(turn, payload, response.status);
          return;
        }
        deliverBotReply(turn, text);
      } catch (_) {
        if (!isCurrentAttempt(turn, attemptId)) return;
        handleApiError(turn, {}, 0);
      }
    };

    const pushToWidget = (prompt, turn = activeTurn) => {
      const seed = (prompt || "").trim();
      if (!seed || typeof widget.sendQuery !== "function") return false;
      const attemptId = turn?.attemptId;
      widget.sendQuery(seed).catch(() => {
        if (!progressive || !isCurrentAttempt(turn, attemptId)) return;
        renderFallback(turn);
      });
      return true;
    };

    const sendTurnQuery = (prompt, turn = activeTurn) => {
      if (progressive) {
        void requestChatAnswer(prompt, turn);
        return true;
      }
      return pushToWidget(prompt, turn);
    };

    const isCurrentAttempt = (turn, attemptId = turn?.attemptId) =>
      Boolean(
        turn &&
          activeTurn?.id === turn.id &&
          turn.attemptId === attemptId &&
          turn.state === "pending" &&
          !turn.responseReceived
      );

    const scheduleTransientRetry = (turn) => {
      if (!turn || turn.autoRetryUsed || turn.responseReceived || retryTimer) return;
      turn.autoRetryUsed = true;
      const attemptId = turn.attemptId;
      retryTimer = setTimeout(() => {
        retryTimer = null;
        if (!isCurrentAttempt(turn, attemptId)) return;
        sendTurnQuery(turn.query, turn);
      }, retryDelayMs);
    };

    const handleBridgeError = (event) => {
      if (progressive || !activeTurn || activeTurn.state !== "pending" || activeTurn.responseReceived) return;
      const detail = event?.detail || {};
      const status = String(detail.status ?? detail?.error?.status ?? "");
      const message = String(detail.message || detail?.error?.message || "");
      if (status === "429" || /fetch error/i.test(message)) {
        renderTurnActions(activeTurn);
        setStatus("Vent litt. Vi prøver igjen …");
        scheduleTransientRetry(activeTurn);
        return;
      }
      setStatus("Noe nølte. Vent litt, eller prøv igjen.");
    };

    const markBridgeReady = () => {
      if (!widget || typeof widget.sendQuery !== "function") return false;
      bridgeReady = true;
      return true;
    };

    const observeReady = () => {
      if (markBridgeReady()) return;
      let tries = 0;
      const timer = setInterval(() => {
        tries += 1;
        if (markBridgeReady() || tries > 40) clearInterval(timer);
      }, 250);
    };

    const startTurn = (seed, options = {}) => {
      const query = (seed || "").trim();
      if (!query) return;
      if (isTurnBusy()) {
        renderTurnActions(activeTurn);
        setStatus("Et svar hentes allerede. Prøv igjen, avbryt eller åpne fri samtale.");
        return;
      }
      revealDialog();
      if (progressive) ensureActiveConversation();
      clearTurnTimers();
      const turn = options.turn || createTurn(query, { source: options.source || "seed" });
      if (!turn) return;
      activeTurn = turn;
      turn.query = query;
      turn.state = "pending";
      turn.responseReceived = false;
      turn.autoRetryUsed = false;
      turn.manualRetryInFlight = false;
      turn.attemptId += 1;
      if (options.isManualRetry) turn.manualRetryCount = (turn.manualRetryCount || 0) + 1;
      setSeedsBusy(true);
      syncComposeState();
      setState("started");
      scrollToLatest({ force: true });
      if (progressive) {
        scheduleSilentAutoRetry(turn);
        scheduleManualControls(turn);
        startSlowTimer(turn);
        startResponseTimer(turn);
        setState("active");
        sendTurnQuery(query, turn);
        return;
      }
      if (pushToWidget(query, turn)) {
        scheduleSilentAutoRetry(turn);
        scheduleManualControls(turn);
        startSlowTimer(turn);
        startResponseTimer(turn);
        setState("active");
        return;
      }
      let tries = 0;
      const readyTimer = setInterval(() => {
        tries += 1;
        const pushed = pushToWidget(query, turn);
        if (pushed || tries > 20) {
          if (pushed) {
            scheduleSilentAutoRetry(turn);
            scheduleManualControls(turn);
            startSlowTimer(turn);
            startResponseTimer(turn);
            setState("active");
          }
          if (!pushed && tries > 20) renderFallback(turn);
          clearInterval(readyTimer);
        }
      }, 250);
    };

    const retryTurn = (turn) => {
      if (!turn) return;
      if (activeTurn?.state === "pending" && activeTurn.id !== turn.id) return;
      if (turn.manualRetryInFlight) return;
      activeTurn = turn;
      turn.state = "pending";
      turn.responseReceived = false;
      turn.autoRetryUsed = true;
      turn.manualRetryInFlight = true;
      turn.attemptId += 1;
      turn.manualRetryCount = (turn.manualRetryCount || 0) + 1;
      clearTurnTimers();
      setSeedsBusy(true);
      syncComposeState();
      setState("active");
      scrollToLatest({ force: true });
      if (sendTurnQuery(turn.query, turn)) {
        window.setTimeout(() => {
          turn.manualRetryInFlight = false;
        }, 1400);
        scheduleManualControls(turn);
        startSlowTimer(turn);
        startResponseTimer(turn);
        return;
      }
      turn.manualRetryInFlight = false;
      renderFallback(turn);
    };

    const abortTurn = (turn) => {
      if (!turn || activeTurn?.id !== turn.id || turn.state !== "pending") return;
      turn.state = "cancelled";
      clearTurnTimers();
      setSeedsBusy(false);
      activeTurn = null;
      setState("cancelled");
      turn.assistantText.innerHTML = renderFormattedText(
        "Vi stoppet ventingen her. Du kan velge et nytt spørsmål eller åpne fri samtale."
      );
      turn.manualRetryInFlight = false;
      syncComposeState();
      setStatus("Avbrutt. Svar som kommer senere, vises ikke her.");
      scrollToLatest();
    };

    seedButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const seed = btn.getAttribute("data-inline-chat-seed") || "";
        if (progressive) {
          startTurn(seed);
          return;
        }
        if (pushToWidget(seed)) setStatus("Sendt.");
      });
    });

    if (composeInput) {
      composeInput.addEventListener("input", () => {
        resizeComposeInput();
        syncComposeState();
      });
      composeInput.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" || event.shiftKey) return;
        event.preventDefault();
        composeForm?.requestSubmit();
      });
    }
    const nudgeScrollIfNearBottom = () => {
      if (!userNearBottom) return;
      window.requestAnimationFrame(() => {
        const t = getDefaultScrollTarget();
        if (t) keepAboveCompose(t, { behavior: "auto" });
        window.requestAnimationFrame(() => {
          const t2 = getDefaultScrollTarget();
          if (t2) keepAboveCompose(t2, { behavior: "auto" });
        });
      });
    };
    const onComposeLayoutChange = () => {
      syncBottomReserve();
      nudgeScrollIfNearBottom();
    };
    if (composeStack && "ResizeObserver" in window && progressive) {
      const stackObserver = new ResizeObserver(onComposeLayoutChange);
      stackObserver.observe(composeStack);
    }
    if (composeForm && "ResizeObserver" in window) {
      const composeObserver = new ResizeObserver(onComposeLayoutChange);
      composeObserver.observe(composeForm);
    }
    if (window.visualViewport) {
      window.visualViewport.addEventListener("resize", onComposeLayoutChange, { passive: true });
    }
    composeForm?.addEventListener("submit", (event) => {
      event.preventDefault();
      const query = composeInput?.value.trim() || "";
      if (!query || isTurnBusy()) {
        syncComposeState();
        return;
      }
      if (composeInput) {
        composeInput.value = "";
        resizeComposeInput();
      }
      startTurn(query, { source: "compose" });
      syncComposeState();
    });
    latestButton?.addEventListener("click", () => {
      if (activeTurn?.state === "revealing") activeTurn.revealShouldFollow = true;
      scrollToLatest({ force: true });
    });
    if ("IntersectionObserver" in window && bottomAnchor) {
      const bottomObserver = new IntersectionObserver(
        ([entry]) => {
          userNearBottom = Boolean(entry?.isIntersecting);
          if (userNearBottom) hideLatestButton();
        },
        {
          root: null,
          rootMargin: progressive ? "0px 0px 96px 0px" : "0px 0px 240px 0px",
          threshold: 0,
        }
      );
      bottomObserver.observe(bottomAnchor);
    }
    const stopRevealFollow = () => {
      if (activeTurn?.state === "revealing") activeTurn.revealShouldFollow = false;
    };
    window.addEventListener("wheel", stopRevealFollow, { passive: true });
    window.addEventListener("touchmove", stopRevealFollow, { passive: true });
    window.addEventListener("keydown", (event) => {
      if (!["PageUp", "PageDown", "Home", "End", "ArrowUp", "ArrowDown", " "].includes(event.key)) return;
      stopRevealFollow();
    });

    if (widget) {
      widget.addEventListener("chat-messenger-response-received", handleBotReply);
      widget.addEventListener("chat-messenger-error-v2", handleBridgeError);
    }
    if (!progressive) {
      window.addEventListener("chat-messenger-response-received", handleBotReply);
      window.addEventListener("chat-messenger-error-v2", handleBridgeError);
    }

    window.addEventListener("vox-ces-register", (event) => {
      if (!widget) return;
      const detail = event?.detail || {};
      if (detail.widgetId !== "article-inline-chat-widget") return;
      if (detail.success) {
        observeReady();
        return;
      }
      if (progressive) setStatus("Hørehjelpen er ikke klar ennå.");
    });
    if (widget) {
      window.addEventListener("chat-messenger-loaded", observeReady, { once: true });
      window.addEventListener("ces-messenger-connected", observeReady, { once: true });
      observeReady();
      let readinessTries = 0;
      const timer = setInterval(() => {
        readinessTries += 1;
        bridgeReady = typeof widget.sendQuery === "function";
        if (bridgeReady || readinessTries > 40) clearInterval(timer);
      }, 250);
    }
    window.requestAnimationFrame(() => syncBottomReserve());
    if (isTransitionV01 && composeStack && "ResizeObserver" in window) {
      const idleStackObserver = new ResizeObserver(() => syncBottomReserve());
      idleStackObserver.observe(composeStack);
    }
    window.addEventListener("resize", () => syncBottomReserve(), { passive: true });
    if (window.visualViewport) {
      window.visualViewport.addEventListener("resize", () => syncBottomReserve(), { passive: true });
    }
  })();
</script>

<style is:global>
  .inline-chat-shell__transcript {
    display: grid;
    gap: 0.9rem;
  }

  .inline-chat-shell[data-inline-chat-mode="inline"] .inline-chat-shell__dialog-thread {
    padding-bottom: calc(var(--inline-chat-bottom-reserve, 120px) + env(safe-area-inset-bottom, 0px) + 0.75rem);
  }

  .inline-chat-shell[data-inline-chat-mode="progressive"][data-inline-chat-conversation="active"] .inline-chat-shell__dialog-thread {
    padding-bottom: calc(var(--inline-chat-bottom-reserve, 0px) + 0.12rem);
  }

  .inline-chat-shell__transcript-divider {
    align-items: center;
    display: grid;
    gap: 0.55rem;
    grid-template-columns: minmax(1.4rem, 1fr) auto;
    margin: 0.15rem 0 0.75rem;
  }

  .inline-chat-shell__transcript-divider-line {
    border-top: 1px solid rgb(var(--border) / 0.48);
    display: block;
    min-width: 0;
  }

  .inline-chat-shell__transcript-divider-label {
    color: rgb(var(--reading-ink-secondary));
    font-size: 0.68rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .inline-chat-shell[data-inline-chat-mode="inline"] .inline-chat-shell__bottom-anchor {
    height: clamp(0.5rem, calc(var(--inline-chat-bottom-reserve, 120px) * 0.12), 2.75rem);
    scroll-margin-bottom: min(3.5rem, var(--inline-chat-bottom-reserve, 120px));
  }

  .inline-chat-shell[data-inline-chat-mode="inline"] .inline-chat-shell__message-text {
