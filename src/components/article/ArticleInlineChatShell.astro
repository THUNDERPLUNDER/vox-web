---
/* CONTRACT: Inline article chat shell with seed starters and in-place CES conversation. */
export interface PromptItem {
  question: string;
}

export interface Props {
  title: string;
  intro: string;
  headingId: string;
  items: PromptItem[];
  sourceLabel?: string;
  mode?: "inline" | "progressive";
  freeChatLabel?: string;
}

const {
  title,
  intro,
  headingId,
  items,
  sourceLabel = "artikkel",
  mode = "inline",
  freeChatLabel = "Start fri samtale",
} = Astro.props;
---

<section
  class="inline-chat-shell ams-zone"
  aria-labelledby={headingId}
  data-component="ArticleInlineChatShell"
  data-inline-chat-mode={mode}
  data-inline-chat-state={mode === "progressive" ? "idle" : "active"}
>
  <header class="inline-chat-shell__header">
    <h2 id={headingId} class="inline-chat-shell__title">{title}</h2>
    <p class="inline-chat-shell__intro">{intro}</p>
  </header>

  {mode === "progressive" ? (
    <p
      class="inline-chat-shell__affordance text-xs font-medium uppercase tracking-[0.12em] text-[rgb(var(--reading-ink-secondary))]"
      data-inline-chat-affordance
    >
      Dialog med Hørehjelpen
    </p>
  ) : null}

  <ul
    class:list={[
      "inline-chat-shell__seed-list",
      mode === "progressive" && "inline-chat-shell__seed-list--rows",
    ]}
    role="list"
  >
    {
      items.map((item) => (
        <li class={mode === "progressive" ? "inline-chat-shell__seed-item" : undefined}>
          <button
            type="button"
            class:list={[
              "inline-chat-shell__seed-btn",
              mode === "progressive" && "inline-chat-shell__seed-row",
            ]}
            data-inline-chat-seed={item.question}
          >
            <span class={mode === "progressive" ? "inline-chat-shell__seed-question" : undefined}>{item.question}</span>
            {mode === "progressive" ? (
              <span class="inline-chat-shell__seed-icon" aria-hidden="true">
                <svg class="inline-chat-shell__seed-icon-svg" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            ) : null}
          </button>
        </li>
      ))
    }
  </ul>

  {mode === "progressive" ? (
    <button type="button" class="prompt-group__cta inline-chat-shell__free-chat" data-inline-chat-free-trigger>
      {freeChatLabel}
    </button>
  ) : null}

  <p class="inline-chat-shell__source text-[11px] text-[rgb(var(--muted))]">
    Kontekst: {sourceLabel}. Velg et startspørsmål{mode === "progressive" ? " for å åpne samtalen." : " eller skriv fritt i feltet under."}
  </p>

  <div class="inline-chat-shell__dialog-thread mt-3 hidden" data-inline-chat-selected>
    <div class="inline-chat-shell__message inline-chat-shell__message--user">
      <p class="inline-chat-shell__message-eyebrow">Du valgte</p>
      <p class="inline-chat-shell__message-text" data-inline-chat-selected-text></p>
    </div>
    <div class="inline-chat-shell__message inline-chat-shell__message--assistant">
      <p class="inline-chat-shell__message-eyebrow">Hørehjelpen</p>
      <p class="inline-chat-shell__message-text" data-inline-chat-reply>Hørehjelpen svarer ...</p>
    </div>
    <p class="inline-chat-shell__status" data-inline-chat-status aria-live="polite">
      Vi bruker chatmotoren i bakgrunnen.
    </p>
  </div>

  <div
    class:list={[
      "vox-surface-embedded-app mt-3",
      mode === "progressive" && "hidden",
    ]}
    data-kl-surface="embedded-app"
    data-inline-chat-surface
  >
    <chat-messenger
      id="article-inline-chat-widget"
      url-allowlist="*"
      class:list={[
        "block w-full overflow-hidden rounded-none bg-[rgb(var(--surface-subtle))]",
        mode === "progressive" ? "h-[min(34vh,360px)] sm:h-[min(42vh,420px)]" : "h-[min(54vh,520px)]",
      ]}
    >
      <chat-messenger-container
        chat-title="Horehjelpen"
        enable-file-upload
        enable-audio-input
      ></chat-messenger-container>
    </chat-messenger>
  </div>
</section>

<script is:inline define:vars={{ sourceLabel, mode }}>
  (() => {
    const shell = document.querySelector('[data-component="ArticleInlineChatShell"][data-inline-chat-mode]');
    const widget = shell?.querySelector("#article-inline-chat-widget");
    if (!widget) return;
    const progressive = mode === "progressive";
    const selectedBox = shell?.querySelector("[data-inline-chat-selected]");
    const selectedText = shell?.querySelector("[data-inline-chat-selected-text]");
    const replyText = shell?.querySelector("[data-inline-chat-reply]");
    const statusText = shell?.querySelector("[data-inline-chat-status]");
    const surface = shell?.querySelector("[data-inline-chat-surface]");
    let bridgeReady = false;
    let responseTimer = null;
    let awaitingResponse = false;
    const setState = (next) => {
      if (!shell) return;
      shell.setAttribute("data-inline-chat-state", next);
    };
    const setStatus = (text) => {
      if (statusText) statusText.textContent = text;
    };
    const clearResponseTimer = () => {
      if (!responseTimer) return;
      clearTimeout(responseTimer);
      responseTimer = null;
    };
    const startResponseTimer = () => {
      clearResponseTimer();
      awaitingResponse = true;
      responseTimer = setTimeout(() => {
        if (!awaitingResponse) return;
        awaitingResponse = false;
        if (replyText) {
          replyText.textContent =
            "Vi fikk ikke hentet svaret inn i artikkelflaten ennå. Prøv fri samtale under hvis du vil fortsette nå.";
        }
        setStatus("Svar-event fra chatmotoren ble ikke fanget innen tidsgrensen.");
        setState("fallback");
      }, 14000);
    };
    const revealDialog = () => {
      if (selectedBox) selectedBox.classList.remove("hidden");
    };
    const revealSurface = () => {
      revealDialog();
      if (surface) surface.classList.remove("hidden");
    };

    const asText = (payload) => {
      if (!payload) return "";
      if (typeof payload === "string") return payload.trim();
      if (Array.isArray(payload)) {
        return payload.map((item) => asText(item)).filter(Boolean).join("\n").trim();
      }
      if (typeof payload === "object") {
        const candidates = [
          payload.text,
          payload.transcript,
          payload.outputText,
          payload.message,
          payload.content,
          payload.payload,
          payload.raw,
          payload.data,
          payload.messages,
        ];
        for (const candidate of candidates) {
          const parsed = asText(candidate);
          if (parsed) return parsed;
        }
      }
      return "";
    };

    const handleBotReply = (event) => {
      if (!progressive) return;
      const text = asText(event?.detail);
      if (!text) return;
      awaitingResponse = false;
      clearResponseTimer();
      if (replyText) replyText.textContent = text;
      setStatus("Svar mottatt.");
      setState("answered");
    };

    const markBridgeReady = () => {
      if (!widget || typeof widget.sessionInput !== "function") return false;
      bridgeReady = true;
      return true;
    };

    const observeReady = () => {
      if (markBridgeReady()) return;
      let tries = 0;
      const timer = setInterval(() => {
        tries += 1;
        if (markBridgeReady() || tries > 40) clearInterval(timer);
      }, 250);
    };

    const pushToWidget = (prompt) => {
      const seed = (prompt || "").trim();
      if (!seed || typeof widget.sessionInput !== "function") return false;
      const wrapped = [
        "Du er Hørehjelpen, en varm og konkret veileder for hørsel i hverdagen.",
        "Svar kort og handlingsrettet i norsk.",
        `Kontekst: brukeren kommer fra ${sourceLabel}.`,
        "",
        `Spørsmål: ${seed}`,
      ].join("\n");
      widget.open?.();
      widget.show?.();
      widget.sessionInput(wrapped);
      return true;
    };

    const startFreeChat = () => {
      revealSurface();
      if (selectedText) selectedText.textContent = "Fri samtale";
      if (replyText) replyText.textContent = "Skriv i feltet under når du er klar.";
      setStatus("Fri samtale bruker den synlige chatflaten.");
      setState("started");
      widget.open?.();
      widget.show?.();
      if (typeof widget.sessionInput === "function") {
        setState("active");
        return;
      }
      let retry = 0;
      const freeRetryTimer = setInterval(() => {
        retry += 1;
        widget.open?.();
        widget.show?.();
        if (typeof widget.sessionInput === "function" || retry > 20) {
          if (typeof widget.sessionInput === "function") setState("active");
          clearInterval(freeRetryTimer);
        }
      }, 250);
    };

    bridgeReady = !progressive && pushToWidget("");
    let tries = 0;
    const timer = setInterval(() => {
      tries += 1;
      bridgeReady = typeof widget.sessionInput === "function";
      if (bridgeReady || tries > 40) clearInterval(timer);
    }, 250);

    shell?.querySelectorAll("[data-inline-chat-seed]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const seed = btn.getAttribute("data-inline-chat-seed") || "";
        if (progressive) {
          if (selectedText) selectedText.textContent = seed;
          if (replyText) replyText.textContent = "Hørehjelpen svarer ...";
          setStatus(bridgeReady ? "Hørehjelpen svarer ..." : "Kobler til Hørehjelpen ...");
          revealDialog();
          setState("started");
        }
        if (pushToWidget(seed)) {
          if (progressive) {
            setStatus("Sendt til Hørehjelpen. Venter på svar ...");
            startResponseTimer();
          }
          if (progressive) setState("active");
          return;
        }
        let retry = 0;
        const retryTimer = setInterval(() => {
          retry += 1;
          const pushed = pushToWidget(seed);
          if (pushed || retry > 20) {
            if (pushed && progressive) {
              setStatus("Sendt til Hørehjelpen. Venter på svar ...");
              startResponseTimer();
            }
            if (!pushed && retry > 20 && progressive) {
              awaitingResponse = false;
              clearResponseTimer();
              if (replyText) {
                replyText.textContent =
                  "Vi fikk ikke sendt spørsmålet til chatmotoren akkurat nå. Prøv fri samtale under.";
              }
              setStatus("Kunne ikke sende til chatmotoren akkurat nå.");
            }
            if (pushed && progressive) setState("active");
            clearInterval(retryTimer);
          }
        }, 250);
      });
    });

    const freeTrigger = shell?.querySelector("[data-inline-chat-free-trigger]");
    if (freeTrigger) {
      freeTrigger.addEventListener("click", startFreeChat);
    }

    for (const eventName of ["ces-text-received", "ces-message-received"]) {
      widget.addEventListener(eventName, handleBotReply);
    }

    window.addEventListener("vox-ces-register", (event) => {
      const detail = event?.detail || {};
      if (detail.widgetId !== "article-inline-chat-widget") return;
      if (detail.success) {
        observeReady();
        return;
      }
      if (progressive) setStatus("Chatmotoren er ikke klar ennå.");
    });
    window.addEventListener("chat-messenger-loaded", observeReady, { once: true });
    window.addEventListener("ces-messenger-connected", observeReady, { once: true });
    observeReady();
  })();
</script>
