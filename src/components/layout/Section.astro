<!-- CONTRACT: Page section wrapper with optional surface tone and extra classes. -->
---
const { as: Tag = "section", id, tone = "default", class: className = "" } = Astro.props;

const tones = {
  default: "",
  surface: "bg-[rgb(var(--surface))] border border-[rgb(var(--border))] rounded-[var(--radius-lg)] shadow-[var(--shadow-sm)]",
  /** Full-width tonal band (rytme under hero / mellom blokker) */
  band: "border-y border-[rgb(var(--border))/0.45] bg-[rgb(var(--surface-subtle))]",
};
---

<Tag id={id} class={`py-12 sm:py-16 ${tones[tone] ?? tones.default} ${className}`.trim()}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <slot />
  </div>
</Tag>