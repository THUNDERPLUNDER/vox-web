<!-- CONTRACT: Shared inline boot for theme + inspect toggles (single inclusion per page). -->
<script is:inline>
  (function () {
    var STORAGE_KEY = "vox-theme";
    var INSPECT_STORAGE_KEY = "vox-inspect-components";
    var TESTINFO_STORAGE_KEY = "vox-inspect-testinfo";

    function resolvedColorScheme(mode) {
      if (mode === "light") return "light";
      if (mode === "dark") return "dark";
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }

    function applyTheme(mode) {
      if (mode !== "light" && mode !== "dark" && mode !== "system") mode = "system";
      try {
        localStorage.setItem(STORAGE_KEY, mode);
      } catch (_) {}
      document.documentElement.setAttribute("data-theme", mode);
      document.documentElement.style.colorScheme = resolvedColorScheme(mode);
      syncButtons();
    }

    function syncButtons() {
      var mode = document.documentElement.getAttribute("data-theme") || "system";
      document.querySelectorAll("[data-theme-choice]").forEach(function (btn) {
        var choice = btn.getAttribute("data-theme-choice");
        btn.setAttribute("aria-pressed", choice === mode ? "true" : "false");
      });
      var inspectOn = document.documentElement.getAttribute("data-inspect-components") === "true";
      document.querySelectorAll("[data-inspect-toggle='components']").forEach(function (btn) {
        btn.setAttribute("aria-pressed", inspectOn ? "true" : "false");
      });
      var testInfoOn = document.documentElement.getAttribute("data-inspect-testinfo") === "true";
      document.querySelectorAll("[data-inspect-toggle='testinfo']").forEach(function (btn) {
        btn.setAttribute("aria-pressed", testInfoOn ? "true" : "false");
      });
    }

    function normalizePath(pathname) {
      var p = pathname.replace(/\/$/, "");
      return p || "/";
    }

    function isDemoQueryOnlyInspectPath(pathname) {
      return normalizePath(pathname) === "/no/artikkel/r1-spoke-v03";
    }

    function supportsInspectToggle(pathname) {
      pathname = normalizePath(pathname);
      return (
        pathname === "/no/artikkel/r1-spoke-v01" ||
        pathname === "/no/artikkel/r1-spoke-v02" ||
        pathname === "/no/artikkel/r1-spoke-v03" ||
        pathname === "/no/artikkel/r2-spoke-v01" ||
        pathname === "/no/artikkel/r3-spoke-v01" ||
        pathname === "/no/artikkel/slik-tar-du-praten" ||
        pathname === "/no/sandbox/article-template-v01"
      );
    }

    function syncFooterInspectButtonVisibility() {
      var path = normalizePath(window.location.pathname);
      var enableInspect = supportsInspectToggle(path);
      var params = new URLSearchParams(window.location.search);
      var inspectInUrl = params.get("inspect") === "components";
      var testinfoInUrl = params.get("testinfo") === "true";
      var showOnDemoFooter = inspectInUrl || testinfoInUrl;
      document.querySelectorAll("[data-inspect-toggle='components']").forEach(function (btn) {
        if (btn.closest("[data-vox-inspect-drawer]")) {
          btn.hidden = false;
          return;
        }
        btn.hidden = !enableInspect || (isDemoQueryOnlyInspectPath(path) && !showOnDemoFooter);
      });
      document.querySelectorAll("[data-inspect-toggle='testinfo']").forEach(function (btn) {
        if (btn.closest("[data-vox-inspect-drawer]")) {
          btn.hidden = false;
          return;
        }
        btn.hidden = !enableInspect || (isDemoQueryOnlyInspectPath(path) && !showOnDemoFooter);
      });
    }

    function toggleInspectParam() {
      var url = new URL(window.location.href);
      var params = url.searchParams;
      var enabled = params.get("inspect") === "components";
      var nextEnabled = !enabled;
      if (nextEnabled) params.set("inspect", "components");
      else params.delete("inspect");
      window.history.replaceState({}, "", url.pathname + (params.toString() ? "?" + params.toString() : "") + url.hash);
      setInspectState(nextEnabled);
      syncFooterInspectButtonVisibility();
      syncButtons();
    }

    function toggleTestInfoParam() {
      var url = new URL(window.location.href);
      var params = url.searchParams;
      var enabled = params.get("testinfo") === "true";
      var nextEnabled = !enabled;
      if (nextEnabled) params.set("testinfo", "true");
      else params.delete("testinfo");
      window.history.replaceState({}, "", url.pathname + (params.toString() ? "?" + params.toString() : "") + url.hash);
      setTestInfoState(nextEnabled);
      syncFooterInspectButtonVisibility();
      syncButtons();
    }

    function setInspectState(enabled) {
      document.documentElement.setAttribute("data-inspect-components", enabled ? "true" : "false");
      if (isDemoQueryOnlyInspectPath(window.location.pathname)) return;
      try {
        localStorage.setItem(INSPECT_STORAGE_KEY, enabled ? "true" : "false");
      } catch (_) {}
    }

    function setTestInfoState(enabled) {
      document.documentElement.setAttribute("data-inspect-testinfo", enabled ? "true" : "false");
      if (isDemoQueryOnlyInspectPath(window.location.pathname)) return;
      try {
        localStorage.setItem(TESTINFO_STORAGE_KEY, enabled ? "true" : "false");
      } catch (_) {}
    }

    function resolveInitialInspectState(pathname) {
      var fromQuery = new URLSearchParams(window.location.search).get("inspect") === "components";
      if (isDemoQueryOnlyInspectPath(pathname)) return fromQuery;
      if (fromQuery) return true;
      try {
        return localStorage.getItem(INSPECT_STORAGE_KEY) === "true";
      } catch (_) {
        return false;
      }
    }

    function resolveInitialTestInfoState(pathname) {
      var fromQuery = new URLSearchParams(window.location.search).get("testinfo") === "true";
      if (isDemoQueryOnlyInspectPath(pathname)) return fromQuery;
      if (fromQuery) return true;
      try {
        return localStorage.getItem(TESTINFO_STORAGE_KEY) === "true";
      } catch (_) {
        return false;
      }
    }

    window.addEventListener("DOMContentLoaded", function () {
      var path = normalizePath(window.location.pathname);
      var enableInspect = supportsInspectToggle(path);
      syncFooterInspectButtonVisibility();
      setInspectState(enableInspect ? resolveInitialInspectState(path) : false);
      setTestInfoState(enableInspect ? resolveInitialTestInfoState(path) : false);
      syncButtons();
      document.querySelectorAll("[data-theme-choice]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          applyTheme(btn.getAttribute("data-theme-choice"));
        });
      });
      document.querySelectorAll("[data-inspect-toggle='components']").forEach(function (btn) {
        btn.addEventListener("click", function () {
          toggleInspectParam();
        });
      });
      document.querySelectorAll("[data-inspect-toggle='testinfo']").forEach(function (btn) {
        btn.addEventListener("click", function () {
          toggleTestInfoParam();
        });
      });
    });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", function () {
        if (document.documentElement.getAttribute("data-theme") === "system") {
          document.documentElement.style.colorScheme = resolvedColorScheme("system");
        }
      });
  })();
</script>
