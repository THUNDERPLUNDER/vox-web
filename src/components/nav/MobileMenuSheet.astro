<!-- CONTRACT: Full-screen mobile drawer; must stay outside backdrop-blur ancestors so fixed positioning works. -->
---
import { NO_NAV_LINKS } from "../../lib/no-nav-links";
import { isNavActive } from "../../lib/nav-active";

type Props = {
  currentPath?: string;
  brand?: "default" | "klarlyd";
  showDevtoolsToggle?: boolean;
};

const { currentPath = "", brand = "default", showDevtoolsToggle = false } = Astro.props as Props;
const menuTitle = brand === "klarlyd" ? "KLARLYD meny" : "VOX meny";
---

<div
  id="mobileSheet"
  class="fixed inset-0 z-[100] hidden lg:hidden"
  data-open="false"
>
  <button
    id="mobileOverlay"
    type="button"
    class="fixed inset-0 z-[3000] bg-[rgb(var(--text))/0.25] backdrop-blur-[1px]"
    aria-label="Lukk meny"
  ></button>
  <div
    id="mobilePanel"
    class="fixed top-0 right-0 z-[3001] h-full w-[min(420px,90vw)] translate-x-full overflow-y-auto bg-[rgb(var(--surface-elevated))] px-4 pb-6 pt-5 shadow-[var(--shadow-md)] transition-transform duration-200"
  >
    <div
      class="sticky top-0 z-10 mb-3 flex items-center justify-between bg-[rgb(var(--surface-elevated))/0.96] py-2 backdrop-blur-sm"
    >
      <p class="text-sm font-medium text-[rgb(var(--muted))]">{menuTitle}</p>
    </div>

    <nav class="mt-1 space-y-1">
      {
        NO_NAV_LINKS.map((link) => {
          const isActive = isNavActive(link.href, currentPath);
          return (
            <a
              href={link.href}
              class={`flex w-full items-center justify-between rounded-[var(--radius-sm)] px-3 py-3 text-sm transition-colors ${
                isActive
                  ? "bg-[rgb(var(--surface-subtle))] font-semibold text-[rgb(var(--text))]"
                  : "text-[rgb(var(--muted))] hover:bg-[rgb(var(--surface-subtle))/0.7] hover:text-[rgb(var(--text))]"
              }`}
            >
              <span>{link.label}</span>
              <span aria-hidden="true">→</span>
            </a>
          );
        })
      }
    </nav>
    {
      showDevtoolsToggle ? (
        <div class="mt-4 border-t border-[rgb(var(--border))/0.35] pt-4">
          <button
            type="button"
            class="flex w-full items-center justify-center rounded-[var(--radius-sm)] border border-dashed border-[rgb(var(--border))/0.55] px-3 py-2.5 text-sm text-[rgb(var(--muted))] transition-colors hover:bg-[rgb(var(--surface-subtle))/0.6] hover:text-[rgb(var(--text-secondary))]"
            data-vox-header-devtools-toggle
            data-vox-internal-devtools
            aria-label="Devtools (intern)"
            aria-pressed="false"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M4 21v-7" />
              <path d="M4 10V3" />
              <path d="M12 21v-9" />
              <path d="M12 8V3" />
              <path d="M20 21v-5" />
              <path d="M20 12V3" />
              <path d="M2 14h4" />
              <path d="M10 8h4" />
              <path d="M18 16h4" />
            </svg>
          </button>
        </div>
      ) : null
    }
  </div>
</div>

<script is:inline>
  const sheet = document.getElementById("mobileSheet");
  const panel = document.getElementById("mobilePanel");
  const overlay = document.getElementById("mobileOverlay");
  const toggleBtn = document.getElementById("menuToggleBtn");
  const menuIconPath = document.getElementById("menuIconPath");

  const setMenuOpen = (isOpen) => {
    if (!menuIconPath) return;
    menuIconPath.setAttribute(
      "d",
      isOpen ? "M6 6l12 12M18 6L6 18" : "M4 7h16M4 12h16M4 17h16",
    );
  };

  const openSheet = () => {
    if (!sheet || !panel) return;
    sheet.classList.remove("hidden");
    sheet.dataset.open = "true";
    toggleBtn?.setAttribute("aria-label", "Lukk meny");
    setMenuOpen(true);
    requestAnimationFrame(() => panel.classList.remove("translate-x-full"));
  };

  const closeSheet = () => {
    if (!sheet || !panel) return;
    panel.classList.add("translate-x-full");
    sheet.dataset.open = "false";
    toggleBtn?.setAttribute("aria-label", "Meny");
    setMenuOpen(false);
    setTimeout(() => sheet.classList.add("hidden"), 180);
  };

  toggleBtn?.addEventListener("click", () => {
    if (sheet?.dataset.open === "true") {
      closeSheet();
    } else {
      openSheet();
    }
  });
  overlay?.addEventListener("click", closeSheet);
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && sheet?.dataset.open === "true") closeSheet();
  });
</script>
