<!-- CONTRACT: Global site header with desktop nav and mobile menu trigger. -->
---
import MobileMenuTrigger from "./MobileMenuTrigger.astro";
import { NO_NAV_LINKS } from "../../lib/no-nav-links";
import { isNavActive } from "../../lib/nav-active";

type Props = {
  currentPath?: string;
  /** Sandbox wordmark test — default keeps VOX · Hørehjelpen */
  brand?: "default" | "klarlyd";
};

const { currentPath = "", brand = "default" } = Astro.props as Props;
const base = import.meta.env.BASE_URL;
const homeHref = `${base}no`;
const chatHref = `${base}no/chat`;
---

<header class="h-16 sm:h-[4.5rem]">
  <div class="flex h-full items-center gap-3 sm:gap-4">
    <a
      href={homeHref}
      class="inline-flex items-center rounded-[var(--radius-sm)] px-2 py-1.5 text-sm font-semibold tracking-tight text-[rgb(var(--text))] sm:text-base"
    >
      {
        brand === "klarlyd" ? (
          <span class="inline-flex items-baseline gap-0.5 font-display text-[0.8125rem] font-semibold tracking-[0.16em] text-[rgb(var(--text))] sm:text-[0.9375rem]">
            <span>KLAR</span>
            <span class="bg-gradient-to-r from-[rgb(var(--primary))] to-[rgb(var(--accent-gradient-end))] bg-clip-text text-transparent">
              LYD
            </span>
          </span>
        ) : (
          <>
            <span class="font-semibold">VOX</span>
            <span class="mx-2 text-[rgb(var(--muted))]">·</span>
            <span class="text-[rgb(var(--muted))]">Hørehjelpen</span>
          </>
        )
      }
    </a>
    <nav class="hidden flex-1 items-center justify-center gap-1 lg:flex">
      {NO_NAV_LINKS.map((link) => {
        const isActive = isNavActive(link.href, currentPath);
        return (
          <a
            href={link.href}
            class={`rounded-[var(--radius-sm)] px-3 py-2 text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus-ring))/0.4] ${
              isActive
                ? "bg-[rgb(var(--surface-subtle))] font-semibold text-[rgb(var(--text))] shadow-[0_6px_16px_-14px_rgba(15,23,42,0.5)]"
                : "text-[rgb(var(--muted))] hover:bg-[rgb(var(--surface-subtle))/0.7] hover:text-[rgb(var(--text))]"
            }`}
          >
            {link.label}
          </a>
        );
      })}
    </nav>
    <a
      href={chatHref}
      class="sonic-pulse-cta hidden items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-semibold lg:inline-flex"
    >
      Start samtale
    </a>
    <MobileMenuTrigger />
  </div>
</header>
