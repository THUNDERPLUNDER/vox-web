<!-- CONTRACT: Global footer with utility links and neutral line. -->
---
import ThemeControl from "../ThemeControl.astro";
---

<footer class="mt-16 py-8 sm:mt-20 sm:py-10">
  <nav class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[rgb(var(--muted))]">
    <a href="/no/ordbok" class="hover:text-[rgb(var(--text))]">Ordbok</a>
    <a href="/no/om" class="hover:text-[rgb(var(--text))]">Om</a>
    <a href="/no/personvern" class="hover:text-[rgb(var(--text))]">Personvern</a>
  </nav>
  <p class="mt-4 text-xs text-[rgb(var(--muted))]">
    Hørehjelpen er under utvikling.
  </p>
  <div class="mt-5">
    <ThemeControl />
  </div>
</footer>
