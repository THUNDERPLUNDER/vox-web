<!-- CONTRACT: MVP theme switcher (system / light / dark); pairs with head script in BaseLayout. -->
---
import ThemeInspectBootScript from "./ThemeInspectBootScript.astro";

const {
  compact = false,
  omitScript = false,
  /** Inspect/testinfo toggles: keep in inspect drawer (#76); article footers may still host them until drawer is universal. */
  includeInspectToggles = true,
} = Astro.props as {
  compact?: boolean;
  /** When true, markup only — pair with ThemeInspectBootScript once per page. */
  omitScript?: boolean;
  includeInspectToggles?: boolean;
};
---

<div
  class:list={["theme-control", compact && "theme-control--compact", !compact && "mt-10"]}
  role="group"
  aria-label="Fargetema"
>
  <p class="mb-2 text-xs font-medium text-[rgb(var(--muted))]">Tema</p>
  <div class="flex flex-wrap gap-2">
    <button
      type="button"
      class="theme-control__btn"
      data-theme-choice="system"
      aria-pressed="false"
    >
      System
    </button>
    <button type="button" class="theme-control__btn" data-theme-choice="light" aria-pressed="false">
      Lys
    </button>
    <button type="button" class="theme-control__btn" data-theme-choice="dark" aria-pressed="false">
      Mørk
    </button>
    {
      includeInspectToggles ? (
        <>
          <button
            type="button"
            class="theme-control__btn"
            data-inspect-toggle="components"
            aria-pressed="false"
            hidden
          >
            Komponenter
          </button>
          <button
            type="button"
            class="theme-control__btn"
            data-inspect-toggle="testinfo"
            aria-pressed="false"
            hidden
          >
            Testinfo
          </button>
        </>
      ) : null
    }
  </div>
</div>

{!omitScript ? <ThemeInspectBootScript /> : null}
