<!-- CONTRACT: MVP theme switcher (system / light / dark); pairs with head script in BaseLayout. -->
---
const { compact = false } = Astro.props;
---

<div
  class:list={["theme-control", compact && "theme-control--compact", !compact && "mt-10"]}
  role="group"
  aria-label="Fargetema"
>
  <p class="mb-2 text-xs font-medium text-[rgb(var(--muted))]">Tema</p>
  <div class="flex flex-wrap gap-2">
    <button
      type="button"
      class="theme-control__btn"
      data-theme-choice="system"
      aria-pressed="false"
    >
      System
    </button>
    <button type="button" class="theme-control__btn" data-theme-choice="light" aria-pressed="false">
      Lys
    </button>
    <button type="button" class="theme-control__btn" data-theme-choice="dark" aria-pressed="false">
      Mørk
    </button>
    <button
      type="button"
      class="theme-control__btn"
      data-inspect-toggle="components"
      aria-pressed="false"
      hidden
    >
      Komponenter
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = "vox-theme";

    function resolvedColorScheme(mode) {
      if (mode === "light") return "light";
      if (mode === "dark") return "dark";
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }

    function applyTheme(mode) {
      if (mode !== "light" && mode !== "dark" && mode !== "system") mode = "system";
      try {
        localStorage.setItem(STORAGE_KEY, mode);
      } catch (_) {}
      document.documentElement.setAttribute("data-theme", mode);
      document.documentElement.style.colorScheme = resolvedColorScheme(mode);
      syncButtons();
    }

    function syncButtons() {
      var mode = document.documentElement.getAttribute("data-theme") || "system";
      document.querySelectorAll("[data-theme-choice]").forEach(function (btn) {
        var choice = btn.getAttribute("data-theme-choice");
        btn.setAttribute("aria-pressed", choice === mode ? "true" : "false");
      });
      var inspectOn = new URLSearchParams(window.location.search).get("inspect") === "components";
      document.querySelectorAll("[data-inspect-toggle='components']").forEach(function (btn) {
        btn.setAttribute("aria-pressed", inspectOn ? "true" : "false");
      });
    }

    function supportsInspectToggle(pathname) {
      return (
        pathname === "/no/artikkel/r1-spoke-v01" ||
        pathname === "/no/artikkel/r2-spoke-v01" ||
        pathname === "/no/artikkel/r3-spoke-v01" ||
        pathname === "/no/sandbox/article-template-v01"
      );
    }

    function toggleInspectParam() {
      var url = new URL(window.location.href);
      var params = url.searchParams;
      var enabled = params.get("inspect") === "components";
      if (enabled) params.delete("inspect");
      else params.set("inspect", "components");
      url.search = params.toString();
      window.location.assign(url.toString());
    }

    window.addEventListener("DOMContentLoaded", function () {
      syncButtons();
      var enableInspect = supportsInspectToggle(window.location.pathname);
      document.querySelectorAll("[data-inspect-toggle='components']").forEach(function (btn) {
        btn.hidden = !enableInspect;
      });
      document.querySelectorAll("[data-theme-choice]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          applyTheme(btn.getAttribute("data-theme-choice"));
        });
      });
      document.querySelectorAll("[data-inspect-toggle='components']").forEach(function (btn) {
        btn.addEventListener("click", function () {
          toggleInspectParam();
        });
      });
    });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", function () {
        if (document.documentElement.getAttribute("data-theme") === "system") {
          document.documentElement.style.colorScheme = resolvedColorScheme("system");
        }
      });
  })();
</script>
