---
/* CONTRACT: Sandbox-only curated next-step prompts into Hørehjelpen — article-integrated ghost pills; not FAQ/chips/forms. */
import { buildChatShellHref } from "../../lib/chat-shell";

export interface PromptItem {
  question: string;
}

export interface Props {
  title: string;
  intro: string;
  items: PromptItem[];
  /** Anchor id for section heading (a11y). */
  headingId: string;
  ctaLabel?: string;
  /** Absolute path to fri samtale (respects `base`). */
  freeChatHref?: string;
  seedFrom?: "hub" | "article";
}

const {
  title,
  intro,
  items,
  headingId,
  ctaLabel = "Åpne fri samtale",
  freeChatHref: freeChatHrefProp,
  seedFrom = "article",
} = Astro.props;

const base = import.meta.env.BASE_URL ?? "/";
const freeChatHref = freeChatHrefProp ?? (base.endsWith("/") ? `${base}no/chat` : `${base}/no/chat`);
---

<section class="prompt-group ams-zone prompt-group--ghost-pill" aria-labelledby={headingId}>
  <header class="prompt-group__header">
    <h2 id={headingId} class="prompt-group__title">{title}</h2>
    <p class="prompt-group__intro">{intro}</p>
  </header>

  <ul class="prompt-group__list" role="list">
    {
      items.map((item, index) => (
        <li class="prompt-group__item">
          <a
            href={buildChatShellHref(item.question, seedFrom)}
            class="prompt-group__link"
            data-qa-hover={index === 0 ? "true" : undefined}
          >
            <span class="prompt-group__question">{item.question}</span>
            <span class="prompt-group__hint" aria-hidden="true">
              <svg class="prompt-group__hint-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M6 3l5 5-5 5"
                  stroke="currentColor"
                  stroke-width="1.25"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <a href={freeChatHref} class="prompt-group__cta">{ctaLabel}</a>
</section>
