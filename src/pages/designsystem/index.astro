---
/* CONTRACT: Canonical MVP design system v0.1 — visual HITL catalog for patterns, primitives, applied surfaces. */
import PrototypeLayout from "../../layouts/PrototypeLayout.astro";
import PatternPreview from "../../components/designsystem/PatternPreview.astro";
import "../../styles/global.css";
import "../../styles/r1-dialog-article.css";
import "../../styles/viddel-standalone-chat.css";
import "../../styles/designsystem-catalog.css";
import {
  designSystemMeta,
  workingRule,
  returnTicketRule,
  canonicalNote,
  primitiveCategories,
  patterns,
  appliedSurfaces,
  historicalVisLinks,
  type PatternStatus,
} from "../../data/design-system-source-of-truth-v01.ts";

const base = import.meta.env.BASE_URL;

const statusClass: Record<PatternStatus, string> = {
  Candidate: "ds-status--candidate",
  Accepted: "ds-status--accepted",
  Applied: "ds-status--applied",
  "Needs QA": "ds-status--needs-qa",
  Deprecated: "ds-status--deprecated",
};

const primitiveSwatchClass: Record<string, string> = {
  Surfaces: "ds-catalog__primitive-swatch--surfaces",
  Buttons: "ds-catalog__primitive-swatch--buttons",
  Inputs: "ds-catalog__primitive-swatch--input",
  "Pills / chips": "ds-catalog__primitive-swatch--pills",
  Focus: "ds-catalog__primitive-swatch--focus",
  Elevation: "ds-catalog__primitive-swatch--elevation",
  Radius: "ds-catalog__primitive-swatch--radius",
  Strokes: "ds-catalog__primitive-swatch--strokes",
};
---

<PrototypeLayout title="Designsystem — Viddel MVP">
  <main class="ds-catalog" data-design-system-catalog>
    <nav class="ds-catalog__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <span>Designsystem</span>
    </nav>

    <header class="ds-catalog__hero">
      <h1>Designsystem</h1>
      <p class="ds-catalog__hero-lead">Gjeldende mønstre for Viddel MVP.</p>
      <p class="ds-catalog__hero-note">
        <code>/designsystem/</code> er gjeldende sannhet. <code>/vis/sprints/…</code> er historikk og beslutningsgrunnlag.
      </p>
    </header>

    <aside class="ds-catalog__rule" aria-label="Working Rule">
      <span class="ds-catalog__rule-label">Working Rule</span>
      {workingRule}
    </aside>

    <section class="ds-catalog__section" aria-labelledby="patterns-overview">
      <div class="ds-catalog__section-head">
        <p class="ds-catalog__kicker">Mønstre</p>
        <h2 id="patterns-overview">Pattern overview</h2>
        <p>Visuell referanse først — detaljer under hvert mønster.</p>
      </div>

      <div class="ds-catalog__pattern-grid">
        {patterns.map((pattern) => (
          <a class="ds-catalog__pattern-card" href={`#pattern-${pattern.id}`}>
            <div class="ds-catalog__pattern-card-head">
              <h3>{pattern.name}</h3>
              <span class:list={["ds-status", statusClass[pattern.status]]}>{pattern.status}</span>
            </div>
            <div class="ds-catalog__pattern-card-preview" aria-hidden="true">
              <PatternPreview id={pattern.id} size="sm" />
            </div>
            <div class="ds-catalog__pattern-card-body">
              <p>{pattern.summary}</p>
              <p class="ds-catalog__pattern-card-used">
                <strong>Brukes på:</strong> {pattern.usedOn.join(" · ")}
              </p>
              <span class="ds-catalog__pattern-card-link">Åpne detaljer ↓</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="ds-catalog__section" aria-labelledby="patterns-detail">
      <div class="ds-catalog__section-head">
        <p class="ds-catalog__kicker">Detaljer</p>
        <h2 id="patterns-detail">Pattern details</h2>
      </div>

      <div class="ds-catalog__detail-list">
        {patterns.map((pattern) => (
          <article class="ds-catalog__detail" id={`pattern-${pattern.id}`}>
            <header class="ds-catalog__detail-head">
              <h3>{pattern.name}</h3>
              <span class:list={["ds-status", statusClass[pattern.status]]}>{pattern.status}</span>
            </header>

            <div class="ds-catalog__detail-preview" aria-hidden="true">
              <PatternPreview id={pattern.id} size="lg" />
            </div>

            <div class="ds-catalog__detail-grid">
              <div class="ds-catalog__detail-block ds-catalog__detail-block--rule">
                <h4>Regel</h4>
                <p>{pattern.rule}</p>
              </div>
              <div class="ds-catalog__detail-block">
                <h4>Når brukes dette?</h4>
                <p>{pattern.purpose}</p>
              </div>
              <div class="ds-catalog__detail-block">
                <h4>Brukes på</h4>
                <ul role="list">
                  {pattern.usedOn.map((route) => (
                    <li>{route}</li>
                  ))}
                </ul>
              </div>
              <div class="ds-catalog__detail-block">
                <h4>Do</h4>
                <ul role="list">
                  {pattern.do.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
              <div class="ds-catalog__detail-block">
                <h4>Don't</h4>
                <ul role="list">
                  {pattern.dont.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>

            <details class="ds-catalog__detail-tech">
              <summary>Kilde / implementasjon</summary>
              <ul role="list">
                {pattern.sourceFiles.map((file) => (
                  <li><code>{file}</code></li>
                ))}
              </ul>
              {(pattern.issueRef || pattern.commitRef) && (
                <p>
                  {pattern.issueRef && <span>{pattern.issueRef}</span>}
                  {pattern.issueRef && pattern.commitRef && " · "}
                  {pattern.commitRef && <code>{pattern.commitRef}</code>}
                </p>
              )}
            </details>
          </article>
        ))}
      </div>
    </section>

    <section class="ds-catalog__section" aria-labelledby="primitives-heading">
      <div class="ds-catalog__section-head">
        <p class="ds-catalog__kicker">Sekundært</p>
        <h2 id="primitives-heading">Primitives</h2>
        <p>Grunnleggende byggeklosser — detaljert lab under Primitives Lab (historikk).</p>
      </div>
      <div class="ds-catalog__primitive-grid">
        {primitiveCategories.map((cat) => (
          <article class="ds-catalog__primitive">
            <div class="ds-catalog__primitive-head">
              <b>{cat.name}</b>
              <span class:list={["ds-status", statusClass[cat.status]]}>{cat.status}</span>
            </div>
            <div class:list={["ds-catalog__primitive-swatch", primitiveSwatchClass[cat.name]]} aria-hidden="true">
              {cat.name === "Surfaces" && (
                <>
                  <span /><span /><span /><span />
                </>
              )}
              {cat.name === "Buttons" && (
                <>
                  <span>Primary</span><span>Quiet</span>
                </>
              )}
              {cat.name === "Inputs" && "AI prompt …"}
              {cat.name === "Pills / chips" && (
                <>
                  <span>Seed</span><span>Tag</span>
                </>
              )}
              {cat.name === "Focus" && <span />}
              {cat.name === "Elevation" && null}
              {cat.name === "Radius" && null}
              {cat.name === "Strokes" && null}
            </div>
            <a href={`${base}${cat.labHref.replace(/^\//, "")}`}>Lab →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="ds-catalog__section" aria-labelledby="applied-heading">
      <div class="ds-catalog__section-head">
        <p class="ds-catalog__kicker">Produksjon</p>
        <h2 id="applied-heading">Applied surfaces</h2>
      </div>
      <div class="ds-catalog__table-wrap">
        <table class="ds-catalog__table">
          <thead>
            <tr>
              <th scope="col">Route</th>
              <th scope="col">Mønstre</th>
              <th scope="col">Status</th>
              <th scope="col">Note</th>
            </tr>
          </thead>
          <tbody>
            {appliedSurfaces.map((surface) => (
              <tr>
                <td><code>{surface.route}</code></td>
                <td>{surface.patterns.join(", ")}</td>
                <td>
                  <span class:list={["ds-status", statusClass[surface.status]]}>{surface.status}</span>
                </td>
                <td>{surface.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <footer class="ds-catalog__tech" aria-labelledby="tech-heading">
      <h2 id="tech-heading">Technical reference</h2>
      <div class="ds-catalog__tech-grid">
        <div>
          <strong>Return Ticket-regel</strong>
          <p>{returnTicketRule}</p>
        </div>
        <div>
          <strong>Meta</strong>
          <p>
            {designSystemMeta.version} · {designSystemMeta.updated} · {designSystemMeta.issue} ·{" "}
            <code>{designSystemMeta.canonicalPath}</code>
          </p>
        </div>
        <div>
          <strong>Historikk / beslutningsgrunnlag</strong>
          <ul role="list">
            {historicalVisLinks.map((link) => (
              <li>
                <a href={`${base}${link.href.replace(/^\//, "")}`}>{link.label}</a> — {link.role}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <strong>Decision docs</strong>
          <ul role="list">
            {designSystemMeta.relatedDecisions.map((doc) => (
              <li><code>{doc}</code></li>
            ))}
          </ul>
        </div>
        <p><em>{canonicalNote}</em></p>
      </div>
    </footer>
  </main>
</PrototypeLayout>
