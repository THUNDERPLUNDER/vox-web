---
/* CONTRACT: Canonical MVP design system v0.1 — visual HITL catalog for patterns, primitives, applied surfaces. */
import VisInternalLayout from "../../layouts/VisInternalLayout.astro";
import PatternPreview from "../../components/designsystem/PatternPreview.astro";
import "../../styles/global.css";
import "../../styles/r1-dialog-article.css";
import "../../styles/viddel-standalone-chat.css";
import "../../styles/designsystem-catalog.css";
import {
  designSystemMeta,
  workingRule,
  returnTicketRule,
  canonicalNote,
  primitiveCategories,
  patterns,
  appliedSurfaces,
  historicalVisLinks,
  type PatternStatus,
} from "../../data/design-system-source-of-truth-v01.ts";

const base = import.meta.env.BASE_URL;

const statusClass: Record<PatternStatus, string> = {
  Candidate: "ds-status--candidate",
  Accepted: "ds-status--accepted",
  Applied: "ds-status--applied",
  "Needs QA": "ds-status--needs-qa",
  Deprecated: "ds-status--deprecated",
};

const primitiveSwatchClass: Record<string, string> = {
  Surfaces: "ds-catalog__swatch--surfaces",
  Buttons: "ds-catalog__swatch--buttons",
  Inputs: "ds-catalog__swatch--input",
  "Pills / chips": "ds-catalog__swatch--pills",
  Focus: "ds-catalog__swatch--focus",
  Elevation: "ds-catalog__swatch--elevation",
  Radius: "ds-catalog__swatch--radius",
  Strokes: "ds-catalog__swatch--strokes",
};
---

<VisInternalLayout title="Designsystem — Viddel MVP" showPageIntro={false}>
  <main class="ds-catalog" data-design-system-catalog>
    <nav class="ds-catalog__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <span>Designsystem</span>
    </nav>

    <header class="ds-catalog__hero">
      <h1>Designsystem</h1>
      <p class="ds-catalog__hero-lead">Gjeldende mønstre for Viddel MVP.</p>
      <p class="ds-catalog__hero-note">
        <code>/designsystem/</code> er gjeldende sannhet. <code>/vis/sprints/…</code> er historikk.
      </p>
    </header>

    <p class="ds-catalog__rule" aria-label="Working Rule">
      <span class="ds-catalog__rule-label">Working Rule</span>
      {workingRule}
    </p>

    <section class="ds-catalog__section" aria-labelledby="patterns-overview">
      <h2 id="patterns-overview" class="ds-catalog__section-title">Mønstre</h2>

      <div class="ds-catalog__pattern-grid">
        {patterns.map((pattern) => (
          <a class="ds-catalog__pattern-card" href={`#pattern-${pattern.id}`}>
            <div class="ds-catalog__pattern-card-preview" aria-hidden="true">
              <PatternPreview id={pattern.id} size="sm" />
            </div>
            <div class="ds-catalog__pattern-card-meta">
              <div class="ds-catalog__pattern-card-head">
                <h3>{pattern.name}</h3>
                <span class:list={["ds-status", statusClass[pattern.status]]}>{pattern.status}</span>
              </div>
              <p class="ds-catalog__pattern-card-summary">{pattern.summary}</p>
              <p class="ds-catalog__pattern-card-used">{pattern.usedOn.join(" · ")}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="ds-catalog__section ds-catalog__section--details" aria-labelledby="patterns-detail">
      <h2 id="patterns-detail" class="ds-catalog__section-title ds-catalog__section-title--sub">Detaljer</h2>

      <div class="ds-catalog__detail-list">
        {patterns.map((pattern) => (
          <article class="ds-catalog__detail" id={`pattern-${pattern.id}`}>
            <header class="ds-catalog__detail-head">
              <h3>{pattern.name}</h3>
              <span class:list={["ds-status", statusClass[pattern.status]]}>{pattern.status}</span>
            </header>

            <div class="ds-catalog__detail-preview" aria-hidden="true">
              <PatternPreview id={pattern.id} size="lg" />
            </div>

            <div class="ds-catalog__detail-copy">
              <div>
                <h4>Når brukes dette?</h4>
                <p>{pattern.purpose}</p>
              </div>
              <div>
                <h4>Regel</h4>
                <p>{pattern.rule}</p>
              </div>
            </div>

            <div class="ds-catalog__do-dont">
              <div>
                <h4>Do</h4>
                <ul role="list">
                  {pattern.do.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
              <div>
                <h4>Don't</h4>
                <ul role="list">
                  {pattern.dont.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>

            <details class="ds-catalog__detail-tech">
              <summary>Kilde / implementasjon</summary>
              <ul role="list">
                {pattern.sourceFiles.map((file) => (
                  <li><code>{file}</code></li>
                ))}
              </ul>
              {(pattern.issueRef || pattern.commitRef) && (
                <p class="ds-catalog__detail-tech-meta">
                  {pattern.issueRef}
                  {pattern.issueRef && pattern.commitRef && " · "}
                  {pattern.commitRef && <code>{pattern.commitRef}</code>}
                </p>
              )}
            </details>
          </article>
        ))}
      </div>
    </section>

    <section class="ds-catalog__section ds-catalog__section--secondary" aria-labelledby="composer-pattern-entry">
      <h2 id="composer-pattern-entry" class="ds-catalog__section-title ds-catalog__section-title--sub">
        Pattern previews
      </h2>
      <a class="ds-catalog__feature-link" href={`${base}designsystem/composer`}>
        <span class="ds-catalog__feature-link-kicker">Composer Pattern v0.1</span>
        <span class="ds-catalog__feature-link-title">Se fire kontrollerte composer states</span>
        <span class="ds-catalog__feature-link-body">
          Standalone idle, standalone active, article idle og article active. Previewen skiller mellom shared composer
          body, variant halo/dramaturgy og local functional difference.
        </span>
      </a>
    </section>

    <section class="ds-catalog__section ds-catalog__section--secondary" aria-labelledby="primitives-heading">
      <h2 id="primitives-heading" class="ds-catalog__section-title ds-catalog__section-title--sub">Primitives</h2>
      <ul class="ds-catalog__primitive-list" role="list">
        {primitiveCategories.map((cat) => (
          <li class="ds-catalog__primitive-item">
            <span class:list={["ds-catalog__swatch", primitiveSwatchClass[cat.name]]} aria-hidden="true">
              {cat.name === "Surfaces" && (
                <>
                  <span /><span /><span /><span />
                </>
              )}
              {cat.name === "Buttons" && (
                <>
                  <span /><span />
                </>
              )}
              {cat.name === "Inputs" && <span />}
              {cat.name === "Pills / chips" && (
                <>
                  <span /><span />
                </>
              )}
              {cat.name === "Focus" && <span />}
            </span>
            <span class="ds-catalog__primitive-name">{cat.name}</span>
            <span class:list={["ds-status", "ds-status--plain", statusClass[cat.status]]}>{cat.status}</span>
            <a href={`${base}${cat.labHref.replace(/^\//, "")}`}>Lab</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="ds-catalog__section ds-catalog__section--secondary" aria-labelledby="applied-heading">
      <h2 id="applied-heading" class="ds-catalog__section-title ds-catalog__section-title--sub">Applied surfaces</h2>
      <ul class="ds-catalog__surface-list" role="list">
        {appliedSurfaces.map((surface) => (
          <li class="ds-catalog__surface-item">
            <div class="ds-catalog__surface-main">
              <code>{surface.route}</code>
              <span class:list={["ds-status", "ds-status--plain", statusClass[surface.status]]}>{surface.status}</span>
            </div>
            <p class="ds-catalog__surface-patterns">{surface.patterns.join(" · ")}</p>
            <p class="ds-catalog__surface-note">{surface.note}</p>
          </li>
        ))}
      </ul>
    </section>

    <footer class="ds-catalog__tech">
      <details>
        <summary>Technical reference</summary>
        <div class="ds-catalog__tech-body">
          <p><strong>Return Ticket:</strong> {returnTicketRule}</p>
          <p>
            {designSystemMeta.version} · {designSystemMeta.updated} · {designSystemMeta.issue} ·{" "}
            <code>{designSystemMeta.canonicalPath}</code>
          </p>
          <p>{canonicalNote}</p>
          <ul role="list">
            {historicalVisLinks.map((link) => (
              <li>
                <a href={`${base}${link.href.replace(/^\//, "")}`}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </footer>
  </main>
</VisInternalLayout>
