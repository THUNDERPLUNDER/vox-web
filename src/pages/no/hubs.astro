---
/* CONTRACT: Hub-and-spoke overview — tre emnehuber (én live + to planlagte) og vei til artikler. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/nav/Footer.astro";
import { fetchPublishingHub } from "../../lib/storyblok-publishing";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const hub = await fetchPublishingHub();
const hub1Title = hub?.title || "Relasjoner og samtale";
const hub1Intro =
  hub?.intro && hub.intro.length > 0
    ? hub.intro.length > 220
      ? `${hub.intro.slice(0, 217).trim()}…`
      : hub.intro
    : "Et rolig sted å starte når du vil hjelpe noen du bryr deg om — og finne artikler som bygger videre.";
---

<BaseLayout title="Viddel - Emnehuber" currentPath="/no/hubs">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section class="!pt-2 !pb-8 sm:!pt-4 sm:!pb-10">
      <div class="max-w-3xl">
        <p class="text-xs font-medium uppercase tracking-wide text-[rgb(var(--muted))]">Viddel · hub & spoke</p>
        <h1 class="font-display mt-2 text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl">Emnehuber</h1>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-[rgb(var(--text-secondary))]">
          Start med et tema. Hver hub samler artikler og korte veier inn i Hørehjelpen når du vil snakke videre — uten å måtte formulere alt selv.
        </p>
      </div>
    </Section>

    <Section tone="band" class="!py-8 sm:!py-10">
      <ul class="mx-auto grid max-w-3xl list-none gap-4 p-0 sm:gap-5" role="list">
        <li>
          <a
            href="/no/hub"
            class="vox-surface-lifted flex flex-col gap-2 no-underline transition-opacity hover:opacity-[0.98] sm:flex-row sm:items-start sm:justify-between"
          >
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--primary))]">Hub 1 · live</p>
              <h2 class="font-display mt-1 text-xl font-semibold text-[rgb(var(--text))]">{hub1Title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">{hub1Intro}</p>
            </div>
            <span class="mt-3 inline-flex shrink-0 rounded-[var(--radius-md)] bg-[rgb(var(--surface-elevated))] px-3 py-2 text-sm font-medium text-[rgb(var(--text))] ring-1 ring-[rgb(var(--border))/0.25] sm:mt-0">
              Gå til hub →
            </span>
          </a>
        </li>
        <li class="vox-surface-calm opacity-[0.92]">
          <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--muted))]">Hub 2 · kommer</p>
          <h2 class="font-display mt-1 text-xl font-semibold text-[rgb(var(--text))]">Teknikk og hverdag</h2>
          <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
            App, tilkobling og praktiske grep — samlet i én hub. Vi kobler denne til innhold og spørsmål etter hvert.
          </p>
        </li>
        <li class="vox-surface-calm opacity-[0.92]">
          <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--muted))]">Hub 3 · kommer</p>
          <h2 class="font-display mt-1 text-xl font-semibold text-[rgb(var(--text))]">Helse og avklaring</h2>
          <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
            Når du vil forstå symptomer, utredning eller neste steg — før du er klar for samtale.
          </p>
        </li>
      </ul>
    </Section>

    <Section class="!pb-12 sm:!pb-16">
      <div class="mx-auto max-w-3xl">
        <h2 class="vox-section-title text-lg">Fri samtale</h2>
        <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
          Uten å gå via artikkel kan du alltid åpne Hørehjelpen i egen modus og skrive det du vil.
        </p>
        <a
          href="/no/chat"
          class="sonic-pulse-cta mt-5 inline-flex items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-semibold transition-shadow"
        >
          Åpne Hørehjelpen
        </a>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
