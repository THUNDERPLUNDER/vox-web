---
/* CONTRACT: First factual MVP hub for "Bedre lyd i hverdagen" with clear spoke entries. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/nav/Footer.astro";
import { buildChatShellHref } from "../../lib/chat-shell";
import { fetchAiSeedQuestions } from "../../lib/storyblok-publishing";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const seeds = await fetchAiSeedQuestions();
const sanitizeHubCopy = (text: string) =>
  text.replace(/\brolig\b/gi, "passende").replace(/\s{2,}/g, " ").trim();

const title = "Bedre lyd i hverdagen";
const mandate =
  "Denne huben samler første praktiske innganger for deg som vil forstå utfordringer, løse konkrete situasjoner og finne neste steg uten å starte på nytt hver gang.";

const topTasks = [
  {
    title: "Forstå hvorfor samtaler blir krevende",
    text: "Få en tydelig forklaring på hva som skjer når lyttebelastning bygger seg opp, og hvordan det påvirker overskudd i hverdagen.",
    href: "/no/artikkel/r1-spoke-v01",
    cta: "Gå til R1",
  },
  {
    title: "Løse praktiske problemer raskt",
    text: "Følg en enkel steg-for-steg-guide når høreapparat eller telefon ikke samarbeider, så du kommer raskere videre.",
    href: "/no/artikkel/r2-spoke-v01",
    cta: "Gå til R2",
  },
  {
    title: "Få faglig overblikk og forklaring",
    text: "Les en mer faglig inngang som forklarer mønstre over tid og viser hvilke grep som ofte virker i praksis.",
    href: "/no/artikkel/r3-spoke-v01",
    cta: "Gå til R3",
  },
];

const spokeEntries = [
  {
    eyebrow: "R1 · Samtale og overskudd",
    title: "Når hørselen endrer samtalen",
    description:
      "En trygg inngang for å forstå belastning i samtaler og starte med små grep som reduserer friksjon.",
    href: "/no/artikkel/r1-spoke-v01",
  },
  {
    eyebrow: "R2 · Teknisk guide",
    title: "Når høreapparatet ikke kobler seg til",
    description:
      "Praktisk feilsøking i fire steg for vanlige tilkoblingsutfordringer i hverdagen.",
    href: "/no/artikkel/r2-spoke-v01",
  },
  {
    eyebrow: "R3 · Faglig fokus",
    title: "Når samtaler bryter sammen ved hørselstap",
    description:
      "Faglig forklaring med praktiske konsekvenser for relasjoner, akustikk og samtalestruktur.",
    href: "/no/artikkel/r3-spoke-v01",
  },
];
---

<BaseLayout title={`VOX - ${title}`} currentPath="/no/hub">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-7 sm:py-10">
    <Section class="!pt-2 !pb-8 sm:!pt-4 sm:!pb-10">
      <div class="max-w-5xl">
        <p class="mb-4 text-xs font-medium uppercase tracking-[0.08em] text-[rgb(var(--muted))]">
          <a href="/no/hubs" class="font-medium text-[rgb(var(--text-secondary))] underline-offset-2 hover:text-[rgb(var(--text))] hover:underline">
            ← Alle emnehuber
          </a>
        </p>
        <div class="vox-surface-lifted grid gap-6 sm:gap-7 lg:grid-cols-[1.5fr_1fr] lg:items-start">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.1em] text-[rgb(var(--primary))]">KlarLyd · Emnehub v0.1</p>
            <h1 class="font-display mt-2 text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl">
              {title}
            </h1>
            <p class="mt-4 text-sm font-semibold text-[rgb(var(--text-secondary))]">
              Første faktiske hub-side i epic #49.
            </p>
            <p class="vox-lead mt-4">{mandate}</p>
          </div>
          <div class="vox-surface-tech p-5">
            <h2 class="text-base font-semibold text-[rgb(var(--text))]">Slik bruker du huben</h2>
            <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
              <li>Velg top task som passer situasjonen din.</li>
              <li>Gå videre til riktig inngangsartikkel (R1, R2 eller R3).</li>
              <li>Bruk videre hjelp når du vil formulere neste steg.</li>
            </ol>
          </div>
        </div>
      </div>
    </Section>

    <Section tone="band" class="!py-7 sm:!py-9">
      <div class="max-w-5xl">
        <div class="flex items-end justify-between gap-4">
          <h2 class="vox-section-title">Top tasks</h2>
          <p class="hidden text-xs font-semibold uppercase tracking-[0.1em] text-[rgb(var(--muted))] sm:block">Prioriterte innganger</p>
        </div>
        <ul class="mt-5 grid list-none gap-3 p-0 sm:mt-6 sm:gap-4 lg:grid-cols-3" role="list">
          {topTasks.map((task, index) => (
            <li class="vox-surface-lifted p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[rgb(var(--primary))]">Top task {index + 1}</p>
              <h3 class="mt-2 text-base font-semibold text-[rgb(var(--text))]">{task.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">{task.text}</p>
              <p class="mt-4">
                <a href={task.href} class="inline-flex items-center gap-1 text-sm font-semibold text-[rgb(var(--text))] underline-offset-2 hover:underline">
                  {task.cta}
                  <span aria-hidden="true">→</span>
                </a>
              </p>
            </li>
            ))}
        </ul>
      </div>
    </Section>

    <Section class="!pt-4 !pb-10 sm:!pb-14">
      <div class="max-w-5xl">
        <h2 class="vox-section-title">Innganger til innhold</h2>
        <p class="mt-2 max-w-3xl text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
          Velg inngangen som passer situasjonen din nå. Du kan alltid gå tilbake hit og bytte spor.
        </p>
        <ul class="mt-5 grid list-none gap-3 p-0 sm:gap-4 lg:grid-cols-3" role="list">
          {spokeEntries.map((entry) => (
            <li class="vox-surface-tech p-5">
              <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--primary))]">{entry.eyebrow}</p>
              <h3 class="mt-2 text-lg font-semibold text-[rgb(var(--text))]">{entry.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">{entry.description}</p>
              <p class="mt-4">
                <a href={entry.href} class="inline-flex items-center gap-1 text-sm font-semibold text-[rgb(var(--text))] underline-offset-2 hover:underline">
                  Les artikkel
                  <span aria-hidden="true">→</span>
                </a>
              </p>
            </li>
          ))}
        </ul>
      </div>
    </Section>

    <Section class="!pt-0 !pb-8 sm:!pb-12">
      <div class="max-w-5xl">
        <div class="vox-surface-lifted">
          <h2 class="vox-section-title text-lg sm:text-xl">Videre hjelp</h2>
          <p class="mt-2 max-w-3xl text-sm text-[rgb(var(--text-secondary))]">
            Trenger du å tenke høyt eller få hjelp til å formulere neste steg? Start med et spørsmål under.
          </p>
          {seeds.length ? (
            <ul class="mt-4 grid list-none gap-3 p-0 sm:gap-4 lg:grid-cols-3" role="list">
              {seeds.slice(0, 3).map((seed) => (
                <li>
                  <a href={buildChatShellHref(seed.question, "hub")} class="vox-surface-calm-tile h-full p-4">
                    <p class="text-sm font-semibold text-[rgb(var(--text))]">{sanitizeHubCopy(seed.question)}</p>
                    {seed.shortAnswer ? (
                      <p class="mt-1.5 text-sm text-[rgb(var(--muted))]">{sanitizeHubCopy(seed.shortAnswer)}</p>
                    ) : (
                      <p class="mt-1.5 text-sm text-[rgb(var(--muted))]">Trykk for forslag til neste steg i chat.</p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-4 text-sm text-[rgb(var(--muted))]">
              Vi har ingen forslag klare akkurat nå. Du kan fortsatt{" "}
              <a href="/no/chat" class="font-medium text-[rgb(var(--text-secondary))] underline underline-offset-2 hover:text-[rgb(var(--text))]">
                åpne Hørehjelpen
              </a>{" "}
              og skrive spørsmålet ditt med egne ord.
            </p>
          )}
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
