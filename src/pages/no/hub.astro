---
/* CONTRACT: Minimal Slice 01 hub page from Storyblok hub_page + ai_seed_question content. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/nav/Footer.astro";
import { buildChatShellHref } from "../../lib/chat-shell";
import { fetchAiSeedQuestions, fetchPublishingHub } from "../../lib/storyblok-publishing";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const hub = await fetchPublishingHub();
const seeds = await fetchAiSeedQuestions();

const title = hub?.title || "KlarLyd Hub";
const intro =
  hub?.intro ||
  "Et rolig sted å starte når du vil hjelpe noen du bryr deg om.";
---

<BaseLayout title={`VOX - ${title}`} currentPath="/no/hub">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section class="!pt-2 !pb-10 sm:!pt-4 sm:!pb-12">
      <div class="max-w-3xl">
        <div class="vox-surface-calm">
          <h1 class="font-display text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl">
            {title}
          </h1>
          {hub?.kjerne ? <p class="mt-4 text-sm font-semibold text-[rgb(var(--text-secondary))]">{hub.kjerne}</p> : null}
          <p class="vox-lead mt-5">{intro}</p>
        </div>
      </div>
    </Section>

    <Section tone="band" class="!py-8 sm:!py-10">
      <div class="max-w-3xl">
        <h2 class="vox-section-title">Dette får du hjelp med</h2>
        {hub?.helpPoints.length ? (
          <ul class="mt-6 grid list-none gap-3 p-0 sm:gap-4" role="list">
            {hub.helpPoints.map((point) => (
              <li class="vox-surface-tech text-sm font-medium leading-relaxed text-[rgb(var(--text-secondary))]">{point}</li>
            ))}
          </ul>
        ) : (
          <p class="mt-4 text-sm text-[rgb(var(--muted))]">Vi fyller på denne oversikten fortløpende.</p>
        )}

        {(hub?.primaryCtaLabel && hub?.primaryCtaTarget) || hub?.secondaryLinks.length ? (
          <div class="mt-8 space-y-4">
            {hub?.primaryCtaLabel && hub?.primaryCtaTarget ? (
              <a
                href={hub.primaryCtaTarget}
                class="sonic-pulse-cta inline-flex items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-semibold transition-shadow"
              >
                {hub.primaryCtaLabel}
              </a>
            ) : null}

            {hub?.secondaryLinks.length ? (
              <ul class="grid list-none gap-3 p-0 sm:grid-cols-2" role="list">
                {hub.secondaryLinks.map((link) => (
                  <li class="vox-surface-tech">
                    <a
                      href={link.href}
                      class:list={[
                        "block text-sm text-[rgb(var(--text))] no-underline",
                        link.comingSoon
                          ? "pointer-events-none text-[rgb(var(--text-secondary))]"
                          : "font-medium hover:underline",
                      ]}
                      aria-disabled={link.comingSoon ? "true" : undefined}
                    >
                      <span class="font-medium">{link.label}</span>
                      {link.comingSoon ? (
                        <span class="ml-2 inline-flex rounded-full border border-[rgb(var(--border))] bg-[rgb(var(--surface))/0.6] px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-[rgb(var(--muted))]">
                          Kommer snart
                        </span>
                      ) : null}
                    </a>
                  </li>
                ))}
              </ul>
            ) : null}
          </div>
        ) : null}
      </div>
    </Section>

    {seeds.length ? (
      <Section class="!pt-4 !pb-12 sm:!pb-16">
        <div class="max-w-3xl">
          <div class="vox-surface-lifted">
            <h2 class="vox-section-title text-lg sm:text-xl">Smarte spørsmål du kan starte med</h2>
            <p class="mt-2 text-sm text-[rgb(var(--text-secondary))]">
              Les i ditt eget tempo, eller bruk ett av spørsmålene for å starte en rolig samtale videre.
            </p>
            <ul class="mt-4 grid list-none gap-3 p-0" role="list">
              {seeds.map((seed) => (
                <li>
                  <a
                    href={buildChatShellHref(seed.question, "hub")}
                    class="w-full rounded-[var(--radius-md)] border border-[rgb(var(--border))] bg-[rgb(var(--surface))/0.42] p-4 text-left transition-colors hover:bg-[rgb(var(--surface))/0.7]"
                  >
                    <p class="text-sm font-semibold text-[rgb(var(--text))]">{seed.question}</p>
                    {seed.shortAnswer ? (
                      <p class="mt-1.5 text-sm text-[rgb(var(--muted))]">{seed.shortAnswer}</p>
                    ) : null}
                  </a>
                </li>
              ))}
            </ul>
            <p class="mt-4 text-xs text-[rgb(var(--muted))]">
              Velg et spørsmål for å åpne samtaleflaten i rolig lesemodus.
            </p>
          </div>
        </div>
      </Section>
    ) : null}

    {hub?.trustNote ? (
      <Section class="!pt-0 !pb-8 sm:!pb-12">
        <div class="max-w-3xl">
          <p class="text-sm leading-relaxed text-[rgb(var(--muted))]">{hub.trustNote}</p>
        </div>
      </Section>
    ) : null}
  </main>

  <Footer />
</BaseLayout>
