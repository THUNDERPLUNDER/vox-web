---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/nav/Footer.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
---

<BaseLayout title="VOX - Om" currentPath="/no/om">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Om</h1>
      <p class="mt-4 text-[rgb(var(--muted))]">
        Placeholder: Informasjon om tjenesten kommer her.
      </p>
    </Section>
  </main>

  <Footer />
</BaseLayout>
