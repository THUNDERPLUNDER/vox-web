---
/* CONTRACT: Demo chat surface with product-owned frame and stable CES engine as the only visible conversation mode. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
---

<BaseLayout title="VOX - Hørehjelpen samtale" currentPath="/no/chat">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="relative pb-2 sm:pb-3">
    <Section class="!pt-1 !pb-4 sm:!pt-2 sm:!pb-5">
      <div class="mx-auto max-w-[920px] space-y-2.5">
        <div>
          <h1 class="font-display text-2xl font-semibold tracking-[-0.03em] text-balance sm:text-3xl">Her starter samtalen</h1>
          <p class="mt-1.5 max-w-2xl text-sm leading-relaxed text-[rgb(var(--muted))]">
            Ta ett steg om gangen. Skriv selv, eller fortsett fra spørsmålet du valgte.
          </p>
          <div id="seed-strip" class="mt-2 hidden border-l-2 border-[rgb(var(--primary))/0.35] pl-3">
            <p class="text-[11px] uppercase tracking-wide text-[rgb(var(--muted))]">Valgt startspørsmål</p>
            <p id="seed-text" class="mt-0.5 text-sm text-[rgb(var(--text))]"></p>
            <p id="seed-sync-status" class="mt-0.5 text-xs text-[rgb(var(--muted))]"></p>
          </div>
        </div>

        <div class="overflow-hidden rounded-[var(--radius-lg)] border border-[rgb(var(--border))/0.75] bg-[rgb(var(--surface-subtle))]">
          <chat-messenger
            id="ces-demo-widget"
            url-allowlist="*"
            class="block h-[min(70vh,680px)] w-full overflow-hidden rounded-none bg-[rgb(var(--surface-subtle))]"
          >
            <chat-messenger-container
              chat-title="Hørehjelpen"
              enable-file-upload
              enable-audio-input
            ></chat-messenger-container>
          </chat-messenger>
        </div>
      </div>
    </Section>
  </main>

  <script is:inline>
    (() => {
      const widget = document.getElementById("ces-demo-widget");
      const seedStrip = document.getElementById("seed-strip");
      const seedTextEl = document.getElementById("seed-text");
      const statusEl = document.getElementById("seed-sync-status");
      const params = new URLSearchParams(window.location.search);
      const initialQuestion = (params.get("seed") || "").trim();
      const from = (params.get("from") || "").trim();
      if (seedStrip && initialQuestion) seedStrip.classList.remove("hidden");
      if (seedTextEl) seedTextEl.textContent = initialQuestion;
      if (statusEl && initialQuestion) {
        statusEl.textContent = from ? `Hentet fra ${from === "article" ? "artikkel" : "hub"}. Klargjør samtalestart ...` : "Klargjør samtalestart ...";
      }
      if (!widget || !initialQuestion) return;

      const sendSeed = () => {
        if (typeof widget.sessionInput !== "function") return false;
        widget.open?.();
        widget.show?.();
        widget.sessionInput(initialQuestion);
        if (statusEl) statusEl.textContent = "Startspørsmål sendt til samtalen.";
        return true;
      };

      if (sendSeed()) return;
      let tries = 0;
      const timer = setInterval(() => {
        tries += 1;
        if (sendSeed() || tries > 40) {
          clearInterval(timer);
          if (tries > 40 && statusEl) {
            statusEl.textContent = "Startspørsmålet er klart over chatten dersom du vil sende det manuelt.";
          }
        }
      }, 250);
    })();
  </script>
</BaseLayout>
