---
/* CONTRACT: Standalone Viddel AI chat — open start surface, headless via /api/chat. #125M-C R1 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/r1-dialog-article.css";
import "../../styles/viddel-standalone-chat.css";
import "../../styles/viddel-chat-attachment.css";
import "../../styles/viddel-chat-scroll.css";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const exampleQuestions = [
  "Appen finner ikke høreapparatet",
  "Høreapparatet har ikke lyd",
  "Lyden blir slitsom i støy",
];
---

<BaseLayout
  title="Viddel - Spør Viddel"
  currentPath="/no/chat"
  headerBrand="viddel"
  shellVariant="standalone-chat"
  showHeaderDevtoolsToggle={false}
>
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="viddel-chat-standalone" data-viddel-chat>
    <div class="r1-editorial-container">
      <div data-r1-editorial class="viddel-chat-standalone__editorial">
        <section class="r1-ai-bridge px-0.5 py-1">
          <section
            class="inline-chat-shell"
            aria-labelledby="viddel-chat-title"
            data-viddel-chat-shell
            data-inline-chat-mode="progressive"
            data-inline-chat-conversation="idle"
            data-inline-chat-state="idle"
          >
            <div class="viddel-chat-start viddel-chat-start--open" data-viddel-chat-start>
              <header class="viddel-chat-start__intro" data-viddel-chat-intro>
                <h1 id="viddel-chat-title" class="sr-only">Spør Viddel</h1>
                <p class="viddel-chat-start__hint">
                  Spør Viddel om lyd, hørsel, hjelpemidler, eller annet som handler om å høre bedre i hverdagen
                </p>
              </header>

              <div class="viddel-chat-start__surface viddel-chat-start__surface--open" data-viddel-chat-start-surface>
                <div class="inline-chat-shell__compose-stack" data-viddel-chat-compose-stack>
                  <p class="inline-chat-shell__status inline-chat-shell__status--dock hidden" data-viddel-chat-loading role="status">
                    Viddel svarer …
                  </p>
                  <p class="viddel-chat-standalone__error hidden" data-viddel-chat-error role="alert"></p>
                  <div class="viddel-chat-attach__attach-layer hidden" data-viddel-chat-attach-layer>
                    <div
                      class="viddel-chat-attach__attach-menu-backdrop hidden"
                      data-viddel-chat-attach-backdrop
                      aria-hidden="true"
                    >
                    </div>
                    <div
                      id="viddel-chat-attach-menu"
                      class="viddel-chat-attach__attach-menu hidden"
                      data-viddel-chat-attach-menu
                      role="menu"
                      aria-label="Legg til bilde"
                    >
                      <button
                        type="button"
                        class="viddel-chat-attach__attach-menu-item viddel-chat-attach__attach-menu-item--camera"
                        data-viddel-chat-attach-camera
                        role="menuitem"
                      >
                        <span class="viddel-chat-attach__attach-menu-item-content">
                          <svg
                            class="viddel-chat-attach__attach-menu-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.85"
                            aria-hidden="true"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M4 8h3l2-2h6l2 2h3v11H4V8z"
                            ></path>
                            <circle cx="12" cy="13" r="3.25"></circle>
                          </svg>
                          <span>Ta bilde</span>
                        </span>
                      </button>
                      <button
                        type="button"
                        class="viddel-chat-attach__attach-menu-item"
                        data-viddel-chat-attach-pick
                        role="menuitem"
                      >
                        <span class="viddel-chat-attach__attach-menu-item-content">
                          <svg
                            class="viddel-chat-attach__attach-menu-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.85"
                            aria-hidden="true"
                          >
                            <rect x="4" y="5" width="16" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round"
                            ></rect>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.5 14.5 11 11.5l2.5 3 2-1.5L18 15"
                            ></path>
                            <circle cx="9" cy="9" r="1"></circle>
                          </svg>
                          <span class="viddel-chat-attach__attach-menu-label--mobile">Velg bilde</span>
                          <span class="viddel-chat-attach__attach-menu-label--desktop">Last opp bilde</span>
                        </span>
                      </button>
                    </div>
                  </div>
                  <form class="inline-chat-shell__compose viddel-chat-attach__compose" data-viddel-chat-form>
                    <input
                      id="viddel-chat-file"
                      type="file"
                      accept="image/*"
                      class="sr-only"
                      data-viddel-chat-file
                    />
                    <div class="viddel-chat-attach__attachment-strip hidden" data-viddel-chat-attachment-strip>
                      <div class="viddel-chat-attach__attachment-list" data-viddel-chat-attachment-list>
                        <div class="viddel-chat-attach__attachment" data-viddel-chat-attachment>
                          <img class="viddel-chat-attach__thumb" data-viddel-chat-thumb alt="Valgt utstyr-bilde" />
                          <button
                            type="button"
                            class="viddel-chat-attach__remove-attachment"
                            data-viddel-chat-remove
                            aria-label="Fjern bilde"
                          >
                            ×
                          </button>
                        </div>
                      </div>
                    </div>
                    <div class="viddel-chat-attach__compose-row">
                      <div class="viddel-chat-attach__attach-wrap" data-viddel-chat-attach-wrap>
                        <button
                          type="button"
                          class="viddel-chat-attach__attach"
                          data-viddel-chat-attach
                          aria-label="Legg til bilde"
                          aria-haspopup="menu"
                          aria-expanded="false"
                          aria-controls="viddel-chat-attach-menu"
                        >
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" aria-hidden="true">
                            <path stroke-linecap="round" d="M12 5v14M5 12h14"></path>
                          </svg>
                        </button>
                      </div>
                      <div class="inline-chat-shell__compose-input-wrap viddel-chat-attach__compose-input-wrap">
                        <label class="sr-only" for="viddel-chat-input">Skriv spørsmål til Viddel</label>
                        <textarea
                          id="viddel-chat-input"
                          data-viddel-chat-input
                          class="inline-chat-shell__compose-input"
                          rows="1"
                          enterkeyhint="send"
                          placeholder="Hva lurer du på?"
                        ></textarea>
                      </div>
                      <button
                        type="submit"
                        class="inline-chat-shell__compose-send"
                        data-viddel-chat-send
                        aria-label="Send spørsmål"
                        disabled
                      >
                        <span aria-hidden="true">↑</span>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </div>

            <div class="inline-chat-shell__dialog-thread mt-3 hidden" data-viddel-chat-dialog>
              <div class="viddel-chat-scroll__viewport" data-viddel-chat-scroll-viewport>
                <div class="viddel-chat-scroll__top-spacer" aria-hidden="true"></div>
                <div class="inline-chat-shell__transcript-divider">
                  <span class="inline-chat-shell__transcript-divider-line" aria-hidden="true"></span>
                  <span class="inline-chat-shell__transcript-divider-label" id="viddel-chat-dialog-label">
                    Dialog med Viddel
                  </span>
                </div>
                <div
                  class="inline-chat-shell__transcript"
                  data-viddel-chat-transcript
                  role="log"
                  aria-live="polite"
                  aria-relevant="additions text"
                >
                </div>
                <div class="viddel-chat-scroll__bottom-spacer" data-viddel-chat-scroll-spacer aria-hidden="true"></div>
              </div>
            </div>
          </section>
        </section>
      </div>
    </div>
  </main>

  <style is:global>
    body.vox-shell--standalone-chat {
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }

    @media (max-width: 639px) {
      body.vox-shell--standalone-chat {
        height: 100dvh;
      }

      body.vox-shell--standalone-chat .vox-shell-standalone-chat__stage {
        flex: 1 1 auto;
        min-height: 0;
      }
    }
  </style>

  <script>
    import { initChatAttachmentMenu } from "../../lib/chat-image-attachment-menu-v01";
    import {
      fileToImageBase64Payload,
      validateChatImageFile,
    } from "../../lib/chat-image-file-v01";
    import { composeChatImageMessage } from "../../lib/chat-image-message-v01";
    import { renderAssistantMarkdownInto } from "../../lib/render-assistant-markdown";

    (() => {
      const root = document.querySelector("[data-viddel-chat]");
      const shell = root?.querySelector("[data-viddel-chat-shell]");
      const intro = root?.querySelector("[data-viddel-chat-intro]");
      const dialog = root?.querySelector("[data-viddel-chat-dialog]");
      const scrollViewport = root?.querySelector("[data-viddel-chat-scroll-viewport]");
      const transcript = root?.querySelector("[data-viddel-chat-transcript]");
      const composeStack = root?.querySelector("[data-viddel-chat-compose-stack]");
      const startGroup = shell?.querySelector("[data-viddel-chat-start]");
      const loadingEl = root?.querySelector("[data-viddel-chat-loading]");
      const errorEl = root?.querySelector("[data-viddel-chat-error]");
      const form = root?.querySelector("[data-viddel-chat-form]");
      const input = root?.querySelector("[data-viddel-chat-input]");
      const sendBtn = root?.querySelector("[data-viddel-chat-send]");
      const fileInput = root?.querySelector("[data-viddel-chat-file]");
      const attachLayer = root?.querySelector("[data-viddel-chat-attach-layer]");
      const attachBtn = root?.querySelector("[data-viddel-chat-attach]");
      const attachMenu = root?.querySelector("[data-viddel-chat-attach-menu]");
      const attachBackdrop = root?.querySelector("[data-viddel-chat-attach-backdrop]");
      const attachCameraBtn = root?.querySelector("[data-viddel-chat-attach-camera]");
      const attachPickBtn = root?.querySelector("[data-viddel-chat-attach-pick]");
      const attachmentStrip = root?.querySelector("[data-viddel-chat-attachment-strip]");
      const thumbEl = root?.querySelector("[data-viddel-chat-thumb]");
      const removeBtn = root?.querySelector("[data-viddel-chat-remove]");
      const exampleButtons = root?.querySelectorAll("[data-viddel-chat-example]");

      if (
        !root ||
        !shell ||
        !intro ||
        !dialog ||
        !scrollViewport ||
        !transcript ||
        !composeStack ||
        !loadingEl ||
        !errorEl ||
        !form ||
        !input ||
        !sendBtn ||
        !fileInput ||
        !attachLayer ||
        !attachBtn ||
        !attachMenu ||
        !attachBackdrop ||
        !attachCameraBtn ||
        !attachPickBtn ||
        !attachmentStrip ||
        !thumbEl ||
        !removeBtn
      ) {
        return;
      }

      const SESSION_KEY = "viddel-chat-session";
      const SESSION_PATTERN = /^[a-zA-Z0-9][a-zA-Z0-9-_]{4,62}$/;
      const params = new URLSearchParams(window.location.search);
      const seedFromUrl = (params.get("seed") || params.get("q") || "").trim();
      const entrySurface = (params.get("from") || "standalone").trim() || "standalone";

      if (typeof window.viddelTrack === "function") {
        window.viddelTrack("chat_opened", { entry_surface: entrySurface });
      }

      let isSending = false;
      let hasConversation = false;
      let pendingSeed = seedFromUrl;
      let activeTurn = null;
      /** @type {HTMLElement | null} */
      let pendingAssistantEl = null;
      /** First turn keeps top offset; scroll to end after first assistant reply. */
      let isInitialConversation = true;
      /** @type {{ file: File; previewUrl: string } | null} */
      let selectedFile = null;

      const BODY_IMAGE_WARNING = /øre|hud|kropp|ansikt|person/i;

      const ensureSessionId = () => {
        try {
          const existing = sessionStorage.getItem(SESSION_KEY);
          if (existing && SESSION_PATTERN.test(existing)) return existing;
        } catch (_) {}
        const created = `viddel-${crypto.randomUUID().replace(/-/g, "").slice(0, 24)}`;
        try {
          sessionStorage.setItem(SESSION_KEY, created);
        } catch (_) {}
        return created;
      };

      const syncComposeReserve = () => {
        const reserveEl = !hasConversation && startGroup ? startGroup : composeStack;
        const rect = reserveEl.getBoundingClientRect();
        const blockedBottom = Math.max(0, Math.ceil(window.innerHeight - rect.top)) + 20;
        const blockedPx = `${blockedBottom}px`;
        root.style.setProperty("--viddel-chat-bottom-spacer", blockedPx);
        shell.style.setProperty("--inline-chat-bottom-reserve", blockedPx);
        document.body.style.setProperty("--viddel-chat-compose-reserve", blockedPx);
      };

      const scrollDialogToStart = () => {
        requestAnimationFrame(() => {
          scrollViewport.scrollTop = 0;
        });
      };

      const scrollDialogToEnd = () => {
        requestAnimationFrame(() => {
          scrollViewport.scrollTop = Math.max(0, scrollViewport.scrollHeight - scrollViewport.clientHeight);
        });
      };

      const scrollDialogInitial = () => {
        requestAnimationFrame(() => {
          scrollViewport.scrollTop = 0;
          const anchor = activeTurn ?? pendingAssistantEl;
          anchor?.scrollIntoView({ behavior: "smooth", block: "nearest" });
        });
      };

      const scrollAfterContent = () => {
        if (isInitialConversation) {
          scrollDialogInitial();
          return;
        }
        scrollDialogToEnd();
      };

      const completeInitialConversation = () => {
        if (!isInitialConversation) return;
        isInitialConversation = false;
        scrollViewport.removeAttribute("data-viddel-chat-initial-conversation");
      };

      const activateConversation = () => {
        if (hasConversation) return;
        hasConversation = true;
        intro.classList.add("hidden");
        dialog.classList.remove("hidden");
        shell.setAttribute("data-inline-chat-conversation", "active");
        shell.setAttribute("data-inline-chat-state", "active");
        shell.setAttribute("aria-labelledby", "viddel-chat-dialog-label");
        document.body.setAttribute("data-viddel-chat-active", "true");
        scrollViewport.setAttribute("data-viddel-chat-initial-conversation", "true");
        syncComposeReserve();
        scrollDialogToStart();
      };

      const canSend = () => {
        if (isSending) return false;
        const hasText = Boolean(input.value.trim());
        const hasImage = Boolean(selectedFile);
        return hasText || hasImage;
      };

      const updateSendState = () => {
        const enabled = canSend();
        sendBtn.disabled = !enabled;
        sendBtn.setAttribute("aria-disabled", String(!enabled));
      };

      const refreshSendState = () => {
        requestAnimationFrame(updateSendState);
      };

      const clearAttachment = ({ revokePreview = true } = {}) => {
        if (revokePreview && selectedFile?.previewUrl) URL.revokeObjectURL(selectedFile.previewUrl);
        selectedFile = null;
        fileInput.value = "";
        thumbEl.removeAttribute("src");
        attachmentStrip.classList.add("hidden");
        refreshSendState();
        resizeInput();
        syncComposeReserve();
      };

      const setAttachment = (file) => {
        clearAttachment();
        const validation = validateChatImageFile(file);
        if (!validation.ok) {
          showError(validation.message);
          return;
        }
        clearError();
        const previewUrl = URL.createObjectURL(file);
        thumbEl.src = previewUrl;
        attachmentStrip.classList.remove("hidden");
        selectedFile = { file, previewUrl };
        refreshSendState();
        resizeInput();
        input.focus();
      };

      const resetComposerAfterSend = () => {
        input.value = "";
        clearAttachment({ revokePreview: false });
        resizeInput();
        refreshSendState();
      };

      const appendUserMessage = (text, previewUrl) => {
        const turn = document.createElement("div");
        turn.className = "inline-chat-shell__turn";

        if (previewUrl) {
          const userTurn = document.createElement("div");
          userTurn.className = "viddel-chat-attach__user-turn";
          const img = document.createElement("img");
          img.className = "viddel-chat-attach__message-thumb";
          img.src = previewUrl;
          img.alt = "Vedlagt utstyr-bilde";
          userTurn.append(img);
          const message = document.createElement("div");
          message.className = "inline-chat-shell__message inline-chat-shell__message--user";
          const body = document.createElement("p");
          body.className = "inline-chat-shell__message-text";
          body.textContent = text || "Bilde av utstyr";
          message.append(body);
          userTurn.append(message);
          turn.append(userTurn);
        } else {
          turn.innerHTML = `
            <div class="inline-chat-shell__message inline-chat-shell__message--user">
              <p class="inline-chat-shell__message-text"></p>
            </div>
          `;
          turn.querySelector(".inline-chat-shell__message-text").textContent = text;
        }

        transcript.append(turn);
        activeTurn = turn;
        scrollAfterContent();
      };

      const removePendingAssistant = () => {
        pendingAssistantEl?.remove();
        pendingAssistantEl = null;
      };

      const showPendingAssistant = (label = "Viddel svarer …") => {
        if (!activeTurn) return;
        removePendingAssistant();
        const assistant = document.createElement("div");
        assistant.className =
          "inline-chat-shell__message inline-chat-shell__message--assistant viddel-chat-scroll__message--pending";
        assistant.setAttribute("data-viddel-chat-pending", "");
        const eyebrow = document.createElement("p");
        eyebrow.className = "inline-chat-shell__message-eyebrow";
        eyebrow.textContent = "Viddel";
        const body = document.createElement("p");
        body.className = "inline-chat-shell__message-text";
        body.textContent = label;
        assistant.append(eyebrow, body);
        activeTurn.append(assistant);
        pendingAssistantEl = assistant;
        scrollAfterContent();
      };

      const appendAssistantMessage = (text) => {
        if (!activeTurn) return;
        removePendingAssistant();
        const assistant = document.createElement("div");
        assistant.className = "inline-chat-shell__message inline-chat-shell__message--assistant";
        const eyebrow = document.createElement("p");
        eyebrow.className = "inline-chat-shell__message-eyebrow";
        eyebrow.textContent = "Viddel";
        const body = document.createElement("div");
        body.className = "inline-chat-shell__message-text";
        renderAssistantMarkdownInto(body, text);
        assistant.append(eyebrow, body);
        activeTurn.append(assistant);
        completeInitialConversation();
        scrollDialogToEnd();
      };

      const showError = (message) => {
        errorEl.textContent = message;
        errorEl.classList.remove("hidden");
      };

      const clearError = () => {
        errorEl.textContent = "";
        errorEl.classList.add("hidden");
      };

      const setLoading = (active) => {
        loadingEl.classList.toggle("hidden", !active);
        syncComposeReserve();
      };

      const beginTranscriptPending = (label) => {
        showPendingAssistant(label);
        setLoading(false);
      };

      const resizeInput = () => {
        const minHeight = 46;
        input.style.height = "auto";
        const nextHeight = Math.max(minHeight, input.scrollHeight);
        const isExpanded = input.value.includes("\n") || nextHeight > minHeight + 2;
        input.toggleAttribute("data-chat-input-expanded", isExpanded);
        input.style.height = isExpanded ? `${nextHeight}px` : "";
        syncComposeReserve();
        updateSendState();
      };

      const handleComposerInput = () => {
        resizeInput();
      };

      const submitIfReady = () => {
        if (!canSend()) return;
        sendMessage(input.value);
      };

      const friendlyError = (payload) => {
        if (typeof payload?.message === "string" && payload.message.trim()) {
          return payload.message.trim();
        }
        if (payload?.error === "configuration_missing") {
          return "Viddel er ikke tilgjengelig akkurat nå. Prøv igjen om litt.";
        }
        if (payload?.error === "invalid_message") {
          return "Skriv et spørsmål før du sender.";
        }
        return "Vi fikk ikke tak i svaret akkurat nå. Prøv igjen.";
      };

      const visionFailureMessage = (payload) => {
        if (typeof payload?.message === "string" && payload.message.trim()) return payload.message.trim();
        return "Jeg klarte ikke å analysere bildet akkurat nå. Prøv et tydelig bilde av høreapparatutstyret, eller still spørsmålet som tekst.";
      };

      const hasUnsafeImageWarnings = (warnings) => {
        if (!Array.isArray(warnings)) return false;
        return warnings.some((warning) => typeof warning === "string" && BODY_IMAGE_WARNING.test(warning));
      };

      const sendMessageWithImage = async () => {
        if (!selectedFile || isSending) return;

        const userProblem = input.value.trim();
        const previewForMessage = selectedFile.previewUrl;
        const fileForUpload = selectedFile.file;

        clearError();
        activateConversation();
        appendUserMessage(userProblem, previewForMessage);
        resetComposerAfterSend();
        beginTranscriptPending("Viddel analyserer …");
        isSending = true;
        refreshSendState();
        input.disabled = true;
        attachBtn.disabled = true;
        removeBtn.disabled = true;

        try {
          const { base64, mimeType } = await fileToImageBase64Payload(fileForUpload);

          const visionRes = await fetch("/api/image-vision", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({
              imageBase64: base64,
              mimeType,
              userProblem,
            }),
          });
          const visionPayload = await visionRes.json().catch(() => ({}));

          if (!visionRes.ok) {
            removePendingAssistant();
            showError(visionFailureMessage(visionPayload));
            return;
          }

          if (hasUnsafeImageWarnings(visionPayload.warnings)) {
            removePendingAssistant();
            showError(
              "Bildet ser ut til å vise person eller kropp. Ta et bilde av høreapparatutstyret alene, uten øre, hud eller ansikt.",
            );
            return;
          }

          if (!visionPayload.vision) {
            removePendingAssistant();
            showError(visionFailureMessage(visionPayload));
            return;
          }

          const composedMessage = composeChatImageMessage(visionPayload.vision, userProblem);
          const response = await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              message: composedMessage,
              sessionId: ensureSessionId(),
            }),
          });
          const payload = await response.json().catch(() => ({}));

          if (!response.ok) {
            removePendingAssistant();
            showError(friendlyError(payload));
            return;
          }

          const text = typeof payload.text === "string" ? payload.text.trim() : "";
          if (!text) {
            removePendingAssistant();
            showError("Vi fikk ikke tak i svaret akkurat nå. Prøv igjen.");
            return;
          }

          clearError();
          if (typeof window.viddelTrack === "function") {
            window.viddelTrack("chat_answer_success", { entry_surface: entrySurface });
          }
          appendAssistantMessage(text);
        } catch (_) {
          removePendingAssistant();
          if (typeof window.viddelTrack === "function") {
            window.viddelTrack("chat_answer_error", { entry_surface: entrySurface, error_code: "network_error" });
          }
          showError("Nettverksfeil. Sjekk tilkoblingen og prøv igjen.");
        } finally {
          isSending = false;
          input.disabled = false;
          attachBtn.disabled = false;
          removeBtn.disabled = false;
          refreshSendState();
          setLoading(false);
          input.focus();
          syncComposeReserve();
        }
      };

      const sendMessage = async (rawMessage) => {
        const message = (rawMessage || "").trim();
        if (selectedFile) {
          await sendMessageWithImage();
          return;
        }
        if (!message || isSending) return;

        clearError();
        activateConversation();
        appendUserMessage(message, null);
        input.value = "";
        resizeInput();
        beginTranscriptPending();
        isSending = true;
        refreshSendState();
        input.disabled = true;

        const inputType = exampleButtons.length && Array.from(exampleButtons).some((btn) => btn.getAttribute("data-viddel-chat-example") === message)
          ? "seed"
          : seedFromUrl && message === seedFromUrl
            ? "seed"
            : "freeform";

        if (typeof window.viddelTrack === "function") {
          const trackProps = { entry_surface: entrySurface, input_type: inputType };
          if (inputType === "seed" && typeof window.viddelSeedId === "function") {
            trackProps.seed_id = window.viddelSeedId(message);
          }
          window.viddelTrack("chat_question_sent", trackProps);
        }

        try {
          const response = await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              message,
              sessionId: ensureSessionId(),
            }),
          });
          const payload = await response.json().catch(() => ({}));

          if (!response.ok) {
            const trackedCode = typeof payload?.error === "string" ? payload.error : "unknown";
            if (typeof window.viddelTrack === "function") {
              if (trackedCode === "rate_limited") {
                window.viddelTrack("chat_rate_limited", { entry_surface: entrySurface, error_code: trackedCode });
              } else if (trackedCode === "message_too_long") {
                window.viddelTrack("chat_message_too_long", { entry_surface: entrySurface, error_code: trackedCode });
              } else {
                window.viddelTrack("chat_answer_error", { entry_surface: entrySurface, error_code: trackedCode });
              }
            }
            removePendingAssistant();
            showError(friendlyError(payload));
            return;
          }

          const text = typeof payload.text === "string" ? payload.text.trim() : "";
          if (!text) {
            removePendingAssistant();
            if (typeof window.viddelTrack === "function") {
              window.viddelTrack("chat_answer_error", { entry_surface: entrySurface, error_code: "empty_response" });
            }
            showError("Vi fikk ikke tak i svaret akkurat nå. Prøv igjen.");
            return;
          }

          clearError();
          if (typeof window.viddelTrack === "function") {
            window.viddelTrack("chat_answer_success", { entry_surface: entrySurface });
          }
          appendAssistantMessage(text);
        } catch (_) {
          removePendingAssistant();
          if (typeof window.viddelTrack === "function") {
            window.viddelTrack("chat_answer_error", { entry_surface: entrySurface, error_code: "network_error" });
          }
          showError("Nettverksfeil. Sjekk tilkoblingen og prøv igjen.");
        } finally {
          isSending = false;
          input.disabled = false;
          refreshSendState();
          setLoading(false);
          input.focus();
          syncComposeReserve();
        }
      };

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        submitIfReady();
      });

      input.addEventListener("keydown", (event) => {
        if (event.key === "Enter" && !event.shiftKey) {
          event.preventDefault();
          submitIfReady();
        }
      });

      for (const eventName of ["input", "change", "keyup", "compositionend", "paste", "cut"]) {
        input.addEventListener(eventName, handleComposerInput);
      }

      removeBtn.addEventListener("click", () => {
        clearError();
        clearAttachment();
      });

      initChatAttachmentMenu(
        {
          attachLayer,
          attachBtn,
          attachMenu,
          attachBackdrop,
          attachCameraBtn,
          attachPickBtn,
          fileInput,
          composeStack,
        },
        {
          onFileSelected: (file) => {
            setAttachment(file);
            syncComposeReserve();
          },
        },
      );

      exampleButtons.forEach((button) => {
        button.addEventListener("click", () => {
          sendMessage(button.getAttribute("data-viddel-chat-example") || "");
        });
      });

      if ("ResizeObserver" in window) {
        const observer = new ResizeObserver(() => {
          syncComposeReserve();
          updateSendState();
        });
        observer.observe(composeStack);
        if (startGroup) observer.observe(startGroup);
        observer.observe(scrollViewport);
        observer.observe(input);
      }

      window.addEventListener("resize", () => {
        syncComposeReserve();
        updateSendState();
      }, { passive: true });

      if (window.visualViewport) {
        window.visualViewport.addEventListener("resize", () => {
          syncComposeReserve();
          updateSendState();
        }, { passive: true });
      }

      if (pendingSeed) {
        input.value = pendingSeed;
        handleComposerInput();
        window.setTimeout(() => {
          if (pendingSeed) {
            sendMessage(pendingSeed);
            pendingSeed = "";
          }
        }, 120);
      } else {
        input.focus();
      }

      updateSendState();
      syncComposeReserve();
    })();
  </script>
</BaseLayout>
