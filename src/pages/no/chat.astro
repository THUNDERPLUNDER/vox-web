---
/* CONTRACT: Standalone Viddel AI chat — headless CES via /api/chat, no widget. #125M-C R1 */
import BaseLayout from "../../layouts/BaseLayout.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const exampleQuestions = [
  "Hvordan kobler jeg høreapparatet til mobilen?",
  "Hvorfor blir lyden så slitsom på restaurant?",
  "Hva gjør jeg når appen ikke finner høreapparatet?",
  "Hvordan vet jeg om jeg bør kontakte audiograf?",
  "Hva kan jeg prøve hvis lyden fra TV-en blir utydelig?",
];
---

<BaseLayout
  title="Viddel - Spør Viddel"
  currentPath="/no/chat"
  headerBrand="viddel"
  shellVariant="standalone-chat"
  showHeaderDevtoolsToggle={false}
>
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="viddel-chat" data-viddel-chat data-state="idle">
    <div class="viddel-chat__inner">
      <section class="viddel-chat__intro" data-viddel-chat-intro aria-labelledby="viddel-chat-title">
        <h1 id="viddel-chat-title" class="viddel-chat__title">Spør Viddel</h1>
        <p class="viddel-chat__lede">
          Spør om høreapparat, app, lyd, innstillinger eller situasjoner i hverdagen. Viddel svarer best når du
          beskriver hva du prøver å få til.
        </p>

        <div class="viddel-chat__seed" data-viddel-chat-seed>
          <h2 class="viddel-chat__seed-title" id="viddel-chat-seed-title">Spør om dette</h2>
          <ul class="viddel-chat__seed-list" role="list" aria-labelledby="viddel-chat-seed-title" data-viddel-chat-examples>
            {
              exampleQuestions.map((question) => (
                <li class="viddel-chat__seed-item">
                  <button type="button" class="viddel-chat__seed-row" data-viddel-chat-example={question}>
                    <span class="viddel-chat__seed-question">{question}</span>
                  </button>
                </li>
              ))
            }
          </ul>
        </div>

        <p class="viddel-chat__safety">
          Viddel kan gi praktiske forslag og hjelpe deg å finne neste steg. Ved medisinske spørsmål eller vedvarende
          problemer bør du kontakte audiograf eller annet helsepersonell.
        </p>
      </section>

      <div class="viddel-chat__dialog hidden" data-viddel-chat-dialog>
        <div class="viddel-chat__transcript-divider hidden" data-viddel-chat-divider aria-hidden="true">
          <span class="viddel-chat__transcript-divider-line"></span>
          <span class="viddel-chat__transcript-divider-label" id="viddel-chat-dialog-label">Dialog med Viddel</span>
        </div>
        <div
          class="viddel-chat__transcript"
          data-viddel-chat-transcript
          role="log"
          aria-live="polite"
          aria-relevant="additions text"
        >
        </div>
      </div>

      <div class="viddel-chat__compose-stack" data-viddel-chat-compose-stack>
        <p class="viddel-chat__status hidden" data-viddel-chat-loading role="status">Viddel svarer …</p>
        <p class="viddel-chat__error hidden" data-viddel-chat-error role="alert"></p>

        <form class="viddel-chat__compose" data-viddel-chat-form>
          <label for="viddel-chat-input" class="sr-only">Skriv spørsmål til Viddel</label>
          <div class="viddel-chat__compose-input-wrap">
            <textarea
              id="viddel-chat-input"
              data-viddel-chat-input
              rows="1"
              placeholder="Beskriv situasjonen eller spørsmålet ditt ..."
              class="viddel-chat__input"
            ></textarea>
          </div>
          <button type="submit" class="viddel-chat__send" data-viddel-chat-send aria-label="Send spørsmål">
            <span aria-hidden="true">↑</span>
          </button>
        </form>
      </div>
    </div>
  </main>

  <style is:global>
    body.vox-shell--standalone-chat {
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }

    @media (max-width: 639px) {
      body.vox-shell--standalone-chat {
        height: 100dvh;
        overflow: hidden;
      }

      body.vox-shell--standalone-chat .vox-shell-standalone-chat__stage {
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden;
      }
    }

    @media (min-width: 640px) {
      body.vox-shell--standalone-chat .vox-shell-standalone-chat__stage {
        max-width: 42rem;
      }
    }
  </style>

  <style>
    .viddel-chat {
      --viddel-ai-dialog-measure: min(100%, 46rem);
      --viddel-ai-user-measure: min(92%, 32rem);
      --viddel-ai-input-radius: 1.15rem;
      --viddel-ai-user-surface: rgb(244 245 247);
      --viddel-ai-seed-hover: rgb(248 250 252 / 0.72);
      --viddel-chat-compose-reserve: 6.5rem;

      display: flex;
      flex: 1 1 auto;
      flex-direction: column;
      min-height: 0;
      width: 100%;
    }

    html[data-theme="dark"] .viddel-chat {
      --viddel-ai-user-surface: rgb(var(--reading-inline));
      --viddel-ai-seed-hover: rgb(var(--surface-subtle) / 0.92);
    }

    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .viddel-chat {
        --viddel-ai-user-surface: rgb(var(--reading-inline));
        --viddel-ai-seed-hover: rgb(var(--surface-subtle) / 0.92);
      }
    }

    .viddel-chat__inner {
      display: flex;
      flex: 1 1 auto;
      flex-direction: column;
      gap: 0.85rem;
      min-height: 0;
      width: 100%;
      max-width: var(--viddel-ai-dialog-measure);
      margin-inline: auto;
    }

    @media (max-width: 639px) {
      .viddel-chat {
        height: 100%;
        min-height: 0;
      }

      .viddel-chat[data-state="active"] .viddel-chat__dialog:not(.hidden) {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        overscroll-behavior: contain;
        -webkit-overflow-scrolling: touch;
        padding-bottom: calc(var(--viddel-chat-compose-reserve) + env(safe-area-inset-bottom, 0px));
      }

      .viddel-chat[data-state="active"] .viddel-chat__compose-stack {
        position: fixed;
        z-index: 24;
        left: 50%;
        bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
        width: min(var(--viddel-ai-dialog-measure), calc(100vw - 1.5rem));
        transform: translateX(-50%);
        border: 1px solid rgb(var(--border) / 0.44);
        border-radius: 1.12rem;
        background: rgb(var(--surface) / 0.98);
        padding: 0.42rem 0.58rem 0.55rem;
      }
    }

    @media (min-width: 640px) {
      .viddel-chat {
        padding-bottom: 2rem;
      }

      .viddel-chat__inner {
        gap: 1.15rem;
      }

      .viddel-chat[data-state="active"] .viddel-chat__compose-stack {
        position: sticky;
        bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
      }
    }

    .viddel-chat__title {
      font-family: var(--font-display, inherit);
      font-size: clamp(1.65rem, 4vw, 2.15rem);
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: 1.15;
      color: rgb(var(--text));
    }

    .viddel-chat__lede {
      margin-top: 0.65rem;
      max-width: 36rem;
      font-size: 0.95rem;
      line-height: 1.55;
      color: rgb(var(--muted));
    }

    .viddel-chat__seed {
      margin-top: 1.15rem;
    }

    .viddel-chat__seed-title {
      font-size: 1.08rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      line-height: 1.3;
      color: rgb(var(--reading-ink, var(--text)));
    }

    .viddel-chat__seed-list {
      display: grid;
      gap: 0.32rem;
      margin: 0.45rem 0 0;
      padding: 0;
      list-style: none;
    }

    .viddel-chat__seed-item {
      display: flex;
      justify-content: flex-end;
    }

    .viddel-chat__seed-row {
      display: flex;
      width: var(--viddel-ai-user-measure);
      align-items: flex-start;
      justify-content: flex-start;
      border: 1px solid rgb(var(--border) / 0.32);
      border-radius: var(--viddel-ai-input-radius);
      background: transparent;
      padding: 0.7rem 0.84rem;
      cursor: pointer;
      text-align: left;
      color: rgb(var(--reading-ink, var(--text)));
      transition:
        background-color 140ms ease,
        border-color 140ms ease;
    }

    .viddel-chat__seed-row:hover {
      border-color: rgb(var(--border) / 0.52);
      background: var(--viddel-ai-seed-hover);
    }

    .viddel-chat__seed-row:focus-visible {
      outline: 2px solid rgb(var(--reading-accent-iris, var(--focus-ring)) / 0.34);
      outline-offset: 2px;
    }

    .viddel-chat__seed-question {
      min-width: 0;
      flex: 1;
      font-size: 0.94rem;
      line-height: 1.42;
      letter-spacing: -0.006em;
    }

    .viddel-chat__safety {
      margin-top: 1rem;
      max-width: 36rem;
      font-size: 0.78rem;
      line-height: 1.5;
      color: rgb(var(--muted));
    }

    .viddel-chat__dialog.hidden,
    .viddel-chat__status.hidden,
    .viddel-chat__error.hidden,
    .viddel-chat__intro.hidden,
    .viddel-chat__transcript-divider.hidden {
      display: none;
    }

    .viddel-chat__transcript-divider {
      display: grid;
      grid-template-columns: minmax(1.4rem, 1fr) auto;
      gap: 0.55rem;
      align-items: center;
      margin: 0.15rem 0 0.75rem;
    }

    .viddel-chat__transcript-divider-line {
      display: block;
      min-width: 0;
      border-top: 1px solid rgb(var(--border) / 0.48);
    }

    .viddel-chat__transcript-divider-label {
      font-size: 0.68rem;
      font-weight: 650;
      letter-spacing: 0.12em;
      line-height: 1.2;
      text-transform: uppercase;
      white-space: nowrap;
      color: rgb(var(--reading-ink-secondary, var(--muted)));
    }

    .viddel-chat__transcript {
      display: grid;
      gap: 0.55rem;
      padding: 0.15rem 0 0.5rem;
    }

    .viddel-chat__turn {
      display: grid;
      gap: 0.55rem;
    }

    .viddel-chat__message {
      max-width: var(--viddel-ai-dialog-measure);
    }

    .viddel-chat__message--user {
      margin-left: auto;
      width: var(--viddel-ai-user-measure);
      border-radius: var(--viddel-ai-input-radius);
      background: var(--viddel-ai-user-surface);
      padding: 0.78rem 0.9rem;
    }

    html[data-theme="dark"] .viddel-chat__message--user {
      border: 1px solid rgb(var(--border) / 0.38);
    }

    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .viddel-chat__message--user {
        border: 1px solid rgb(var(--border) / 0.38);
      }
    }

    .viddel-chat__message--assistant {
      width: min(100%, 40rem);
      padding: 0.45rem 0;
      background: transparent;
    }

    .viddel-chat__message-eyebrow {
      font-size: 0.66rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgb(var(--reading-ink-secondary, var(--muted)));
    }

    .viddel-chat__message-text {
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.48;
      color: rgb(var(--reading-ink, var(--text)));
      white-space: pre-wrap;
    }

    .viddel-chat__message--assistant .viddel-chat__message-text {
      margin-top: 0.28rem;
    }

    .viddel-chat__message--user .viddel-chat__message-text {
      margin-top: 0;
    }

    .viddel-chat__compose-stack {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      margin-top: 0.35rem;
    }

    .viddel-chat[data-state="active"] .viddel-chat__compose-stack {
      margin-top: 0;
    }

    .viddel-chat__status,
    .viddel-chat__error {
      margin: 0;
      padding: 0.1rem 0.35rem 0.2rem;
      font-size: 0.8rem;
      line-height: 1.35;
    }

    .viddel-chat__status {
      color: rgb(var(--reading-ink-secondary, var(--muted)));
    }

    .viddel-chat__error {
      color: rgb(var(--text));
    }

    .viddel-chat__compose {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.55rem;
      align-items: flex-end;
      border: 1px solid rgb(var(--border) / 0.5);
      border-radius: var(--viddel-ai-input-radius);
      background: rgb(var(--surface) / 0.97);
      padding: 0.58rem;
    }

    .viddel-chat__compose:focus-within {
      border-color: rgb(var(--reading-accent-iris, var(--focus-ring)) / 0.46);
    }

    .viddel-chat[data-state="active"] .viddel-chat__compose-stack .viddel-chat__compose {
      background: transparent;
      border: 0;
      border-radius: 0.85rem;
      padding: 0.35rem 0.28rem 0.28rem;
    }

    .viddel-chat__compose-input-wrap {
      display: grid;
      min-width: 0;
    }

    .viddel-chat__input {
      width: 100%;
      min-height: 2.35rem;
      max-height: min(9rem, 32vh);
      resize: none;
      border: 0;
      background: transparent;
      font: inherit;
      font-size: 0.95rem;
      line-height: 1.45;
      color: rgb(var(--reading-ink, var(--text)));
      outline: 0;
      padding: 0.42rem 0.34rem;
      overflow-y: auto;
    }

    .viddel-chat__input::placeholder {
      color: rgb(var(--reading-ink-secondary, var(--muted)) / 0.72);
    }

    .viddel-chat__send {
      display: inline-flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      width: 2.35rem;
      height: 2.35rem;
      min-height: 2.35rem;
      border: 0;
      border-radius: 999px;
      background: rgb(var(--reading-ink, var(--text)));
      color: rgb(var(--surface));
      font-size: 0.82rem;
      font-weight: 650;
      line-height: 1;
      cursor: pointer;
      transition: opacity 0.15s ease;
    }

    .viddel-chat[data-state="active"] .viddel-chat__send {
      width: 2.68rem;
      height: 2.68rem;
      min-height: 2.68rem;
      font-size: 1.02rem;
      font-weight: 700;
    }

    .viddel-chat__send:hover:not(:disabled) {
      opacity: 0.9;
    }

    .viddel-chat__send:disabled {
      cursor: not-allowed;
      opacity: 0.46;
    }

    .viddel-chat__send:focus-visible {
      outline: 2px solid rgb(var(--reading-accent-iris, var(--focus-ring)) / 0.42);
      outline-offset: 3px;
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-viddel-chat]");
      const intro = document.querySelector("[data-viddel-chat-intro]");
      const dialog = document.querySelector("[data-viddel-chat-dialog]");
      const divider = document.querySelector("[data-viddel-chat-divider]");
      const transcript = document.querySelector("[data-viddel-chat-transcript]");
      const composeStack = document.querySelector("[data-viddel-chat-compose-stack]");
      const loadingEl = document.querySelector("[data-viddel-chat-loading]");
      const errorEl = document.querySelector("[data-viddel-chat-error]");
      const form = document.querySelector("[data-viddel-chat-form]");
      const input = document.querySelector("[data-viddel-chat-input]");
      const sendBtn = document.querySelector("[data-viddel-chat-send]");
      const exampleButtons = document.querySelectorAll("[data-viddel-chat-example]");

      if (
        !root ||
        !intro ||
        !dialog ||
        !divider ||
        !transcript ||
        !composeStack ||
        !loadingEl ||
        !errorEl ||
        !form ||
        !input ||
        !sendBtn
      ) {
        return;
      }

      const SESSION_KEY = "viddel-chat-session";
      const SESSION_PATTERN = /^[a-zA-Z0-9][a-zA-Z0-9-_]{4,62}$/;
      const params = new URLSearchParams(window.location.search);
      const seedFromUrl = (params.get("seed") || params.get("q") || "").trim();

      let isSending = false;
      let hasConversation = false;
      let pendingSeed = seedFromUrl;

      const ensureSessionId = () => {
        try {
          const existing = sessionStorage.getItem(SESSION_KEY);
          if (existing && SESSION_PATTERN.test(existing)) return existing;
        } catch (_) {}
        const created = `viddel-${crypto.randomUUID().replace(/-/g, "").slice(0, 24)}`;
        try {
          sessionStorage.setItem(SESSION_KEY, created);
        } catch (_) {}
        return created;
      };

      const setState = (state) => {
        root.dataset.state = state;
      };

      const showError = (message) => {
        errorEl.textContent = message;
        errorEl.classList.remove("hidden");
      };

      const clearError = () => {
        errorEl.textContent = "";
        errorEl.classList.add("hidden");
      };

      const setLoading = (active) => {
        loadingEl.classList.toggle("hidden", !active);
      };

      const syncComposeReserve = () => {
        const h = composeStack.getBoundingClientRect().height;
        root.style.setProperty("--viddel-chat-compose-reserve", `${Math.ceil(h + 12)}px`);
      };

      const activateConversation = () => {
        if (hasConversation) return;
        hasConversation = true;
        intro.classList.add("hidden");
        dialog.classList.remove("hidden");
        divider.classList.remove("hidden");
        divider.removeAttribute("aria-hidden");
        root.setAttribute("aria-labelledby", "viddel-chat-dialog-label");
        setState("active");
        syncComposeReserve();
      };

      const appendMessage = (role, text) => {
        const turn = document.createElement("div");
        turn.className = "viddel-chat__turn";

        const message = document.createElement("article");
        message.className = `viddel-chat__message viddel-chat__message--${role === "user" ? "user" : "assistant"}`;

        if (role === "assistant") {
          const eyebrow = document.createElement("p");
          eyebrow.className = "viddel-chat__message-eyebrow";
          eyebrow.textContent = "Viddel";
          message.append(eyebrow);
        }

        const body = document.createElement("p");
        body.className = "viddel-chat__message-text";
        body.textContent = text;
        message.append(body);
        turn.append(message);
        transcript.append(turn);
        message.scrollIntoView({ behavior: "smooth", block: "nearest" });
      };

      const resizeInput = () => {
        input.style.height = "auto";
        input.style.height = `${input.scrollHeight}px`;
        syncComposeReserve();
      };

      const friendlyError = (payload) => {
        if (payload?.error === "configuration_missing") {
          return "Viddel er ikke tilgjengelig akkurat nå. Prøv igjen om litt.";
        }
        if (payload?.error === "invalid_message") {
          return "Skriv et spørsmål før du sender.";
        }
        return "Vi fikk ikke tak i svaret akkurat nå. Prøv igjen.";
      };

      const sendMessage = async (rawMessage) => {
        const message = (rawMessage || "").trim();
        if (!message || isSending) return;

        clearError();
        activateConversation();
        appendMessage("user", message);
        input.value = "";
        resizeInput();
        isSending = true;
        sendBtn.disabled = true;
        input.disabled = true;
        setLoading(true);

        try {
          const response = await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              message,
              sessionId: ensureSessionId(),
            }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            showError(friendlyError(payload));
            return;
          }

          const text = typeof payload.text === "string" ? payload.text.trim() : "";
          if (!text) {
            showError("Vi fikk ikke tak i svaret akkurat nå. Prøv igjen.");
            return;
          }

          appendMessage("assistant", text);
        } catch (_) {
          showError("Nettverksfeil. Sjekk tilkoblingen og prøv igjen.");
        } finally {
          isSending = false;
          sendBtn.disabled = false;
          input.disabled = false;
          setLoading(false);
          input.focus();
          syncComposeReserve();
        }
      };

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        sendMessage(input.value);
      });

      input.addEventListener("keydown", (event) => {
        if (event.key === "Enter" && !event.shiftKey) {
          event.preventDefault();
          sendMessage(input.value);
        }
      });

      input.addEventListener("input", resizeInput);

      exampleButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const question = button.getAttribute("data-viddel-chat-example") || "";
          sendMessage(question);
        });
      });

      if ("ResizeObserver" in window) {
        const observer = new ResizeObserver(syncComposeReserve);
        observer.observe(composeStack);
      }

      window.addEventListener("resize", syncComposeReserve, { passive: true });

      if (pendingSeed) {
        input.value = pendingSeed;
        window.setTimeout(() => {
          if (pendingSeed) {
            sendMessage(pendingSeed);
            pendingSeed = "";
          }
        }, 120);
      } else {
        input.focus();
      }

      syncComposeReserve();
    })();
  </script>
</BaseLayout>
