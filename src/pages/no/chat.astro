---
/* CONTRACT: Demo chat surface with product-owned frame and stable CES engine as the only visible conversation mode. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
---

<BaseLayout title="VOX - Hørehjelpen (fri samtale)" currentPath="/no/chat">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="relative pb-2 sm:pb-3">
    <Section class="!pt-1 !pb-4 sm:!pt-2 sm:!pb-5">
      <div class="mx-auto max-w-[920px] space-y-6">
        <div>
          <h1 class="font-display text-2xl font-semibold tracking-[-0.03em] text-balance sm:text-3xl">Hørehjelpen — fri samtale</h1>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-[rgb(var(--muted))]">
            Skriv det du vil, uten forhåndsvalgt tema. Kom du fra en artikkel med valgt spørsmål, fyller vi inn utgangspunktet for deg.
          </p>
          <div id="seed-strip" class="mt-5 hidden border-l-2 border-[rgb(var(--primary))/0.35] pl-3">
            <p class="text-[11px] uppercase tracking-wide text-[rgb(var(--muted))]">Valgt startspørsmål</p>
            <p id="seed-text" class="mt-0.5 text-sm text-[rgb(var(--text))]"></p>
            <button
              id="seed-start-button"
              type="button"
              class="mt-3 inline-flex items-center justify-center rounded-none bg-[rgb(var(--text))] px-3 py-2 text-xs font-semibold text-[rgb(var(--surface))] transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50"
            >
              Start samtale med dette spørsmålet
            </button>
            <p id="seed-sync-status" class="mt-0.5 text-xs text-[rgb(var(--muted))]"></p>
          </div>
        </div>

        <div class="vox-surface-embedded-app" data-kl-surface="embedded-app">
          <chat-messenger
            id="ces-demo-widget"
            url-allowlist="*"
            class="block h-[min(70vh,680px)] w-full overflow-hidden rounded-none bg-[rgb(var(--surface-subtle))]"
          >
            <chat-messenger-container
              chat-title="Hørehjelpen"
              enable-file-upload
              enable-audio-input
            ></chat-messenger-container>
          </chat-messenger>
        </div>

        <div
          id="no-chat-debug-panel"
          class="hidden border border-[rgb(var(--border))] bg-[rgb(var(--surface-subtle))] p-3 text-xs text-[rgb(var(--muted))]"
        >
          <p class="mb-2 font-semibold uppercase tracking-wide text-[rgb(var(--text))]">No chat debug</p>
          <pre id="no-chat-debug-output" class="whitespace-pre-wrap break-words font-mono leading-relaxed"></pre>
          <div class="mt-3 border-t border-[rgb(var(--border))] pt-3">
            <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
              <p class="font-semibold uppercase tracking-wide text-[rgb(var(--text))]">Kopierbar status</p>
              <button
                id="no-chat-debug-copy"
                type="button"
                class="inline-flex items-center justify-center rounded-none border border-[rgb(var(--border))] px-2.5 py-1 text-[11px] font-semibold text-[rgb(var(--text))]"
              >
                Kopier debugstatus
              </button>
            </div>
            <textarea
              id="no-chat-debug-report"
              class="min-h-[180px] w-full resize-y rounded-none border border-[rgb(var(--border))] bg-[rgb(var(--surface))] p-2 font-mono text-[11px] leading-relaxed text-[rgb(var(--text))]"
              readonly
            ></textarea>
            <p id="no-chat-debug-copy-status" class="mt-1 text-[11px] text-[rgb(var(--muted))]"></p>
          </div>
        </div>
        <div class="flex justify-end">
          <button
            id="no-chat-debug-toggle"
            type="button"
            class="inline-flex items-center justify-center rounded-none border border-[rgb(var(--border))] bg-[rgb(var(--surface))] px-2.5 py-1 text-[11px] font-semibold text-[rgb(var(--muted))]"
            aria-pressed="false"
          >
            Debug
          </button>
        </div>
      </div>
    </Section>
  </main>

  <script is:inline>
    (() => {
      const widget = document.getElementById("ces-demo-widget");
      const seedStrip = document.getElementById("seed-strip");
      const seedTextEl = document.getElementById("seed-text");
      const seedStartBtn = document.getElementById("seed-start-button");
      const statusEl = document.getElementById("seed-sync-status");
      const params = new URLSearchParams(window.location.search);
      const initialQuestion = (params.get("seed") || "").trim();
      const from = (params.get("from") || "").trim();
      let debugEnabled = params.get("debug") === "1";
      const debugPanel = document.getElementById("no-chat-debug-panel");
      const debugOutput = document.getElementById("no-chat-debug-output");
      const debugToggleBtn = document.getElementById("no-chat-debug-toggle");
      const debugReportEl = document.getElementById("no-chat-debug-report");
      const debugCopyBtn = document.getElementById("no-chat-debug-copy");
      const debugCopyStatus = document.getElementById("no-chat-debug-copy-status");
      const debugState = {
        widgetExists: false,
        tagName: "(missing)",
        nodeName: "(missing)",
        sessionInputType: "undefined",
        sendQueryType: "undefined",
        renderCustomTextType: "undefined",
        startNewSessionType: "undefined",
        customElementDefined: false,
        chatMessengerLoaded: false,
        voxCesRegister: false,
        cesMessengerConnected: false,
        readinessPolls: 0,
        startNewSessionCalled: false,
        startNewSessionResult: "",
        startNewSessionError: "",
        sendQueryCalled: false,
        sendQueryResult: "",
        sendQueryError: "",
        cooldownUsed: false,
        cooldownMsWaited: 0,
        lastSeedSendAt: "",
        lastSeedStatus: "Script startet.",
        lifecycleEvents: [],
      };
      const seedCooldownMs = 6000;
      const seedCooldownKey = "vox:no-chat:last-seed-send-at";

      const stringifyDebugPayload = (payload) => {
        if (payload === undefined) return "";
        if (payload === null) return "null";
        if (typeof payload === "string") return payload;
        try {
          return JSON.stringify(payload);
        } catch (error) {
          try {
            return String(payload);
          } catch {
            return "[unserializable payload]";
          }
        }
      };

      const addLifecycleEvent = (name, payload) => {
        const time = new Date().toISOString();
        const detail = stringifyDebugPayload(payload);
        debugState.lifecycleEvents = [
          ...debugState.lifecycleEvents,
          detail ? `${time} ${name} ${detail}` : `${time} ${name}`,
        ].slice(-24);
        renderDebug();
      };

      const updateDebugState = () => {
        const currentWidget = document.getElementById("ces-demo-widget");
        debugState.widgetExists = Boolean(currentWidget);
        debugState.tagName = currentWidget?.tagName || "(missing)";
        debugState.nodeName = currentWidget?.nodeName || "(missing)";
        debugState.sessionInputType = typeof currentWidget?.sessionInput;
        debugState.sendQueryType = typeof currentWidget?.sendQuery;
        debugState.renderCustomTextType = typeof currentWidget?.renderCustomText;
        debugState.startNewSessionType = typeof currentWidget?.startNewSession;
        debugState.customElementDefined = Boolean(window.customElements?.get("chat-messenger"));
      };

      const getLastSeedSendAt = () => {
        try {
          return Number(window.sessionStorage.getItem(seedCooldownKey) || "0") || 0;
        } catch {
          return 0;
        }
      };

      const setLastSeedSendAt = (value) => {
        try {
          window.sessionStorage.setItem(seedCooldownKey, String(value));
        } catch {
          // Ignore storage failures; cooldown is a best-effort CES throttle.
        }
        debugState.lastSeedSendAt = value ? new Date(value).toISOString() : "";
      };

      const updateDebugToggle = () => {
        if (!debugToggleBtn) return;
        debugToggleBtn.setAttribute("aria-pressed", debugEnabled ? "true" : "false");
        debugToggleBtn.classList.toggle("text-[rgb(var(--text))]", debugEnabled);
        debugToggleBtn.classList.toggle("text-[rgb(var(--muted))]", !debugEnabled);
        debugToggleBtn.classList.toggle("bg-[rgb(var(--surface-subtle))]", debugEnabled);
      };

      const buildDebugReport = () => [
        `current URL: ${window.location.href}`,
        `seed: ${initialQuestion || "(none)"}`,
        `tidspunkt: ${new Date().toISOString()}`,
        `typeof widget.sendQuery: ${debugState.sendQueryType}`,
        `typeof widget.startNewSession: ${debugState.startNewSessionType}`,
        `startNewSession kalt: ${debugState.startNewSessionCalled}`,
        `startNewSession result: ${debugState.startNewSessionResult || "(none)"}`,
        `startNewSession error: ${debugState.startNewSessionError || "(none)"}`,
        `sendQuery kalt: ${debugState.sendQueryCalled}`,
        `sendQuery result: ${debugState.sendQueryResult || "(none)"}`,
        `sendQuery error: ${debugState.sendQueryError || "(none)"}`,
        `cooldown brukt: ${debugState.cooldownUsed}`,
        `cooldown ms ventet: ${debugState.cooldownMsWaited}`,
        `last seed send timestamp: ${debugState.lastSeedSendAt || "(none)"}`,
        `siste seed-status: ${debugState.lastSeedStatus}`,
        "",
        "CES lifecycle-logg:",
        ...(debugState.lifecycleEvents.length ? debugState.lifecycleEvents : ["(none)"]),
      ].join("\n");

      const renderDebug = () => {
        updateDebugToggle();
        if (!debugEnabled) {
          if (debugPanel) debugPanel.classList.add("hidden");
          return;
        }
        updateDebugState();
        if (debugPanel) debugPanel.classList.remove("hidden");
        if (debugOutput) {
          debugOutput.textContent = [
            `#ces-demo-widget finnes: ${debugState.widgetExists}`,
            `tagName: ${debugState.tagName}`,
            `nodeName: ${debugState.nodeName}`,
            `typeof widget.sessionInput: ${debugState.sessionInputType}`,
            `typeof widget.sendQuery: ${debugState.sendQueryType}`,
            `typeof widget.renderCustomText: ${debugState.renderCustomTextType}`,
            `typeof widget.startNewSession: ${debugState.startNewSessionType}`,
            `customElements.get("chat-messenger"): ${debugState.customElementDefined}`,
            `chat-messenger-loaded mottatt: ${debugState.chatMessengerLoaded}`,
            `vox-ces-register mottatt: ${debugState.voxCesRegister}`,
            `ces-messenger-connected mottatt: ${debugState.cesMessengerConnected}`,
            `readiness polling ticks: ${debugState.readinessPolls}`,
            `startNewSession kalt: ${debugState.startNewSessionCalled}`,
            `startNewSession result: ${debugState.startNewSessionResult || "(none)"}`,
            `startNewSession error: ${debugState.startNewSessionError || "(none)"}`,
            `sendQuery kalt: ${debugState.sendQueryCalled}`,
            `sendQuery result: ${debugState.sendQueryResult || "(none)"}`,
            `sendQuery error: ${debugState.sendQueryError || "(none)"}`,
            `cooldown brukt: ${debugState.cooldownUsed}`,
            `cooldown ms ventet: ${debugState.cooldownMsWaited}`,
            `last seed send timestamp: ${debugState.lastSeedSendAt || "(none)"}`,
            `siste seed-status: ${debugState.lastSeedStatus}`,
            "",
            "CES lifecycle:",
            ...(debugState.lifecycleEvents.length ? debugState.lifecycleEvents : ["(none)"]),
          ].join("\n");
        }
        if (debugReportEl) debugReportEl.value = buildDebugReport();
        window.__voxNoChatDebug = {
          ...debugState,
          refresh: () => {
            renderDebug();
            return window.__voxNoChatDebug;
          },
        };
        console.debug("[vox-no-chat-debug]", { ...debugState });
      };

      const setDebugEnabled = (next) => {
        debugEnabled = next;
        const nextUrl = new URL(window.location.href);
        if (debugEnabled) nextUrl.searchParams.set("debug", "1");
        else nextUrl.searchParams.delete("debug");
        window.history.replaceState({}, "", nextUrl);
        renderDebug();
      };

      if (debugToggleBtn) {
        debugToggleBtn.addEventListener("click", () => setDebugEnabled(!debugEnabled));
      }

      if (debugCopyBtn) {
        debugCopyBtn.addEventListener("click", async () => {
          renderDebug();
          const report = debugReportEl?.value || buildDebugReport();
          try {
            await navigator.clipboard?.writeText(report);
            if (debugCopyStatus) debugCopyStatus.textContent = "Debugstatus kopiert";
          } catch {
            debugReportEl?.focus();
            debugReportEl?.select();
            if (debugCopyStatus) debugCopyStatus.textContent = "Marker teksten manuelt hvis kopiering ikke virker.";
          }
        });
      }

      const setSeedStatus = (text) => {
        debugState.lastSeedStatus = text;
        if (statusEl && initialQuestion) statusEl.textContent = text;
        renderDebug();
      };

      if (seedStrip && initialQuestion) seedStrip.classList.remove("hidden");
      if (seedTextEl) seedTextEl.textContent = initialQuestion;
      if (seedStartBtn && initialQuestion) seedStartBtn.setAttribute("disabled", "");
      if (statusEl && initialQuestion) {
        setSeedStatus(from
          ? `Hentet fra ${from === "article" ? "artikkel" : "hub"}. Kobler til Hørehjelpen ...`
          : "Kobler til Hørehjelpen ...");
      }
      renderDebug();

      let isSending = false;
      let sendQueryReadyAt = 0;
      let seedSessionReset = false;
      const sendQueryStabilizeMs = 700;
      const seedSessionTokenTimeoutMs = 3500;

      const hasSendQuery = () => typeof widget?.sendQuery === "function";

      const markReady = () => {
        renderDebug();
        if (!widget) return false;
        if (!hasSendQuery()) return false;
        if (!sendQueryReadyAt) sendQueryReadyAt = Date.now();
        // The hosted widget can expose sendQuery before its session is settled.
        if (Date.now() - sendQueryReadyAt < sendQueryStabilizeMs) return false;
        if (!isSending && seedStartBtn) seedStartBtn.removeAttribute("disabled");
        if (!isSending) setSeedStatus("Klar til å starte");
        return true;
      };

      const observeReadiness = () => {
        if (markReady()) return;
        let tries = 0;
        const timer = setInterval(() => {
          tries += 1;
          debugState.readinessPolls += 1;
          if (markReady() || tries > 120) clearInterval(timer);
        }, 250);
      };

      const waitForSeedCooldown = async () => {
        const lastSendAt = getLastSeedSendAt();
        debugState.lastSeedSendAt = lastSendAt ? new Date(lastSendAt).toISOString() : "";
        const elapsed = lastSendAt ? Date.now() - lastSendAt : seedCooldownMs;
        const waitMs = Math.max(0, seedCooldownMs - elapsed);
        debugState.cooldownUsed = waitMs > 0;
        debugState.cooldownMsWaited = waitMs;
        renderDebug();
        if (!waitMs) return;
        setSeedStatus("Klargjør ny samtale ...");
        addLifecycleEvent("seed cooldown wait", { waitMs });
        await new Promise((resolve) => setTimeout(resolve, waitMs));
      };

      const resetSeedSession = async () => {
        if (seedSessionReset) return;
        seedSessionReset = true;
        if (typeof widget?.startNewSession !== "function") return;
        debugState.startNewSessionCalled = true;
        debugState.startNewSessionResult = "";
        debugState.startNewSessionError = "";
        addLifecycleEvent("reset/startNewSession called");
        renderDebug();
        const tokenReady = new Promise((resolve) => {
          const timer = setTimeout(() => {
            window.removeEventListener("chat-messenger-access-token-resolved", onTokenResolved);
            resolve("timeout");
          }, seedSessionTokenTimeoutMs);
          function onTokenResolved() {
            clearTimeout(timer);
            resolve("access-token-resolved");
          }
          window.addEventListener("chat-messenger-access-token-resolved", onTokenResolved, { once: true });
        });
        try {
          widget.startNewSession();
          debugState.startNewSessionResult = await tokenReady;
          renderDebug();
        } catch (error) {
          debugState.startNewSessionError = String(error?.message || error || "unknown");
          renderDebug();
        }
      };

      const sendSeed = async () => {
        if (!widget || !initialQuestion) return false;
        if (!hasSendQuery()) return false;
        await waitForSeedCooldown();
        await resetSeedSession();
        debugState.sendQueryCalled = true;
        debugState.sendQueryResult = "";
        debugState.sendQueryError = "";
        addLifecycleEvent("sendQuery called", { seedLength: initialQuestion.length });
        renderDebug();
        setLastSeedSendAt(Date.now());
        const result = await widget.sendQuery(initialQuestion);
        debugState.sendQueryResult = result === undefined ? "resolved: undefined" : `resolved: ${String(result)}`;
        addLifecycleEvent("sendQuery resolved", { result: debugState.sendQueryResult });
        setSeedStatus("Spørsmålet er sendt");
        isSending = false;
        return true;
      };

      const sendSeedWithRetry = async () => {
        isSending = true;
        if (seedStartBtn) seedStartBtn.setAttribute("disabled", "");
        setSeedStatus("Sender spørsmålet til Hørehjelpen ...");
        try {
          if (await sendSeed()) return;
        } catch (error) {
          console.error("chat-messenger-error", error);
          debugState.sendQueryResult = "rejected";
          debugState.sendQueryError = String(error?.message || error || "unknown");
          addLifecycleEvent("sendQuery rejected", { error: debugState.sendQueryError });
          isSending = false;
          setSeedStatus("Kunne ikke sende spørsmålet akkurat nå. Prøv igjen.");
          if (seedStartBtn) seedStartBtn.removeAttribute("disabled");
          return;
        }
        let tries = 0;
        const timer = setInterval(async () => {
          tries += 1;
          debugState.readinessPolls += 1;
          if (hasSendQuery()) {
            clearInterval(timer);
            try {
              await sendSeed();
            } catch (error) {
              console.error("chat-messenger-error", error);
              debugState.sendQueryResult = "rejected";
              debugState.sendQueryError = String(error?.message || error || "unknown");
              addLifecycleEvent("sendQuery rejected", { error: debugState.sendQueryError });
              isSending = false;
              setSeedStatus("Kunne ikke sende spørsmålet akkurat nå. Prøv igjen.");
              if (seedStartBtn) seedStartBtn.removeAttribute("disabled");
            }
            return;
          }
          if (tries > 120) {
            clearInterval(timer);
            isSending = false;
            setSeedStatus("Kunne ikke sende spørsmålet akkurat nå. Prøv igjen.");
            if (seedStartBtn) seedStartBtn.removeAttribute("disabled");
          }
        }, 250);
      };

      if (seedStartBtn) {
        seedStartBtn.addEventListener("click", sendSeedWithRetry);
      }
      window.addEventListener("chat-messenger-start-new-session", (event) => {
        addLifecycleEvent("chat-messenger-start-new-session event", event?.detail);
      });
      window.addEventListener("chat-messenger-access-token-resolved", (event) => {
        addLifecycleEvent("chat-messenger-access-token-resolved event", event?.detail);
      });
      window.addEventListener("chat-messenger-response-received", (event) => {
        addLifecycleEvent("chat-messenger-response-received event", event?.detail);
      });
      if (widget) {
        widget.addEventListener("chat-messenger-error-v2", (event) => {
          addLifecycleEvent("chat-messenger-error-v2 event", event?.detail);
        });
        widget.addEventListener("chat-messenger-error", (event) => {
          addLifecycleEvent("chat-messenger-error event", event?.detail);
        });
      }
      window.addEventListener("vox-ces-register", (event) => {
        debugState.voxCesRegister = true;
        const detail = event?.detail || {};
        renderDebug();
        if (detail.widgetId !== "ces-demo-widget") return;
        if (detail.success) observeReadiness();
      });
      window.addEventListener(
        "chat-messenger-loaded",
        () => {
          debugState.chatMessengerLoaded = true;
          renderDebug();
          observeReadiness();
        },
        { once: true },
      );
      window.addEventListener(
        "ces-messenger-connected",
        () => {
          debugState.cesMessengerConnected = true;
          renderDebug();
          observeReadiness();
        },
        { once: true },
      );
      observeReadiness();
    })();
  </script>
</BaseLayout>
