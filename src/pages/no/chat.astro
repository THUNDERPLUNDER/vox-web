---
/* CONTRACT: Demo chat surface with product-owned frame and stable CES engine as the only visible conversation mode. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/nav/Footer.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const seed = Astro.url.searchParams.get("seed")?.trim();
const from = Astro.url.searchParams.get("from")?.trim();
---

<BaseLayout title="VOX - Hørehjelpen samtale" currentPath="/no/chat">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="relative pb-8 sm:pb-10">
    <Section class="!pt-4 !pb-8 sm:!pb-10">
      <div class="mx-auto max-w-[920px] space-y-4">
        <div>
          <h1 class="font-display text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl">Her starter samtalen</h1>
          <p class="mt-3 max-w-2xl text-sm leading-relaxed text-[rgb(var(--muted))]">
            Ta ett steg om gangen. Skriv selv, eller fortsett fra spørsmålet du valgte.
          </p>
          {seed ? (
            <div class="mt-3 rounded-[var(--radius-sm)] border border-[rgb(var(--border))] bg-[rgb(var(--surface))/0.65] px-3 py-2">
              <p class="text-[11px] uppercase tracking-wide text-[rgb(var(--muted))]">Valgt startspørsmål</p>
              <p class="mt-1 text-sm text-[rgb(var(--text))]">{seed}</p>
              <p id="seed-sync-status" class="mt-1 text-xs text-[rgb(var(--muted))]">
                {from ? `Hentet fra ${from === "article" ? "artikkel" : "hub"}.` : "Klargjør samtalestart ..."}
              </p>
            </div>
          ) : null}
        </div>

        <div class="rounded-[var(--radius-lg)] border border-[rgb(var(--border))] bg-[rgb(var(--surface-subtle))/0.96] p-2 sm:p-3">
          <chat-messenger
            id="ces-demo-widget"
            url-allowlist="*"
            class="block h-[min(62vh,620px)] w-full overflow-hidden rounded-[var(--radius-md)] bg-[rgb(var(--surface-subtle))]"
          >
            <chat-messenger-container
              chat-title="Hørehjelpen"
              enable-file-upload
              enable-audio-input
            ></chat-messenger-container>
          </chat-messenger>
        </div>
      </div>
    </Section>
  </main>

  <Footer />

  <script is:inline define:vars={{ seed }}>
    (() => {
      const widget = document.getElementById("ces-demo-widget");
      const statusEl = document.getElementById("seed-sync-status");
      const initialQuestion = typeof seed === "string" ? seed.trim() : "";
      if (!widget || !initialQuestion) return;

      const sendSeed = () => {
        if (typeof widget.sessionInput !== "function") return false;
        widget.open?.();
        widget.show?.();
        widget.sessionInput(initialQuestion);
        if (statusEl) statusEl.textContent = "Startspørsmål sendt til samtalen.";
        return true;
      };

      if (sendSeed()) return;
      let tries = 0;
      const timer = setInterval(() => {
        tries += 1;
        if (sendSeed() || tries > 40) {
          clearInterval(timer);
          if (tries > 40 && statusEl) {
            statusEl.textContent = "Startspørsmålet er klart over chatten dersom du vil sende det manuelt.";
          }
        }
      }, 250);
    })();
  </script>
</BaseLayout>
