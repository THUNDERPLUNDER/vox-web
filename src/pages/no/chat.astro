---
/* CONTRACT: Demo chat surface with product-owned frame and stable CES engine as the only visible conversation mode. */
import BaseLayout from "../../layouts/BaseLayout.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const exampleQuestions = [
  "Appen finner ikke høreapparatet",
  "Lyden blir slitsom utover dagen",
  "Hvordan kobler jeg høreapparatet til mobilen?",
  "Når bør jeg kontakte audiograf?",
];
---

<BaseLayout title="Viddel - Spør Viddel" currentPath="/no/chat">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="chat-page" data-standalone-chat>
    <div class="chat-container">
      <div class="chat-surface">
        <header class="chat-hero">
          <nav class="chat-breadcrumb" aria-label="Du er her">
            <a href="/no">Forside</a>
            <span aria-hidden="true">/</span>
            <span>Spør Viddel</span>
          </nav>
          <p class="chat-kicker">Direkte spørsmål</p>
          <h1>Spør Viddel</h1>
          <p class="chat-lead">
            Still et spørsmål om høreapparat, app, lyd i hverdagen eller hva du bør prøve videre.
          </p>
        </header>

        <section class="chat-compose-block" aria-label="Still et spørsmål">
          <form class="chat-compose" action="/no/chat" method="get">
            <label class="sr-only" for="chat-compose-input">Skriv spørsmålet ditt</label>
            <div class="chat-compose__input-wrap">
              <input
                id="chat-compose-input"
                type="search"
                name="seed"
                class="chat-compose__input"
                required
                autocomplete="off"
                enterkeyhint="send"
                placeholder="F.eks. piping, Bluetooth, TV-lyd eller når du bør kontakte audiograf..."
              />
            </div>
            <input type="hidden" name="from" value="chat" />
            <button type="submit" class="chat-compose__send" aria-label="Send spørsmål">
              <span aria-hidden="true">↑</span>
            </button>
          </form>

          <div class="chat-examples" aria-label="Eksempelspørsmål">
            <p class="chat-examples__label">Eksempler</p>
            <ul class="chat-examples__list" role="list">
              {exampleQuestions.map((question) => (
                <li>
                  <a class="chat-example-chip" href={`/no/chat?seed=${encodeURIComponent(question)}&from=chat`}>
                    {question}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div id="seed-strip" class="chat-seed-strip hidden">
            <p class="chat-seed-strip__label">Valgt startspørsmål</p>
            <p id="seed-text" class="chat-seed-strip__text"></p>
            <button id="seed-start-button" type="button" class="chat-seed-strip__button">
              Start samtale med dette spørsmålet
            </button>
            <p id="seed-sync-status" class="chat-seed-strip__status"></p>
          </div>
        </section>

        <section class="chat-widget-shell" aria-label="Samtale med Viddel">
          <div class="chat-widget-shell__header">
            <p class="chat-widget-shell__label">Viddel svarer</p>
            <p class="chat-widget-shell__hint">Skriv direkte i chatten, eller start med et av forslagene over.</p>
          </div>
          <div class="vox-surface-embedded-app chat-widget-frame" data-kl-surface="embedded-app">
            <chat-messenger id="ces-demo-widget" url-allowlist="*" class="chat-widget">
              <chat-messenger-container chat-title="Viddel" enable-file-upload enable-audio-input></chat-messenger-container>
            </chat-messenger>
          </div>
        </section>

        <p class="chat-safety-note">
          Viddel gir generell støtte og kan ikke erstatte råd fra audiograf eller helsepersonell.
        </p>

        <div id="no-chat-debug-panel" class="chat-debug-panel hidden">
          <p class="chat-debug-panel__title">No chat debug</p>
          <pre id="no-chat-debug-output" class="chat-debug-panel__output"></pre>
          <div class="chat-debug-panel__report">
            <div class="chat-debug-panel__report-head">
              <p class="chat-debug-panel__title">Kopierbar status</p>
              <button id="no-chat-debug-copy" type="button" class="chat-debug-panel__copy">
                Kopier debugstatus
              </button>
            </div>
            <textarea id="no-chat-debug-report" class="chat-debug-panel__textarea" readonly></textarea>
            <p id="no-chat-debug-copy-status" class="chat-debug-panel__copy-status"></p>
          </div>
        </div>
        <div class="chat-debug-toggle-row">
          <button id="no-chat-debug-toggle" type="button" class="chat-debug-toggle" aria-pressed="false">
            Debug
          </button>
        </div>
      </div>
    </div>
  </main>

  <style>
    .chat-page {
      background: rgb(var(--article-page-canvas));
      padding: 0.5rem 0 clamp(3rem, 6vw, 4rem);
    }

    @media (min-width: 640px) {
      .chat-page {
        padding-top: 0.75rem;
      }
    }

    .chat-container {
      margin: 0 auto;
      padding: 0 1rem;
    }

    @media (min-width: 640px) {
      .chat-container {
        padding-inline: 1.5rem;
      }
    }

    .chat-surface {
      max-width: min(100%, 52rem);
      margin: 0 auto;
      background: rgb(var(--reading-paper));
      border-radius: var(--radius-md);
      padding: 2.25rem 1.15rem;
      color: rgb(var(--reading-ink));
    }

    @media (min-width: 640px) {
      .chat-surface {
        padding: 3rem 2.5rem;
      }
    }

    .chat-hero {
      padding-bottom: clamp(1rem, 2.5vw, 1.25rem);
      border-bottom: 1px solid rgb(var(--border) / 0.16);
    }

    .chat-breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      margin-bottom: 0.85rem;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgb(var(--reading-ink-secondary) / 0.6);
    }

    .chat-breadcrumb a {
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .chat-kicker,
    .chat-widget-shell__label,
    .chat-examples__label,
    .chat-seed-strip__label {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 750;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgb(var(--reading-ink-secondary));
    }

    [data-standalone-chat] h1 {
      margin: 0.45rem 0 0;
      font-family: var(--font-display);
      font-size: clamp(2.05rem, 6vw, 3rem);
      font-weight: 650;
      line-height: 1.02;
      letter-spacing: -0.058em;
      text-wrap: balance;
      color: rgb(var(--reading-ink));
    }

    .chat-lead {
      margin: 0.8rem 0 0;
      max-width: 38rem;
      font-size: clamp(0.95rem, 2.2vw, 1.04rem);
      line-height: 1.55;
      color: rgb(var(--reading-ink-secondary));
    }

    .chat-compose-block {
      padding: clamp(1.1rem, 2.8vw, 1.4rem) 0 0;
    }

    .chat-compose {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: flex-end;
      gap: 0.55rem;
      padding: 0.62rem;
      border: 1px solid rgb(var(--border) / 0.42);
      border-radius: 1.15rem;
      background: rgb(var(--reading-paper));
      box-shadow: 0 10px 30px rgb(var(--reading-ink) / 0.035);
      transition:
        border-color 150ms ease,
        box-shadow 150ms ease;
    }

    .chat-compose:focus-within {
      border-color: rgb(var(--border) / 0.68);
      box-shadow: 0 0 0 3px rgb(14 165 233 / 0.14), 0 10px 30px rgb(var(--reading-ink) / 0.045);
    }

    .chat-compose__input-wrap {
      min-width: 0;
    }

    .chat-compose__input {
      width: 100%;
      min-height: 3rem;
      padding: 0.5rem 0.4rem;
      border: 0;
      background: transparent;
      color: rgb(var(--reading-ink));
      font: inherit;
      font-size: 0.95rem;
      line-height: 1.45;
      outline: 0;
    }

    .chat-compose__input::placeholder {
      color: rgb(var(--reading-ink-secondary) / 0.7);
    }

    .chat-compose__send,
    .chat-seed-strip__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 0;
      background: rgb(var(--reading-ink));
      color: rgb(var(--reading-paper));
      font-weight: 700;
      cursor: pointer;
      transition: opacity 150ms ease;
    }

    .chat-compose__send {
      width: 2.85rem;
      height: 2.85rem;
      min-height: 2.85rem;
      padding: 0;
      border-radius: 999px;
      font-size: 1.02rem;
      line-height: 1;
    }

    .chat-compose__send:hover,
    .chat-seed-strip__button:hover {
      opacity: 0.9;
    }

    .chat-compose__send:focus-visible,
    .chat-seed-strip__button:focus-visible,
    .chat-example-chip:focus-visible,
    .chat-debug-toggle:focus-visible,
    .chat-debug-panel__copy:focus-visible {
      outline: 2px solid rgb(14 165 233 / 0.42);
      outline-offset: 3px;
    }

    .chat-examples {
      margin-top: 1rem;
    }

    .chat-examples__list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 0.55rem 0 0;
      padding: 0;
      list-style: none;
    }

    .chat-example-chip {
      display: inline-flex;
      align-items: center;
      min-height: 2.25rem;
      padding: 0.52rem 0.78rem;
      border: 1px solid rgb(var(--border) / 0.28);
      border-radius: 999px;
      background: rgb(var(--reading-paper));
      color: rgb(var(--reading-ink-secondary));
      font-size: 0.82rem;
      font-weight: 600;
      line-height: 1.25;
      text-decoration: none;
      transition:
        border-color 150ms ease,
        color 150ms ease,
        transform 150ms ease,
        box-shadow 150ms ease;
    }

    .chat-example-chip:hover {
      border-color: rgb(var(--border) / 0.46);
      color: rgb(var(--reading-ink));
      box-shadow: 0 8px 22px rgb(var(--reading-ink) / 0.045);
      transform: translateY(-1px);
    }

    .chat-seed-strip {
      margin-top: 1rem;
      padding: 0.85rem 0.95rem;
      border: 1px solid rgb(var(--border) / 0.2);
      border-radius: 0.9rem;
      background: rgb(var(--surface-subtle));
    }

    .chat-seed-strip__text {
      margin: 0.35rem 0 0;
      font-size: 0.92rem;
      line-height: 1.45;
      color: rgb(var(--reading-ink));
    }

    .chat-seed-strip__button {
      margin-top: 0.75rem;
      min-height: 2.3rem;
      padding: 0.58rem 0.9rem;
      border-radius: 999px;
      font-size: 0.8rem;
    }

    .chat-seed-strip__button:disabled {
      cursor: not-allowed;
      opacity: 0.5;
    }

    .chat-seed-strip__status {
      margin: 0.45rem 0 0;
      font-size: 0.78rem;
      line-height: 1.4;
      color: rgb(var(--reading-ink-secondary));
    }

    .chat-widget-shell {
      margin-top: clamp(1.5rem, 3.5vw, 2rem);
      padding: 1rem;
      border: 1px solid rgb(var(--border) / 0.18);
      border-radius: 1.25rem;
      background: rgb(var(--reading-paper));
      box-shadow: 0 16px 40px rgb(var(--reading-ink) / 0.055);
    }

    @media (min-width: 640px) {
      .chat-widget-shell {
        padding: 1.15rem;
      }
    }

    .chat-widget-shell__header {
      display: flex;
      flex-direction: column;
      gap: 0.28rem;
      padding: 0.1rem 0.1rem 0.85rem;
    }

    @media (min-width: 640px) {
      .chat-widget-shell__header {
        flex-direction: row;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
      }
    }

    .chat-widget-shell__hint {
      margin: 0;
      font-size: 0.82rem;
      line-height: 1.4;
      color: rgb(var(--reading-ink-secondary));
    }

    .chat-widget-frame {
      overflow: hidden;
      border: 1px solid rgb(var(--border) / 0.12);
      border-radius: 1rem;
      background: rgb(var(--surface-subtle));
    }

    .chat-widget {
      display: block;
      width: 100%;
      height: min(68vh, 660px);
      min-height: 520px;
      overflow: hidden;
      background: rgb(var(--surface-subtle));
    }

    .chat-safety-note {
      margin: 1rem 0 0;
      max-width: 42rem;
      font-size: 0.78rem;
      line-height: 1.5;
      color: rgb(var(--reading-ink-secondary));
    }

    .chat-debug-panel {
      margin-top: 1rem;
      border: 1px solid rgb(var(--border));
      background: rgb(var(--surface-subtle));
      padding: 0.9rem;
      font-size: 0.75rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .chat-debug-panel__title {
      margin: 0 0 0.5rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgb(var(--reading-ink));
    }

    .chat-debug-panel__output {
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      font-family: var(--font-mono, monospace);
      line-height: 1.55;
    }

    .chat-debug-panel__report {
      margin-top: 0.85rem;
      border-top: 1px solid rgb(var(--border));
      padding-top: 0.85rem;
    }

    .chat-debug-panel__report-head {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      margin-bottom: 0.55rem;
    }

    .chat-debug-panel__copy,
    .chat-debug-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgb(var(--border));
      background: rgb(var(--reading-paper));
      color: rgb(var(--reading-ink-secondary));
      font-size: 0.72rem;
      font-weight: 700;
    }

    .chat-debug-panel__copy {
      padding: 0.34rem 0.6rem;
    }

    .chat-debug-panel__textarea {
      min-height: 180px;
      width: 100%;
      resize: vertical;
      border: 1px solid rgb(var(--border));
      background: rgb(var(--reading-paper));
      padding: 0.5rem;
      font-family: var(--font-mono, monospace);
      font-size: 0.7rem;
      line-height: 1.55;
      color: rgb(var(--reading-ink));
    }

    .chat-debug-panel__copy-status {
      margin: 0.35rem 0 0;
      font-size: 0.7rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .chat-debug-toggle-row {
      display: flex;
      justify-content: flex-end;
      margin-top: 0.7rem;
    }

    .chat-debug-toggle {
      padding: 0.34rem 0.62rem;
    }
  </style>

  <script is:inline>
    (() => {
      const widget = document.getElementById("ces-demo-widget");
      const seedStrip = document.getElementById("seed-strip");
      const seedTextEl = document.getElementById("seed-text");
      const seedStartBtn = document.getElementById("seed-start-button");
      const statusEl = document.getElementById("seed-sync-status");
      const params = new URLSearchParams(window.location.search);
      const initialQuestion = (params.get("seed") || "").trim();
      const from = (params.get("from") || "").trim();
      let debugEnabled = params.get("debug") === "1";
      const debugPanel = document.getElementById("no-chat-debug-panel");
      const debugOutput = document.getElementById("no-chat-debug-output");
      const debugToggleBtn = document.getElementById("no-chat-debug-toggle");
      const debugReportEl = document.getElementById("no-chat-debug-report");
      const debugCopyBtn = document.getElementById("no-chat-debug-copy");
      const debugCopyStatus = document.getElementById("no-chat-debug-copy-status");
      const debugState = {
        widgetExists: false,
        tagName: "(missing)",
        nodeName: "(missing)",
        sessionInputType: "undefined",
        sendQueryType: "undefined",
        renderCustomTextType: "undefined",
        startNewSessionType: "undefined",
        customElementDefined: false,
        chatMessengerLoaded: false,
        voxCesRegister: false,
        cesMessengerConnected: false,
        readinessPolls: 0,
        startNewSessionCalled: false,
        startNewSessionResult: "",
        startNewSessionError: "",
        sendQueryCalled: false,
        sendQueryResult: "",
        sendQueryError: "",
        cooldownUsed: false,
        cooldownMsWaited: 0,
        lastSeedSendAt: "",
        lastCesErrorAt: "",
        lastCesErrorTimeMs: 0,
        lastCesErrorMessage: "",
        lastCesErrorStatus: "",
        lastResponseReceivedAt: "",
        lastResponseReceivedTimeMs: 0,
        responseReceivedAfterError: false,
        msFromErrorToResponse: "",
        lastSeedStatus: "Script startet.",
        lifecycleEvents: [],
      };
      const seedCooldownMs = 6000;
      const seedCooldownKey = "vox:no-chat:last-seed-send-at";

      const stringifyDebugPayload = (payload) => {
        if (payload === undefined) return "";
        if (payload === null) return "null";
        if (typeof payload === "string") return payload;
        try {
          return JSON.stringify(payload);
        } catch (error) {
          try {
            return String(payload);
          } catch {
            return "[unserializable payload]";
          }
        }
      };

      const addLifecycleEvent = (name, payload) => {
        const time = new Date().toISOString();
        const detail = stringifyDebugPayload(payload);
        debugState.lifecycleEvents = [
          ...debugState.lifecycleEvents,
          detail ? `${time} ${name} ${detail}` : `${time} ${name}`,
        ].slice(-24);
        renderDebug();
      };

      const updateDebugState = () => {
        const currentWidget = document.getElementById("ces-demo-widget");
        debugState.widgetExists = Boolean(currentWidget);
        debugState.tagName = currentWidget?.tagName || "(missing)";
        debugState.nodeName = currentWidget?.nodeName || "(missing)";
        debugState.sessionInputType = typeof currentWidget?.sessionInput;
        debugState.sendQueryType = typeof currentWidget?.sendQuery;
        debugState.renderCustomTextType = typeof currentWidget?.renderCustomText;
        debugState.startNewSessionType = typeof currentWidget?.startNewSession;
        debugState.customElementDefined = Boolean(window.customElements?.get("chat-messenger"));
      };

      const getLastSeedSendAt = () => {
        try {
          return Number(window.sessionStorage.getItem(seedCooldownKey) || "0") || 0;
        } catch {
          return 0;
        }
      };

      const setLastSeedSendAt = (value) => {
        try {
          window.sessionStorage.setItem(seedCooldownKey, String(value));
        } catch {
          // Ignore storage failures; cooldown is a best-effort CES throttle.
        }
        debugState.lastSeedSendAt = value ? new Date(value).toISOString() : "";
      };

      const updateDebugToggle = () => {
        if (!debugToggleBtn) return;
        debugToggleBtn.setAttribute("aria-pressed", debugEnabled ? "true" : "false");
        debugToggleBtn.classList.toggle("text-[rgb(var(--text))]", debugEnabled);
        debugToggleBtn.classList.toggle("text-[rgb(var(--muted))]", !debugEnabled);
        debugToggleBtn.classList.toggle("bg-[rgb(var(--surface-subtle))]", debugEnabled);
      };

      const buildDebugReport = () => [
        `current URL: ${window.location.href}`,
        `seed: ${initialQuestion || "(none)"}`,
        `tidspunkt: ${new Date().toISOString()}`,
        `typeof widget.sendQuery: ${debugState.sendQueryType}`,
        `typeof widget.startNewSession: ${debugState.startNewSessionType}`,
        `startNewSession kalt: ${debugState.startNewSessionCalled}`,
        `startNewSession result: ${debugState.startNewSessionResult || "(none)"}`,
        `startNewSession error: ${debugState.startNewSessionError || "(none)"}`,
        `sendQuery kalt: ${debugState.sendQueryCalled}`,
        `sendQuery result: ${debugState.sendQueryResult || "(none)"}`,
        `sendQuery error: ${debugState.sendQueryError || "(none)"}`,
        `cooldown brukt: ${debugState.cooldownUsed}`,
        `cooldown ms ventet: ${debugState.cooldownMsWaited}`,
        `last seed send timestamp: ${debugState.lastSeedSendAt || "(none)"}`,
        `last CES error at: ${debugState.lastCesErrorAt || "(none)"}`,
        `last CES error message: ${debugState.lastCesErrorMessage || "(none)"}`,
        `last CES error status: ${debugState.lastCesErrorStatus || "(none)"}`,
        `last response received at: ${debugState.lastResponseReceivedAt || "(none)"}`,
        `response received after error: ${debugState.responseReceivedAfterError}`,
        `ms from error to response: ${debugState.msFromErrorToResponse || "(none)"}`,
        `siste seed-status: ${debugState.lastSeedStatus}`,
        "",
        "CES lifecycle-logg:",
        ...(debugState.lifecycleEvents.length ? debugState.lifecycleEvents : ["(none)"]),
      ].join("\n");

      const renderDebug = () => {
        updateDebugToggle();
        if (!debugEnabled) {
          if (debugPanel) debugPanel.classList.add("hidden");
          return;
        }
        updateDebugState();
        if (debugPanel) debugPanel.classList.remove("hidden");
        if (debugOutput) {
          debugOutput.textContent = [
            `#ces-demo-widget finnes: ${debugState.widgetExists}`,
            `tagName: ${debugState.tagName}`,
            `nodeName: ${debugState.nodeName}`,
            `typeof widget.sessionInput: ${debugState.sessionInputType}`,
            `typeof widget.sendQuery: ${debugState.sendQueryType}`,
            `typeof widget.renderCustomText: ${debugState.renderCustomTextType}`,
            `typeof widget.startNewSession: ${debugState.startNewSessionType}`,
            `customElements.get("chat-messenger"): ${debugState.customElementDefined}`,
            `chat-messenger-loaded mottatt: ${debugState.chatMessengerLoaded}`,
            `vox-ces-register mottatt: ${debugState.voxCesRegister}`,
            `ces-messenger-connected mottatt: ${debugState.cesMessengerConnected}`,
            `readiness polling ticks: ${debugState.readinessPolls}`,
            `startNewSession kalt: ${debugState.startNewSessionCalled}`,
            `startNewSession result: ${debugState.startNewSessionResult || "(none)"}`,
            `startNewSession error: ${debugState.startNewSessionError || "(none)"}`,
            `sendQuery kalt: ${debugState.sendQueryCalled}`,
            `sendQuery result: ${debugState.sendQueryResult || "(none)"}`,
            `sendQuery error: ${debugState.sendQueryError || "(none)"}`,
            `cooldown brukt: ${debugState.cooldownUsed}`,
            `cooldown ms ventet: ${debugState.cooldownMsWaited}`,
            `last seed send timestamp: ${debugState.lastSeedSendAt || "(none)"}`,
            `last CES error at: ${debugState.lastCesErrorAt || "(none)"}`,
            `last CES error message: ${debugState.lastCesErrorMessage || "(none)"}`,
            `last CES error status: ${debugState.lastCesErrorStatus || "(none)"}`,
            `last response received at: ${debugState.lastResponseReceivedAt || "(none)"}`,
            `response received after error: ${debugState.responseReceivedAfterError}`,
            `ms from error to response: ${debugState.msFromErrorToResponse || "(none)"}`,
            `siste seed-status: ${debugState.lastSeedStatus}`,
            "",
            "CES lifecycle:",
            ...(debugState.lifecycleEvents.length ? debugState.lifecycleEvents : ["(none)"]),
          ].join("\n");
        }
        if (debugReportEl) debugReportEl.value = buildDebugReport();
        window.__voxNoChatDebug = {
          ...debugState,
          refresh: () => {
            renderDebug();
            return window.__voxNoChatDebug;
          },
        };
        console.debug("[vox-no-chat-debug]", { ...debugState });
      };

      const setDebugEnabled = (next) => {
        debugEnabled = next;
        const nextUrl = new URL(window.location.href);
        if (debugEnabled) nextUrl.searchParams.set("debug", "1");
        else nextUrl.searchParams.delete("debug");
        window.history.replaceState({}, "", nextUrl);
        renderDebug();
      };

      if (debugToggleBtn) {
        debugToggleBtn.addEventListener("click", () => setDebugEnabled(!debugEnabled));
      }

      if (debugCopyBtn) {
        debugCopyBtn.addEventListener("click", async () => {
          renderDebug();
          const report = debugReportEl?.value || buildDebugReport();
          try {
            await navigator.clipboard?.writeText(report);
            if (debugCopyStatus) debugCopyStatus.textContent = "Debugstatus kopiert";
          } catch {
            debugReportEl?.focus();
            debugReportEl?.select();
            if (debugCopyStatus) debugCopyStatus.textContent = "Marker teksten manuelt hvis kopiering ikke virker.";
          }
        });
      }

      const setSeedStatus = (text) => {
        debugState.lastSeedStatus = text;
        if (statusEl && initialQuestion) statusEl.textContent = text;
        renderDebug();
      };

      const recordCesError = (detail) => {
        const now = Date.now();
        debugState.lastCesErrorAt = new Date(now).toISOString();
        debugState.lastCesErrorTimeMs = now;
        debugState.lastCesErrorMessage = String(detail?.message || detail?.error?.message || "unknown");
        debugState.lastCesErrorStatus = String(detail?.status ?? detail?.error?.status ?? "unknown");
        debugState.responseReceivedAfterError = false;
        debugState.msFromErrorToResponse = "";
        if (debugState.sendQueryCalled && !debugState.lastResponseReceivedAt) {
          setSeedStatus("Viddel meldte en midlertidig feil, men vi venter fortsatt på svar ...");
        } else {
          renderDebug();
        }
      };

      const recordCesResponse = () => {
        const now = Date.now();
        debugState.lastResponseReceivedAt = new Date(now).toISOString();
        debugState.lastResponseReceivedTimeMs = now;
        if (debugState.lastCesErrorTimeMs && debugState.lastCesErrorTimeMs <= now) {
          debugState.responseReceivedAfterError = true;
          debugState.msFromErrorToResponse = String(now - debugState.lastCesErrorTimeMs);
          setSeedStatus("Svar mottatt etter midlertidig feil.");
          return;
        }
        renderDebug();
      };

      if (seedStrip && initialQuestion) seedStrip.classList.remove("hidden");
      if (seedTextEl) seedTextEl.textContent = initialQuestion;
      if (seedStartBtn && initialQuestion) seedStartBtn.setAttribute("disabled", "");
      if (statusEl && initialQuestion) {
        const sourceLabel = from === "article" ? "artikkel" : from === "hjelp" ? "hjelp" : "Spør Viddel";
        setSeedStatus(from ? `Hentet fra ${sourceLabel}. Kobler til Viddel ...` : "Kobler til Viddel ...");
      }
      renderDebug();

      let isSending = false;
      let sendQueryReadyAt = 0;
      let seedSessionReset = false;
      const sendQueryStabilizeMs = 700;
      const seedSessionTokenTimeoutMs = 3500;

      const hasSendQuery = () => typeof widget?.sendQuery === "function";

      const markReady = () => {
        renderDebug();
        if (!widget) return false;
        if (!hasSendQuery()) return false;
        if (!sendQueryReadyAt) sendQueryReadyAt = Date.now();
        // The hosted widget can expose sendQuery before its session is settled.
        if (Date.now() - sendQueryReadyAt < sendQueryStabilizeMs) return false;
        if (!isSending && seedStartBtn) seedStartBtn.removeAttribute("disabled");
        if (!isSending) setSeedStatus("Klar til å starte");
        return true;
      };

      const observeReadiness = () => {
        if (markReady()) return;
        let tries = 0;
        const timer = setInterval(() => {
          tries += 1;
          debugState.readinessPolls += 1;
          if (markReady() || tries > 120) clearInterval(timer);
        }, 250);
      };

      const waitForSeedCooldown = async () => {
        const lastSendAt = getLastSeedSendAt();
        debugState.lastSeedSendAt = lastSendAt ? new Date(lastSendAt).toISOString() : "";
        const elapsed = lastSendAt ? Date.now() - lastSendAt : seedCooldownMs;
        const waitMs = Math.max(0, seedCooldownMs - elapsed);
        debugState.cooldownUsed = waitMs > 0;
        debugState.cooldownMsWaited = waitMs;
        renderDebug();
        if (!waitMs) return;
        setSeedStatus("Klargjør ny samtale ...");
        addLifecycleEvent("seed cooldown wait", { waitMs });
        await new Promise((resolve) => setTimeout(resolve, waitMs));
      };

      const resetSeedSession = async () => {
        if (seedSessionReset) return;
        seedSessionReset = true;
        if (typeof widget?.startNewSession !== "function") return;
        debugState.startNewSessionCalled = true;
        debugState.startNewSessionResult = "";
        debugState.startNewSessionError = "";
        addLifecycleEvent("reset/startNewSession called");
        renderDebug();
        const tokenReady = new Promise((resolve) => {
          const timer = setTimeout(() => {
            window.removeEventListener("chat-messenger-access-token-resolved", onTokenResolved);
            resolve("timeout");
          }, seedSessionTokenTimeoutMs);
          function onTokenResolved() {
            clearTimeout(timer);
            resolve("access-token-resolved");
          }
          window.addEventListener("chat-messenger-access-token-resolved", onTokenResolved, { once: true });
        });
        try {
          widget.startNewSession();
          debugState.startNewSessionResult = await tokenReady;
          renderDebug();
        } catch (error) {
          debugState.startNewSessionError = String(error?.message || error || "unknown");
          renderDebug();
        }
      };

      const sendSeed = async () => {
        if (!widget || !initialQuestion) return false;
        if (!hasSendQuery()) return false;
        await waitForSeedCooldown();
        await resetSeedSession();
        debugState.sendQueryCalled = true;
        debugState.sendQueryResult = "";
        debugState.sendQueryError = "";
        addLifecycleEvent("sendQuery called", { seedLength: initialQuestion.length });
        renderDebug();
        setLastSeedSendAt(Date.now());
        const result = await widget.sendQuery(initialQuestion);
        debugState.sendQueryResult = result === undefined ? "resolved: undefined" : `resolved: ${String(result)}`;
        addLifecycleEvent("sendQuery resolved", { result: debugState.sendQueryResult });
        setSeedStatus("Spørsmålet er sendt");
        isSending = false;
        return true;
      };

      const sendSeedWithRetry = async () => {
        isSending = true;
        if (seedStartBtn) seedStartBtn.setAttribute("disabled", "");
        setSeedStatus("Sender spørsmålet til Viddel ...");
        try {
          if (await sendSeed()) return;
        } catch (error) {
          console.error("chat-messenger-error", error);
          debugState.sendQueryResult = "rejected";
          debugState.sendQueryError = String(error?.message || error || "unknown");
          addLifecycleEvent("sendQuery rejected", { error: debugState.sendQueryError });
          isSending = false;
          setSeedStatus("Kunne ikke sende spørsmålet akkurat nå. Prøv igjen.");
          if (seedStartBtn) seedStartBtn.removeAttribute("disabled");
          return;
        }
        let tries = 0;
        const timer = setInterval(async () => {
          tries += 1;
          debugState.readinessPolls += 1;
          if (hasSendQuery()) {
            clearInterval(timer);
            try {
              await sendSeed();
            } catch (error) {
              console.error("chat-messenger-error", error);
              debugState.sendQueryResult = "rejected";
              debugState.sendQueryError = String(error?.message || error || "unknown");
              addLifecycleEvent("sendQuery rejected", { error: debugState.sendQueryError });
              isSending = false;
              setSeedStatus("Kunne ikke sende spørsmålet akkurat nå. Prøv igjen.");
              if (seedStartBtn) seedStartBtn.removeAttribute("disabled");
            }
            return;
          }
          if (tries > 120) {
            clearInterval(timer);
            isSending = false;
            setSeedStatus("Kunne ikke sende spørsmålet akkurat nå. Prøv igjen.");
            if (seedStartBtn) seedStartBtn.removeAttribute("disabled");
          }
        }, 250);
      };

      if (seedStartBtn) {
        seedStartBtn.addEventListener("click", sendSeedWithRetry);
      }
      window.addEventListener("chat-messenger-start-new-session", (event) => {
        addLifecycleEvent("chat-messenger-start-new-session event", event?.detail);
      });
      window.addEventListener("chat-messenger-access-token-resolved", (event) => {
        addLifecycleEvent("chat-messenger-access-token-resolved event", event?.detail);
      });
      window.addEventListener("chat-messenger-response-received", (event) => {
        recordCesResponse();
        addLifecycleEvent("chat-messenger-response-received event", event?.detail);
      });
      if (widget) {
        widget.addEventListener("chat-messenger-error-v2", (event) => {
          recordCesError(event?.detail || {});
          addLifecycleEvent("chat-messenger-error-v2 event", event?.detail);
        });
        widget.addEventListener("chat-messenger-error", (event) => {
          addLifecycleEvent("chat-messenger-error event", event?.detail);
        });
      }
      window.addEventListener("vox-ces-register", (event) => {
        debugState.voxCesRegister = true;
        const detail = event?.detail || {};
        renderDebug();
        if (detail.widgetId !== "ces-demo-widget") return;
        if (detail.success) observeReadiness();
      });
      window.addEventListener(
        "chat-messenger-loaded",
        () => {
          debugState.chatMessengerLoaded = true;
          renderDebug();
          observeReadiness();
        },
        { once: true },
      );
      window.addEventListener(
        "ces-messenger-connected",
        () => {
          debugState.cesMessengerConnected = true;
          renderDebug();
          observeReadiness();
        },
        { once: true },
      );
      observeReadiness();
    })();
  </script>
</BaseLayout>
