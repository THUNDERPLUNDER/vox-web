---
/* CONTRACT: Standalone Viddel AI chat — headless CES via /api/chat, no widget. #125M-C R1 */
import BaseLayout from "../../layouts/BaseLayout.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const exampleQuestions = [
  "Hvordan kobler jeg høreapparatet til mobilen?",
  "Hvorfor blir lyden så slitsom på restaurant?",
  "Hva gjør jeg når appen ikke finner høreapparatet?",
  "Hvordan vet jeg om jeg bør kontakte audiograf?",
  "Hva kan jeg prøve hvis lyden fra TV-en blir utydelig?",
];
---

<BaseLayout
  title="Viddel - Spør Viddel"
  currentPath="/no/chat"
  headerBrand="viddel"
  shellVariant="standalone-chat"
  showHeaderDevtoolsToggle={false}
>
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="viddel-chat" data-viddel-chat data-state="idle">
    <div class="viddel-chat__inner">
      <section class="viddel-chat__intro" data-viddel-chat-intro aria-labelledby="viddel-chat-title">
        <h1 id="viddel-chat-title" class="viddel-chat__title">Spør Viddel</h1>
        <p class="viddel-chat__lede">
          Spør om høreapparat, app, lyd, innstillinger eller situasjoner i hverdagen. Viddel svarer best når du
          beskriver hva du prøver å få til.
        </p>

        <ul class="viddel-chat__examples" role="list" data-viddel-chat-examples>
          {
            exampleQuestions.map((question) => (
              <li>
                <button type="button" class="viddel-chat__example" data-viddel-chat-example={question}>
                  {question}
                </button>
              </li>
            ))
          }
        </ul>

        <p class="viddel-chat__safety">
          Viddel kan gi praktiske forslag og hjelpe deg å finne neste steg. Ved medisinske spørsmål eller vedvarende
          problemer bør du kontakte audiograf eller annet helsepersonell.
        </p>
      </section>

      <div class="viddel-chat__transcript-wrap hidden" data-viddel-chat-transcript-wrap>
        <div class="viddel-chat__transcript" data-viddel-chat-transcript role="log" aria-live="polite" aria-relevant="additions text"></div>
      </div>

      <p class="viddel-chat__status hidden" data-viddel-chat-loading role="status">Viddel svarer …</p>
      <p class="viddel-chat__error hidden" data-viddel-chat-error role="alert"></p>

      <form class="viddel-chat__compose" data-viddel-chat-form>
        <label for="viddel-chat-input" class="sr-only">Skriv spørsmål til Viddel</label>
        <div class="viddel-chat__compose-row">
          <textarea
            id="viddel-chat-input"
            data-viddel-chat-input
            rows="1"
            placeholder="Beskriv situasjonen eller spørsmålet ditt …"
            class="viddel-chat__input"
          ></textarea>
          <button type="submit" class="viddel-chat__send" data-viddel-chat-send aria-label="Send spørsmål">
            <span aria-hidden="true">↑</span>
          </button>
        </div>
      </form>
    </div>
  </main>

  <style is:global>
    body.vox-shell--standalone-chat {
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
    }

    @media (max-width: 639px) {
      body.vox-shell--standalone-chat {
        height: 100dvh;
        overflow: hidden;
      }

      body.vox-shell--standalone-chat .vox-shell-standalone-chat__stage {
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden;
      }
    }

    @media (min-width: 640px) {
      body.vox-shell--standalone-chat .vox-shell-standalone-chat__stage {
        max-width: 42rem;
      }
    }
  </style>

  <style>
    .viddel-chat {
      display: flex;
      flex: 1 1 auto;
      flex-direction: column;
      min-height: 0;
      width: 100%;
    }

    .viddel-chat__inner {
      display: flex;
      flex: 1 1 auto;
      flex-direction: column;
      gap: 0.85rem;
      min-height: 0;
      width: 100%;
    }

    @media (max-width: 639px) {
      .viddel-chat {
        height: 100%;
        min-height: 0;
        padding-bottom: max(0.5rem, env(safe-area-inset-bottom, 0px));
      }

      .viddel-chat__transcript-wrap:not(.hidden) {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        overscroll-behavior: contain;
        -webkit-overflow-scrolling: touch;
      }

      .viddel-chat__compose {
        flex-shrink: 0;
        margin-top: auto;
      }
    }

    @media (min-width: 640px) {
      .viddel-chat {
        padding-bottom: 2rem;
      }

      .viddel-chat__inner {
        gap: 1.25rem;
      }
    }

    .viddel-chat__title {
      font-family: var(--font-display, inherit);
      font-size: clamp(1.65rem, 4vw, 2.15rem);
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: 1.15;
      color: rgb(var(--text));
    }

    .viddel-chat__lede {
      margin-top: 0.65rem;
      max-width: 36rem;
      font-size: 0.95rem;
      line-height: 1.55;
      color: rgb(var(--muted));
    }

    .viddel-chat__examples {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      margin-top: 1.1rem;
    }

    .viddel-chat__example {
      width: 100%;
      border: 1px solid rgb(var(--border) / 0.5);
      border-radius: var(--radius-md);
      background: rgb(var(--surface));
      padding: 0.72rem 0.85rem;
      text-align: left;
      font-size: 0.9rem;
      line-height: 1.45;
      color: rgb(var(--text));
      transition:
        border-color 0.15s ease,
        box-shadow 0.15s ease;
    }

    .viddel-chat__example:hover {
      border-color: rgb(var(--border) / 0.75);
      box-shadow: var(--shadow-sm);
    }

    .viddel-chat__example:focus-visible {
      outline: 2px solid rgb(var(--focus-ring) / 0.5);
      outline-offset: 2px;
    }

    .viddel-chat__safety {
      margin-top: 1rem;
      max-width: 36rem;
      font-size: 0.78rem;
      line-height: 1.5;
      color: rgb(var(--muted));
    }

    .viddel-chat__transcript-wrap.hidden,
    .viddel-chat__status.hidden,
    .viddel-chat__error.hidden,
    .viddel-chat__intro.hidden {
      display: none;
    }

    .viddel-chat__transcript {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      padding: 0.15rem 0 0.5rem;
    }

    .viddel-chat__bubble {
      max-width: min(100%, 34rem);
      border-radius: var(--radius-md);
      padding: 0.72rem 0.85rem;
      font-size: 0.94rem;
      line-height: 1.55;
      white-space: pre-wrap;
    }

    .viddel-chat__bubble--user {
      margin-left: auto;
      background: rgb(var(--text));
      color: rgb(var(--surface));
    }

    .viddel-chat__bubble--assistant {
      border: 1px solid rgb(var(--border) / 0.45);
      background: rgb(var(--surface));
      color: rgb(var(--text));
    }

    .viddel-chat__bubble-label {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.72;
    }

    .viddel-chat__status {
      font-size: 0.82rem;
      color: rgb(var(--muted));
    }

    .viddel-chat__error {
      font-size: 0.82rem;
      color: rgb(var(--text));
    }

    .viddel-chat__compose {
      margin-top: 0.35rem;
    }

    .viddel-chat[data-state="active"] .viddel-chat__compose {
      margin-top: 0;
    }

    .viddel-chat__compose-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.55rem;
      align-items: flex-end;
      border: 1px solid rgb(var(--border) / 0.55);
      border-radius: 1rem;
      background: rgb(var(--surface));
      padding: 0.45rem 0.45rem 0.45rem 0.65rem;
      box-shadow: var(--shadow-sm);
    }

    .viddel-chat__input {
      width: 100%;
      min-height: 2.75rem;
      max-height: min(9rem, 32vh);
      resize: none;
      border: 0;
      background: transparent;
      font: inherit;
      font-size: 0.95rem;
      line-height: 1.45;
      color: rgb(var(--text));
      outline: 0;
    }

    .viddel-chat__input::placeholder {
      color: rgb(var(--muted));
    }

    .viddel-chat__send {
      display: inline-flex;
      height: 2.65rem;
      width: 2.65rem;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      border: 0;
      border-radius: 0.85rem;
      background: rgb(var(--text));
      color: rgb(var(--surface));
      font-size: 1.15rem;
      font-weight: 700;
      line-height: 1;
      transition: opacity 0.15s ease;
    }

    .viddel-chat__send:hover:not(:disabled) {
      opacity: 0.9;
    }

    .viddel-chat__send:disabled {
      cursor: not-allowed;
      opacity: 0.45;
    }

    .viddel-chat__send:focus-visible {
      outline: 2px solid rgb(var(--focus-ring) / 0.5);
      outline-offset: 2px;
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-viddel-chat]");
      const intro = document.querySelector("[data-viddel-chat-intro]");
      const transcriptWrap = document.querySelector("[data-viddel-chat-transcript-wrap]");
      const transcript = document.querySelector("[data-viddel-chat-transcript]");
      const loadingEl = document.querySelector("[data-viddel-chat-loading]");
      const errorEl = document.querySelector("[data-viddel-chat-error]");
      const form = document.querySelector("[data-viddel-chat-form]");
      const input = document.querySelector("[data-viddel-chat-input]");
      const sendBtn = document.querySelector("[data-viddel-chat-send]");
      const exampleButtons = document.querySelectorAll("[data-viddel-chat-example]");

      if (!root || !intro || !transcriptWrap || !transcript || !loadingEl || !errorEl || !form || !input || !sendBtn) {
        return;
      }

      const SESSION_KEY = "viddel-chat-session";
      const SESSION_PATTERN = /^[a-zA-Z0-9][a-zA-Z0-9-_]{4,62}$/;
      const params = new URLSearchParams(window.location.search);
      const seedFromUrl = (params.get("seed") || params.get("q") || "").trim();

      let isSending = false;
      let hasConversation = false;
      let pendingSeed = seedFromUrl;

      const ensureSessionId = () => {
        try {
          const existing = sessionStorage.getItem(SESSION_KEY);
          if (existing && SESSION_PATTERN.test(existing)) return existing;
        } catch (_) {}
        const created = `viddel-${crypto.randomUUID().replace(/-/g, "").slice(0, 24)}`;
        try {
          sessionStorage.setItem(SESSION_KEY, created);
        } catch (_) {}
        return created;
      };

      const setState = (state) => {
        root.dataset.state = state;
      };

      const showError = (message) => {
        errorEl.textContent = message;
        errorEl.classList.remove("hidden");
      };

      const clearError = () => {
        errorEl.textContent = "";
        errorEl.classList.add("hidden");
      };

      const setLoading = (active) => {
        loadingEl.classList.toggle("hidden", !active);
      };

      const activateConversation = () => {
        if (hasConversation) return;
        hasConversation = true;
        intro.classList.add("hidden");
        transcriptWrap.classList.remove("hidden");
        setState("active");
      };

      const appendBubble = (role, text) => {
        const bubble = document.createElement("article");
        bubble.className = `viddel-chat__bubble viddel-chat__bubble--${role === "user" ? "user" : "assistant"}`;
        const label = document.createElement("span");
        label.className = "viddel-chat__bubble-label";
        label.textContent = role === "user" ? "Du" : "Viddel";
        const body = document.createElement("p");
        body.className = "m-0";
        body.textContent = text;
        bubble.append(label, body);
        transcript.append(bubble);
        bubble.scrollIntoView({ behavior: "smooth", block: "nearest" });
      };

      const friendlyError = (payload) => {
        if (payload?.error === "configuration_missing") {
          return "Viddel er ikke tilgjengelig akkurat nå. Prøv igjen om litt.";
        }
        if (payload?.error === "invalid_message") {
          return "Skriv et spørsmål før du sender.";
        }
        return "Vi fikk ikke tak i svaret akkurat nå. Prøv igjen.";
      };

      const sendMessage = async (rawMessage) => {
        const message = (rawMessage || "").trim();
        if (!message || isSending) return;

        clearError();
        activateConversation();
        appendBubble("user", message);
        input.value = "";
        isSending = true;
        sendBtn.disabled = true;
        input.disabled = true;
        setLoading(true);

        try {
          const response = await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              message,
              sessionId: ensureSessionId(),
            }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            showError(friendlyError(payload));
            return;
          }

          const text = typeof payload.text === "string" ? payload.text.trim() : "";
          if (!text) {
            showError("Vi fikk ikke tak i svaret akkurat nå. Prøv igjen.");
            return;
          }

          appendBubble("assistant", text);
        } catch (_) {
          showError("Nettverksfeil. Sjekk tilkoblingen og prøv igjen.");
        } finally {
          isSending = false;
          sendBtn.disabled = false;
          input.disabled = false;
          setLoading(false);
          input.focus();
        }
      };

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        sendMessage(input.value);
      });

      input.addEventListener("keydown", (event) => {
        if (event.key === "Enter" && !event.shiftKey) {
          event.preventDefault();
          sendMessage(input.value);
        }
      });

      exampleButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const question = button.getAttribute("data-viddel-chat-example") || "";
          sendMessage(question);
        });
      });

      if (pendingSeed) {
        input.value = pendingSeed;
        window.setTimeout(() => {
          if (pendingSeed) {
            sendMessage(pendingSeed);
            pendingSeed = "";
          }
        }, 120);
      } else {
        input.focus();
      }
    })();
  </script>
</BaseLayout>
