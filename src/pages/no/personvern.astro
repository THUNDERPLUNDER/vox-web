---
/* CONTRACT: Norwegian privacy page with clear, readable MVP privacy framing in VOX style. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/nav/Footer.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
---

<BaseLayout title="VOX - Personvern" currentPath="/no/personvern">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section class="!pt-2 !pb-10 sm:!pt-4 sm:!pb-12">
      <div class="max-w-3xl">
        <div class="vox-surface-calm relative overflow-hidden">
          <div
            class="pointer-events-none absolute -inset-x-2 -top-2 h-16 rounded-[var(--radius-md)] bg-gradient-to-r from-[rgb(var(--accent-gradient-start)/0.14)] to-[rgb(var(--accent-gradient-end)/0.12)] blur-2xl"
            aria-hidden="true"
          ></div>
          <h1
            class="font-display text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl"
          >
            Personvern
          </h1>
          <p class="vox-lead mt-5">
            Vi skal behandle personopplysninger på en trygg, tydelig og ansvarlig måte.
            Denne siden oppsummerer hva som gjelder i MVP-fasen.
          </p>
          <p class="mt-4 text-sm text-[rgb(var(--muted))]">
            Fullstendig personvernerklæring og eventuelle databehandlerdetaljer publiseres
            fortløpende etter hvert som tjenesten utvikles.
          </p>
        </div>
      </div>
    </Section>

    <Section tone="band" class="!py-10 sm:!py-12">
      <div class="max-w-3xl">
        <h2 class="vox-section-title">Kort forklart</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 sm:gap-5">
          <div class="vox-surface-tech">
            <p class="text-sm font-semibold text-[rgb(var(--text))]">Dataminimering</p>
            <p class="mt-1.5 text-sm leading-relaxed text-[rgb(var(--muted))]">
              Vi skal ikke samle inn mer enn det som trengs for å levere tjenesten.
            </p>
          </div>
          <div class="vox-surface-tech">
            <p class="text-sm font-semibold text-[rgb(var(--text))]">Sikker håndtering</p>
            <p class="mt-1.5 text-sm leading-relaxed text-[rgb(var(--muted))]">
              Informasjon behandles med relevante tekniske og organisatoriske tiltak.
            </p>
          </div>
          <div class="vox-surface-tech sm:col-span-2">
            <p class="text-sm font-semibold text-[rgb(var(--text))]">Åpenhet</p>
            <p class="mt-1.5 text-sm leading-relaxed text-[rgb(var(--muted))]">
              Vi oppdaterer denne siden når praksis, verktøy eller datatyper endrer seg.
            </p>
          </div>
        </div>
      </div>
    </Section>

    <Section class="!pt-6 !pb-12 sm:!pt-8 sm:!pb-16">
      <div class="max-w-3xl">
        <div class="vox-surface-lifted">
          <h2 class="vox-section-title text-lg sm:text-xl">Kontakt og innsyn</h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-[rgb(var(--muted))]">
            Har du spørsmål om personvern, kan du bruke kontaktpunktet i tjenesten.
            Vi svarer og følger opp henvendelser etter gjeldende regler.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/no"
              class="sonic-pulse-cta inline-flex items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-semibold transition-shadow"
            >
              Til forsiden
            </a>
            <a
              href="/no/om"
              class="inline-flex items-center justify-center rounded-[var(--radius-md)] border border-[rgb(var(--border))/0.35] bg-[rgb(var(--surface-elevated))/0.6] px-5 py-2.5 text-sm font-medium text-[rgb(var(--text))] backdrop-blur-sm transition-colors hover:bg-[rgb(var(--surface-elevated))/0.82]"
            >
              Les om VOX
            </a>
          </div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
