---
/* CONTRACT: Norwegian glossary index; curated knowledge entry in Sonic family. */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/layout/Section.astro";
import Footer from "../../../components/nav/Footer.astro";
import { fetchGlossaryTerms, truncateForCard } from "../../../lib/storyblok-glossary";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const glossaryTerms = await fetchGlossaryTerms();
const hasStoryblokTerms = glossaryTerms.length > 0;
---

<BaseLayout title="VOX - Ordbok" currentPath="/no/ordbok">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section class="!pt-2 !pb-10 sm:!pt-4 sm:!pb-12">
      <div class="max-w-3xl">
        <div class="vox-surface-calm relative overflow-hidden">
          <div
            class="pointer-events-none absolute -inset-x-2 -top-2 h-16 rounded-[var(--radius-md)] bg-gradient-to-r from-[rgb(var(--accent-gradient-start)/0.12)] to-[rgb(var(--accent-gradient-end)/0.1)] blur-2xl"
            aria-hidden="true"
          ></div>
          <h1
            class="font-display text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl"
          >
            Ordbok
          </h1>
          <p class="vox-lead mt-5">
            Korte, tydelige forklaringer på begreper om hørsel, teknologi og hverdagsbruk — i samme rolige tone som resten av Hørehjelpen.
          </p>
          <p class="mt-4 text-sm text-[rgb(var(--muted))]">
            {
              hasStoryblokTerms
                ? "Begrepene under er hentet fra Storyblok og oppdateres når du publiserer."
                : "Ordboken bygges ut fortløpende — under ser du eksempel på hvordan begreper kan presenteres."
            }
          </p>
        </div>
      </div>
    </Section>

    <Section tone="band" class="!py-10 sm:!py-12">
      <div class="max-w-3xl">
        <h2 class="vox-section-title">Begreper</h2>
        <p class="mt-3 max-w-2xl text-[rgb(var(--text-secondary))]">
          {
            hasStoryblokTerms
              ? "Trykk på et begrep for å lese hele oppslaget — skannbart, uten tunge rammer."
              : "Slik kan et oppslag se ut når det er publisert — skannbart, uten tunge rammer."
          }
        </p>
        <ul class="mt-8 grid list-none gap-3 p-0 sm:grid-cols-1 sm:gap-4" role="list">
          {
            hasStoryblokTerms ? (
              glossaryTerms.map((t) => {
                const blurb = truncateForCard(t.description);
                return (
                  <li>
                    <a
                      href={`/no/ordbok/${encodeURIComponent(t.slug)}`}
                      class="vox-surface-tech block no-underline text-inherit transition-colors hover:bg-[rgb(var(--surface-elevated))/0.62] focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--focus))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bg))]"
                    >
                      <span class="text-sm font-semibold text-[rgb(var(--text))]">{t.title}</span>
                      {blurb ? (
                        <span class="mt-1.5 block text-sm leading-relaxed text-[rgb(var(--muted))]">
                          {blurb}
                        </span>
                      ) : null}
                    </a>
                  </li>
                );
              })
            ) : (
              <>
                <li class="vox-surface-tech">
                  <span class="text-sm font-semibold text-[rgb(var(--text))]">Tilkobling</span>
                  <span class="mt-1.5 block text-sm leading-relaxed text-[rgb(var(--muted))]">
                    Eksempel: paring, Bluetooth, vanlige feil.
                  </span>
                </li>
                <li class="vox-surface-tech">
                  <span class="text-sm font-semibold text-[rgb(var(--text))]">Feedback</span>
                  <span class="mt-1.5 block text-sm leading-relaxed text-[rgb(var(--muted))]">
                    Eksempel: piping, støy, hvordan du beskriver det i chat.
                  </span>
                </li>
                <li class="vox-surface-tech">
                  <span class="text-sm font-semibold text-[rgb(var(--text))]">Romklang</span>
                  <span class="mt-1.5 block text-sm leading-relaxed text-[rgb(var(--muted))]">
                    Eksempel: akustikk og opplevelse i rom.
                  </span>
                </li>
              </>
            )
          }
        </ul>
      </div>
    </Section>

    <Section class="!pt-6 !pb-12 sm:!pb-16">
      <div class="max-w-3xl">
        <div class="vox-surface-lifted">
          <h2 class="vox-section-title text-lg sm:text-xl">Mer kontekst</h2>
          <p class="mt-2 max-w-xl text-sm leading-relaxed text-[rgb(var(--muted))]">
            Trenger du overblikk før du dykker i begreper? Info-siden og om-siden forklarer hvordan Hørehjelpen henger sammen.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/no/info"
              class="sonic-pulse-cta inline-flex items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-semibold transition-shadow"
            >
              Kom i gang (info)
            </a>
            <a
              href="/no/om"
              class="inline-flex items-center justify-center rounded-[var(--radius-md)] bg-[rgb(var(--surface-elevated))/0.45] px-5 py-2.5 text-sm font-medium text-[rgb(var(--text))] shadow-sm ring-0 backdrop-blur-md transition-colors hover:bg-[rgb(var(--surface-elevated))/0.65]"
            >
              Om VOX
            </a>
          </div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
