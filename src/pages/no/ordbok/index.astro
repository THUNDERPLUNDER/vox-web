---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/layout/Section.astro";
import Header from "../../../components/nav/Header.astro";
import Footer from "../../../components/nav/Footer.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
---

<BaseLayout title="VOX - Ordbok">
  <meta slot="head" name="robots" content="noindex,follow" />
  <Header currentPath="/no/ordbok" />

  <main class="py-8 sm:py-10">
    <Section>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Ordbok</h1>
      <p class="mt-4 text-[rgb(var(--muted))]">
        Placeholder: Liste med begreper kommer her.
      </p>
    </Section>
  </main>

  <Footer />
</BaseLayout>
