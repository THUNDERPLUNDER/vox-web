---
/* CONTRACT: Norwegian glossary term page; Storyblok spike for title/description + existing calm layout. */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/layout/Section.astro";
import Footer from "../../../components/nav/Footer.astro";
import {
  getStoryblokVersion,
  STORYBLOK_GLOSSARY_STARTS_WITH,
  termSlugFromFullSlug,
} from "../../../lib/storyblok-glossary";

type TermProps = {
  storyTitle: string;
  storyDescription: string;
  fromStoryblok: boolean;
};

export async function getStaticPaths() {
  const token = import.meta.env.STORYBLOK_DELIVERY_API_TOKEN;
  if (typeof token !== "string" || !token.trim()) {
    return [];
  }

  try {
    const { useStoryblokApi } = await import("@storyblok/astro");
    const storyblokApi = useStoryblokApi();
    const version = getStoryblokVersion();
    const { data } = await storyblokApi.get("cdn/stories", {
      version,
      starts_with: STORYBLOK_GLOSSARY_STARTS_WITH,
    });

    const stories = data?.stories;
    if (!Array.isArray(stories) || stories.length === 0) {
      return [];
    }

    const paths: {
      params: { term: string };
      props: TermProps;
    }[] = [];

    for (const story of stories) {
      const slug = termSlugFromFullSlug(story.full_slug);
      if (!slug) continue;

      const content = story.content && typeof story.content === "object" ? story.content : {};
      const rawTitle = "title" in content ? content.title : undefined;
      const rawDesc = "description" in content ? content.description : undefined;

      const storyTitle =
        typeof rawTitle === "string" && rawTitle.trim()
          ? rawTitle.trim()
          : typeof story.name === "string"
            ? story.name
            : slug;

      const storyDescription =
        typeof rawDesc === "string" && rawDesc.trim() ? rawDesc.trim() : "";

      paths.push({
        params: { term: slug },
        props: {
          storyTitle,
          storyDescription,
          fromStoryblok: true,
        },
      });
    }

    return paths;
  } catch {
    return [];
  }
}

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const FALLBACK_LEAD =
  "Her vises definisjon og forklaring når oppslaget er publisert. Under MVP er dette en mal for hvordan et begrep kan presenteres tydelig og rolig.";

const FALLBACK_BODY =
  "Brødtekst, eksempler og eventuelle «se også»-henvisninger plasseres her med god linjeavstand og tydelig avsnittsrytme — uten tette tabeller eller teknisk PDF-følelse.";

const { term } = Astro.params;
const props = Astro.props as TermProps | undefined;

const termLabel = term ? decodeURIComponent(term) : "";
const storyTitle = props?.storyTitle ?? termLabel;
const storyDescription = props?.storyDescription ?? "";
const fromStoryblok = props?.fromStoryblok === true;

const leadText = fromStoryblok && storyDescription ? storyDescription : FALLBACK_LEAD;
const bodyText = fromStoryblok && storyDescription ? storyDescription : FALLBACK_BODY;
---

<BaseLayout title={`VOX - Ordbok: ${storyTitle}`} currentPath="/no/ordbok">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section class="!pt-2 !pb-10 sm:!pt-4 sm:!pb-12">
      <div class="max-w-3xl">
        <div class="vox-surface-calm relative overflow-hidden">
          <div
            class="pointer-events-none absolute -inset-x-2 -top-2 h-16 rounded-[var(--radius-md)] bg-gradient-to-r from-[rgb(var(--accent-gradient-start)/0.12)] to-[rgb(var(--accent-gradient-end)/0.1)] blur-2xl"
            aria-hidden="true"
          ></div>
          <p class="text-xs font-medium uppercase tracking-wide text-[rgb(var(--muted))]">
            Ordbok
          </p>
          <h1
            class="font-display mt-2 text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl"
          >
            {storyTitle}
          </h1>
          <p class="vox-lead mt-5">
            {leadText}
          </p>
        </div>
      </div>
    </Section>

    <Section tone="band" class="!py-10 sm:!py-12">
      <div class="max-w-3xl">
        <h2 class="vox-section-title">Innhold</h2>
        <div class="vox-surface-tech mt-6">
          <p class="text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
            {bodyText}
          </p>
        </div>
        <p class="mt-6 text-sm text-[rgb(var(--muted))]">
          {
            fromStoryblok
              ? "Innhold hentet fra Storyblok (spike)."
              : "Når datakilde er koblet til, fylles dette feltet automatisk for hvert begrep."
          }
        </p>
      </div>
    </Section>

    <Section class="!pt-6 !pb-12 sm:!pb-16">
      <div class="max-w-3xl">
        <div class="vox-surface-lifted">
          <h2 class="vox-section-title text-lg sm:text-xl">Navigasjon</h2>
          <p class="mt-2 max-w-xl text-sm leading-relaxed text-[rgb(var(--muted))]">
            Gå tilbake til ordboksiden eller til forsiden når du vil fortsette samtalen.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/no/ordbok"
              class="sonic-pulse-cta inline-flex items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-semibold transition-shadow"
            >
              Til ordboken
            </a>
            <a
              href="/no"
              class="inline-flex items-center justify-center rounded-[var(--radius-md)] bg-[rgb(var(--surface-elevated))/0.45] px-5 py-2.5 text-sm font-medium text-[rgb(var(--text))] shadow-sm ring-0 backdrop-blur-md transition-colors hover:bg-[rgb(var(--surface-elevated))/0.65]"
            >
              Til forsiden
            </a>
          </div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
