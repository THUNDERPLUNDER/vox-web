---
/* CONTRACT: Norwegian glossary term page; calm knowledge surface (paths from getStaticPaths when data exists). */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/layout/Section.astro";
import Footer from "../../../components/nav/Footer.astro";

export async function getStaticPaths() {
  // TODO: Replace with real term source when glossary data is available.
  return [];
}

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const { term } = Astro.params;
const termLabel = term ? decodeURIComponent(term) : "";
---

<BaseLayout title={`VOX - Ordbok: ${termLabel}`} currentPath="/no/ordbok">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section class="!pt-2 !pb-10 sm:!pt-4 sm:!pb-12">
      <div class="max-w-3xl">
        <div class="vox-surface-calm relative overflow-hidden">
          <div
            class="pointer-events-none absolute -inset-x-2 -top-2 h-16 rounded-[var(--radius-md)] bg-gradient-to-r from-[rgb(var(--accent-gradient-start)/0.12)] to-[rgb(var(--accent-gradient-end)/0.1)] blur-2xl"
            aria-hidden="true"
          ></div>
          <p class="text-xs font-medium uppercase tracking-wide text-[rgb(var(--muted))]">
            Ordbok
          </p>
          <h1
            class="font-display mt-2 text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl"
          >
            {termLabel}
          </h1>
          <p class="vox-lead mt-5">
            Her vises definisjon og forklaring når oppslaget er publisert. Under MVP er dette en mal for hvordan et begrep kan presenteres tydelig og rolig.
          </p>
        </div>
      </div>
    </Section>

    <Section tone="band" class="!py-10 sm:!py-12">
      <div class="max-w-3xl">
        <h2 class="vox-section-title">Innhold</h2>
        <div class="vox-surface-tech mt-6">
          <p class="text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
            Brødtekst, eksempler og eventuelle «se også»-henvisninger plasseres her med god linjeavstand og tydelig avsnittsrytme — uten tette tabeller eller teknisk PDF-følelse.
          </p>
        </div>
        <p class="mt-6 text-sm text-[rgb(var(--muted))]">
          Når datakilde er koblet til, fylles dette feltet automatisk for hvert begrep.
        </p>
      </div>
    </Section>

    <Section class="!pt-6 !pb-12 sm:!pb-16">
      <div class="max-w-3xl">
        <div class="vox-surface-lifted">
          <h2 class="vox-section-title text-lg sm:text-xl">Navigasjon</h2>
          <p class="mt-2 max-w-xl text-sm leading-relaxed text-[rgb(var(--muted))]">
            Gå tilbake til ordboksiden eller til forsiden når du vil fortsette samtalen.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/no/ordbok"
              class="sonic-pulse-cta inline-flex items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-semibold transition-shadow"
            >
              Til ordboken
            </a>
            <a
              href="/no"
              class="inline-flex items-center justify-center rounded-[var(--radius-md)] bg-[rgb(var(--surface-elevated))/0.45] px-5 py-2.5 text-sm font-medium text-[rgb(var(--text))] shadow-sm ring-0 backdrop-blur-md transition-colors hover:bg-[rgb(var(--surface-elevated))/0.65]"
            >
              Til forsiden
            </a>
          </div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
