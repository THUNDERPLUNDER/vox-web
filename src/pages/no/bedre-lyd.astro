---
/* CONTRACT: Editorial hub — «Bedre lyd» #125F / #125J / editorial R1.
   Aktuelt først → AI seeds → temakategorier → bro til Hjelp. Motflate til /no/hjelp/.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/nav/Footer.astro";
import "../../styles/r1-dialog-article.css";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const pageTitle = "Bedre lyd";
const pageIntro =
  "Små grep, bedre situasjoner og mer av lyden som gjør hverdagen tydelig.";

const featuredStory = {
  eyebrow: "Lyd og energi",
  title: "Når lyden blir for mye",
  deck:
    "Lyttetrøtthet er mer enn en dårlig dag. Slik kan du kjenne den igjen og gjøre hverdagen lettere.",
  href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
};

const currentArticles: Array<{
  series: string;
  title: string;
  deck: string;
  visual: string;
  href: string;
}> = [
  {
    series: "Lydglede",
    title: "Små lyder og følelsen av å være påkoblet",
    deck: "Fugler, regn, musikk og stemmer — og hvordan du kan legge merke til dem.",
    visual: "joy",
    href: "/no/artikkel/fra-skuff-til-daglig-bruk",
  },
  {
    series: "Sosialt",
    title: "Hvorfor selskap fortsatt kan være krevende",
    deck: "Erfaringer fra et støyende bord — uten å gi opp sosialt liv.",
    visual: "social",
    href: "/no/artikkel/for-restaurant-eller-stort-selskap",
  },
  {
    series: "Lydglede",
    title: "Musikk med høreapparat",
    deck: "Små grep for å få mer ut av musikk, podkast og lyd du liker.",
    visual: "joy",
    href: "/no/artikkel/fra-skuff-til-daglig-bruk",
  },
];

const themeGroups: Array<{
  title: string;
  hint: string;
  links: Array<{ label: string; href: string }>;
}> = [
  {
    title: "Situasjoner",
    hint: "Selskap, restaurant, møter, bil og TV",
    links: [
      { label: "Selskap og restaurant", href: "/no/artikkel/for-restaurant-eller-stort-selskap" },
      { label: "Møter og samtaler på jobb", href: "/no/artikkel/slik-tar-du-praten" },
      { label: "De første ukene med høreapparat", href: "/no/artikkel/de-forste-ukene-med-horeapparat" },
    ],
  },
  {
    title: "Lydkvalitet",
    hint: "Musikk, tale, støy og små lyder",
    links: [
      { label: "Små lyder som gjør verden nær", href: "/no/artikkel/fra-skuff-til-daglig-bruk" },
      { label: "Tale og tilvenning", href: "/no/artikkel/de-forste-ukene-med-horeapparat" },
    ],
  },
  {
    title: "Energi og nærvær",
    hint: "Lytteutmattelse, ro, fokus og sosial deltakelse",
    links: [
      { label: "Når lyden blir for mye", href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen" },
      { label: "Støtte uten å ta over samtalen", href: "/no/artikkel/stotte-uten-a-ta-over-samtalen" },
    ],
  },
  {
    title: "Hjemme med andre",
    hint: "TV, samtaler og felles lydvaner",
    links: [
      { label: "Slik løste jeg middagsbordet", href: "/no/artikkel/for-restaurant-eller-stort-selskap" },
      { label: "For pårørende hjemme", href: "/no/artikkel/stotte-uten-a-ta-over-samtalen" },
    ],
  },
];

const editorialSeeds = [
  "Spør om lyttetrøtthet",
  "Få forslag til hva jeg kan si til kollegaene mine",
  "Hjelp meg å forstå om dette er normalt",
];
---

<BaseLayout title={`Viddel - ${pageTitle}`} currentPath="/no/bedre-lyd" shellVariant="article">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="ed-page" data-editorial-hub>
    <div class="ed-container">

      <header class="ed-header">
        <nav class="ed-breadcrumb" aria-label="Du er her">
          <a href="/no">Forside</a>
          <span aria-hidden="true">/</span>
          <span>{pageTitle}</span>
        </nav>
        <h1>{pageTitle}</h1>
        <p class="ed-lead">{pageIntro}</p>
      </header>

      <div class="ed-core">

        <section class="ed-block ed-block--current" aria-labelledby="current-heading">
          <h2 id="current-heading" class="ed-block__title">Aktuelt</h2>
          <a href={featuredStory.href} class="ed-featured">
            <div class="ed-featured__media" aria-hidden="true"></div>
            <div class="ed-featured__body">
              <p class="ed-eyebrow">{featuredStory.eyebrow}</p>
              <h3 class="ed-featured__title">{featuredStory.title}</h3>
              <p class="ed-featured__deck">{featuredStory.deck}</p>
            </div>
          </a>
          <ul class="ed-current-grid" role="list">
            {currentArticles.map((article) => (
              <li>
                <a href={article.href} class="ed-article-card" data-visual={article.visual}>
                  <span class="ed-article-card__visual" aria-hidden="true"></span>
                  <span class="ed-article-card__body">
                    <span class="ed-article-card__series">{article.series}</span>
                    <span class="ed-article-card__title">{article.title}</span>
                    <span class="ed-article-card__deck">{article.deck}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="ed-block ed-block--ai" aria-labelledby="ai-heading">
          <h2 id="ai-heading" class="ed-block__title">Videre samtale etter lesing</h2>
          <p class="ed-ai-intro">
            Spørsmål som videreføring av det du har lest — ikke supportboks.
          </p>
          <div class="ed-seed-bridge" data-r1-editorial>
            <section class="r1-ai-bridge">
              <section class="inline-chat-shell" data-inline-chat-mode="progressive">
                <div class="inline-chat-shell__seed-suggestions">
                  <ul class="inline-chat-shell__seed-list inline-chat-shell__seed-list--rows" role="list">
                    {editorialSeeds.map((seed) => (
                      <li class="inline-chat-shell__seed-item">
                        <a
                          href={`/no/chat?seed=${encodeURIComponent(seed)}&from=bedre-lyd`}
                          class="inline-chat-shell__seed-btn inline-chat-shell__seed-row"
                        >
                          <span class="inline-chat-shell__seed-question">{seed}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </section>
            </section>
          </div>
        </section>

        <section class="ed-block ed-block--themes" aria-labelledby="themes-heading">
          <h2 id="themes-heading" class="ed-block__title">Utforsk etter tema</h2>
          <p class="ed-themes-intro">Finn artikler og grep etter situasjon — uten å starte med problemløsning.</p>
          <div class="ed-theme-stack">
            {themeGroups.map((group) => (
              <article class="ed-theme-group">
                <h3 class="ed-theme-group__title">{group.title}</h3>
                <p class="ed-theme-group__hint">{group.hint}</p>
                <ul class="ed-theme-gateway-list" role="list">
                  {group.links.map((link) => (
                    <li>
                      <a href={link.href} class="ed-theme-gateway">
                        <span class="ed-theme-gateway__label">{link.label}</span>
                        <span class="ed-theme-gateway__arrow" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <footer class="ed-help-link">
          <p>
            Trenger du konkret hjelp nå?
            <a href="/no/hjelp/">Gå til Hjelp</a>
          </p>
        </footer>

      </div>
    </div>
  </main>

  <Footer variant="article" />
</BaseLayout>

<style>
  [data-editorial-hub] {
    background: rgb(var(--article-page-canvas));
    min-height: 100vh;
  }

  .ed-container {
    max-width: min(100%, 52rem);
    margin: 0 auto;
    padding: 0 1rem 4.5rem;
  }

  .ed-header {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(1.25rem, 3vw, 1.75rem);
    border-bottom: 1px solid rgb(var(--border) / 0.2);
  }

  .ed-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary) / 0.6);
  }

  .ed-breadcrumb a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ed-kicker {
    margin: 0 0 0.55rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  [data-editorial-hub] h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 7vw, 3.8rem);
    font-weight: 650;
    line-height: 0.99;
    letter-spacing: -0.065em;
    text-wrap: balance;
    color: rgb(var(--reading-ink));
  }

  .ed-lead {
    margin: 0.85rem 0 0;
    max-width: 36rem;
    font-size: clamp(1rem, 2.4vw, 1.12rem);
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-core {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ed-block {
    padding: clamp(1.75rem, 4.5vw, 2.35rem) 0;
    border-bottom: 1px solid rgb(var(--border) / 0.14);
  }

  .ed-block:last-of-type {
    border-bottom: 0;
  }

  .ed-block__title {
    margin: 0 0 0.55rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-block--current {
    padding-top: clamp(1.5rem, 4vw, 2rem);
  }

  .ed-current-grid {
    margin: 1.15rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.85rem;
  }

  .ed-block--themes {
    padding-top: clamp(1.75rem, 4vw, 2.25rem);
  }

  .ed-themes-intro {
    margin: -0.1rem 0 1rem;
    max-width: 34rem;
    font-size: 0.86rem;
    line-height: 1.55;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-theme-stack {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
  }

  .ed-theme-group {
    padding: 0.95rem 0 0;
    border-top: 1px solid rgb(var(--border) / 0.12);
  }

  .ed-theme-group:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .ed-theme-group__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: rgb(var(--reading-ink));
  }

  .ed-theme-group__hint {
    margin: 0.35rem 0 0.65rem;
    font-size: 0.8rem;
    line-height: 1.45;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-theme-gateway-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .ed-theme-gateway {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    border: 1px solid rgb(var(--border) / 0.1);
    background: rgb(var(--reading-paper) / 0.55);
    color: inherit;
    text-decoration: none;
    transition: border-color 150ms ease, background-color 150ms ease;
  }

  .ed-theme-gateway:hover {
    border-color: rgb(var(--border) / 0.24);
    background: rgb(var(--reading-paper));
  }

  .ed-theme-gateway:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-theme-gateway__label {
    font-size: 0.88rem;
    font-weight: 550;
    line-height: 1.35;
    color: rgb(var(--reading-ink));
  }

  .ed-theme-gateway__arrow {
    flex-shrink: 0;
    font-size: 0.9rem;
    color: rgb(var(--reading-ink-secondary) / 0.7);
  }

  /* Featured — stacked, media-first editorial weight */
  .ed-featured {
    display: flex;
    flex-direction: column;
    gap: 0;
    color: inherit;
    text-decoration: none;
    border-radius: 12px;
    overflow: hidden;
    background: rgb(var(--reading-paper));
    border: 1px solid rgb(var(--border) / 0.12);
    transition: box-shadow 180ms ease, border-color 180ms ease;
  }

  .ed-featured:hover {
    border-color: rgb(var(--border) / 0.28);
    box-shadow: 0 8px 32px rgb(var(--reading-ink) / 0.06);
  }

  .ed-featured:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-featured__media {
    aspect-ratio: 16 / 9;
    min-height: 11rem;
    background:
      linear-gradient(145deg, rgb(19 77 106 / 0.38), rgb(95 82 220 / 0.14)),
      linear-gradient(165deg, rgb(30 58 80 / 0.18), rgb(253 252 250));
  }

  .ed-featured__body {
    padding: clamp(1.15rem, 3vw, 1.5rem) clamp(1.1rem, 3vw, 1.45rem) clamp(1.35rem, 3.5vw, 1.65rem);
  }

  .ed-eyebrow {
    margin: 0;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  .ed-featured__title {
    margin: 0.5rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 4.5vw, 2.15rem);
    font-weight: 650;
    letter-spacing: -0.045em;
    line-height: 1.08;
    text-wrap: balance;
    color: rgb(var(--reading-ink));
  }

  .ed-featured__deck {
    margin: 0.75rem 0 0;
    max-width: 40rem;
    font-size: clamp(0.92rem, 2.2vw, 1.02rem);
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  /* Article cards — editorial, not FAQ rows */
  .ed-article-grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1rem;
  }

  .ed-article-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    color: inherit;
    text-decoration: none;
    border-radius: 10px;
    overflow: hidden;
    background: rgb(var(--reading-paper));
    border: 1px solid rgb(var(--border) / 0.12);
    transition: box-shadow 150ms ease, border-color 150ms ease, transform 150ms ease;
  }

  .ed-article-card:hover {
    border-color: rgb(var(--border) / 0.28);
    box-shadow: 0 4px 18px rgb(var(--reading-ink) / 0.05);
    transform: translateY(-1px);
  }

  .ed-article-card:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-article-card__visual {
    display: block;
    height: 5.5rem;
    background: linear-gradient(145deg, rgb(19 77 106 / 0.12), rgb(224 242 254 / 0.45));
  }

  [data-visual="social"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(95 82 220 / 0.14), rgb(238 235 255));
  }

  [data-visual="start"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(14 165 233 / 0.14), rgb(234 246 255));
  }

  [data-visual="energy"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(19 77 106 / 0.16), rgb(243 241 255));
  }

  [data-visual="work"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(96 165 250 / 0.14), rgb(248 250 255));
  }

  [data-visual="mind"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(200 192 176 / 0.22), rgb(252 250 245));
  }

  [data-visual="joy"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(34 197 94 / 0.16), rgb(234 246 255 / 0.55));
  }

  .ed-article-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 0.95rem 1rem;
  }

  .ed-article-card__series {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  .ed-article-card__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.22;
    color: rgb(var(--reading-ink));
  }

  .ed-article-card__deck {
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgb(var(--reading-ink-secondary));
  }

  /* AI seeds */
  .ed-block--ai {
    padding-bottom: clamp(1.25rem, 3vw, 1.75rem);
  }

  .ed-ai-intro {
    margin: -0.15rem 0 0.85rem;
    font-size: 0.86rem;
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-seed-bridge {
    padding: 0.85rem;
    border-radius: 10px;
    background: rgb(var(--reading-paper));
  }

  .ed-seed-bridge .inline-chat-shell__seed-row {
    text-decoration: none;
    color: inherit;
  }

  /* Hjelp cross-link */
  .ed-help-link {
    padding: 1.25rem 0 0.5rem;
    border-top: 1px solid rgb(var(--border) / 0.12);
  }

  .ed-help-link p {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-help-link a {
    margin-left: 0.25rem;
    font-weight: 600;
    color: rgb(var(--reading-ink));
    text-underline-offset: 2px;
  }

  .ed-help-link a:hover {
    color: rgb(var(--reading-accent-iris));
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 479px) {
    .ed-current-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 480px) {
    .ed-container {
      padding: 0 1.25rem 5rem;
    }

    .ed-current-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 640px) {
    .ed-container {
      padding: 0 1.75rem 5.5rem;
    }

    .ed-featured__media {
      aspect-ratio: 21 / 9;
      min-height: 14rem;
    }
  }
</style>
