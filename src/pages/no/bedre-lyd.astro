---
/* CONTRACT: Editorial hub — «Bedre lyd» #125J / editorial R2.
   Situation-first: hero → situasjonsinnganger → utvalgte artikler → bro til Hjelp.
   Ingen AI-seeds på landing. Surface-paritet med /no/hjelp/ (46rem).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/nav/Footer.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const pageTitle = "Bedre lyd";
const pageIntro =
  "Grep, forklaringer og historier som hjelper deg å få mer ut av lyden rundt deg.";

const situationGateways: Array<{ title: string; hint: string; href: string }> = [
  {
    title: "I selskap og restaurant",
    hint: "Middag, støy og samtaler uten å gi opp sosialt liv.",
    href: "/no/artikkel/for-restaurant-eller-stort-selskap",
  },
  {
    title: "Med TV, mobil og bil",
    hint: "Små grep når lyden kommer fra skjerm, telefon eller kjøretur.",
    href: "/no/artikkel/slik-tar-du-praten",
  },
  {
    title: "Når lyden blir for mye",
    hint: "Lyttetrøtthet, pauser og tegn på at dagen blir tung.",
    href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
  },
  {
    title: "Små lyder og nærvær",
    hint: "Musikk, fugler, stemmer og det som gjør verden nær.",
    href: "/no/artikkel/fra-skuff-til-daglig-bruk",
  },
];

const selectedArticles: Array<{ series: string; title: string; deck: string; href: string }> = [
  {
    series: "Erfaring",
    title: "Slik løste jeg middagsbordet",
    deck: "Erfaringer fra et støyende bord — uten å gi opp sosialt liv.",
    href: "/no/artikkel/for-restaurant-eller-stort-selskap",
  },
  {
    series: "Normalt?",
    title: "Hva som er normalt de første ukene",
    deck: "Forventninger, tilpasning og tegn på at ting går riktig vei.",
    href: "/no/artikkel/de-forste-ukene-med-horeapparat",
  },
  {
    series: "Relasjon",
    title: "Slik kan du be kollegaene dine hjelpe",
    deck: "Ord og små grep som gjør hverdagen på jobb enklere.",
    href: "/no/artikkel/slik-tar-du-praten",
  },
  {
    series: "Pårørende",
    title: "Støtte uten å ta over samtalen",
    deck: "Hvordan hjelpe hjemme uten å presse.",
    href: "/no/artikkel/stotte-uten-a-ta-over-samtalen",
  },
];
---

<BaseLayout title={`Viddel - ${pageTitle}`} currentPath="/no/bedre-lyd" shellVariant="article">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="bl-page" data-bedre-lyd>
    <div class="bl-container">
      <div class="bl-surface">
        <header class="bl-header">
          <nav class="bl-breadcrumb" aria-label="Du er her">
            <a href="/no">Forside</a>
            <span aria-hidden="true">/</span>
            <span>{pageTitle}</span>
          </nav>
          <h1>{pageTitle}</h1>
          <p class="bl-lead">{pageIntro}</p>
        </header>

        <div class="bl-body">
          <section class="bl-block" aria-labelledby="situations-heading">
            <h2 id="situations-heading" class="bl-block__title">Velg en situasjon</h2>
            <p class="bl-block__hint">Start der du er — finn grep og forklaringer for hverdagslytting.</p>
            <ul class="bl-situation-grid" role="list">
              {situationGateways.map((item) => (
                <li>
                  <a href={item.href} class="bl-situation-card">
                    <span class="bl-situation-card__title">{item.title}</span>
                    <span class="bl-situation-card__hint">{item.hint}</span>
                    <span class="bl-situation-card__arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>

          <section class="bl-block" aria-labelledby="articles-heading">
            <h2 id="articles-heading" class="bl-block__title">Utvalgte artikler</h2>
            <ul class="bl-article-list" role="list">
              {selectedArticles.map((article) => (
                <li class="bl-article-row">
                  <a href={article.href} class="bl-article-row__action">
                    <span class="bl-article-row__series">{article.series}</span>
                    <span class="bl-article-row__title">{article.title}</span>
                    <span class="bl-article-row__deck">{article.deck}</span>
                    <span class="bl-article-row__arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>

          <footer class="bl-help-link">
            <p>
              Trenger du konkret hjelp nå?
              <a href="/no/hjelp/">Gå til Hjelp</a>
            </p>
          </footer>
        </div>
      </div>
    </div>
  </main>

  <Footer variant="article" />
</BaseLayout>

<style>
  [data-bedre-lyd] {
    --bl-hover: rgb(var(--reading-paper));
  }

  .bl-page {
    background: rgb(var(--article-page-canvas));
    padding: 0.5rem 0 clamp(3rem, 6vw, 4rem);
    min-height: 100vh;
  }

  @media (min-width: 640px) {
    .bl-page {
      padding-top: 0.75rem;
    }
  }

  .bl-container {
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .bl-container {
      padding-inline: 1.5rem;
    }
  }

  .bl-surface {
    max-width: min(100%, 46rem);
    margin: 0 auto;
    background: rgb(var(--reading-paper));
    border-radius: var(--radius-md);
    padding: 2.5rem 1.75rem;
    color: rgb(var(--reading-ink));
  }

  @media (min-width: 640px) {
    .bl-surface {
      padding: 3rem 2.5rem;
    }
  }

  .bl-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.75rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary) / 0.6);
  }

  .bl-breadcrumb a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  [data-bedre-lyd] h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.8vw, 2.6rem);
    font-weight: 650;
    line-height: 1.05;
    letter-spacing: -0.055em;
    text-wrap: balance;
    color: rgb(var(--reading-ink));
  }

  .bl-lead {
    margin: 0.85rem 0 0;
    max-width: 36rem;
    font-size: clamp(1rem, 2.2vw, 1.08rem);
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  .bl-body {
    padding-top: clamp(1.35rem, 3vw, 1.75rem);
  }

  .bl-block {
    padding: clamp(1.35rem, 3.5vw, 1.85rem) 0;
    border-top: 1px solid rgb(var(--border) / 0.14);
  }

  .bl-block:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .bl-block__title {
    margin: 0;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary));
  }

  .bl-block__hint {
    margin: 0.45rem 0 1rem;
    max-width: 34rem;
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgb(var(--reading-ink-secondary));
  }

  .bl-situation-grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .bl-situation-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }
  }

  .bl-situation-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-height: 6.5rem;
    padding: 1.15rem 1.2rem 1.1rem;
    border: 1px solid rgb(var(--border) / 0.22);
    border-radius: var(--radius-md);
    background: rgb(var(--reading-paper));
    box-shadow: 0 1px 2px rgb(var(--reading-ink) / 0.04);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }

  .bl-situation-card:hover {
    border-color: rgb(var(--border) / 0.28);
    box-shadow: 0 4px 18px rgb(var(--reading-ink) / 0.05);
    transform: translateY(-2px);
  }

  .bl-situation-card:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .bl-situation-card__title {
    padding-right: 1.25rem;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.8vw, 1.2rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: rgb(var(--reading-ink));
  }

  .bl-situation-card__hint {
    font-size: 0.84rem;
    line-height: 1.45;
    color: rgb(var(--reading-ink-secondary));
  }

  .bl-situation-card__arrow {
    margin-top: auto;
    font-size: 0.95rem;
    color: rgb(var(--reading-ink-secondary) / 0.65);
  }

  .bl-article-list {
    margin: 0.65rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid rgb(var(--border) / 0.16);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .bl-article-row {
    border-bottom: 1px solid rgb(var(--border) / 0.12);
  }

  .bl-article-row:last-child {
    border-bottom: 0;
  }

  .bl-article-row__action {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    gap: 0.2rem 0.75rem;
    padding: 0.95rem 1rem;
    color: inherit;
    text-decoration: none;
    background: rgb(var(--reading-paper));
    transition: background-color 150ms ease;
  }

  .bl-article-row__action:hover {
    background: rgb(var(--surface-subtle) / 0.35);
  }

  .bl-article-row__action:focus-visible {
    outline: none;
    box-shadow: inset 0 0 0 2px rgb(14 165 233 / 0.32);
  }

  .bl-article-row__series {
    grid-column: 1;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  .bl-article-row__title {
    grid-column: 1;
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 650;
    letter-spacing: -0.025em;
    line-height: 1.25;
    color: rgb(var(--reading-ink));
  }

  .bl-article-row__deck {
    grid-column: 1;
    font-size: 0.82rem;
    line-height: 1.45;
    color: rgb(var(--reading-ink-secondary));
  }

  .bl-article-row__arrow {
    grid-column: 2;
    grid-row: 1 / span 3;
    align-self: center;
    font-size: 0.95rem;
    color: rgb(var(--reading-ink-secondary) / 0.65);
  }

  .bl-help-link {
    padding: 1.35rem 0 0.25rem;
    border-top: 1px solid rgb(var(--border) / 0.14);
  }

  .bl-help-link p {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: rgb(var(--reading-ink-secondary));
  }

  .bl-help-link a {
    margin-left: 0.25rem;
    font-weight: 600;
    color: rgb(var(--reading-ink));
    text-underline-offset: 2px;
  }

  .bl-help-link a:hover {
    color: rgb(var(--reading-accent-iris));
  }
</style>
