---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
---

<BaseLayout title="VOX - Hørehjelpen">
  <main class="py-8 sm:py-10">
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_460px] lg:items-start">
      <aside class="order-1 lg:order-2 lg:sticky lg:top-6">
        <chat-messenger
          id="ces-widget"
          url-allowlist="*"
          class="block w-full"
          style="height:min(720px,calc(100vh - 6rem));"
        >
          <chat-messenger-container chat-title="Hørehjelpen" enable-file-upload enable-audio-input></chat-messenger-container>
        </chat-messenger>
      </aside>

      <div class="order-2 lg:order-1">
        <!-- Hero -->
        <Section>
          <div class="max-w-3xl">
            <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Få høreapparatet tilbake i hverdagen
            </h1>

            <p class="mt-4 text-lg text-[rgb(var(--muted))]">
              Hørehjelpen gir deg korte, konkrete steg når teknikken frustrerer - og en trygg inngang når terskelen er høy.
              Du trenger ikke kunne alt for å starte.
            </p>

            <div class="mt-8 flex flex-wrap items-center gap-3">
              <button
                type="button"
                onclick="document.getElementById('ces-widget')?.scrollIntoView({behavior:'smooth', block:'start'}); document.getElementById('ces-widget')?.open?.(); document.getElementById('ces-widget')?.show?.();"
                class="inline-flex items-center justify-center rounded-[var(--radius-sm)] bg-[rgb(var(--primary))] px-5 py-3 text-sm font-medium text-[rgb(var(--primary-contrast))]"
              >
                Start chat
              </button>

              <a
                href="#kan-hjelpe"
                class="inline-flex items-center justify-center rounded-[var(--radius-sm)] border border-[rgb(var(--border))] bg-transparent px-5 py-3 text-sm font-medium"
              >
                Hva kan jeg få hjelp med?
              </a>
            </div>

            <p class="mt-4 text-sm text-[rgb(var(--muted))]">
              Start med én setning. Vi tar resten stegvis.
            </p>
          </div>
        </Section>

        <!-- Neste seksjoner kommer her (vi bygger de i morgen eller neste steg) -->
        <Section id="kan-hjelpe" tone="surface">
          <h2 class="text-xl font-semibold tracking-tight">Dette kan jeg hjelpe med</h2>
          <p class="mt-2 text-[rgb(var(--muted))]">Kommer: 5 kort.</p>
        </Section>
      </div>
    </div>
  </main>
</BaseLayout>
