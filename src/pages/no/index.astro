---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
---

<BaseLayout title="VOX - Hørehjelpen">
  <main class="py-8 sm:py-10">
    <button
      id="openInfoBtn"
      type="button"
      aria-label="Meny"
      class="lg:hidden fixed right-3 z-[2000] rounded-full border border-[rgb(var(--border))] bg-[rgb(var(--surface))] shadow-[var(--shadow-sm)] w-10 h-10 flex items-center justify-center"
      style="top: calc(env(safe-area-inset-top) + 12px);"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path id="menuIconPath" d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_460px] lg:items-start">
      <aside class="order-1 lg:order-2 lg:sticky lg:top-6">
        <chat-messenger
          id="ces-widget"
          url-allowlist="*"
          class="block w-full"
          style="height:min(720px,calc(100vh - 6rem));"
        >
          <chat-messenger-container chat-title="Hørehjelpen" enable-file-upload enable-audio-input></chat-messenger-container>
        </chat-messenger>
      </aside>

      <div class="order-2 lg:order-1">
        <div id="infoContent" class="hidden lg:block">
          <!-- Hero -->
          <Section>
            <div class="max-w-3xl">
              <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
                Få høreapparatet tilbake i hverdagen
              </h1>

              <p class="mt-4 text-lg text-[rgb(var(--muted))]">
                Hørehjelpen gir deg korte, konkrete steg når teknikken frustrerer - og en trygg inngang når terskelen er høy.
                Du trenger ikke kunne alt for å starte.
              </p>

              <div class="mt-8 flex flex-wrap items-center gap-3">
                <button
                  type="button"
                  onclick="document.getElementById('ces-widget')?.scrollIntoView({behavior:'smooth', block:'start'}); document.getElementById('ces-widget')?.open?.(); document.getElementById('ces-widget')?.show?.();"
                  class="inline-flex items-center justify-center rounded-[var(--radius-sm)] bg-[rgb(var(--primary))] px-5 py-3 text-sm font-medium text-[rgb(var(--primary-contrast))]"
                >
                  Start chat
                </button>

                <a
                  href="#kan-hjelpe"
                  class="inline-flex items-center justify-center rounded-[var(--radius-sm)] border border-[rgb(var(--border))] bg-transparent px-5 py-3 text-sm font-medium"
                >
                  Hva kan jeg få hjelp med?
                </a>
              </div>

              <p class="mt-4 text-sm text-[rgb(var(--muted))]">
                Start med én setning. Vi tar resten stegvis.
              </p>
            </div>
          </Section>

          <!-- Neste seksjoner kommer her (vi bygger de i morgen eller neste steg) -->
          <Section id="kan-hjelpe" tone="surface">
            <h2 class="text-xl font-semibold tracking-tight">Dette kan jeg hjelpe med</h2>
            <p class="mt-2 text-[rgb(var(--muted))]">Kommer: 5 kort.</p>
          </Section>
        </div>
      </div>
    </div>

    <div id="mobileSheet" class="fixed inset-0 hidden lg:hidden" data-open="false">
      <button id="mobileOverlay" type="button" class="fixed inset-0 bg-black/40 z-[3000]" aria-label="Lukk meny"></button>
      <div class="fixed top-0 right-0 z-[3001] h-full w-[min(420px,90vw)] translate-x-full overflow-y-auto border-l border-[rgb(var(--border))] bg-[rgb(var(--surface))] p-4 shadow-[var(--shadow-md)] transition-transform duration-200">
        <div class="mb-3 flex items-center justify-between">
          <p class="text-sm font-medium text-[rgb(var(--muted))]">Meny</p>
          <button
            id="closeSheetBtn"
            type="button"
            aria-label="Lukk meny"
            class="rounded-full border border-[rgb(var(--border))] bg-[rgb(var(--surface))] shadow-[var(--shadow-sm)] w-10 h-10 flex items-center justify-center"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <section class="mb-6">
          <h2 class="text-base font-semibold tracking-tight text-[rgb(var(--text))]">Info</h2>
          <div id="infoSheetContent" class="mt-3"></div>
        </section>

        <section>
          <h2 class="text-base font-semibold tracking-tight text-[rgb(var(--text))]">Meny</h2>
          <nav class="mt-3">
            <a href="/no" class="flex w-full items-center justify-between border-b border-[rgb(var(--border))] py-3 text-sm">
              <span>Start</span><span aria-hidden="true">→</span>
            </a>
            <a href="/no/ordbok" class="flex w-full items-center justify-between border-b border-[rgb(var(--border))] py-3 text-sm">
              <span>Ordbok</span><span aria-hidden="true">→</span>
            </a>
            <a href="/no/om" class="flex w-full items-center justify-between border-b border-[rgb(var(--border))] py-3 text-sm">
              <span>Om</span><span aria-hidden="true">→</span>
            </a>
            <a href="/no/personvern" class="flex w-full items-center justify-between border-b border-[rgb(var(--border))] py-3 text-sm">
              <span>Personvern</span><span aria-hidden="true">→</span>
            </a>
          </nav>
        </section>
      </div>
    </div>
  </main>

  <script is:inline>
    const sheet = document.getElementById("mobileSheet");
    const panel = sheet?.querySelector("div.fixed.top-0.right-0");
    const overlay = document.getElementById("mobileOverlay");
    const openBtn = document.getElementById("openInfoBtn");
    const closeBtn = document.getElementById("closeSheetBtn");
    const menuIconPath = document.getElementById("menuIconPath");
    const source = document.getElementById("infoContent");
    const target = document.getElementById("infoSheetContent");

    const setMenuOpen = (isOpen) => {
      if (!menuIconPath) return;
      menuIconPath.setAttribute("d", isOpen ? "M6 6l12 12M18 6L6 18" : "M4 7h16M4 12h16M4 17h16");
    };

    const openSheet = () => {
      if (!sheet || !panel) return;
      if (target && source && !target.innerHTML.trim()) target.innerHTML = source.innerHTML;
      sheet.classList.remove("hidden");
      sheet.dataset.open = "true";
      setMenuOpen(true);
      requestAnimationFrame(() => panel.classList.remove("translate-x-full"));
    };

    const closeSheet = () => {
      if (!sheet || !panel) return;
      panel.classList.add("translate-x-full");
      sheet.dataset.open = "false";
      setMenuOpen(false);
      setTimeout(() => sheet.classList.add("hidden"), 180);
    };

    openBtn?.addEventListener("click", openSheet);
    closeBtn?.addEventListener("click", closeSheet);
    overlay?.addEventListener("click", closeSheet);
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && sheet?.dataset.open === "true") closeSheet();
    });
  </script>
</BaseLayout>
