---
/* CONTRACT: Norwegian landing page with hero content and CES panel entrypoint. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/layout/Section.astro";
import Footer from "../../components/nav/Footer.astro";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
---

<BaseLayout title="VOX - Hørehjelpen" currentPath="/no">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_460px] lg:items-start">
      <aside class="order-1 lg:order-2 lg:sticky lg:top-6">
        <chat-messenger
          id="ces-widget"
          url-allowlist="*"
          class="block w-full rounded-[var(--radius-md)] bg-[rgb(var(--surface-elevated))] shadow-[var(--shadow-md)]"
          style="height:min(720px,calc(100vh - 6rem));"
        >
          <chat-messenger-container
            chat-title="Hørehjelpen"
            enable-file-upload
            enable-audio-input
          ></chat-messenger-container>
        </chat-messenger>
      </aside>

      <div class="order-2 lg:order-1">
        <Section class="!py-10 sm:!py-14 lg:flex lg:min-h-[min(58vh,520px)] lg:flex-col lg:justify-center">
          <div class="relative max-w-3xl">
            <div
              class="pointer-events-none absolute -inset-x-4 -inset-y-3 -z-10 rounded-[var(--radius-lg)] bg-gradient-to-br from-[rgb(var(--primary)/0.07)] via-transparent to-[rgb(var(--focus)/0.06)] sm:-inset-x-6 sm:-inset-y-4"
              aria-hidden="true"
            ></div>
            <h1
              class="font-display text-3xl font-semibold tracking-[-0.03em] text-balance sm:text-4xl lg:text-[2.5rem] lg:leading-tight"
            >
              Få høreapparatet tilbake i hverdagen
            </h1>
            <p class="mt-5 text-lg font-normal leading-relaxed text-[rgb(var(--text-secondary))]">
              Hørehjelpen gir deg korte, konkrete steg når teknikken frustrerer - og en trygg inngang når terskelen er høy.
              Du trenger ikke kunne alt for å starte.
            </p>
            <div class="mt-9 flex flex-wrap items-center gap-3">
              <button
                type="button"
                onclick="document.getElementById('ces-widget')?.scrollIntoView({behavior:'smooth', block:'start'}); document.getElementById('ces-widget')?.open?.(); document.getElementById('ces-widget')?.show?.();"
                class="sonic-pulse-cta inline-flex items-center justify-center rounded-[var(--radius-md)] px-6 py-3 text-sm font-semibold transition-shadow"
              >
                Start chat
              </button>
              <a
                href="/no/info"
                class="inline-flex items-center justify-center rounded-[var(--radius-md)] border border-[rgb(var(--border))] bg-[rgb(var(--surface-elevated))/0.55] px-6 py-3 text-sm font-medium text-[rgb(var(--text))] backdrop-blur-sm transition-colors hover:bg-[rgb(var(--surface-elevated))/0.85]"
              >
                Kom i gang
              </a>
            </div>
            <p class="mt-4 text-sm text-[rgb(var(--muted))]">
              Start med én setning. Vi tar resten stegvis.
            </p>
          </div>
        </Section>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
