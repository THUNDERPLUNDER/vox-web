---
/* CONTRACT: Editorial hub (E2) — «Lyd i hverdagen» production slice #125F.
   Situation-first: situasjoner → featured → artikler → AI seeds. Motflate til Hjelp A3.
   Arbeidstittel/rute — ikke i toppmeny ennå.
*/
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/nav/Footer.astro";
import "../../styles/r1-dialog-article.css";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const pageTitle = "Lyd i hverdagen";
const pageIntro =
  "Artikler, erfaringer og konkrete strategier for å leve bedre med høreapparat i hverdagen.";

const situations: Array<{ label: string; href: string }> = [
  { label: "Ny med høreapparat", href: "/no/artikkel/de-forste-ukene-med-horeapparat" },
  { label: "Sosialt liv", href: "/no/artikkel/slik-tar-du-praten" },
  { label: "På jobb", href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen" },
  { label: "For pårørende", href: "/no/artikkel/stotte-uten-a-ta-over-samtalen" },
  { label: "Lyd og energi", href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen" },
  { label: "Middag og støy", href: "/no/artikkel/for-restaurant-eller-stort-selskap" },
];

const featuredStory = {
  eyebrow: "Lyd og energi",
  title: "Den usynlige utmattelsen: hvorfor du er helt skutt etter jobb",
  deck:
    "Lyttetrøtthet er mer enn en dårlig dag. Slik kan du kjenne den igjen og gjøre hverdagen lettere.",
  href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
};

const articles: Array<{ series: string; title: string; href: string }> = [
  {
    series: "Erfaring",
    title: "Slik løste jeg middagsbordet",
    href: "/no/artikkel/for-restaurant-eller-stort-selskap",
  },
  {
    series: "Normalt?",
    title: "Hva som er normalt de første ukene",
    href: "/no/artikkel/de-forste-ukene-med-horeapparat",
  },
  {
    series: "Energi",
    title: "Når lyden blir for mye",
    href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
  },
  {
    series: "Relasjon",
    title: "Slik kan du be kollegaene dine hjelpe",
    href: "/no/artikkel/slik-tar-du-praten",
  },
  {
    series: "Forståelse",
    title: "Derfor blir hjernen sliten før apparatet er feil",
    href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
  },
];

const editorialSeeds = [
  "Snakk med Hørehjelpen om lyttetrøtthet",
  "Få forslag til hva jeg kan si til kollegaene mine",
  "Hjelp meg å forstå om dette er normalt",
];
---

<BaseLayout title={`Viddel - ${pageTitle}`} currentPath="/no/lyd-i-hverdagen" shellVariant="article">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="ed-page" data-editorial-hub>
    <div class="ed-container">

      <header class="ed-header">
        <nav class="ed-breadcrumb" aria-label="Du er her">
          <a href="/no">Forside</a>
          <span aria-hidden="true">/</span>
          <span>{pageTitle}</span>
        </nav>
        <p class="ed-kicker">{pageTitle}</p>
        <h1>{pageTitle}</h1>
        <p class="ed-lead">{pageIntro}</p>
      </header>

      <div class="ed-core">

        <section class="ed-block" aria-labelledby="situations-heading">
          <h2 id="situations-heading" class="ed-block__title">Hvor er du i hverdagen?</h2>
          <ul class="ed-situation-grid" role="list">
            {situations.map((situation) => (
              <li>
                <a href={situation.href} class="ed-situation-card">
                  <span class="ed-situation-card__label">{situation.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="ed-block" aria-labelledby="featured-heading">
          <h2 id="featured-heading" class="sr-only">Utvalgt artikkel</h2>
          <a href={featuredStory.href} class="ed-featured">
            <div class="ed-featured__media" aria-hidden="true"></div>
            <div class="ed-featured__body">
              <p class="ed-eyebrow">Utvalgt · {featuredStory.eyebrow}</p>
              <h3 class="ed-featured__title">{featuredStory.title}</h3>
              <p class="ed-featured__deck">{featuredStory.deck}</p>
            </div>
          </a>
        </section>

        <section class="ed-block" aria-labelledby="articles-heading">
          <h2 id="articles-heading" class="ed-block__title">Artikler og serier</h2>
          <ul class="ed-article-list" role="list">
            {articles.map((article) => (
              <li>
                <a href={article.href} class="ed-article-row">
                  <span class="ed-article-row__series">{article.series}</span>
                  <span class="ed-article-row__title">{article.title}</span>
                  <span class="ed-article-row__arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="ed-block ed-block--ai" aria-labelledby="ai-heading">
          <h2 id="ai-heading" class="ed-block__title">Videre samtale etter lesing</h2>
          <p class="ed-ai-intro">
            Spørsmål som videreføring av det du har lest — ikke supportboks.
          </p>
          <div class="ed-seed-bridge" data-r1-editorial>
            <section class="r1-ai-bridge">
              <section class="inline-chat-shell" data-inline-chat-mode="progressive">
                <div class="inline-chat-shell__seed-suggestions">
                  <ul class="inline-chat-shell__seed-list inline-chat-shell__seed-list--rows" role="list">
                    {editorialSeeds.map((seed) => (
                      <li class="inline-chat-shell__seed-item">
                        <a
                          href={`/no/chat?seed=${encodeURIComponent(seed)}&from=lyd-i-hverdagen`}
                          class="inline-chat-shell__seed-btn inline-chat-shell__seed-row"
                        >
                          <span class="inline-chat-shell__seed-question">{seed}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </section>
            </section>
          </div>
        </section>

        <footer class="ed-help-link">
          <p>
            Trenger du rask problemløsning?
            <a href="/no/hub/">Gå til Hjelp</a>
          </p>
        </footer>

      </div>
    </div>
  </main>

  <Footer variant="article" />
</BaseLayout>

<style>
  [data-editorial-hub] {
    background: rgb(var(--article-page-canvas));
    min-height: 100vh;
  }

  .ed-container {
    max-width: min(100%, 52rem);
    margin: 0 auto;
    padding: 0 1rem 4.5rem;
  }

  .ed-header {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(1.75rem, 4vw, 2.5rem);
    border-bottom: 1px solid rgb(var(--border) / 0.2);
  }

  .ed-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary) / 0.6);
  }

  .ed-breadcrumb a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ed-kicker {
    margin: 0 0 0.55rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  [data-editorial-hub] h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 7vw, 3.8rem);
    font-weight: 650;
    line-height: 0.99;
    letter-spacing: -0.065em;
    text-wrap: balance;
    color: rgb(var(--reading-ink));
  }

  .ed-lead {
    margin: clamp(0.9rem, 2.5vw, 1.35rem) 0 0;
    max-width: 40rem;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.55;
    letter-spacing: -0.01em;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-core {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ed-block {
    padding: clamp(1.75rem, 4.5vw, 2.35rem) 0;
    border-bottom: 1px solid rgb(var(--border) / 0.14);
  }

  .ed-block:last-of-type {
    border-bottom: 0;
  }

  .ed-block__title {
    margin: 0 0 1rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary));
  }

  /* Situations */
  .ed-situation-grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .ed-situation-card {
    display: flex;
    align-items: center;
    min-height: 3.5rem;
    padding: 0.75rem 0.85rem;
    border-radius: 10px;
    border: 1px solid rgb(var(--border) / 0.18);
    background: rgb(var(--reading-paper));
    color: inherit;
    text-decoration: none;
    transition: box-shadow 150ms ease, border-color 150ms ease, transform 150ms ease;
  }

  .ed-situation-card:hover {
    border-color: rgb(var(--border) / 0.35);
    box-shadow: 0 3px 16px rgb(var(--reading-ink) / 0.05);
    transform: translateY(-1px);
  }

  .ed-situation-card:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-situation-card__label {
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.3;
    color: rgb(var(--reading-ink));
  }

  /* Featured */
  .ed-featured {
    display: grid;
    gap: 1.15rem;
    color: inherit;
    text-decoration: none;
    transition: opacity 120ms ease;
  }

  .ed-featured:hover {
    opacity: 0.92;
  }

  .ed-featured:focus-visible {
    outline: none;
    border-radius: 10px;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-featured__media {
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    background:
      linear-gradient(145deg, rgb(19 77 106 / 0.28), rgb(148 163 184 / 0.18)),
      linear-gradient(160deg, rgb(30 58 80 / 0.12), rgb(253 252 250));
  }

  .ed-eyebrow {
    margin: 0;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-featured__title {
    margin: 0.45rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 4vw, 1.9rem);
    font-weight: 650;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: rgb(var(--reading-ink));
  }

  .ed-featured__deck {
    margin: 0.65rem 0 0;
    max-width: 38rem;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  /* Articles */
  .ed-article-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.45rem;
  }

  .ed-article-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.45rem 0.85rem;
    align-items: baseline;
    padding: 0.75rem 0.85rem;
    border-radius: 8px;
    background: rgb(var(--reading-paper));
    border: 1px solid rgb(var(--border) / 0.16);
    color: inherit;
    text-decoration: none;
    transition: background-color 120ms ease, border-color 120ms ease;
  }

  .ed-article-row:hover {
    background: rgb(var(--border) / 0.1);
    border-color: rgb(var(--border) / 0.3);
  }

  .ed-article-row:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-article-row__series {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  .ed-article-row__title {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 650;
    letter-spacing: -0.025em;
    line-height: 1.3;
    color: rgb(var(--reading-ink));
  }

  .ed-article-row__arrow {
    color: rgb(var(--muted));
    font-size: 0.85rem;
  }

  /* AI seeds */
  .ed-block--ai {
    padding-bottom: clamp(1.25rem, 3vw, 1.75rem);
  }

  .ed-ai-intro {
    margin: -0.35rem 0 0.85rem;
    font-size: 0.86rem;
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-seed-bridge {
    padding: 0.85rem;
    border-radius: 10px;
    background: rgb(var(--reading-paper));
  }

  .ed-seed-bridge .inline-chat-shell__seed-row {
    text-decoration: none;
    color: inherit;
  }

  /* Hjelp cross-link */
  .ed-help-link {
    padding: 1.25rem 0 0.5rem;
    border-top: 1px solid rgb(var(--border) / 0.12);
  }

  .ed-help-link p {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-help-link a {
    margin-left: 0.25rem;
    font-weight: 600;
    color: rgb(var(--reading-ink));
    text-underline-offset: 2px;
  }

  .ed-help-link a:hover {
    color: rgb(var(--reading-accent-iris));
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 479px) {
    .ed-situation-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 480px) {
    .ed-container {
      padding: 0 1.25rem 5rem;
    }
  }

  @media (min-width: 640px) {
    .ed-container {
      padding: 0 1.75rem 5.5rem;
    }

    .ed-situation-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ed-featured {
      grid-template-columns: 1.15fr 1fr;
      align-items: start;
      gap: 1.35rem;
    }

    .ed-featured__media {
      aspect-ratio: 4 / 5;
      max-height: 14rem;
    }
  }
</style>
