---
/* CONTRACT: Editorial hub (E2) — «Lyd i hverdagen» #125F / #125F-R3.
   Situasjonskort → featured → artikkelkort → AI seeds. Motflate til Hjelp A3.
   Hero uten metaintro — innganger og kort bærer innholdet.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/nav/Footer.astro";
import "../../styles/r1-dialog-article.css";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const pageTitle = "Lyd i hverdagen";

const situations: Array<{ label: string; hint: string; href: string }> = [
  {
    label: "Ny med høreapparat",
    hint: "Forventninger, tilvenning og de første ukene.",
    href: "/no/artikkel/de-forste-ukene-med-horeapparat",
  },
  {
    label: "Små lyder og lydglede",
    hint: "Fugler, regn, musikk, stemmer og det som gjør verden nær.",
    href: "/no/artikkel/fra-skuff-til-daglig-bruk",
  },
  {
    label: "Sosialt liv og samtaler",
    hint: "Middag, restaurant, familie og støy.",
    href: "/no/artikkel/for-restaurant-eller-stort-selskap",
  },
  {
    label: "Lyd og energi",
    hint: "Når hjernen blir sliten, og hvordan du kan ta pauser.",
    href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
  },
  {
    label: "På jobb",
    hint: "Møter, Teams, kollegaer og konsentrasjon.",
    href: "/no/artikkel/slik-tar-du-praten",
  },
  {
    label: "For pårørende",
    hint: "Hvordan støtte uten å presse.",
    href: "/no/artikkel/stotte-uten-a-ta-over-samtalen",
  },
];

const featuredStory = {
  eyebrow: "Lyd og energi",
  title: "Den usynlige utmattelsen: hvorfor du er helt skutt etter jobb",
  deck:
    "Lyttetrøtthet er mer enn en dårlig dag. Slik kan du kjenne den igjen og gjøre hverdagen lettere.",
  href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
};

const articles: Array<{
  series: string;
  title: string;
  deck: string;
  visual: string;
  href: string;
}> = [
  {
    series: "Erfaring",
    title: "Slik løste jeg middagsbordet",
    deck: "Erfaringer fra et støyende bord — uten å gi opp sosialt liv.",
    visual: "social",
    href: "/no/artikkel/for-restaurant-eller-stort-selskap",
  },
  {
    series: "Normalt?",
    title: "Hva som er normalt de første ukene",
    deck: "Forventninger, tilpasning og tegn på at ting går riktig vei.",
    visual: "start",
    href: "/no/artikkel/de-forste-ukene-med-horeapparat",
  },
  {
    series: "Energi",
    title: "Når lyden blir for mye",
    deck: "Hvorfor dagen kan føles tyngre — og hva som hjelper.",
    visual: "energy",
    href: "/no/artikkel/lyden-blir-slitsom-utpa-dagen",
  },
  {
    series: "Relasjon",
    title: "Slik kan du be kollegaene dine hjelpe",
    deck: "Ord og små grep som gjør hverdagen på jobb enklere.",
    visual: "work",
    href: "/no/artikkel/slik-tar-du-praten",
  },
  {
    series: "Lydglede",
    title: "Små lyder som gjør verden nær",
    deck: "Fugler, regn, musikk og stemmer — og hvordan du kan legge merke til dem.",
    visual: "joy",
    href: "/no/artikkel/fra-skuff-til-daglig-bruk",
  },
];

const editorialSeeds = [
  "Snakk med Hørehjelpen om lyttetrøtthet",
  "Få forslag til hva jeg kan si til kollegaene mine",
  "Hjelp meg å forstå om dette er normalt",
];
---

<BaseLayout title={`Viddel - ${pageTitle}`} currentPath="/no/lyd-i-hverdagen" shellVariant="article">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="ed-page" data-editorial-hub>
    <div class="ed-container">

      <header class="ed-header">
        <nav class="ed-breadcrumb" aria-label="Du er her">
          <a href="/no">Forside</a>
          <span aria-hidden="true">/</span>
          <span>{pageTitle}</span>
        </nav>
        <p class="ed-kicker">{pageTitle}</p>
        <h1>{pageTitle}</h1>
      </header>

      <div class="ed-core">

        <section class="ed-block ed-block--situations" aria-label="Temaer i hverdagen">
          <ul class="ed-situation-grid" role="list">
            {situations.map((situation) => (
              <li>
                <a href={situation.href} class="ed-situation-card">
                  <span class="ed-situation-card__label">{situation.label}</span>
                  <span class="ed-situation-card__hint">{situation.hint}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="ed-block ed-block--featured" aria-labelledby="featured-heading">
          <h2 id="featured-heading" class="ed-block__title">Utvalgt nå</h2>
          <a href={featuredStory.href} class="ed-featured">
            <div class="ed-featured__media" aria-hidden="true"></div>
            <div class="ed-featured__body">
              <p class="ed-eyebrow">{featuredStory.eyebrow}</p>
              <h3 class="ed-featured__title">{featuredStory.title}</h3>
              <p class="ed-featured__deck">{featuredStory.deck}</p>
            </div>
          </a>
        </section>

        <section class="ed-block" aria-labelledby="articles-heading">
          <h2 id="articles-heading" class="ed-block__title">Artikler og serier</h2>
          <ul class="ed-article-grid" role="list">
            {articles.map((article) => (
              <li>
                <a href={article.href} class="ed-article-card" data-visual={article.visual}>
                  <span class="ed-article-card__visual" aria-hidden="true"></span>
                  <span class="ed-article-card__body">
                    <span class="ed-article-card__series">{article.series}</span>
                    <span class="ed-article-card__title">{article.title}</span>
                    <span class="ed-article-card__deck">{article.deck}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="ed-block ed-block--ai" aria-labelledby="ai-heading">
          <h2 id="ai-heading" class="ed-block__title">Videre samtale etter lesing</h2>
          <p class="ed-ai-intro">
            Spørsmål som videreføring av det du har lest — ikke supportboks.
          </p>
          <div class="ed-seed-bridge" data-r1-editorial>
            <section class="r1-ai-bridge">
              <section class="inline-chat-shell" data-inline-chat-mode="progressive">
                <div class="inline-chat-shell__seed-suggestions">
                  <ul class="inline-chat-shell__seed-list inline-chat-shell__seed-list--rows" role="list">
                    {editorialSeeds.map((seed) => (
                      <li class="inline-chat-shell__seed-item">
                        <a
                          href={`/no/chat?seed=${encodeURIComponent(seed)}&from=lyd-i-hverdagen`}
                          class="inline-chat-shell__seed-btn inline-chat-shell__seed-row"
                        >
                          <span class="inline-chat-shell__seed-question">{seed}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </section>
            </section>
          </div>
        </section>

        <footer class="ed-help-link">
          <p>
            Trenger du rask problemløsning?
            <a href="/no/hub/">Gå til Hjelp</a>
          </p>
        </footer>

      </div>
    </div>
  </main>

  <Footer variant="article" />
</BaseLayout>

<style>
  [data-editorial-hub] {
    background: rgb(var(--article-page-canvas));
    min-height: 100vh;
  }

  .ed-container {
    max-width: min(100%, 52rem);
    margin: 0 auto;
    padding: 0 1rem 4.5rem;
  }

  .ed-header {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(1.25rem, 3vw, 1.75rem);
    border-bottom: 1px solid rgb(var(--border) / 0.2);
  }

  .ed-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary) / 0.6);
  }

  .ed-breadcrumb a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ed-kicker {
    margin: 0 0 0.55rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  [data-editorial-hub] h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 7vw, 3.8rem);
    font-weight: 650;
    line-height: 0.99;
    letter-spacing: -0.065em;
    text-wrap: balance;
    color: rgb(var(--reading-ink));
  }

  .ed-core {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ed-block {
    padding: clamp(1.75rem, 4.5vw, 2.35rem) 0;
    border-bottom: 1px solid rgb(var(--border) / 0.14);
  }

  .ed-block:last-of-type {
    border-bottom: 0;
  }

  .ed-block__title {
    margin: 0 0 0.55rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-block--situations {
    padding-top: clamp(1.5rem, 4vw, 2rem);
  }

  /* Situations — self-explanatory cards, no section instruction */
  .ed-situation-grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .ed-situation-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-height: 4.25rem;
    padding: 0.85rem 0.9rem;
    border-radius: 10px;
    border: 1px solid rgb(var(--border) / 0.14);
    background: transparent;
    color: inherit;
    text-decoration: none;
    transition: background-color 150ms ease, border-color 150ms ease;
  }

  .ed-situation-card:hover {
    background: rgb(var(--reading-paper));
    border-color: rgb(var(--border) / 0.28);
  }

  .ed-situation-card:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-situation-card__label {
    font-size: 0.9rem;
    font-weight: 650;
    letter-spacing: -0.025em;
    line-height: 1.25;
    color: rgb(var(--reading-ink));
  }

  .ed-situation-card__hint {
    font-size: 0.78rem;
    line-height: 1.4;
    color: rgb(var(--reading-ink-secondary));
  }

  /* Featured — stacked, media-first editorial weight */
  .ed-block--featured {
    padding-top: clamp(2rem, 5vw, 2.75rem);
  }

  .ed-featured {
    display: flex;
    flex-direction: column;
    gap: 0;
    color: inherit;
    text-decoration: none;
    border-radius: 12px;
    overflow: hidden;
    background: rgb(var(--reading-paper));
    border: 1px solid rgb(var(--border) / 0.12);
    transition: box-shadow 180ms ease, border-color 180ms ease;
  }

  .ed-featured:hover {
    border-color: rgb(var(--border) / 0.28);
    box-shadow: 0 8px 32px rgb(var(--reading-ink) / 0.06);
  }

  .ed-featured:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-featured__media {
    aspect-ratio: 16 / 9;
    min-height: 11rem;
    background:
      linear-gradient(145deg, rgb(19 77 106 / 0.38), rgb(95 82 220 / 0.14)),
      linear-gradient(165deg, rgb(30 58 80 / 0.18), rgb(253 252 250));
  }

  .ed-featured__body {
    padding: clamp(1.15rem, 3vw, 1.5rem) clamp(1.1rem, 3vw, 1.45rem) clamp(1.35rem, 3.5vw, 1.65rem);
  }

  .ed-eyebrow {
    margin: 0;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  .ed-featured__title {
    margin: 0.5rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 4.5vw, 2.15rem);
    font-weight: 650;
    letter-spacing: -0.045em;
    line-height: 1.08;
    text-wrap: balance;
    color: rgb(var(--reading-ink));
  }

  .ed-featured__deck {
    margin: 0.75rem 0 0;
    max-width: 40rem;
    font-size: clamp(0.92rem, 2.2vw, 1.02rem);
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  /* Article cards — editorial, not FAQ rows */
  .ed-article-grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1rem;
  }

  .ed-article-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    color: inherit;
    text-decoration: none;
    border-radius: 10px;
    overflow: hidden;
    background: rgb(var(--reading-paper));
    border: 1px solid rgb(var(--border) / 0.12);
    transition: box-shadow 150ms ease, border-color 150ms ease, transform 150ms ease;
  }

  .ed-article-card:hover {
    border-color: rgb(var(--border) / 0.28);
    box-shadow: 0 4px 18px rgb(var(--reading-ink) / 0.05);
    transform: translateY(-1px);
  }

  .ed-article-card:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgb(14 165 233 / 0.32);
  }

  .ed-article-card__visual {
    display: block;
    height: 5.5rem;
    background: linear-gradient(145deg, rgb(19 77 106 / 0.12), rgb(224 242 254 / 0.45));
  }

  [data-visual="social"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(95 82 220 / 0.14), rgb(238 235 255));
  }

  [data-visual="start"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(14 165 233 / 0.14), rgb(234 246 255));
  }

  [data-visual="energy"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(19 77 106 / 0.16), rgb(243 241 255));
  }

  [data-visual="work"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(96 165 250 / 0.14), rgb(248 250 255));
  }

  [data-visual="mind"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(200 192 176 / 0.22), rgb(252 250 245));
  }

  [data-visual="joy"] .ed-article-card__visual {
    background: linear-gradient(145deg, rgb(34 197 94 / 0.16), rgb(234 246 255 / 0.55));
  }

  .ed-article-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 0.95rem 1rem;
  }

  .ed-article-card__series {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--reading-accent-iris));
  }

  .ed-article-card__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.22;
    color: rgb(var(--reading-ink));
  }

  .ed-article-card__deck {
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgb(var(--reading-ink-secondary));
  }

  /* AI seeds */
  .ed-block--ai {
    padding-bottom: clamp(1.25rem, 3vw, 1.75rem);
  }

  .ed-ai-intro {
    margin: -0.15rem 0 0.85rem;
    font-size: 0.86rem;
    line-height: 1.6;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-seed-bridge {
    padding: 0.85rem;
    border-radius: 10px;
    background: rgb(var(--reading-paper));
  }

  .ed-seed-bridge .inline-chat-shell__seed-row {
    text-decoration: none;
    color: inherit;
  }

  /* Hjelp cross-link */
  .ed-help-link {
    padding: 1.25rem 0 0.5rem;
    border-top: 1px solid rgb(var(--border) / 0.12);
  }

  .ed-help-link p {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: rgb(var(--reading-ink-secondary));
  }

  .ed-help-link a {
    margin-left: 0.25rem;
    font-weight: 600;
    color: rgb(var(--reading-ink));
    text-underline-offset: 2px;
  }

  .ed-help-link a:hover {
    color: rgb(var(--reading-accent-iris));
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 479px) {
    .ed-situation-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 480px) {
    .ed-container {
      padding: 0 1.25rem 5rem;
    }

    .ed-article-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 640px) {
    .ed-container {
      padding: 0 1.75rem 5.5rem;
    }

    .ed-situation-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ed-featured__media {
      aspect-ratio: 21 / 9;
      min-height: 14rem;
    }
  }
</style>
