---
/* CONTRACT: First real R3 spoke wired into ArticleTemplateV01 using Faglig Fokus preset for pilot QA. */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Footer from "../../../components/nav/Footer.astro";
import ArticleTemplateV01 from "../../../components/article/ArticleTemplateV01.astro";
import "../../../styles/article-system.css";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const r3Article = {
  title: "Naar samtaler bryter sammen ved hørselstap - faglig forklaring og praktiske grep",
  ingress:
    "R3 tester Faglig Fokus med mer forklarende innhold. Maalet er aa vise hvordan belastning, akustikk og samspillsmoenstre paavirker samtaler over tid.",
  preset: "faglig-fokus" as const,
  articleType: "spoke",
  hub: "Bedre lyd i hverdagen",
  sourceTrustType: "faglig forankret med redaksjonell kvalitetssjekk",
  relatedTopics: ["Akustikk", "Kommunikasjon", "Hoeretretthet", "Relasjoner"],
  aiSeedGroup: "hearing-conversation-v1",
  body: [
    "Ved hørselstap oppstaar ofte det som beskrives som lyttebelastning: hjernen bruker mer kapasitet paa aa tolke ufullstendig tale, spesielt i stoy eller ved flere samtidige stemmer.",
    "Denne belastningen gir ofte forsinket respons, kortere svar og hyppigere misforstaaelser. For omgivelsene kan det se ut som lav interesse, mens det i praksis handler om redusert kognitivt overskudd i situasjonen.",
    "I relasjoner skaper dette lett en negativ sirkel: den ene strammer til budskapet for aa bli forstaa, den andre trekker seg tilbake for aa hente kapasitet, og begge opplever at samtalen blir mer krevende enn temaet tilsier.",
    "Faglig sett er det nyttig aa skille mellom lydstyrke og taleoppfattelse. Mange kan høre at noe blir sagt, men ikke skille ordene tydelig nok til trygg tolkning.",
    "Tiltak med best lavterskeleffekt er ofte kontekstuelle: roligere samtalerom, tydeligere turtaking, kortere setninger og eksplisitt avklaring av hva som ble oppfattet riktig.",
    "R3 i malen viser at Faglig Fokus kan baere mer resonnerende tekst uten aa miste leseflyt, samtidig som railen gir plass til forklarende støtte uten aa bryte hovedspor.",
  ],
  footerTitle: "Faglig kortoppsummering",
  footerText:
    "Naar samtaler blir krevende ved hørselstap, handler det ofte om samlet belastning over tid. Små strukturelle grep i omgivelser og samtaleform kan gi merkbar forbedring.",
  railItems: [
    {
      eyebrow: "Begrep",
      title: "Lyttebelastning",
      body: "Hoey kognitiv innsats for aa tolke tale i krevende lyttemiljoeer. Gir raskere utmattelse, spesielt i lange samtaler.",
    },
    {
      eyebrow: "Faglig grep",
      title: "Lydstyrke vs taleoppfattelse",
      body: "Hoeyere volum alene loeser ikke alltid problemet. Tydelig artikulasjon, tempo og romakustikk er ofte viktigere.",
    },
    {
      eyebrow: "Praktisk konsekvens",
      title: "Samtalestruktur",
      body: "Avtal turtaking, oppsummer kort underveis og verifiser forstaaelse. Dette reduserer friksjon i naere relasjoner.",
    },
  ],
};
---

<BaseLayout title="VOX - R3 spoke v0.1" currentPath="/no/hubs" shellVariant="article">
  <meta slot="head" name="robots" content="noindex,follow" />
  <main class="bg-[rgb(var(--article-page-canvas))] py-8 sm:py-10" data-article-system>
    <div class="px-4 sm:px-6">
      <nav class="mx-auto mb-7 max-w-6xl text-[11px] font-medium uppercase tracking-[0.14em] text-[rgb(var(--reading-ink-secondary))]" aria-label="Du er her">
        <a href="/no" class="underline-offset-2 hover:text-[rgb(var(--reading-ink))] hover:underline">Forside</a>
        <span class="mx-1.5 text-[rgb(var(--border))]" aria-hidden="true">/</span>
        <a href="/no/hubs" class="underline-offset-2 hover:text-[rgb(var(--reading-ink))] hover:underline">Emnehuber</a>
        <span class="mx-1.5 text-[rgb(var(--border))]" aria-hidden="true">/</span>
        <span class="text-[rgb(var(--reading-ink))]">R3 artikkel</span>
      </nav>

      <ArticleTemplateV01 {...r3Article} />
    </div>
  </main>
  <Footer variant="article" />
</BaseLayout>
