---
/* CONTRACT: First real R3 spoke wired into ArticleTemplateV01 using Faglig Fokus preset for pilot QA. */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import InspectDrawerArmScript from "../../../components/dev/InspectDrawerArmScript.astro";
import InspectToolsDrawer from "../../../components/dev/InspectToolsDrawer.astro";
import Footer from "../../../components/nav/Footer.astro";
import ArticleTemplateV01 from "../../../components/article/ArticleTemplateV01.astro";
import "../../../styles/article-system.css";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
const r3Article = {
  title: "Når samtaler bryter sammen ved hørselstap - faglig forklaring og praktiske grep",
  ingress:
    "En faglig inngang til hvordan belastning, akustikk og samspill påvirker samtaler når hørselen er redusert — og hvilke grep som ofte hjelper i praksis.",
  preset: "faglig-fokus" as const,
  articleType: "spoke",
  hub: "Bedre lyd i hverdagen",
  sourceTrustType: "faglig forankret med redaksjonell kvalitetssjekk",
  relatedTopics: ["Akustikk", "Kommunikasjon", "Høretretthet", "Relasjoner"],
  aiSeedGroup: "hearing-conversation-v1",
  body: [
    "Ved hørselstap oppstår ofte det som beskrives som lyttebelastning: hjernen bruker mer kapasitet på å tolke ufullstendig tale, spesielt i støy eller ved flere samtidige stemmer.",
    "Denne belastningen gir ofte forsinket respons, kortere svar og hyppigere misforståelser. For omgivelsene kan det se ut som lav interesse, mens det i praksis handler om redusert kognitivt overskudd i situasjonen.",
    "I relasjoner skaper dette lett en negativ sirkel: den ene strammer til budskapet for å bli forstått, den andre trekker seg tilbake for å hente kapasitet, og begge opplever at samtalen blir mer krevende enn temaet tilsier.",
    "Faglig sett er det nyttig å skille mellom lydstyrke og taleoppfattelse. Mange kan høre at noe blir sagt, men ikke skille ordene tydelig nok til trygg tolkning.",
    "Tiltak med best lavterskeleffekt er ofte kontekstuelle: roligere samtalerom, tydeligere turtaking, kortere setninger og eksplisitt avklaring av hva som ble oppfattet riktig.",
    "Når du kjenner igjen mønstrene, blir det enklere å teste små grep — i rommet, i tempoet og i hvordan dere avklarer hva som ble hørt.",
  ],
  footerTitle: "Faglig kortoppsummering",
  footerText:
    "Når samtaler blir krevende ved hørselstap, handler det ofte om samlet belastning over tid. Små strukturelle grep i omgivelser og samtaleform kan gi merkbar forbedring.",
  railItems: [
    {
      eyebrow: "Begrep",
      title: "Lyttebelastning",
      body: "Høy kognitiv innsats for å tolke tale i krevende lyttemiljøer. Gir raskere utmattelse, spesielt i lange samtaler.",
    },
    {
      eyebrow: "Faglig grep",
      title: "Lydstyrke vs taleoppfattelse",
      body: "Høyere volum alene løser ikke alltid problemet. Tydelig artikulasjon, tempo og romakustikk er ofte viktigere.",
    },
    {
      eyebrow: "Praktisk konsekvens",
      title: "Samtalestruktur",
      body: "Avtal turtaking, oppsummer kort underveis og verifiser forståelse. Dette reduserer friksjon i nære relasjoner.",
    },
  ],
};
---

<BaseLayout title="Viddel - R3 spoke v0.1" currentPath="/no/artikkel/r3-spoke-v01" shellVariant="article">
  <InspectDrawerArmScript />
  <meta slot="head" name="robots" content="noindex,follow" />
  <main class="bg-[rgb(var(--article-page-canvas))] py-8 sm:py-10" data-article-system>
    <div class="px-4 sm:px-6">
      <nav class="mx-auto mb-7 max-w-6xl text-[11px] font-medium uppercase tracking-[0.14em] text-[rgb(var(--reading-ink-secondary))]" aria-label="Du er her">
        <a href="/no" class="underline-offset-2 hover:text-[rgb(var(--reading-ink))] hover:underline">Forside</a>
        <span class="mx-1.5 text-[rgb(var(--border))]" aria-hidden="true">/</span>
        <a href="/no/hubs" class="underline-offset-2 hover:text-[rgb(var(--reading-ink))] hover:underline">Emnehuber</a>
        <span class="mx-1.5 text-[rgb(var(--border))]" aria-hidden="true">/</span>
        <span class="text-[rgb(var(--reading-ink))]">R3 artikkel</span>
      </nav>

      <ArticleTemplateV01 {...r3Article} />
    </div>
  </main>
  <InspectToolsDrawer />
  <Footer variant="article" withInspectDrawer />
</BaseLayout>
