---
/* CONTRACT: R1 spoke v0.3 — dialog-artikkel (én kolonne #82), handlingsbro som artikkelavslutning, divider over Article AI, ingen terminal Footer. */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import InspectToolsDrawer from "../../../components/dev/InspectToolsDrawer.astro";
import ArticleTemplateV01 from "../../../components/article/ArticleTemplateV01.astro";
import ArticleInlineChatShell from "../../../components/article/ArticleInlineChatShell.astro";
import "../../../styles/article-system.css";

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
/** Relaterte tema vises tidlig (etter byline/metadata), ikke i handlingsbroen før Article AI. */
const r1RelatedTopics = ["Samtaletips", "Høreliv", "Hverdagskommunikasjon"] as const;
const r1Article = {
  title: "Når hørselen endrer samtalen, og hvordan du kan møte det med mer overskudd",
  ingress:
    "Når hørselen blir mer krevende i hverdagen, kan samtaler føles tyngre enn før. Her får du en rolig oversikt over hvorfor det skjer, og små grep som kan gjøre det lettere.",
  preset: "standard" as const,
  articleType: "spoke",
  hub: "Bedre lyd i hverdagen",
  sourceTrustType: "redaksjonelt kvalitetssjekket med faglig orientering",
  aiSeedGroup: "hearing-conversation-v1",
  body: [
    "Hørsel handler ikke bare om volum. Det handler også om hvor mye energi du bruker på å fylle inn det du ikke fikk med deg, og hvor raskt du blir sliten av støy, flere stemmer eller dårlig akustikk.",
    "For pårørende kan dette se ut som manglende interesse. For den som strever med å høre, kan det føles som skam eller frustrasjon over å måtte spørre om igjen.",
    "Et nyttig perspektiv er å skille mellom intensjon og effekt: du kan ønske å være til stede, men likevel oppleves som distansert fordi du bruker mye kapasitet på å følge med.",
    "Små grep hjelper ofte: senk tempoet, del opp setninger, flytt samtalen til et roligere sted og vær tydelig på hva du trenger i øyeblikket.",
    "Pause er ikke det samme som å gi opp. En kort avtale om å fortsette samtalen senere kan være mer omsorgsfullt enn å presse alt gjennom når begge er slitne.",
    "Når samtalen blir tydeligere og tempoet roligere, blir det ofte lettere å forstå hverandre uten at noen må «holde maska».",
  ],
  bodyHeading: "Når hørselen påvirker samtalen",
  footerTitle: "Dette kan du ta med deg videre",
  footerText:
    "Små justeringer i tempo, plassering og forventninger kan gjøre samtaler mer skånsomme. Start med ett grep om gangen.",
  trustAuthors: [
    { name: "Nora Lysvik", role: "faglig rådgiver", href: "#" },
    { name: "KlarLyd Redaksjon", role: "redaksjonell fagjournalist", href: "#" },
  ],
  trustPublished: "03. feb 2026, 06:30",
  trustUpdated: "25. mar 2026, 16:04",
  trustShowActions: true,
  trustActionLinks: [
    { label: "Forside", href: "/no" },
    { label: "Emnehuber", href: "/no/hubs" },
    { label: "R1 artikkel v03" },
  ],
  trustAvatarSrc: "/images/klarlyd/r1-byline-profile.png",
  trustAvatarAlt: "Redaksjonell avatar",
  figureAfterTrust: true,
  ingressAfterFigure: true,
  figureImage: {
    src: "/images/klarlyd/r1-storlom-test.png",
    alt: "Storlom i disig fjordlandskap som visualiserer stillhet, fokus og ettertanke.",
    caption: "Testbilde i editorial layer: storlom i fjordlandskap, brukt for å validere bildeplassering i leserommet.",
  },
};

const bridgeQuestions = [
  {
    question:
      "Hvordan kan jeg forklare mine behov i en samtale uten at det blir konflikt eller misforståelser?",
  },
  {
    question:
      "Hvilket første grep bør vi teste hjemme denne uken for å få roligere og tydeligere samtaler?",
  },
  {
    question:
      "Kan du hjelpe meg lage en kort plan for hva vi gjør når samtalen låser seg i støy eller stress?",
  },
];
---

<BaseLayout
  title="KLARLYD - R1 spoke v0.3"
  currentPath="/no/hubs"
  shellVariant="article"
  headerBrand="klarlyd"
  showHeaderDevtoolsToggle
>
  <script is:inline slot="head">
    (function () {
      try {
        var q = new URLSearchParams(window.location.search);
        var qOn = q.get("inspect") === "components" || q.get("devtools") === "true";
        var armed = null;
        try {
          armed = sessionStorage.getItem("vox-devtools-armed");
        } catch (e) {}
        var on = qOn || armed === "1";
        document.documentElement.setAttribute("data-vox-inspect-drawer-active", on ? "true" : "false");
      } catch (e) {
        document.documentElement.setAttribute("data-vox-inspect-drawer-active", "false");
      }
    })();
  </script>
  <meta slot="head" name="robots" content="noindex,follow" />
  <main class="bg-[rgb(var(--article-page-canvas))] py-2 sm:py-3" data-article-system data-r1-editorial>
    <span class="article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950" data-component-label>
      R1PageMain
    </span>
    <div class="px-4 sm:px-6">
      <section class="r1-orientation mx-auto mb-7 max-w-[min(100%,46rem)] px-0.5 py-1">
        <span class="article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950" data-component-label>
          OrientationBlock
        </span>
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[rgb(var(--reading-ink-secondary))]">Produktanatomi v0.3 test</p>
        <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--reading-ink-secondary))]">
          Les artikkelen først. Når du velger et spørsmål (eller fri samtale), åpnes chatten direkte under i samme kontekst.
        </p>
      </section>

      <ArticleTemplateV01 {...r1Article}>
        <section
          slot="after-trust"
          class="r1-early-topics ams-zone px-0.5 pb-1 pt-0.5"
          data-component="RelatedTopicsEarly"
        >
          <span class="article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950" data-component-label>
            RelatedTopicsEarly
          </span>
          <div class="r1-early-topics__inline" role="group" aria-label="Relaterte tema">
            <span id="r1-related-topics-label" class="r1-early-topics__label">Relaterte tema</span>
            <ul class="r1-early-topics__list" role="list" aria-labelledby="r1-related-topics-label">
              {r1RelatedTopics.map((topic) => (
                <li>{topic}</li>
              ))}
            </ul>
          </div>
        </section>
        <section slot="before-summary" class="r1-ai-bridge ams-zone px-0.5 py-1" data-component="PromptBridgeInArticle">
          <span class="article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950" data-component-label>
            PromptBridge
          </span>
          <hr class="r1-article-to-klarlyd-divider" aria-hidden="true" />
          <ArticleInlineChatShell
            title="Spør KlarLyd:"
            headingId="r1-continue-v03"
            items={bridgeQuestions}
            sourceLabel="r1-spoke-v03"
            mode="progressive"
          />
        </section>
      </ArticleTemplateV01>

      <aside class="r1-component-inventory mx-auto mt-6 max-w-[min(100%,46rem)]" data-component="ComponentInventory">
        <span class="article-component-label mb-2 inline-flex rounded border border-yellow-700/70 bg-yellow-100/95 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-yellow-950" data-component-label>
          ComponentInventory
        </span>
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[rgb(var(--reading-ink-secondary))]">Komponenter i bruk</p>
        <ul class="mt-2 flex flex-wrap gap-1.5 text-[11px] text-[rgb(var(--reading-ink-secondary))]">
          <li>ArticleTemplate</li><li>ArticleHeader</li><li>ArticleTrustBlock</li><li>ArticleFigurePlaceholder</li>
          <li>ArticleIngress</li><li>ArticleBody</li><li>RelatedTopicsEarly</li><li>ArticleSummary</li><li>ArticleInlineChatShell</li><li>InlineChatSeeds</li>
          <li>InlineChatProgressiveState</li><li>InlineChatMessenger</li><li>BreadcrumbNav</li><li>OrientationBlock</li><li>PromptBridge</li>
        </ul>
      </aside>
    </div>
  </main>
  <InspectToolsDrawer />
  <script is:inline>
    (() => {
      const attachInfo = (selector, text, placement = "top-right") => {
        const target = document.querySelector(selector);
        if (!target || target.querySelector("[data-component-info]")) return;
        const badge = document.createElement("span");
        badge.className = `r1-inspect-info-badge r1-inspect-info-badge--${placement}`;
        badge.setAttribute("data-component-info", "");
        badge.textContent = text;
        target.append(badge);
      };
      attachInfo(
        '[data-component="ArticleHeader"]',
        "Standard · Type: spoke · Hub: Bedre lyd i hverdagen"
      );
      attachInfo(
        '[data-component="ArticleInlineChatShell"]',
        "Kontekst: r1-spoke-v03 · Velg et startspørsmål for å åpne samtalen.",
        "bottom-left"
      );
    })();
  </script>
  <style is:global>
    [data-r1-editorial] {
      position: relative;
      --r1-ai-dialog-measure: min(100%, 46rem);
      --r1-ai-user-measure: min(92%, 32rem);
      --r1-ai-input-radius: 1.15rem;
      --r1-ai-user-surface: #f4f5f7;
      --r1-ai-seed-hover-surface: rgb(248 250 252 / 0.72);
    }

    html[data-inspect-components="true"] [data-r1-editorial] [data-component] {
      position: relative;
    }

    html[data-inspect-components="true"] [data-r1-editorial] [data-component-label] {
      position: absolute !important;
      top: 0;
      left: 0;
      z-index: 30;
      margin: 0 !important;
      pointer-events: none;
      transform: translateY(-58%);
      border: 1px solid rgb(161 98 7 / 0.55) !important;
      background: rgb(254 240 138 / 0.72) !important;
      box-shadow: 0 6px 18px rgb(120 53 15 / 0.12);
      backdrop-filter: blur(6px);
    }

    [data-r1-editorial] [data-component-info] {
      display: none;
    }

    html[data-inspect-components="true"] [data-r1-editorial] [data-component-info] {
      display: inline-flex;
      max-width: min(18rem, 82vw);
      position: absolute;
      z-index: 29;
      pointer-events: none;
      border: 1px solid rgb(190 24 93 / 0.34);
      background: rgb(252 231 243 / 0.82);
      box-shadow: 0 8px 24px rgb(131 24 67 / 0.12);
      backdrop-filter: blur(6px);
      color: rgb(131 24 67);
      font-size: 10px;
      font-weight: 650;
      letter-spacing: 0.045em;
      line-height: 1.25;
      padding: 0.36rem 0.48rem;
      text-transform: uppercase;
    }

    html[data-inspect-components="true"] [data-r1-editorial] .r1-inspect-info-badge--top-right {
      top: 0;
      right: 0;
      transform: translateY(-58%);
    }

    html[data-inspect-components="true"] [data-r1-editorial] .r1-inspect-info-badge--bottom-left {
      bottom: 0;
      left: 0;
      transform: translateY(62%);
    }

    [data-r1-editorial] [data-component="ArticleContent"] {
      background: #fff;
      border-radius: 0;
    }

    [data-r1-editorial] [data-component="ArticleHeader"] > div:first-of-type {
      display: none;
    }

    [data-r1-editorial] [data-component="ArticleHeader"] {
      padding-bottom: 0.2rem !important;
      margin-top: 20px !important;
    }

    [data-r1-editorial] [data-component="ArticleHeader"] > div:first-of-type .ams-kicker {
      font-size: 10px;
      letter-spacing: 0.14em;
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] {
      background: transparent;
      border-radius: 0;
      padding: 0;
      margin: 0 0 0.22rem !important;
    }

    [data-r1-editorial] [data-component="ArticleContent"] > [data-component="ArticleTrustBlock"] {
      margin-top: -1.74rem !important;
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] > div {
      margin-top: 0 !important;
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] > p {
      margin-top: 0.08rem !important;
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] .ams-kicker {
      font-size: 10px;
      letter-spacing: 0.14em;
      color: rgb(var(--reading-ink-secondary));
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] p:last-child {
      margin-top: 0.22rem;
      font-size: 12px;
      line-height: 1.45;
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] a {
      color: rgb(var(--reading-ink));
    }

    [data-r1-editorial] .ams-plate {
      background: transparent;
      border-radius: 0;
      padding-left: 0 !important;
      padding-right: 0 !important;
      box-shadow: none;
    }

    [data-r1-editorial] [data-component="ArticleFigurePlaceholder"] {
      margin-top: 0.32rem !important;
      border-top: 0;
      padding-top: 0;
    }

    [data-r1-editorial] [data-component="ArticleFigurePlaceholder"] figcaption {
      margin-top: 0.28rem !important;
    }

    [data-r1-editorial] [data-component="ArticleContent"] > [data-component="ArticleIngress"] {
      margin-top: -2.1rem !important;
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] hr {
      margin-top: 0.38rem !important;
      border-top-color: rgb(var(--border) / 0.42) !important;
      opacity: 1 !important;
    }

    [data-r1-editorial] [data-component="ArticleTrustBlock"] hr + div {
      margin-top: 0.15rem !important;
    }

    [data-r1-editorial] [data-component="RelatedTopicsEarly"] {
      margin-top: 0.12rem;
      margin-bottom: 0.15rem;
      padding-bottom: 0.15rem;
    }

    [data-r1-editorial] [data-component="RelatedTopicsEarly"] .r1-early-topics__inline {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      column-gap: 0.45rem;
      row-gap: 0.28rem;
    }

    [data-r1-editorial] [data-component="RelatedTopicsEarly"] .r1-early-topics__label {
      flex-shrink: 0;
      margin: 0;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: rgb(var(--reading-ink-secondary) / 0.78);
    }

    [data-r1-editorial] [data-component="RelatedTopicsEarly"] .r1-early-topics__list {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.3rem 0.35rem;
      list-style: none;
      margin: 0;
      padding: 0;
      min-width: 0;
    }

    [data-r1-editorial] [data-component="RelatedTopicsEarly"] .r1-early-topics__list li {
      border: 1px solid rgb(var(--border) / 0.42);
      border-radius: 2px;
      padding: 0.1rem 0.38rem;
      font-size: 10px;
      letter-spacing: 0.02em;
      color: rgb(var(--reading-ink-secondary) / 0.95);
      background: transparent;
    }

    [data-r1-editorial] [data-component="ArticleSummary"] {
      margin-top: 1rem;
      border: 0;
      border-top: 0;
      border-radius: 0 !important;
      padding: 0 !important;
      background: transparent !important;
      box-shadow: none !important;
      position: relative;
      order: 25;
    }

    [data-r1-editorial] [data-component="ArticleSummary"] h3 {
      padding-right: 0;
      margin: 0;
      font-size: 1.25rem !important;
      font-weight: 600 !important;
      letter-spacing: -0.02em !important;
      text-transform: none !important;
      line-height: 1.3;
      color: rgb(var(--reading-ink));
    }

    [data-r1-editorial] [data-component="ArticleSummary"] h2 {
      color: rgb(var(--reading-ink));
    }

    [data-r1-editorial] [data-component="ArticleSummary"] > p {
      margin-top: 0.85rem;
      max-width: none;
      font-size: 1.0625rem;
      line-height: 1.66;
      color: rgb(var(--reading-ink));
    }

    [data-r1-editorial] .r1-article-to-klarlyd-divider {
      border: 0;
      border-top: 1px solid rgb(var(--border) / 0.38);
      margin: 0.85rem 0 0.55rem;
      padding: 0;
      height: 0;
    }

    [data-r1-editorial] .r1-orientation {
      display: none;
      border-top: 1px solid rgb(var(--border) / 0.22);
      padding-top: 0.95rem;
      margin-bottom: 2rem;
    }

    html[data-inspect-testinfo="true"] [data-r1-editorial] .r1-orientation {
      display: block;
    }

    [data-r1-editorial] [data-component="ArticleContent"] {
      display: flex;
      flex-direction: column;
    }

    [data-r1-editorial] [data-component="ArticleIngress"] {
      order: 12;
    }

    [data-r1-editorial] [data-component="ArticleBody"] {
      order: 15;
    }

    [data-r1-editorial] .r1-ai-bridge {
      border-top: 0;
      padding-top: 0.15rem;
      margin-top: 0.35rem;
      margin-bottom: 4.25rem;
      order: 35;
    }

    [data-r1-editorial] .r1-ai-bridge .inline-chat-shell {
      max-width: var(--r1-ai-dialog-measure);
    }

    [data-r1-editorial] .r1-ai-bridge .inline-chat-shell__header {
      margin-bottom: 0.12rem;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-seed-suggestions] {
      margin-top: 0.08rem;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-seeds-empty="true"].inline-chat-shell .inline-chat-shell__header,
    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-seeds-empty="true"].inline-chat-shell .inline-chat-shell__source {
      display: none;
    }

    [data-r1-editorial] .r1-ai-bridge .inline-chat-shell__title {
      font-size: 1.08rem;
      letter-spacing: -0.01em;
      line-height: 1.3;
      font-weight: 600;
    }

    [data-r1-editorial] .r1-ai-bridge .inline-chat-shell__intro {
      margin-top: 0.28rem;
      font-size: 0.94rem;
      line-height: 1.48;
      color: rgb(var(--reading-ink-secondary));
    }

    [data-r1-editorial] .r1-ai-bridge .inline-chat-shell__source {
      display: none;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="inline"] .inline-chat-shell__seed-list {
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.42rem;
      padding: 0;
      list-style: none;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="inline"] .inline-chat-shell__seed-btn {
      width: 100%;
      border: 1px solid rgb(var(--border) / 0.52);
      border-radius: 999px;
      background: rgb(var(--surface) / 0.9);
      padding: 0.52rem 0.84rem;
      text-align: left;
      font-size: 0.88rem;
      line-height: 1.4;
      transition: background-color 120ms ease, border-color 120ms ease;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="inline"] .inline-chat-shell__seed-btn:hover {
      background: rgb(var(--surface-subtle) / 0.95);
      border-color: rgb(var(--border) / 0.72);
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__seed-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 0.32rem;
      max-width: var(--r1-ai-dialog-measure);
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__seed-item + .inline-chat-shell__seed-item {
      margin-top: 0;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__seed-item {
      display: flex;
      justify-content: flex-end;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__seed-row {
      display: flex;
      width: var(--r1-ai-user-measure);
      align-items: flex-start;
      justify-content: flex-start;
      border: 1px solid rgb(var(--border) / 0.32);
      border-radius: var(--r1-ai-input-radius);
      background: transparent;
      padding: 0.7rem 0.84rem;
      cursor: pointer;
      text-align: left;
      color: rgb(var(--reading-ink));
      transition: background-color 140ms ease, border-color 140ms ease, transform 140ms ease;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__seed-row:hover {
      border-color: rgb(var(--border) / 0.52);
      background: var(--r1-ai-seed-hover-surface);
      box-shadow: 0 12px 28px rgb(15 23 42 / 0.08);
      transform: translateY(-1px);
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__seed-row:focus-visible {
      outline: 2px solid rgb(var(--reading-accent-iris) / 0.34);
      outline-offset: 2px;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__seed-question {
      min-width: 0;
      flex: 1;
      font-size: 0.94rem;
      line-height: 1.42;
      letter-spacing: -0.006em;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__dialog-thread {
      max-width: var(--r1-ai-dialog-measure);
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__message {
      max-width: var(--r1-ai-dialog-measure);
      padding: 0.78rem 0.9rem;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__message + .inline-chat-shell__message {
      margin-top: 0.55rem;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__message--user {
      margin-left: auto;
      width: var(--r1-ai-user-measure);
      border-radius: var(--r1-ai-input-radius);
      background: var(--r1-ai-user-surface);
      border: 0;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__message--assistant {
      width: min(100%, 40rem);
      border-left: 0;
      background: transparent;
      padding: 0.45rem 0;
    }

    [data-r1-editorial] .r1-ai-bridge [data-inline-chat-mode="progressive"] .inline-chat-shell__message-eyebrow {
