---
/* CONTRACT: Article page — White Paper sheet + redaksjonell brødtekst; få callouts; sekundær rail. */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/layout/Section.astro";
import Footer from "../../../components/nav/Footer.astro";
import { buildChatShellHref } from "../../../lib/chat-shell";
import {
  fetchAiSeedQuestions,
  fetchPublishingArticleBySlug,
  fetchPublishingArticleSlugs,
} from "../../../lib/storyblok-publishing";

type ArticleProps = {
  slug: string;
};

export async function getStaticPaths() {
  const allSlugs = await fetchPublishingArticleSlugs();
  const target = "slik-tar-du-praten";
  const slugs = allSlugs.includes(target) ? [target] : [];
  return slugs.map((slug) => ({ params: { slug }, props: { slug } satisfies ArticleProps }));
}

Astro.response.headers.set("X-Robots-Tag", "noindex, follow");

const { slug } = Astro.props as ArticleProps;
const article = await fetchPublishingArticleBySlug(slug);
if (!article) {
  throw new Error(`[publishing] Missing article_page for slug: ${slug}`);
}

const seeds = (await fetchAiSeedQuestions()).filter((seed) =>
  !seed.relatedArticle || seed.relatedArticle === article.slug,
);

const updatedLabel = article.updatedAt
  ? (() => {
      const d = new Date(article.updatedAt);
      return Number.isNaN(d.getTime()) ? article.updatedAt : d.toLocaleDateString("no-NO");
    })()
  : undefined;

const moduleToneLabel: Record<
  "module_observation_box" | "module_friction_box" | "module_response_block" | "module_reassurance_block",
  string
> = {
  module_observation_box: "Observasjon",
  module_friction_box: "Dette kan skape friksjon",
  module_response_block: "Forslag til respons",
  module_reassurance_block: "Trygghet",
};

/** Del brødtekst i avsnitt (tom linje = nytt avsnitt). */
function bodyToParagraphs(body: string | undefined): string[] {
  if (!body?.trim()) return [];
  return body
    .split(/\r?\n\s*\r?\n/)
    .map((p) => p.trim())
    .filter(Boolean);
}

const firstObservationCalloutIndex = article.moduleBlocks.findIndex((b) => b.component === "module_observation_box");
---

<BaseLayout title={`VOX - ${article.title}`} currentPath="/no/hub">
  <meta slot="head" name="robots" content="noindex,follow" />

  <main class="py-8 sm:py-10">
    <Section class="!py-6 sm:!py-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_17.5rem] lg:gap-10 xl:gap-12">
        <article class="vox-reading-sheet">
          <header class="border-b border-[rgb(var(--border))/0.22] pb-8">
            {article.categoryLabel ? (
              <p class="text-xs font-medium uppercase tracking-wide text-[rgb(var(--reading-ink-secondary))]">
                {article.categoryLabel}
              </p>
            ) : null}
            <h1 class="font-display mt-2 text-3xl font-semibold tracking-[-0.03em] text-balance text-[rgb(var(--reading-ink))] sm:text-4xl">
              {article.title}
            </h1>
            {article.ingress ? (
              <p class="mt-5 text-lg leading-relaxed text-[rgb(var(--reading-ink-secondary))]">{article.ingress}</p>
            ) : null}
          </header>

          <div class="vox-reading-article-body mt-10 space-y-8">
            {article.sections.length ? (
              article.sections.map((section) => (
                <section class="space-y-4">
                  {section.heading ? (
                    <h2 class="font-display text-xl font-semibold tracking-[-0.02em] text-[rgb(var(--reading-ink))] sm:text-2xl">
                      {section.heading}
                    </h2>
                  ) : null}
                  {bodyToParagraphs(section.body).length ? (
                    <div class="space-y-4">
                      {bodyToParagraphs(section.body).map((para) => (
                        <p class="text-base leading-[1.75] text-[rgb(var(--reading-ink-secondary))]">{para}</p>
                      ))}
                    </div>
                  ) : null}
                </section>
              ))
            ) : (
              <p class="text-sm text-[rgb(var(--reading-ink-secondary))]">Ingen sections publisert ennå.</p>
            )}

            {article.moduleBlocks.map((block, modIndex) => {
              if (block.component === "module_phrase_cards") {
                return (
                  <section class="space-y-3">
                    <h3 class="font-display text-lg font-semibold tracking-[-0.02em] text-[rgb(var(--reading-ink))]">
                      {block.title || "Eksempelfraser"}
                    </h3>
                    <ul class="list-disc space-y-2 pl-6 text-base leading-[1.75] text-[rgb(var(--reading-ink-secondary))]" role="list">
                      {block.cards.map((card) => (
                        <li>{card}</li>
                      ))}
                    </ul>
                  </section>
                );
              }

              if (block.component === "related_link") {
                return (
                  <p class="text-base leading-[1.75] text-[rgb(var(--reading-ink-secondary))]">
                    <a
                      href={block.href}
                      class:list={[
                        "font-medium text-[rgb(var(--reading-ink))] underline-offset-[3px] transition-colors",
                        block.comingSoon
                          ? "pointer-events-none opacity-60"
                          : "hover:text-[rgb(var(--reading-ink))] hover:underline",
                      ]}
                      aria-disabled={block.comingSoon ? "true" : undefined}
                    >
                      {block.label}
                    </a>
                    {block.comingSoon ? (
                      <span class="ml-2 text-xs font-medium uppercase tracking-wide text-[rgb(var(--reading-ink-secondary))]">
                        (kommer snart)
                      </span>
                    ) : null}
                  </p>
                );
              }

              const isObservationCallout =
                block.component === "module_observation_box" && modIndex === firstObservationCalloutIndex;

              if (isObservationCallout) {
                return (
                  <aside class="vox-reading-inline" aria-label="Observasjon">
                    <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--reading-ink-secondary))]">
                      {moduleToneLabel[block.component]}
                    </p>
                    {block.title ? (
                      <h3 class="mt-2 font-display text-lg font-semibold tracking-[-0.02em] text-[rgb(var(--reading-ink))]">
                        {block.title}
                      </h3>
                    ) : null}
                    {block.body ? (
                      <p class="mt-3 text-base leading-[1.75] text-[rgb(var(--reading-ink-secondary))]">{block.body}</p>
                    ) : null}
                    {block.points.length ? (
                      <ul class="mt-4 list-disc space-y-2 pl-5 text-base leading-relaxed text-[rgb(var(--reading-ink-secondary))]">
                        {block.points.map((point) => (
                          <li>{point}</li>
                        ))}
                      </ul>
                    ) : null}
                  </aside>
                );
              }

              return (
                <section class="space-y-3">
                  <p class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--reading-ink-secondary))]">
                    {moduleToneLabel[block.component]}
                  </p>
                  {block.title ? (
                    <h3 class="font-display text-lg font-semibold tracking-[-0.02em] text-[rgb(var(--reading-ink))]">
                      {block.title}
                    </h3>
                  ) : null}
                  {block.body ? (
                    <p class="text-base leading-[1.75] text-[rgb(var(--reading-ink-secondary))]">{block.body}</p>
                  ) : null}
                  {block.points.length ? (
                    <ul class="mt-2 list-disc space-y-2 pl-6 text-base leading-[1.75] text-[rgb(var(--reading-ink-secondary))]">
                      {block.points.map((point) => (
                        <li>{point}</li>
                      ))}
                    </ul>
                  ) : null}
                </section>
              );
            })}

            {article.nextSteps.length ? (
              <aside class="vox-reading-inline" aria-label="Neste steg">
                <h2 class="font-display text-lg font-semibold tracking-[-0.02em] text-[rgb(var(--reading-ink))] sm:text-xl">
                  Neste steg
                </h2>
                <ul class="mt-4 list-disc space-y-2 pl-5 text-base leading-relaxed text-[rgb(var(--reading-ink-secondary))]">
                  {article.nextSteps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ul>
              </aside>
            ) : null}
          </div>
        </article>

        <aside class="flex flex-col gap-4 lg:sticky lg:top-28 lg:self-start">
          <div class="vox-reading-rail-card">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--text-secondary))]">Faglig forankret</h2>
            <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
              Innholdet bygger på etablerte råd for hørehelse og samtale i nære relasjoner.
            </p>
            <ul class="mt-3 space-y-1.5 text-sm text-[rgb(var(--text-secondary))]">
              <li>HLF - erfaring fra brukere og pårørende</li>
              <li>FHI - helsefaglig kunnskapsgrunnlag</li>
              <li>Helsedirektoratet - nasjonale råd og veiledning</li>
            </ul>
          </div>

          <div class="vox-reading-rail-card">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--text))]">Om innholdet</h2>
            <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--text-secondary))]">
              {article.authorName ? <li><strong class="text-[rgb(var(--text))]">Forfatter:</strong> {article.authorName}{article.authorRole ? `, ${article.authorRole}` : ""}</li> : null}
              {article.reviewerName ? <li><strong class="text-[rgb(var(--text))]">Faglig sjekk:</strong> {article.reviewerName}{article.reviewerRole ? `, ${article.reviewerRole}` : ""}</li> : null}
              {updatedLabel ? <li><strong class="text-[rgb(var(--text))]">Oppdatert:</strong> {updatedLabel}</li> : null}
            </ul>
            {article.methodNote ? <p class="mt-3 text-xs leading-relaxed text-[rgb(var(--muted))]">{article.methodNote}</p> : null}
          </div>

          {seeds.length ? (
            <div class="vox-reading-rail-card">
              <h2 class="text-xs font-semibold uppercase tracking-wide text-[rgb(var(--text))]">Les videre eller snakk videre</h2>
              <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--text-secondary))]">
                Hvis du vil gå fra lesing til samtale, start med ett av disse spørsmålene.
              </p>
              <ul class="mt-3 space-y-2 text-sm text-[rgb(var(--text-secondary))]">
                {seeds.map((seed) => (
                  <li>
                    <a
                      href={buildChatShellHref(seed.question, "article")}
                      class="vox-surface-calm-tile px-3 py-2 text-sm"
                    >
                      {seed.question}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ) : null}

          <p class="text-xs text-[rgb(var(--muted))]">
            Velg et spørsmål for å åpne samtaleflaten i et eget, rolig shell.
          </p>
        </aside>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>
