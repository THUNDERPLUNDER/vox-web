---
/* CONTRACT: VIS backstage index — auto-lists raw HTML wireframes from public/vis/raw. */
import PrototypeLayout from "../../layouts/PrototypeLayout.astro";
import {
  listVisRawHtmlFiles,
  slugFromHtmlFilename,
  VIS_RAW_PUBLIC_PREFIX,
} from "../../lib/vis-wireframes";

const files = listVisRawHtmlFiles();
---

<PrototypeLayout title="Oversikt" activePage="forside">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Rå HTML-wireframes</h1>
    <p class="mt-2 max-w-prose text-sm text-gray-600">
      Filer i <code class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-xs">public/vis/raw/</code> listes her automatisk ved bygg.
    </p>

    {
      files.length === 0 ? (
        <p class="mt-6 text-sm text-gray-500">
          Ingen <code class="font-mono">.html</code>-filer funnet. Legg filer i{" "}
          <code class="font-mono">public/vis/raw/</code> og bygg på nytt.
        </p>
      ) : (
        <ul class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
          {files.map((name) => {
            const slug = slugFromHtmlFilename(name);
            const view = `/vis/${encodeURIComponent(slug)}`;
            const preview = `${view}?preview=1`;
            const rawUrl = `${VIS_RAW_PUBLIC_PREFIX}/${encodeURIComponent(name)}`;
            return (
              <li class="flex flex-col gap-2 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0">
                  <p class="truncate font-mono text-sm font-medium text-gray-900">{name}</p>
                  <p class="mt-0.5 text-xs text-gray-500">
                    <a href={rawUrl} class="text-gray-600 underline decoration-gray-300 hover:text-gray-900">
                      Direkte fil
                    </a>
                  </p>
                </div>
                <div class="flex flex-wrap gap-2">
                  <a
                    href={view}
                    class="rounded-md bg-gray-900 px-3 py-1.5 font-mono text-xs text-white hover:bg-gray-800"
                  >
                    Åpne
                  </a>
                  <a
                    href={preview}
                    class="rounded-md border border-gray-300 bg-white px-3 py-1.5 font-mono text-xs text-gray-800 hover:bg-gray-50"
                  >
                    Preview
                  </a>
                </div>
              </li>
            );
          })}
        </ul>
      )
    }
  </main>
</PrototypeLayout>
