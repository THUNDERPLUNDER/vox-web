---
/* CONTRACT: VIS backstage index — auto-lists raw HTML from public/vis/raw med type-badge. */
import PrototypeLayout from "../../layouts/PrototypeLayout.astro";
import { visTypeLabelNo, wireframeIndexEntries } from "../../lib/vis-wireframes";

const entries = wireframeIndexEntries();
const base = import.meta.env.BASE_URL;
---

<PrototypeLayout title="Oversikt">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Prototyper og underlag</h1>
    <p class="mt-2 max-w-prose text-sm text-gray-600">
      Rå HTML-filer i{" "}
      <code class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-xs">public/vis/raw/</code> — wireframes og strategidokumenter — listes her automatisk ved bygg.
    </p>

    {
      entries.length === 0 ? (
        <p class="mt-6 text-sm text-gray-500">
          Ingen <code class="font-mono">.html</code>-filer funnet. Legg filer i{" "}
          <code class="font-mono">public/vis/raw/</code> og bygg på nytt.
        </p>
      ) : (
        <ul class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
          {entries.map(({ filename: name, slug, displayTitle, description, visType }) => {
            const view = `${base}vis/${encodeURIComponent(slug)}`;
            const rawUrl = `${base}vis/raw/${encodeURIComponent(name)}`;
            const typeLabel = visTypeLabelNo(visType);
            return (
              <li class="flex flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-2">
                    <span
                      class="inline-flex shrink-0 rounded border border-gray-200 bg-gray-50 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-gray-600"
                    >
                      {typeLabel}
                    </span>
                    <p class="text-sm font-semibold leading-snug text-gray-900">{displayTitle}</p>
                  </div>
                  {description ? (
                    <p class="mt-1 text-sm leading-relaxed text-gray-600">{description}</p>
                  ) : null}
                  <p class="mt-1 truncate font-mono text-xs text-gray-500">{name}</p>
                </div>
                <div class="flex shrink-0 flex-wrap items-center gap-2">
                  <a
                    href={view}
                    class="rounded-md bg-gray-900 px-3 py-1.5 font-mono text-xs text-white hover:bg-gray-800"
                  >
                    Åpne
                  </a>
                  <a
                    href={rawUrl}
                    class="rounded-md border border-gray-300 bg-white px-3 py-1.5 font-mono text-xs text-gray-800 hover:bg-gray-50"
                  >
                    Direkte fil
                  </a>
                </div>
              </li>
            );
          })}
        </ul>
      )
    }
  </main>
</PrototypeLayout>
