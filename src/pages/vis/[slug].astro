---
/* CONTRACT: VIS single wireframe viewer — embeds raw HTML from public/vis/raw via iframe. */
import PrototypeLayout from "../../layouts/PrototypeLayout.astro";
import {
  htmlFileForSlug,
  listVisRawHtmlFiles,
  slugFromHtmlFilename,
  wireframeDisplayMeta,
} from "../../lib/vis-wireframes";

const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const files = listVisRawHtmlFiles();
  return files.map((file) => ({
    params: { slug: slugFromHtmlFilename(file) },
  }));
}

const { slug } = Astro.params;
const files = listVisRawHtmlFiles();
const fileName = slug ? htmlFileForSlug(slug, files) : undefined;

if (!fileName) {
  throw new Error(`[vis] Unknown wireframe slug: ${slug}`);
}

const src = `${base}vis/raw/${encodeURIComponent(fileName)}`;
const { displayTitle, description, delta } = wireframeDisplayMeta(fileName);
---

<PrototypeLayout
  title={displayTitle}
  wireframeFileNav={{ allFiles: files, currentSlug: slug! }}
  wireframeMeta={{ displayTitle, description, delta, rawHref: src }}
>
  <iframe
    title={displayTitle}
    src={src}
    class="vis-wireframe-iframe block min-h-0 w-full flex-1 border-0 bg-white"
  />
</PrototypeLayout>
