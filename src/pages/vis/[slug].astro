---
/* CONTRACT: VIS single wireframe viewer — embeds raw HTML from public/vis/raw via iframe. */
import PrototypeLayout from "../../layouts/PrototypeLayout.astro";
import {
  htmlFileForSlug,
  listVisRawHtmlFiles,
  slugFromHtmlFilename,
  wireframeDisplayMeta,
} from "../../lib/vis-wireframes";

const base = import.meta.env.BASE_URL;
const retiredRoutes: Record<string, { replacementHref: string; replacementLabel: string }> = {
  KlarLyd_Live_Board_Roadmap_v01: {
    replacementHref: `${base}vis/system/roadmap-timeline-v01`,
    replacementLabel: "Roadmap timeline (canonical)",
  },
};

export function getStaticPaths() {
  const files = listVisRawHtmlFiles();
  return files.map((file) => ({
    params: { slug: slugFromHtmlFilename(file) },
  }));
}

const { slug } = Astro.params;
const files = listVisRawHtmlFiles();
const fileName = slug ? htmlFileForSlug(slug, files) : undefined;

if (!fileName) {
  throw new Error(`[vis] Unknown wireframe slug: ${slug}`);
}

const src = `${base}vis/raw/${encodeURIComponent(fileName)}`;
const { displayTitle, description, delta } = wireframeDisplayMeta(fileName);
const retiredRoute = slug ? retiredRoutes[slug] : undefined;
---

<PrototypeLayout
  title={displayTitle}
  wireframeFileNav={{ allFiles: files, currentSlug: slug! }}
  wireframeMeta={{ displayTitle, description, delta, rawHref: src }}
>
  {
    retiredRoute ? (
      <main class="px-4 py-6 sm:px-6 sm:py-8">
        <section class="max-w-3xl rounded-md border border-gray-300 bg-white p-4">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-gray-500">Pensjonert VIS-side</p>
          <h1 class="mt-1 text-lg font-semibold text-gray-900">{displayTitle}</h1>
          <p class="mt-2 text-sm leading-relaxed text-gray-600">
            Denne siden er avpublisert fra aktiv bruk i VIS og holdes kun som historisk artefakt.
          </p>
          <p class="mt-3 text-sm text-gray-700">
            Ny canonical roadmap-flate er{" "}
            <a href={retiredRoute.replacementHref} class="font-medium underline underline-offset-2">
              {retiredRoute.replacementLabel}
            </a>
            .
          </p>
        </section>
      </main>
    ) : (
      <iframe
        title={displayTitle}
        src={src}
        class="vis-wireframe-iframe block min-h-0 w-full flex-1 border-0 bg-white"
      />
    )
  }
</PrototypeLayout>
