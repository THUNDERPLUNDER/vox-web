---
/* CONTRACT: VIS single wireframe viewer — embeds raw HTML from public/vis/raw via iframe. */
import PrototypeLayout from "../../layouts/PrototypeLayout.astro";
import { htmlFileForSlug, listVisRawHtmlFiles, slugFromHtmlFilename } from "../../lib/vis-wireframes";

const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const files = listVisRawHtmlFiles();
  return files.map((file) => ({
    params: { slug: slugFromHtmlFilename(file) },
  }));
}

const { slug } = Astro.params;
const files = listVisRawHtmlFiles();
const fileName = slug ? htmlFileForSlug(slug, files) : undefined;

if (!fileName) {
  throw new Error(`[vis] Unknown wireframe slug: ${slug}`);
}

const src = `${base}vis/raw/${encodeURIComponent(fileName)}`;
const title = fileName.replace(/\.html$/i, "");
---

<PrototypeLayout title={title} wireframeFileNav={{ allFiles: files, currentSlug: slug! }}>
  <iframe
    title={title}
    src={src}
    class="vis-wireframe-iframe block h-[calc(100dvh-2.5rem)] min-h-[calc(100dvh-2.5rem)] w-full border-0 bg-white"
  />
</PrototypeLayout>
