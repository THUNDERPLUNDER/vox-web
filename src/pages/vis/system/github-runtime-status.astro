---
/* CONTRACT: VIS runtime-feed — viser generert GitHub-status (public/vis/runtime/00_GITHUB_RUNTIME_STATUS.md) for @navigator; kuratert /vis forblir separat. */
import fs from "node:fs";
import path from "node:path";
import VisInternalLayout from "../../../layouts/VisInternalLayout.astro";

const base = import.meta.env.BASE_URL;
const mdPath = path.join(process.cwd(), "public", "vis", "runtime", "00_GITHUB_RUNTIME_STATUS.md");
let raw = "";
try {
  raw = fs.readFileSync(mdPath, "utf8");
} catch {
  raw = "# Mangler runtime-fil\n\nKjør `npm run vis:github:runtime-status` med `GITHUB_TOKEN`, eller vent på GitHub Action.\n";
}

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}
const safe = escapeHtml(raw);
---

<VisInternalLayout title="GitHub runtime status" pageContractId="gitbuss">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <nav class="text-xs text-gray-500">
      <a href={`${base}vis/system`} class="underline underline-offset-2">System</a>
      <span aria-hidden="true"> / </span>
      <span class="text-gray-800">Runtime (GitHub)</span>
    </nav>

    <h1 class="mt-4 text-lg font-semibold text-gray-900">GitHub runtime status</h1>
    <p class="mt-2 max-w-prose text-sm leading-relaxed text-gray-600">
      Maskin- og menneskelesbar status generert fra GitHub API (<code class="rounded bg-gray-100 px-1 font-mono text-xs">00_GITHUB_RUNTIME_STATUS.md</code>).
      Oppdateres av workflow <code class="font-mono text-xs">GitHub runtime status (navigator)</code> og ved hver deploy til <code class="font-mono text-xs">main</code>.
      Kuratert VIS-innhold ligger fortsatt på <a href={`${base}vis`} class="font-medium text-gray-900 underline underline-offset-2">/vis</a>.
    </p>
    <p class="mt-3 max-w-prose text-xs text-gray-500">
      Google Drive-synk er ikke koblet i v0.1; se bunntekst i markdown og issue #107.
    </p>

    <article
      class="mt-6 max-w-5xl overflow-x-auto rounded-md border border-gray-200 bg-white p-4 text-sm leading-relaxed text-gray-900"
      aria-label="Generert markdown"
    >
      <pre class="whitespace-pre-wrap break-words font-mono text-[13px]">{safe}</pre>
    </article>

    <p class="mt-6 text-xs text-gray-500">
      Råfil (samme innhold):{" "}
      <a
        class="font-mono text-gray-800 underline underline-offset-2"
        href={`${base}vis/runtime/00_GITHUB_RUNTIME_STATUS.md`}
        >{`${base}vis/runtime/00_GITHUB_RUNTIME_STATUS.md`}</a
      >
    </p>
  </main>
</VisInternalLayout>
