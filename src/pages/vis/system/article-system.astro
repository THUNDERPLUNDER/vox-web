---
/* CONTRACT: Human-readable VIS overview for Article System v0.1 progress and next steps. */
import PrototypeLayout from "../../../layouts/PrototypeLayout.astro";
const base = import.meta.env.BASE_URL;
---

<PrototypeLayout title="Article System v0.1">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Article System v0.1</h1>
    <p class="mt-2 max-w-3xl text-sm leading-relaxed text-gray-600">
      Article System v0.1 viser hvordan KlarLyd-artikler bygges opp, hvilke faste oppsett som finnes, og hvilke felt artikkelmalen trenger for aa
      fungere.
    </p>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Status na</h2>
      <div class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/50" target="_blank" rel="noreferrer" class="rounded border border-emerald-300 bg-emerald-50 px-3 py-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-800">Blokker</p>
          <p class="mt-1 text-sm font-medium text-emerald-900">Landet</p>
        </a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/51" target="_blank" rel="noreferrer" class="rounded border border-emerald-300 bg-emerald-50 px-3 py-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-800">Oppsett</p>
          <p class="mt-1 text-sm font-medium text-emerald-900">Landet</p>
        </a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/52" target="_blank" rel="noreferrer" class="rounded border border-emerald-300 bg-emerald-50 px-3 py-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-800">Felt</p>
          <p class="mt-1 text-sm font-medium text-emerald-900">Landet</p>
        </a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/53" target="_blank" rel="noreferrer" class="rounded border border-amber-300 bg-amber-50 px-3 py-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-amber-800">Template-skjelett</p>
          <p class="mt-1 text-sm font-medium text-amber-900">Paa gaar</p>
        </a>
      </div>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Byggeklosser</h2>
      <div class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-800">Hodeseksjon</div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-800">Tillitsboks</div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-800">Broedtekst</div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-800">Figur / illustrasjon</div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-800">Sidespalte / rail</div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-800">Bunnseksjon</div>
      </div>
      <p class="mt-3 rounded border border-dashed border-violet-300 bg-violet-50 px-3 py-2 text-sm text-violet-900">AI-hjelp er eget lag over blokkene, ikke en vanlig innholdsblokk.</p>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Oppsett / artikkeltyper</h2>
      <div class="mt-3 grid gap-2 sm:grid-cols-2">
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2">
          <p class="text-sm font-semibold text-gray-900">Standard</p>
          <p class="mt-1 text-xs text-gray-600">Vanlig artikkel.</p>
        </div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2">
          <p class="text-sm font-semibold text-gray-900">Faglig Fokus</p>
          <p class="mt-1 text-xs text-gray-600">Faglig tyngre artikkel.</p>
        </div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2">
          <p class="text-sm font-semibold text-gray-900">Minimal</p>
          <p class="mt-1 text-xs text-gray-600">Kort artikkel.</p>
        </div>
        <div class="rounded border border-gray-200 bg-gray-50 px-3 py-2">
          <p class="text-sm font-semibold text-gray-900">AI-drevet</p>
          <p class="mt-1 text-xs text-gray-600">AI som hjelpelag, ikke egen artikkeltype.</p>
        </div>
      </div>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Felt artikkelmalen trenger</h2>
      <div class="mt-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-600">Ma ha</p>
        <div class="mt-1 flex flex-wrap gap-1.5">
          {["title", "ingress", "preset", "article_type", "hub", "source_trust_type"].map((field) => (
            <span class="rounded border border-gray-300 bg-gray-100 px-2 py-0.5 text-xs text-gray-800">{field}</span>
          ))}
        </div>
      </div>
      <div class="mt-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-600">Anbefalt</p>
        <div class="mt-1 flex flex-wrap gap-1.5">
          {["related_topics", "ai_seed_group"].map((field) => (
            <span class="rounded border border-gray-300 bg-white px-2 py-0.5 text-xs text-gray-700">{field}</span>
          ))}
        </div>
      </div>
      <p class="mt-3 text-xs text-gray-600">Feltene brukes i malvisning, hub-kobling og AI-lag, i traad med feltkontrakten i #52.</p>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-gray-50 p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Hva er neste</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-gray-700">
        <li>Template-skjelett bygges naa i #53.</li>
        <li>Deretter kobles pilotartiklene R1-R3 paa.</li>
        <li>Deretter bygges foerste hub.</li>
      </ul>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Kilder</h2>
      <div class="mt-2 grid gap-1 text-sm text-gray-700 sm:grid-cols-2">
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/46" target="_blank" rel="noreferrer" class="underline underline-offset-2">#46 Editorial grammar v0.1</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/47" target="_blank" rel="noreferrer" class="underline underline-offset-2">#47 Spoke template v1</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/50" target="_blank" rel="noreferrer" class="underline underline-offset-2">#50 Blokkbibliotek</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/51" target="_blank" rel="noreferrer" class="underline underline-offset-2">#51 Preset-regler</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/52" target="_blank" rel="noreferrer" class="underline underline-offset-2">#52 Feltkontrakt</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/issues/53" target="_blank" rel="noreferrer" class="underline underline-offset-2">#53 Template-skjelett</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/blob/main/docs/project/11_ARTICLE_SYSTEM_BLOCK_LIBRARY_v0_1.md" target="_blank" rel="noreferrer" class="underline underline-offset-2">11_ARTICLE_SYSTEM_BLOCK_LIBRARY_v0_1.md</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/blob/main/docs/project/12_ARTICLE_SYSTEM_PRESET_RULES_v0_1.md" target="_blank" rel="noreferrer" class="underline underline-offset-2">12_ARTICLE_SYSTEM_PRESET_RULES_v0_1.md</a>
        <a href="https://github.com/THUNDERPLUNDER/vox-web/blob/main/docs/project/13_ARTICLE_TEMPLATE_FIELDS_v0_1.md" target="_blank" rel="noreferrer" class="underline underline-offset-2">13_ARTICLE_TEMPLATE_FIELDS_v0_1.md</a>
      </div>
    </section>
  </main>
</PrototypeLayout>
