---
/* CONTRACT: VIS system landing that routes to lightweight article-system references. */
import PrototypeLayout from "../../../layouts/PrototypeLayout.astro";
const base = import.meta.env.BASE_URL;
---

<PrototypeLayout title="System">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Systemreferanse i VIS</h1>
    <p class="mt-2 max-w-prose text-sm leading-relaxed text-gray-600">
      Dette laget viser landet systemarbeid i lesbar form for beslutning og orientering. VIS er visning/referanse, ikke backlog.
    </p>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Tilgjengelig nå</h2>
      <ul class="mt-3 space-y-2">
        <li>
          <a href={`${base}vis/system/article`} class="text-sm font-medium text-gray-900 underline underline-offset-2">
            Article System v0.1
          </a>
          <p class="text-xs text-gray-600">Overview, foundations, komponenter, template og changelog/status.</p>
        </li>
      </ul>
    </section>
  </main>
</PrototypeLayout>
