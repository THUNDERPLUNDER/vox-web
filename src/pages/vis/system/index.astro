---
/* CONTRACT: VIS system landing — routes to canonical system references, runtime feeds and explicitly experimental sandboxes. */
import PrototypeLayout from "../../../layouts/PrototypeLayout.astro";
const base = import.meta.env.BASE_URL;
---

<PrototypeLayout title="System">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Systemreferanse i VIS</h1>
    <p class="mt-2 max-w-prose text-sm leading-relaxed text-gray-600">
      Dette laget viser landet systemarbeid i lesbar form for beslutning og orientering. Canonical design- og article-referanser bor her;
      sandbox er fortsatt et eksperimentrom.
    </p>

    <section class="mt-6">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Design system / article references</h2>
      <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a href={`${base}vis/system/design-system-v01`} class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50">
          <p class="text-sm font-semibold text-gray-900">Design System Overview</p>
          <p class="mt-1 text-xs leading-relaxed text-gray-600">Kart over tokens, surfaces, editorial patterns og Action-AI.</p>
        </a>
        <a href={`${base}vis/system/article/foundations`} class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50">
          <p class="text-sm font-semibold text-gray-900">Foundations</p>
          <p class="mt-1 text-xs leading-relaxed text-gray-600">Article tokens, prinsipper og grunnrytme.</p>
        </a>
        <a href={`${base}vis/system/article/components`} class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50">
          <p class="text-sm font-semibold text-gray-900">Components / patterns</p>
          <p class="mt-1 text-xs leading-relaxed text-gray-600">Landede artikkelkomponenter og preview-referanser.</p>
        </a>
        <a href={`${base}vis/system/article/templates`} class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50">
          <p class="text-sm font-semibold text-gray-900">Template reference</p>
          <p class="mt-1 text-xs leading-relaxed text-gray-600">Oppskrift og canonical artikkelstruktur.</p>
        </a>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Runtime / prosjektstatus</h2>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <a href={`${base}vis/system/roadmap-timeline-v01`} class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50">
          <p class="text-sm font-semibold text-gray-900">Roadmap timeline read model</p>
          <p class="mt-1 text-xs leading-relaxed text-gray-600">Operativ roadmapflate med spor, initiativ og oppgaver fra GitHub-bussen.</p>
        </a>
        <a href={`${base}vis/system/github-runtime-status`} class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50">
          <p class="text-sm font-semibold text-gray-900">GitHub runtime status</p>
          <p class="mt-1 text-xs leading-relaxed text-gray-600">Generert feed fra GitHub API for @navigator / Daily Sync.</p>
        </a>
      </div>
    </section>

    <section class="mt-8 rounded-md border border-dashed border-gray-300 bg-gray-50 p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Sandbox / experimental</h2>
      <p class="mt-2 max-w-prose text-sm leading-relaxed text-gray-600">
        Sandbox kan brukes til å se og teste rå byggeklosser, men er ikke primær canonical dokumentasjon.
      </p>
      <a href={`${base}no/sandbox`} class="mt-3 inline-flex rounded border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-900 hover:bg-gray-100">
        Åpne /no/sandbox
      </a>
      <p class="mt-4 text-xs text-gray-500">
        Pensjonert: <code class="font-mono">/vis/system/task-bus-live</code> og{" "}
        <code class="font-mono">/vis/KlarLyd_Live_Board_Roadmap_v01</code>.
      </p>
    </section>
  </main>
</PrototypeLayout>
