---
/* CONTRACT: Calm VIS design-system map v0.2 — overview of current Viddel tokens, surfaces and patterns; sandbox remains experimental. */
import PrototypeLayout from "../../../layouts/PrototypeLayout.astro";
import "../../../styles/article-system.css";
import "../../../styles/r1-dialog-article.css";

const base = import.meta.env.BASE_URL;

type Status = "canonical" | "experimental" | "needs review" | "needs parity" | "deprecated";
type Layer = "Chrome" | "Editorial" | "Action-AI";

const statusClass: Record<Status, string> = {
  canonical: "ds-status--canonical",
  experimental: "ds-status--experimental",
  "needs review": "ds-status--needs-review",
  "needs parity": "ds-status--needs-parity",
  deprecated: "ds-status--deprecated",
};

const anatomy: Array<{
  layer: Layer;
  role: string;
  examples: string;
  scope: string;
  status: Status;
}> = [
  {
    layer: "Chrome",
    role: "Orientering, navigasjon og intern arbeidskontekst.",
    examples: "Header, breadcrumb, VIS-systemindeks, inspect/devtools.",
    scope: "BaseLayout, PrototypeLayout, VIS.",
    status: "canonical",
  },
  {
    layer: "Editorial",
    role: "Lesing, forståelse, tillit og redaksjonell rytme.",
    examples: "Article header, ingress, body, callouts, next steps, summary. Hub: top task-innganger, article cards, AI fallback, eskalering.",
    scope: "Artikkel, spoke, Storyblok [slug], /no/hub.",
    status: "needs review",
  },
  {
    layer: "Action-AI",
    role: "Hjelp videre fra lesing uten å forlate artikkelkonteksten.",
    examples: "Article AI bridge, seedspørsmål, progressive compose, terminal bottom.",
    scope: "Dialog-artikkel og senere hjelpeflyt.",
    status: "canonical",
  },
];

const tokens = [
  {
    name: "--vox-brand-primary",
    role: "Sonic primary / handling",
    source: "src/styles/tokens.css",
    sampleClass: "bg-[rgb(var(--vox-brand-primary))]",
  },
  {
    name: "--vox-brand-gradient-*",
    role: "Sonic energi, brukt varsomt",
    source: "src/styles/tokens.css",
    sampleClass: "bg-gradient-to-r from-[rgb(var(--vox-brand-gradient-start))] to-[rgb(var(--vox-brand-gradient-end))]",
  },
  {
    name: "--reading-paper",
    role: "Editorial bakgrunn / papir",
    source: "src/styles/tokens.css",
    sampleClass: "bg-[rgb(var(--reading-paper))]",
  },
  {
    name: "--reading-ink",
    role: "Editorial primærtekst",
    source: "src/styles/tokens.css",
    sampleClass: "bg-[rgb(var(--reading-ink))]",
  },
  {
    name: "--reading-accent-iris",
    role: "Rolig editorial aksent",
    source: "src/styles/tokens.css",
    sampleClass: "bg-[rgb(var(--reading-accent-iris))]",
  },
  {
    name: "--radius-*",
    role: "Felles avrundingsfamilie",
    source: "src/styles/tokens.css",
    sampleClass: "bg-[rgb(var(--surface-subtle))]",
  },
  {
    name: "--font-display / --font-sans",
    role: "Epilogue overskrift, Inter brødtekst",
    source: "src/styles/tokens.css",
    sampleClass: "bg-white",
  },
];

const surfaceRows: Array<{
  name: string;
  purpose: string;
  used: string;
  source: string;
  status: Status;
  preview: "calm" | "lifted" | "tech" | "sheet" | "inline" | "next";
}> = [
  {
    name: ".vox-surface-calm",
    purpose: "Rolig informasjonsflate for forklaring og kontekst.",
    used: "/no/sandbox, ordbok-mønstre",
    source: "global.css",
    status: "canonical",
    preview: "calm",
  },
  {
    name: ".vox-surface-lifted",
    purpose: "Myk, løftet støtteflate når en seksjon trenger egen tyngde.",
    used: "/no/sandbox, ordbok-indeks",
    source: "global.css",
    status: "canonical",
    preview: "lifted",
  },
  {
    name: ".vox-surface-tech",
    purpose: "Kompakt teknisk/lenkeorientert flate; bør vurderes mot editorial retning.",
    used: "/no/sandbox, ordbok",
    source: "global.css",
    status: "needs review",
    preview: "tech",
  },
  {
    name: ".vox-reading-sheet",
    purpose: "Papir/leseflate. Storyblok fjerner hairline i r1-kontekst.",
    used: "Storyblok [slug]",
    source: "global.css + r1-dialog-article.css",
    status: "needs review",
    preview: "sheet",
  },
  {
    name: ".vox-reading-inline",
    purpose: "Callout på leseark. Brukes sparsomt, ikke som generell CTA-boks.",
    used: "Storyblok observasjon",
    source: "global.css",
    status: "needs review",
    preview: "inline",
  },
  {
    name: ".r1-editorial-next-steps",
    purpose: "Rolig overgang fra lesing til handling før AI-bro.",
    used: "Storyblok [slug]",
    source: "r1-dialog-article.css",
    status: "experimental",
    preview: "next",
  },
];

const patternRows: Array<{
  id?: string;
  name: string;
  layer: Layer;
  purpose: string;
  source: string;
  status: Status;
  note: string;
}> = [
  {
    id: "pattern-article-header",
    name: "Article header / editorial intro",
    layer: "Editorial",
    purpose: "Setter kontekst, tone og tittelhierarki før lesing.",
    source: "r1-spoke-v03, [slug], r1-dialog-article.css",
    status: "needs review",
    note: "Storyblok [slug] har r1-nærere tittel/lead/trustlag/actions/related topics med fallback-data; full Storyblok-modell gjenstår.",
  },
  {
    name: "Ingress / lead",
    layer: "Editorial",
    purpose: "Løfter leserens forståelse før hovedtekst.",
    source: "[slug], ArticleTemplateV01",
    status: "canonical",
    note: "Finnes i begge artikkelspor.",
  },
  {
    name: "Observation / callout",
    layer: "Editorial",
    purpose: "Markerer støttepunkt uten å overta hovedløpet.",
    source: "global.css, [slug]",
    status: "needs review",
    note: "Bør harmoniseres videre med editorial grammar.",
  },
  {
    id: "pattern-next-steps",
    name: "Next steps",
    layer: "Editorial",
    purpose: "Overgang fra forståelse til handling.",
    source: "r1-dialog-article.css, [slug]",
    status: "experimental",
    note: "Ryddet i #106; bør vurderes etter visuell QA.",
  },
  {
    name: "ArticleSummary / kort oppsummert",
    layer: "Editorial",
    purpose: "Rolig oppsummering etter hovedløpet.",
    source: "ArticleTemplateV01, r1-spoke-v03",
    status: "needs parity",
    note: "Finnes i r1, ikke Storyblok-renderer ennå.",
  },
  {
    name: "Related topics",
    layer: "Editorial",
    purpose: "Tidlig, lavmælt tematisk orientering.",
    source: "r1-spoke-v03, r1-dialog-article.css",
    status: "needs parity",
    note: "R1-only inntil Storyblok-felt/IA avklares.",
  },
  {
    name: "Hub task row",
    layer: "Editorial",
    purpose: "Top task-inngang på hub: klikk → artikkel. Tydelig hover (border/0.22). Muted + «Kommer»-badge for content gaps.",
    source: "/no/hub.astro (hub-task-row)",
    status: "experimental",
    note: "#112 v0.2. Liste med reading-paper bakgrunn, iris-pil og arrow-nudge on hover.",
  },
  {
    name: "Hub featured guide card",
    layer: "Editorial",
    purpose: "Primær guide-inngang: full bredde, prominent tittel, kort deck, CTA, abstrakt thumbnail-flate.",
    source: "/no/hub.astro (hub-guide-featured)",
    status: "experimental",
    note: "#112 v0.2. Thumbnail (168px) bruker ren CSS-gradient per tema (data-thumb). Hover: subtle box-shadow + border-lift.",
  },
  {
    name: "Hub secondary guide card",
    layer: "Editorial",
    purpose: "2-kols kortgrid for resterende guider: thumbnail + kategori + tittel.",
    source: "/no/hub.astro (hub-guide-secondary)",
    status: "experimental",
    note: "#112 v0.2. Grid 2-kol desktop, 1-kol mobil. Thumbnail 96px.",
  },
  {
    name: "Hub escalation card",
    layer: "Editorial",
    purpose: "Horizontal utility-kort for audiograf-eskalering. Visuelt skilt fra guide-kortene.",
    source: "/no/hub.astro (hub-guide-escalation)",
    status: "experimental",
    note: "#112 v0.2. Varm bakgrunn (#fefaf7-variant), muted kategori-kicker, ingen farget thumbnail.",
  },
  {
    name: "Hub AI fallback entry",
    layer: "Action-AI",
    purpose: "Lavmælt AI-overgang fra hub: seed-piller og CTA til Hørehjelpen.",
    source: "/no/hub.astro (hub-ai-entry)",
    status: "experimental",
    note: "#112. AI støtter ruting og fallback — dominerer ikke siden.",
  },
  {
    name: "Legacy seed links",
    layer: "Action-AI",
    purpose: "Gammel lenkeliste til chat.",
    source: "global.css",
    status: "deprecated",
    note: "Erstattet av inline progressive Article AI bridge i [slug].",
  },
];

const actionRows: Array<{
  name: string;
  purpose: string;
  source: string;
  status: Status;
}> = [
  {
    name: "ArticleInlineChatShell / Article AI bridge",
    purpose: "Terminal handlingsflate i artikkel, etter lesing.",
    source: "ArticleInlineChatShell + r1-dialog-article.css",
    status: "canonical",
  },
  {
    name: "Seed questions",
    purpose: "Startpunkt som åpner inline Hørehjelpen-dialog.",
    source: "fetchAiSeedQuestions(), [slug]",
    status: "canonical",
  },
  {
    name: "Progressive compose",
    purpose: "Composer og dialog vokser frem i samme lesekontekst.",
    source: "ArticleInlineChatShell",
    status: "canonical",
  },
  {
    name: "Terminal article bottom",
    purpose: "Ingen konkurrerende footer når AI-bro finnes.",
    source: "[slug], r1-spoke-v03",
    status: "canonical",
  },
  {
    name: "Inspect/dev notes",
    purpose: "Interne Storyblok/RAG-felt vises bare i inspect.",
    source: "InspectDrawerArmScript, [slug]",
    status: "experimental",
  },
];

const referenceLinks = [
  { label: "Design System Overview", href: `${base}vis/system/design-system-v01`, role: "canonical overview" },
  { label: "Article foundations", href: `${base}vis/system/article/foundations`, role: "foundations" },
  { label: "Article components", href: `${base}vis/system/article/components`, role: "components / patterns" },
  { label: "Article template reference", href: `${base}vis/system/article/templates`, role: "template reference" },
  { label: "r1-spoke-v03", href: `${base}no/artikkel/r1-spoke-v03`, role: "editorial ideal" },
  { label: "Storyblok article", href: `${base}no/artikkel/koble-horeapparatet-til-mobilen`, role: "production-like example" },
  { label: "/no/sandbox", href: `${base}no/sandbox`, role: "experimental showroom" },
];
---

<PrototypeLayout title="Design System Overview v0.1">
  <main class="ds-page">
    <nav class="ds-breadcrumb">
      <a href={`${base}vis/system`}>System</a>
      <span aria-hidden="true">/</span>
      <span>Design System Overview v0.1</span>
    </nav>

    <aside class="ds-canonical-banner" role="note">
      <strong>Canonical hjem:</strong>
      <a href={`${base}designsystem/`}>Design System Source of Truth v0.1</a>
      — denne VIS-siden er historikk og beslutningsgrunnlag, ikke gjeldende referanse.
    </aside>

    <header class="ds-hero">
      <p class="ds-kicker">Viddel · arbeidskart · legacy</p>
      <h1>Design System Overview v0.1</h1>
      <p>
        En tidlig VIS-oversikt over tokens, surfaces og patterns slik de faktisk brukes nå.
        Dette er et rolig kart for designledelse og review — se <a href={`${base}designsystem/`}><code>/designsystem/</code></a> for canonical MVP-referanse.
      </p>
      <div class="ds-hero-links" aria-label="Primærreferanser">
        <a href={`${base}vis/system/article/foundations`}>Foundations</a>
        <a href={`${base}vis/system/article/components`}>Components</a>
        <a href={`${base}no/artikkel/r1-spoke-v03`}>Editorial ideal</a>
      </div>
    </header>

    <section class="ds-under-review" aria-labelledby="under-review-title">
      <div>
        <p class="ds-kicker">Under arbeid</p>
        <h2 id="under-review-title">Needs review</h2>
        <p>Mønstre som er i produksjonsnær QA, men ikke låst som canonical.</p>
      </div>
      <nav aria-label="Mønstre under review">
        <a href="#pattern-article-header">Article header / editorial intro</a>
        <a href="#pattern-next-steps">Next steps</a>
      </nav>
    </section>

    <section class="ds-section">
      <div class="ds-section-head">
        <p class="ds-kicker">01</p>
        <h2>Produktanatomi</h2>
        <p>VIS er beholder. Selve designsysteminnholdet sorteres i tre produktlag.</p>
      </div>
      <div class="ds-anatomy">
        {anatomy.map((item) => (
          <article>
            <div class="ds-row">
              <h3>{item.layer}</h3>
              <span class:list={["ds-status", statusClass[item.status]]}>{item.status}</span>
            </div>
            <p>{item.role}</p>
            <dl>
              <div><dt>Patterns</dt><dd>{item.examples}</dd></div>
              <div><dt>Område</dt><dd>{item.scope}</dd></div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="ds-section">
      <div class="ds-section-head">
        <p class="ds-kicker">02</p>
        <h2>Tokens / primitives</h2>
        <p>Kort liste over primitives som forklarer retningen. Full kilde: <code>src/styles/tokens.css</code>.</p>
      </div>
      <div class="ds-token-grid">
        {tokens.map((token) => (
          <article class="ds-token">
            <span class:list={["ds-swatch", token.sampleClass, token.name.includes("radius") && "ds-swatch--radius"]} aria-hidden="true">
              {token.name.includes("font") ? <span><b>Aa</b> / Aa</span> : null}
            </span>
            <div>
              <h3>{token.name}</h3>
              <p>{token.role}</p>
              <small>{token.source}</small>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="ds-section">
      <div class="ds-section-head">
        <p class="ds-kicker">03</p>
        <h2>Surfaces</h2>
        <p>Surface-patterns vises uten ekstra VIS-rammer rundt hver preview for å unngå bokser i bokser.</p>
      </div>
      <div class="ds-pattern-list">
        {surfaceRows.map((item) => (
          <article class="ds-pattern-row">
            <div class="ds-pattern-copy">
              <div class="ds-row">
                <h3>{item.name}</h3>
                <span class:list={["ds-status", statusClass[item.status]]}>{item.status}</span>
              </div>
              <p>{item.purpose}</p>
              <small>Hvor: {item.used} · Kilde: {item.source}</small>
            </div>
            <div class="ds-preview" data-r1-editorial={item.preview === "next" ? true : undefined}>
              {item.preview === "calm" ? (
                <div class="vox-surface-calm">
                  <b>Rolig forklaringsflate</b>
                  <span>Intro og kontekst.</span>
                </div>
              ) : item.preview === "lifted" ? (
                <div class="vox-surface-lifted">
                  <b>Løftet støtteflate</b>
                  <span>Videre lesning / premium.</span>
                </div>
              ) : item.preview === "tech" ? (
                <div class="vox-surface-tech">
                  <b>Teknisk lenkeflate</b>
                  <span>Struktur og venstreaksent.</span>
                </div>
              ) : item.preview === "sheet" ? (
                <div class="vox-reading-sheet ds-reading-preview">
                  <b>Reading sheet</b>
                  <span>Papir, tekst og lesbarhet.</span>
                </div>
              ) : item.preview === "inline" ? (
                <div class="vox-reading-inline ds-inline-preview">
                  <small>Observasjon</small>
                  <span>Støttepunkt i artikkelflyten.</span>
                </div>
              ) : (
                <aside class="r1-editorial-next-steps ds-next-preview">
                  <h4 class="r1-editorial-next-steps__heading">Neste steg</h4>
                  <ul class="r1-editorial-next-steps__list">
                    <li>Prøv ett grep først.</li>
                  </ul>
                </aside>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="ds-section">
      <div class="ds-section-head">
        <p class="ds-kicker">04</p>
        <h2>Editorial patterns</h2>
        <p>Patterns som bærer lesing og forståelse. <span class="ds-status ds-status--needs-parity">needs parity</span> betyr at r1-idealet ikke er fullt koblet i Storyblok-renderer.</p>
      </div>
      <article class="ds-header-showcase" id="pattern-article-header">
        <div class="ds-row">
          <div>
            <h3>Article header / editorial intro</h3>
            <p>Production pattern under review: Storyblok-header med kicker, stor display-tittel, ingress, byline/trustlag, actions, breadcrumb og relaterte tema.</p>
          </div>
          <span class:list={["ds-status", statusClass["needs review"]]}>needs review</span>
        </div>
        <div class="ds-header-preview" data-r1-editorial>
          <header class="r1-storyblok-article-header">
            <div class="r1-storyblok-kicker-row">
              <p>Praktisk guide</p>
            </div>
            <h1>Koble høreapparatet til mobilen: steg som løser det meste</h1>
            <p class="r1-storyblok-lead">
              Når høreapparatet ikke kobler til mobilen, er det lett å bli usikker på hva som faktisk er feil.
              Start med de enkle grepene først.
            </p>
            <section class="r1-storyblok-trustblock" aria-label="Eksempel på artikkelmetadata">
              <img src="/images/klarlyd/r1-byline-profile.png" alt="" class="r1-storyblok-avatar" loading="lazy" />
              <div class="r1-storyblok-trustcopy">
                <p>Av <strong>Nora Lysvik</strong>, faglig rådgiver</p>
                <p>For <strong>Viddel-redaksjonen</strong>, redaksjonelt kvalitetssjekket med faglig orientering</p>
                <p class="r1-storyblok-dates">Publisert 08.05.2026</p>
              </div>
            </section>
            <div class="r1-storyblok-header-tools">
              <nav class="r1-storyblok-breadcrumb" aria-label="Eksempel på brødsmule">
                <span>Forside</span><span aria-hidden="true">/</span><span>Emnehuber</span><span aria-hidden="true">/</span><span>Artikkel</span>
              </nav>
              <div class="r1-storyblok-actions" aria-label="Eksempel på artikkelhandlinger">
                <button type="button" aria-label="Del artikkel">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8.59 13.51 15.42 17.5M15.41 6.5 8.59 10.49M18 22a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm12-7a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                  </svg>
                </button>
                <button type="button" aria-label="Lagre artikkel">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M19 21 12 16 5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                  </svg>
                </button>
              </div>
            </div>
            <div class="r1-storyblok-related-topics" role="group" aria-label="Eksempel på relaterte tema">
              <span>Relaterte tema</span>
              <ul role="list">
                <li>Samtaletips</li>
                <li>Høreliv</li>
                <li>Hverdagskommunikasjon</li>
              </ul>
            </div>
          </header>
        </div>
      </article>
      <div class="ds-table-like">
        {patternRows.map((item) => (
          <article id={item.id === "pattern-article-header" ? undefined : item.id}>
            <div>
              <h3>{item.name}</h3>
              <p>{item.purpose}</p>
            </div>
            <span>{item.layer}</span>
            <small>{item.source}</small>
            <span class:list={["ds-status", statusClass[item.status]]}>{item.status}</span>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="ds-section">
      <div class="ds-section-head">
        <p class="ds-kicker">05</p>
        <h2>Action / AI bridge patterns</h2>
        <p>AI/action-laget skal slekte visuelt på editorial layer og fungere som terminal handlingsflate.</p>
      </div>
      <div class="ds-action-grid">
        <div class="ds-ai-preview" data-r1-editorial>
          <section class="r1-ai-bridge !mb-0 !mt-0">
            <hr class="r1-article-to-klarlyd-divider" aria-hidden="true" />
            <p class="ds-ai-title">Spør Hørehjelpen:</p>
            <button type="button">Hva bør jeg prøve først?</button>
            <button type="button">Hvorfor piper høreapparatet?</button>
            <div class="ds-compose">Spør videre om dette <span>↑</span></div>
          </section>
        </div>
        <div class="ds-action-list">
          {actionRows.map((item) => (
            <article>
              <div class="ds-row">
                <h3>{item.name}</h3>
                <span class:list={["ds-status", statusClass[item.status]]}>{item.status}</span>
              </div>
              <p>{item.purpose}</p>
              <small>{item.source}</small>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="ds-section ds-section--compact">
      <div class="ds-section-head">
        <p class="ds-kicker">06</p>
        <h2>IA for references</h2>
        <p>Canonical references bor i VIS/system. Sandbox er et eksperimentrom og showroom, ikke primær dokumentasjonskilde.</p>
      </div>
      <div class="ds-reference-grid">
        {referenceLinks.map((link) => (
          <a href={link.href}>
            <span>{link.role}</span>
            <b>{link.label}</b>
          </a>
        ))}
      </div>
    </section>

    <section class="ds-section ds-section--compact">
      <div class="ds-section-head">
        <p class="ds-kicker">07</p>
        <h2>Vedlikehold</h2>
        <p>Dette kartet skal vise faktisk bruk, ikke bare ønsket retning.</p>
      </div>
      <ul class="ds-maintenance-list">
        <li>Når nye production-patterns introduseres, skal de inn i denne oversikten eller eksplisitt merkes som ikke-dokumentert.</li>
        <li>Return Ticket for visuelle endringer skal si om <code>/vis/system/design-system-v01</code> må oppdateres.</li>
        <li>Status skal følge faktisk bruk i kode og ruter: canonical, experimental, needs review, needs parity eller deprecated.</li>
      </ul>
    </section>

    <section class="ds-section ds-section--compact">
      <div class="ds-section-head">
        <p class="ds-kicker">Status</p>
        <h2>Legend</h2>
      </div>
      <dl class="ds-legend">
        <div><dt><span class="ds-status ds-status--canonical">canonical</span></dt><dd>Brukes aktivt og bør videreføres.</dd></div>
