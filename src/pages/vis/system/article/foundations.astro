---
/* CONTRACT: VIS foundations snapshot for landed Article System v0.1 values and principles. */
import PrototypeLayout from "../../../../layouts/PrototypeLayout.astro";
const base = import.meta.env.BASE_URL;
const curatedTokens = [
  "--article-system-page-surface",
  "--article-system-plate-surface",
  "--article-system-text-heading",
  "--article-system-text-body",
  "--article-system-text-muted",
  "--article-system-pill-border-light",
  "--article-system-pill-border-dark-rgb",
  "--article-system-pill-border-dark-alpha",
  "--article-system-pill-dark-base-alpha",
  "--article-system-pill-dark-hover-alpha",
  "--article-system-pill-dark-focus-alpha",
  "--article-system-cta-dark-base",
  "--article-system-cta-dark-hover",
  "--article-system-radius-plate",
  "--article-system-space-section-mobile",
  "--article-system-space-section-desktop",
];
---

<PrototypeLayout title="Article Foundations">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Article foundations (v0.1)</h1>
    <p class="mt-2 max-w-prose text-sm text-gray-600">
      Kuratert snapshot av det som faktisk er landet i kode. Ikke full token-dump.
    </p>

    <section class="mt-6 grid gap-3 sm:grid-cols-2">
      <article class="rounded border border-gray-300 bg-white p-3">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Core surfaces</h2>
        <p class="mt-2 text-sm text-gray-700">Page + plate-surface brukes konsekvent som grunnstruktur for artikkelen.</p>
      </article>
      <article class="rounded border border-gray-300 bg-white p-3">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Type hierarchy</h2>
        <p class="mt-2 text-sm text-gray-700">Kicker, heading og body er stabilisert med moderat editorial tetthet.</p>
      </article>
      <article class="rounded border border-gray-300 bg-white p-3">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Radius</h2>
        <p class="mt-2 text-sm text-gray-700">Plate og interaktive elementer bruker en konsistent avrundingsfamilie.</p>
      </article>
      <article class="rounded border border-gray-300 bg-white p-3">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Spacing rhythm</h2>
        <p class="mt-2 text-sm text-gray-700">Seksjonsrytme styres av dedikerte spacing-tokens for mobil/desktop.</p>
      </article>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-gray-50 p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Light / dark principles</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-gray-700">
        <li>Light mode holder lav kontrastfriksjon med lyse flater og diskrete konturer.</li>
        <li>Dark mode bruker eksplisitte verdier for pill-kontur/fill og CTA for tydelig lesbarhet.</li>
        <li>Ingen ny visuell retning introduseres i VIS; dette speiler landet system.</li>
      </ul>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Relevant tokens snapshot</h2>
      <ul class="mt-3 grid gap-2 sm:grid-cols-2">
        {curatedTokens.map((token) => (
          <li class="rounded border border-gray-200 bg-gray-50 px-2 py-1.5 font-mono text-xs text-gray-700">{token}</li>
        ))}
      </ul>
    </section>

    <p class="mt-6 text-xs text-gray-600">
      Kilde: <code class="font-mono">src/styles/tokens.css</code> og <code class="font-mono">src/styles/article-system.css</code>.
      Se også <a class="underline" href={`${base}vis/system/article`}>overview</a>.
    </p>
  </main>
</PrototypeLayout>
