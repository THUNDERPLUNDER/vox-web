---
/* CONTRACT: VIS template page that presents Article Master as current recipe reference. */
import PrototypeLayout from "../../../../layouts/PrototypeLayout.astro";
const base = import.meta.env.BASE_URL;
const anatomy = [
  "Context line / breadcrumb",
  "Kicker",
  "H1 + ingress",
  "Hero figure",
  "Body sections",
  "Callouts / inline figure modules",
  "Prompt bridge (ghost-pill)",
  "Summary block",
  "Footer",
];
---

<PrototypeLayout title="Article Template">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Template reference: Article Master</h1>
    <p class="mt-2 max-w-prose text-sm text-gray-600">
      Dette er nåværende oppskriftsreferanse for artikkelsystemet. Ikke en ny malutforskning.
    </p>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Nåværende anatomy (v0.1)</h2>
      <ol class="mt-2 list-decimal space-y-1 pl-5 text-sm text-gray-700">
        {anatomy.map((step) => (
          <li>{step}</li>
        ))}
      </ol>
    </section>

    <section class="mt-6 rounded-md border border-gray-300 bg-gray-50 p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Visual source of truth</h2>
      <p class="mt-2 text-sm text-gray-700">
        Nåværende referanse vises i sandbox-siden. Denne VIS-siden peker til den som template-kilde.
      </p>
      <a
        href={`${base}no/sandbox/article-master`}
        class="mt-3 inline-flex rounded border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-900 hover:bg-gray-100"
      >
        Åpne /no/sandbox/article-master
      </a>
    </section>

    <p class="mt-6 text-xs text-gray-600">
      Kildegrunnlag: <code class="font-mono">docs/project/09_ARTICLE_SYSTEM_RECIPE.md</code>.
    </p>
  </main>
</PrototypeLayout>
