---
/* CONTRACT: VIS template page that presents Article Master as current recipe reference. */
import PrototypeLayout from "../../../../layouts/PrototypeLayout.astro";
const base = import.meta.env.BASE_URL;
const anatomy = [
  "Context line / breadcrumb",
  "Kicker",
  "H1 + ingress",
  "Hero figure",
  "Body sections",
  "Callouts / inline figure modules",
  "Prompt bridge (ghost-pill)",
  "Summary block",
  "Footer",
];
---

<PrototypeLayout title="Article Template">
  <main class="template-doc-page">
    <nav class="template-doc-breadcrumb">
      <a href={`${base}vis/system`}>System</a>
      <span aria-hidden="true">/</span>
      <a href={`${base}vis/system/article`}>Article System</a>
      <span aria-hidden="true">/</span>
      <span>Template</span>
    </nav>

    <header class="template-doc-hero">
      <p class="template-doc-kicker">Template reference</p>
      <h1>Article Master</h1>
      <p>
        Nåværende oppskriftsreferanse for artikkelsystemet. Dette er canonical recipe,
        ikke en ny malutforskning eller sandbox-flate.
      </p>
    </header>

    <section class="template-doc-section">
      <div class="template-doc-section-head">
        <p class="template-doc-kicker">01</p>
        <h2>Nåværende anatomy v0.1</h2>
        <p>Strukturen viser rekkefølgen en artikkelmal forventes å følge før videre parity-arbeid.</p>
      </div>
      <ol class="template-doc-list">
        {anatomy.map((step) => (
          <li>{step}</li>
        ))}
      </ol>
    </section>

    <section class="template-doc-section">
      <div class="template-doc-section-head">
        <p class="template-doc-kicker">02</p>
        <h2>References</h2>
        <p>
          <a href={`${base}no/artikkel/r1-spoke-v03`}>r1-spoke-v03</a> er editorial ideal for dialog-artikkel.
          Sandbox-lenken under er live preview / eksperimentflate, ikke primær dokumentasjonskilde.
        </p>
      </div>
      <a href={`${base}no/sandbox/article-master`} class="template-doc-pill">
        Åpne /no/sandbox/article-master
      </a>
    </section>

    <section class="template-doc-section template-doc-section--soft">
      <div class="template-doc-section-head">
        <p class="template-doc-kicker">03</p>
        <h2>Kildegrunnlag</h2>
        <p>
          Recipe følger <code>docs/project/09_ARTICLE_SYSTEM_RECIPE.md</code> og skal holdes i takt med
          `ArticleTemplateV01` / production article-spor når mønsteret endres.
        </p>
      </div>
    </section>
  </main>

  <style>
    .template-doc-page {
      min-height: 100vh;
      background: rgb(var(--article-page-canvas));
      color: rgb(var(--reading-ink));
      padding: 1.5rem 1rem 3rem;
    }

    .template-doc-page > * {
      max-width: 72rem;
      margin-left: auto;
      margin-right: auto;
    }

    .template-doc-breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      color: rgb(var(--reading-ink-secondary));
      font-size: 0.72rem;
      margin-bottom: 1.1rem;
    }

    .template-doc-breadcrumb a,
    .template-doc-section a {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .template-doc-hero {
      border-bottom: 1px solid rgb(var(--border) / 0.24);
      padding: 1.5rem 0 2rem;
    }

    .template-doc-hero h1 {
      margin-top: 0.4rem;
      max-width: 52rem;
      font-size: clamp(2.15rem, 6vw, 4.2rem);
      line-height: 0.98;
      letter-spacing: -0.06em;
    }

    .template-doc-hero p,
    .template-doc-section-head > p {
      max-width: 44rem;
      margin-top: 0.8rem;
      color: rgb(var(--reading-ink-secondary));
      font-size: 0.96rem;
      line-height: 1.68;
    }

    .template-doc-kicker {
      color: rgb(var(--reading-accent-iris));
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .template-doc-section {
      padding: 2.4rem 0;
      border-bottom: 1px solid rgb(var(--border) / 0.18);
    }

    .template-doc-section--soft {
      border-bottom: 0;
    }

    .template-doc-section h2 {
      margin-top: 0.15rem;
      font-size: clamp(1.35rem, 3vw, 2rem);
      line-height: 1.12;
      letter-spacing: -0.035em;
    }

    .template-doc-list {
      display: grid;
      gap: 1px;
      overflow: hidden;
      margin-top: 1.25rem;
      border: 1px solid rgb(var(--border) / 0.22);
      border-radius: var(--radius-md);
      background: rgb(var(--border) / 0.22);
      counter-reset: template-step;
    }

    .template-doc-list li {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.8rem;
      align-items: center;
      padding: 0.85rem 1rem;
      color: rgb(var(--reading-ink));
      background: rgb(var(--reading-paper));
      font-size: 0.9rem;
      line-height: 1.5;
      counter-increment: template-step;
    }

    .template-doc-list li::before {
      content: counter(template-step, decimal-leading-zero);
      color: rgb(var(--reading-accent-iris));
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
    }

    .template-doc-pill {
      display: inline-flex;
      margin-top: 1rem;
      border: 1px solid rgb(var(--border) / 0.38);
      border-radius: 999px;
      padding: 0.48rem 0.72rem;
      color: rgb(var(--reading-ink));
      background: rgb(var(--reading-paper));
      font-size: 0.82rem;
      text-decoration: none;
    }

    @media (min-width: 720px) {
      .template-doc-page {
        padding: 2rem 1.5rem 4rem;
      }
    }
  </style>
</PrototypeLayout>
