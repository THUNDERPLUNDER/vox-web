---
/* CONTRACT: VIS read model v0.1 — initiatives from GitHub KL-META, grouped by repo lane manifest (no Gantt, no task expansion). */
import PrototypeLayout from "../../../layouts/PrototypeLayout.astro";
import laneManifest from "../../../../docs/project/roadmap_timeline_lanes.v0.1.json";

const base = import.meta.env.BASE_URL;
const owner = "THUNDERPLUNDER";
const repo = "vox-web";
const roadmapClientProps = JSON.stringify({ laneManifest, owner, repo });
---

<PrototypeLayout title="Roadmap timeline v0.4.1">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Roadmap timeline (v0.4.1)</h1>
    <p class="mt-2 max-w-prose text-sm leading-relaxed text-gray-600">
      Les modell for initiativer fra GitHub-bussen. Metadata hentes fra KL-META i issue body; spor-navn og rekkefølge kommer fra lane-manifest i repo.
      GitHub er source of truth — VIS viser kun.
    </p>
    <p class="mt-2 max-w-prose text-xs leading-relaxed text-gray-500">
      Operativt board er uendret:{" "}
      <a
        href={`${base}vis/${encodeURIComponent("KlarLyd_Live_Board_Roadmap_v01")}`}
        class="underline underline-offset-2"
      >
        Live board
      </a>
      ·{" "}
      <a href={`${base}vis/system/task-bus-live`} class="underline underline-offset-2">
        Task-bus live
      </a>
    </p>

    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Initiativer etter spor</h2>
        <div class="flex items-center gap-2">
          <label for="vis-roadmap-range" class="text-xs font-medium text-gray-600">Tidsspenn</label>
          <select
            id="vis-roadmap-range"
            class="rounded border border-gray-300 bg-white px-2 py-1 text-xs text-gray-700"
          >
            <option value="2026">2026</option>
            <option value="2026-2027">2026-2027</option>
          </select>
          <button
            type="button"
            id="vis-roadmap-refresh"
            class="rounded border border-gray-300 bg-gray-50 px-2.5 py-1 text-xs font-medium text-gray-700 hover:bg-gray-100"
          >
            Oppdater nå
          </button>
        </div>
      </div>
      <details class="mt-2 rounded border border-gray-200 bg-gray-50/70 px-2 py-1.5">
        <summary class="cursor-pointer text-xs font-medium text-gray-700">Vis forklaring av datagrunnlag</summary>
        <p class="mt-2 text-xs text-gray-600">
          Initiativer oppdages fra GitHub-bussen via KL-META (<code class="font-mono">type: initiative</code>) i <code class="font-mono">{owner}/{repo}</code>.
        </p>
        <p class="mt-1 text-[11px] text-gray-500">
          Sikker avgrensning i v0.3: leser de siste 100 issue-elementene fra GitHub API-responsen.
        </p>
        <p class="mt-1 text-[11px] text-gray-500">
          Human-layer regel i v0.3.1: viser kun åpne initiatives (<code class="font-mono">state: open</code>).
        </p>
      </details>
      <p id="vis-roadmap-meta" class="mt-1 text-[11px] text-gray-500">Laster…</p>
      <div id="vis-roadmap-root" class="mt-4 space-y-4"></div>
    </section>

    <p class="mt-6 text-xs text-gray-600">
      Se også <a href={`${base}vis/system`} class="underline underline-offset-2">/vis/system</a>.
    </p>
  </main>
</PrototypeLayout>

<!-- Props for client module: define:vars + import in the same Astro script breaks prod bundling; JSON bootstrap keeps one bundled module. -->
<script type="application/json" id="vis-roadmap-props" set:html={roadmapClientProps} />
<style is:global>
  /* No explicit chevron icon in v0.4.5 microfix: entire epic row is the control. */
</style>

<script>
  import {
    groupInitiativesByLane,
    initiativesFromGitHubIssues,
    tasksFromGitHubIssues,
    type TaskReadModel,
    type LaneManifestV01,
  } from "../../../lib/roadmap-timeline-v01.ts";

  const propsEl = document.getElementById("vis-roadmap-props");
  if (!propsEl?.textContent) {
    throw new Error("vis-roadmap-props mangler");
  }
  const { laneManifest, owner, repo } = JSON.parse(propsEl.textContent) as {
    laneManifest: LaneManifestV01;
    owner: string;
    repo: string;
  };

  const endpoint = `https://api.github.com/repos/${owner}/${repo}/issues?state=all&per_page=100`;
  const root = document.getElementById("vis-roadmap-root");
  const meta = document.getElementById("vis-roadmap-meta");
  const refresh = document.getElementById("vis-roadmap-refresh");
  const rangeSelect = document.getElementById("vis-roadmap-range") as HTMLSelectElement | null;
  let initiativesCache: ReturnType<typeof initiativesFromGitHubIssues> | null = null;
  let tasksByParentCache: Map<number, TaskReadModel[]> | null = null;

  const RANGE_MONTHS: Record<string, { startYear: number; monthCount: number }> = {
    "2026": { startYear: 2026, monthCount: 12 },
    "2026-2027": { startYear: 2026, monthCount: 24 },
  };
  const monthNamesNo = ["jan", "feb", "mar", "apr", "mai", "jun", "jul", "aug", "sep", "okt", "nov", "des"];
  const knownLaneIds = new Set((laneManifest.lanes ?? []).map((lane) => lane.id));
  const laneToneById: Record<string, string> = {
    content: "bg-amber-50/65 border-amber-200",
    ia: "bg-sky-50/65 border-sky-200",
    "ai-agent": "bg-violet-50/65 border-violet-200",
    "ui-design": "bg-rose-50/65 border-rose-200",
    "ops-architecture": "bg-emerald-50/65 border-emerald-200",
  };

  const fmtPlan = (iso: string | null) => {
    if (!iso) return "—";
    const parts = iso.split("-").map((x) => Number.parseInt(x, 10));
    if (parts.length < 3 || parts.some((n) => Number.isNaN(n))) return iso;
    const [y, m, d] = parts;
    return new Intl.DateTimeFormat("nb-NO", { dateStyle: "medium" }).format(new Date(y!, m! - 1, d!));
  };

  const renderEmpty = (message: string) => {
    if (!root) return;
    root.innerHTML = `<p class="rounded border border-gray-300 bg-gray-50 px-3 py-2 text-sm text-gray-600">${message}</p>`;
  };

  const parseIsoDate = (iso: string | null): Date | null => {
    if (!iso) return null;
    const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (!m) return null;
    const y = Number.parseInt(m[1]!, 10);
    const mo = Number.parseInt(m[2]!, 10);
    const d = Number.parseInt(m[3]!, 10);
    if (mo < 1 || mo > 12 || d < 1 || d > 31) return null;
    return new Date(y, mo - 1, d);
  };

  const monthIndex = (date: Date, startYear: number) => (date.getFullYear() - startYear) * 12 + date.getMonth();

  const clamp = (n: number, min: number, max: number) => Math.max(min, Math.min(max, n));

  const activeRange = () => RANGE_MONTHS[rangeSelect?.value ?? "2026"] ?? RANGE_MONTHS["2026"];

  const resolveTaskStatus = (task: TaskReadModel): { labelNo: "Neste" | "Pågående" | "Ferdig"; lampClass: string } => {
    if (task.issueState === "closed") {
      return { labelNo: "Ferdig", lampClass: "bg-emerald-500" };
    }
    const labels = task.labelNames.map((x) => x.toLowerCase());
    const isReview = labels.some((x) => x.includes("review"));
    const isInWork =
      labels.some((x) => x.includes("i arbeid")) ||
      labels.some((x) => x.includes("pågår")) ||
      labels.some((x) => x.includes("in progress")) ||
      labels.some((x) => x.startsWith("status:in-progress"));
    const hasRecentActivity = (() => {
      if (!task.updatedAt) return false;
      const ms = Date.parse(task.updatedAt);
      if (Number.isNaN(ms)) return false;
      const tenDaysMs = 10 * 24 * 60 * 60 * 1000;
      return Date.now() - ms <= tenDaysMs;
    })();
    const isDone = labels.some((x) => x.includes("done")) || labels.some((x) => x.includes("ferdig"));
    if (isDone) return { labelNo: "Ferdig", lampClass: "bg-emerald-500" };
    if (isReview || isInWork || hasRecentActivity) return { labelNo: "Pågående", lampClass: "bg-amber-500" };
    return { labelNo: "Neste", lampClass: "bg-sky-500" };
  };

  const todayIso = () => {
    const d = new Date();
    const y = d.getFullYear();
    const m = `${d.getMonth() + 1}`.padStart(2, "0");
    const day = `${d.getDate()}`.padStart(2, "0");
    return `${y}-${m}-${day}`;
  };

  const initiativeIsStarted = (initiative: { issueNumber: number; planStart: string | null }) => {
    const childTasks = tasksByParentCache?.get(initiative.issueNumber) ?? [];
    const hasStartedByTask = childTasks.some((task) => resolveTaskStatus(task).labelNo !== "Neste");
    const hasStartedByDate = !!initiative.planStart && initiative.planStart <= todayIso();
    return hasStartedByTask || hasStartedByDate;
  };

  const renderFromCache = () => {
    if (!root || !meta || !initiativesCache) return;
    const range = activeRange();
    const groups = groupInitiativesByLane(laneManifest, initiativesCache);
    const sortedGroups = [...groups].sort((a, b) => {
      const startA = a.initiatives
        .filter((it) => initiativeIsStarted(it))
        .map((it) => it.planStart)
        .filter((x): x is string => typeof x === "string")
        .sort()[0];
      const startB = b.initiatives
        .filter((it) => initiativeIsStarted(it))
        .map((it) => it.planStart)
        .filter((x): x is string => typeof x === "string")
        .sort()[0];
      const aActive = !!startA;
      const bActive = !!startB;
      if (aActive !== bActive) return aActive ? -1 : 1;
      if (aActive && bActive) {
        if (startA! !== startB!) return startA! < startB! ? -1 : 1;
      }
      return a.order - b.order;
    });
    const frag = document.createDocumentFragment();

    const axis = document.createElement("div");
    axis.className = "mb-1 px-1";
    axis.innerHTML = `<div id="vis-roadmap-axis-grid" class="grid gap-1 text-[11px] text-gray-600"></div>`;
    const axisGrid = axis.querySelector("#vis-roadmap-axis-grid") as HTMLElement | null;
    if (axisGrid) {
      axisGrid.style.gridTemplateColumns = `repeat(${range.monthCount}, minmax(0, 1fr))`;
      for (let i = 0; i < range.monthCount; i += 1) {
        const m = document.createElement("div");
        m.className = "truncate border-r border-gray-200 pr-1";
        const y = range.startYear + Math.floor(i / 12);
        m.textContent = `${monthNamesNo[i % 12]} ${y}`;
        axisGrid.appendChild(m);
      }
    }
    root.innerHTML = "";
    root.style.backgroundImage = `repeating-linear-gradient(to right, rgba(15,23,42,0.08) 0 1px, transparent 1px calc(100% / ${range.monthCount}))`;
    root.style.backgroundSize = `calc(100% / ${range.monthCount}) 100%`;
    root.style.backgroundPosition = "0 0";
    root.appendChild(axis);

    for (const lane of sortedGroups) {
      const section = document.createElement("section");
      section.className = "rounded-md border p-2.5 border-gray-200";
      const laneTone = laneToneById[lane.laneId] ?? "bg-gray-50/80 border-gray-200";
      section.classList.add(...laneTone.split(" "));
      section.innerHTML = `
        <div class="-m-2.5 mb-1.5 px-2.5 py-1.5">
          <h3 class="text-base font-semibold text-gray-900"><span class="text-[10px] font-semibold uppercase tracking-wide text-gray-500">Spor</span> · ${lane.labelNo}</h3>
        </div>
        <div class="mt-2 space-y-2.5" id="lane-items"></div>
      `;
      const laneItems = section.querySelector("#lane-items");
      if (!laneItems) continue;

      for (const it of lane.initiatives) {
        const start = parseIsoDate(it.planStart) ?? parseIsoDate(it.planEnd);
        const end = parseIsoDate(it.planEnd) ?? parseIsoDate(it.planStart);
        if (!start || !end) continue;
        const startCol = clamp(monthIndex(start, range.startYear) + 1, 1, range.monthCount);
        const rawEndExclusive = monthIndex(end, range.startYear) + 2;
        const endCol = clamp(rawEndExclusive <= startCol ? startCol + 1 : rawEndExclusive, 2, range.monthCount + 1);

        const item = document.createElement("details");
        item.className = "rounded border border-gray-300 bg-white px-3 py-2";
        const childTasks = tasksByParentCache?.get(it.issueNumber) ?? [];
        const taskCount = childTasks.length;
        const initiativeStarted = initiativeIsStarted(it);
        item.open = false;
        item.innerHTML = `
          <summary class="cursor-pointer list-none py-1">
            <div class="flex items-baseline justify-between gap-3">
              <p class="min-w-0 truncate text-sm font-semibold text-gray-900"><span class="text-[10px] font-semibold uppercase tracking-wide text-gray-500">Initiativ</span> · #${it.issueNumber} ${escapeHtml(it.title)}</p>
              <span class="shrink-0 text-xs font-semibold text-gray-800">Oppgaver: ${taskCount}</span>
            </div>
            <div class="mt-1 grid gap-1 rounded border border-gray-200 bg-gray-50 p-1" id="bar-grid-summary"></div>
          </summary>
          <div class="grid gap-2 pb-1 pt-1">
            <p class="text-xs leading-relaxed text-gray-700"><span class="font-medium text-gray-800">Oppsummering:</span> ${escapeHtml(it.summaryNo || "—")}</p>
            ${
              it.explainerNo
                ? `<p class="text-xs leading-relaxed text-gray-600"><span class="font-medium text-gray-700">Kort forklart:</span> ${escapeHtml(it.explainerNo)}</p>`
                : ""
            }
            <dl class="grid gap-1 text-xs text-gray-700 sm:grid-cols-2">
              <div><dt class="inline font-medium text-gray-600">Planlagt start:</dt> <dd class="inline">${fmtPlan(it.planStart)}</dd></div>
              <div><dt class="inline font-medium text-gray-600">Planlagt slutt:</dt> <dd class="inline">${fmtPlan(it.planEnd)}</dd></div>
            </dl>
            <p>
              <a href="${it.htmlUrl}" target="_blank" rel="noreferrer" class="text-xs font-medium text-gray-900 underline underline-offset-2">
                Åpne i GitHub (#${it.issueNumber})
              </a>
            </p>
            <div class="rounded border border-gray-200 bg-gray-50/70 px-2 py-1.5">
              <p class="text-xs font-medium text-gray-700">Oppgaver (${taskCount})</p>
              <div class="mt-2 grid gap-2 md:grid-cols-3" id="task-board">
                <section class="rounded border border-gray-200 bg-white p-2">
                  <p class="text-[11px] font-semibold text-gray-700">Neste</p>
                  <ul class="mt-1.5 space-y-1.5 text-xs text-gray-700" data-col="Neste"></ul>
                </section>
                <section class="rounded border border-gray-200 bg-white p-2">
                  <p class="text-[11px] font-semibold text-gray-700">Pågående</p>
                  <ul class="mt-1.5 space-y-1.5 text-xs text-gray-700" data-col="Pågående"></ul>
                </section>
                <section class="rounded border border-gray-200 bg-white p-2">
                  <p class="text-[11px] font-semibold text-gray-700">Ferdig</p>
                  <ul class="mt-1.5 space-y-1.5 text-xs text-gray-700" data-col="Ferdig"></ul>
                </section>
              </div>
            </div>
          </div>
        `;

        const mountBar = (el: HTMLElement | null) => {
          if (!el) return;
          el.style.gridTemplateColumns = `repeat(${range.monthCount}, minmax(0, 1fr))`;
          const bar = document.createElement("div");
          bar.className = `h-4 rounded ${initiativeStarted ? "bg-gray-700" : "bg-gray-400"}`;
          bar.style.gridColumn = `${startCol} / ${endCol}`;
          bar.title = `${it.title}: ${fmtPlan(it.planStart)} -> ${fmtPlan(it.planEnd)}`;
          el.appendChild(bar);
        };
        mountBar(item.querySelector("#bar-grid-summary") as HTMLElement | null);
        const taskBoard = item.querySelector("#task-board");
        if (taskBoard) {
          const byCol = new Map<"Neste" | "Pågående" | "Ferdig", TaskReadModel[]>([
            ["Neste", []],
            ["Pågående", []],
            ["Ferdig", []],
          ]);
          for (const task of childTasks) {
            const taskStatus = resolveTaskStatus(task);
            byCol.get(taskStatus.labelNo)!.push(task);
          }
          for (const col of ["Neste", "Pågående", "Ferdig"] as const) {
            const ul = taskBoard.querySelector(`ul[data-col="${col}"]`) as HTMLElement | null;
            if (!ul) continue;
            const tasks = byCol.get(col) ?? [];
            if (tasks.length === 0) {
              const empty = document.createElement("li");
              empty.className = "text-gray-500";
              empty.textContent = "Ingen oppgaver.";
              ul.appendChild(empty);
              continue;
            }
            for (const task of tasks) {
              const li = document.createElement("li");
              const taskStatus = resolveTaskStatus(task);
              li.className = "rounded border border-gray-200 bg-white px-2 py-1";
              li.innerHTML = `
                <div class="flex items-center justify-between gap-2">
                  <p class="font-medium text-gray-800">#${task.issueNumber} ${escapeHtml(task.title)}</p>
                  <span class="inline-flex items-center gap-1.5 text-[11px] text-gray-600">
                    <span class="h-2 w-2 rounded-full ${taskStatus.lampClass}" aria-hidden="true"></span>
                    ${taskStatus.labelNo}
                  </span>
                </div>
                <p class="mt-0.5 text-gray-600">Plan: ${fmtPlan(task.planStart)} -> ${fmtPlan(task.planEnd)}</p>
                <p class="mt-1"><a href="${task.htmlUrl}" target="_blank" rel="noreferrer" class="font-medium underline underline-offset-2">Åpne i GitHub (#${task.issueNumber})</a></p>
              `;
              ul.appendChild(li);
            }
          }
        }
        laneItems.appendChild(item);
      }
      frag.appendChild(section);
    }
    root.appendChild(frag);
    meta.textContent = `Sist oppdatert: ${new Intl.DateTimeFormat("nb-NO", { dateStyle: "medium", timeStyle: "short" }).format(new Date())}`;
  };

  const load = () => {
    if (!root || !meta) return;
    meta.textContent = "Laster fra GitHub API…";
    root.innerHTML = "";

    fetch(endpoint, {
      headers: { Accept: "application/vnd.github+json" },
      cache: "no-store",
    })
      .then((res) => {
        if (!res.ok) {
          if (res.status === 403) throw new Error("GitHub API rate limit nådd i dette miljøet.");
          throw new Error(`GitHub API svarte ${res.status}.`);
        }
        return res.json();
      })
      .then((all: unknown) => {
        if (!Array.isArray(all)) {
          renderEmpty("Uventet svar fra GitHub API.");
          return;
        }
        const issueCandidates = all.filter(
          (issue): issue is { number: number; title: string; body: string | null; html_url: string; state: string; pull_request?: unknown } =>
            issue &&
            typeof issue === "object" &&
            "number" in issue &&
            typeof (issue as { number: unknown }).number === "number" &&
            "state" in issue &&
            (issue as { state?: unknown }).state === "open" &&
            !("pull_request" in issue && (issue as { pull_request?: unknown }).pull_request),
        );

        initiativesCache = initiativesFromGitHubIssues(issueCandidates)
          .filter((initiative) => knownLaneIds.has(initiative.laneId))
          .sort((a, b) => a.issueNumber - b.issueNumber);

        const allTasks = tasksFromGitHubIssues(issueCandidates)
          .filter((task) => knownLaneIds.has(task.laneId) && task.parentIssueNumber !== null);
        const byParent = new Map<number, TaskReadModel[]>();
        for (const task of allTasks) {
          const key = task.parentIssueNumber!;
          const existing = byParent.get(key);
          if (existing) existing.push(task);
          else byParent.set(key, [task]);
        }
        for (const items of byParent.values()) {
          items.sort((a, b) => a.issueNumber - b.issueNumber);
        }
        tasksByParentCache = byParent;

        if (initiativesCache.length === 0) {
          renderEmpty("Fant ingen åpne initiative-issues med KL-META i kjent spor blant de siste 100 issue-elementene.");
          meta.textContent = `Sist forsøkt: ${new Intl.DateTimeFormat("nb-NO", { dateStyle: "medium", timeStyle: "short" }).format(new Date())}`;
          return;
        }
        renderFromCache();
      })
      .catch((error: unknown) => {
        renderEmpty("Kunne ikke hente initiativer akkurat nå. Prøv igjen eller åpne GitHub direkte.");
        meta.textContent = `Feil: ${error instanceof Error ? error.message : "ukjent"}`;
      });
  };

  function escapeHtml(s: string) {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  if (root && meta && refresh) {
    refresh.addEventListener("click", load);
    rangeSelect?.addEventListener("change", renderFromCache);
    load();
  }
</script>
