---
/* CONTRACT: Retired VIS route notice for former task-bus live page; points to canonical roadmap surface. */
import PrototypeLayout from "../../../layouts/PrototypeLayout.astro";

const base = import.meta.env.BASE_URL;
---

<PrototypeLayout title="Task-bus live (pensjonert)">
  <main class="px-4 py-6 sm:px-6 sm:py-8">
    <h1 class="text-lg font-semibold text-gray-900">Task-bus live (pensjonert)</h1>
    <p class="mt-2 max-w-prose text-sm leading-relaxed text-gray-600">
      Denne siden er avpublisert fra aktiv VIS-bruk. Operativ roadmapflate er flyttet til roadmap timeline.
    </p>
    <section class="mt-6 rounded-md border border-gray-300 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Canonical roadmap i VIS</h2>
      <p class="mt-2 text-sm leading-relaxed text-gray-600">
        Bruk roadmap timeline som primar inngang for roadmap og task-status i human-layeret.
      </p>
      <a
        href={`${base}vis/system/roadmap-timeline-v01`}
        class="mt-3 inline-flex rounded-sm border border-gray-300 bg-gray-100 px-3 py-1.5 text-xs font-medium text-gray-800 hover:bg-gray-200"
      >
        Apne roadmap timeline
      </a>
      <p class="mt-3 text-xs text-gray-500">
        Pensjonert erstatning: <code class="font-mono">/vis/system/task-bus-live</code> ->{" "}
        <code class="font-mono">/vis/system/roadmap-timeline-v01</code>.
      </p>
    </section>

    <p class="mt-6 text-xs text-gray-600">
      Se også <a href={`${base}vis/system`} class="underline underline-offset-2">/vis/system</a>.
    </p>
  </main>
</PrototypeLayout>
