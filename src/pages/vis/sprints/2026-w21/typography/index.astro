---
/* CONTRACT: VIS-only Typography Lab for #123 — full-width display direction review.
   Working decision: Direction 0 Existing Bold Display — moderated (MVP hypothesis).
   Parent: #126 sprint preview / #120 Design Lock. Not production design.
*/
import PrototypeLayout from "../../../../../layouts/PrototypeLayout.astro";
import "../../../../../styles/global.css";

const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;

const evalCriteria = ["Lesbarhet", "Viddel-særpreg", "Tillit", "Hverdagsenergi"];

const testContent = {
  kicker: "BESLUTNINGSSTØTTE",
  h1: "Audiograf: når det haster, og hva du kan forberede",
  ingress:
    "Noen høreapparatproblemer kan du feilsøke rolig selv. Andre bør vurderes raskt. Her får du hjelp til å skille mellom det som haster, det som bør bookes, og hva du kan forberede før du tar kontakt.",
  meta: "Oppdatert: 19. mai 2026 · 4 min lesing",
  h2: "Vanlige problemer og hjelp",
  body: "Viddel hjelper deg med vanlige problemer, enkle forklaringer og raske grep som gjør høreapparatet lettere å bruke i hverdagen. Målet er å gjøre det enklere å vite hva du kan prøve selv, og når du bør kontakte audiograf.",
  aiLabel: "SKRIV HVA SOM IKKE FUNGERER",
  inputPlaceholder: "Beskriv problemet kort …",
  button: "Få hjelp nå",
  aiHelper: "Du kan beskrive lyd, piping, app-problemer eller situasjoner der det blir vanskelig å høre.",
  norwegian: "Ærlig tilbakekobling om lyd, ørhet, støy og å gjøre hverdagen enklere.",
  charset: "ABCDEFGHIJKLMNOPQRSTUVWXYZÆØÅ\nabcdefghijklmnopqrstuvwxyzæøå\n0123456789",
};

const heroContent = {
  headline: "Sound, shaped with precision.",
  subline: "Clarity for life's most important moments.",
};

const secondaryArticleContent = {
  kicker: "BESLUTNINGSSTØTTE",
  h1: "Audiograf: når det haster, og hva du kan forberede",
  ingress:
    "Noen høreapparatproblemer kan du feilsøke rolig selv. Andre bør vurderes raskt. Her får du hjelp til å skille mellom det som haster, det som bør bookes, og hva du kan forberede før du tar kontakt.",
  h2: "Vanlige problemer og hjelp",
  body: "Viddel hjelper deg med vanlige problemer, enkle forklaringer og raske grep som gjør høreapparatet lettere å bruke i hverdagen.",
};

const secondaryAlternates = [
  {
    id: "signal-light",
    anchor: "sec-signal-light",
    name: "Signal Sans — light/refined",
    testingFor:
      "Lettere, mer elegant signal/sans — moderne og tydelig uten tung SaaS-følelse. Skal tåle hero bedre enn tyngre signalvariant.",
    fontStack: 'Sora 500/600 · VIS-only · "Sora", "Inter", sans-serif',
  },
  {
    id: "editorial-light",
    anchor: "sec-editorial-light",
    name: "Editorial Serif — light/refined",
    testingFor:
      "Lettere, luftig serif inspirert av editorial-retningen — tillit og eleganse uten spa, retreat eller luksusmagasin.",
    fontStack: 'Source Serif 4 500/600 · VIS-only · "Source Serif 4", Georgia, serif',
  },
  {
    id: "hero-serif",
    anchor: "sec-hero-serif",
    name: "Hero Serif — elegant contrast",
    testingFor:
      "Hero-orientert serif/display inspirert av elegante lys/mørk-mockups — primært brand/hero, ikke nødvendigvis standard artikkel-H1.",
    fontStack: 'Cormorant Garamond 500/600 · VIS-only · "Cormorant Garamond", Georgia, serif',
  },
];

const directions = [
  {
    id: "existing",
    anchor: "dir-existing",
    number: "0",
    name: "Existing Bold Display — moderated",
    testingFor: "Tester om dagens brede, tunge displayenergi kan bevares med mer luft, bedre tracking og kontroll på lange norske overskrifter.",
    fontStack: 'Epilogue 600/700 · VIS-only · "Epilogue", "Inter", sans-serif',
    cssVar: "--tlab-display-existing",
    isWorkingDecision: true,
  },
  {
    id: "signal",
    anchor: "dir-signal",
    number: "1",
    name: "Signal Sans",
    testingFor: "Tester aktiv, presis og produktnær tydelighet — tydelig skilt fra Inter body/UI.",
    fontStack: 'Sora 700 · VIS-only · "Sora", "Inter", sans-serif',
    cssVar: "--tlab-display-signal",
    isWorkingDecision: false,
  },
  {
    id: "tight",
    anchor: "dir-tight",
    number: "2",
    name: "Tight Sans",
    testingFor: "Tester kompakt, fokusert MVP-retning — condensed sans som mulig Viddel Display.",
    fontStack: 'Roboto Condensed 700 · VIS-only · "Roboto Condensed", "Inter", sans-serif',
    cssVar: "--tlab-display-tight",
    isWorkingDecision: false,
  },
  {
    id: "serif",
    anchor: "dir-serif",
    number: "3",
    name: "Editorial Serif",
    testingFor: "Tester redaksjonell varme og tillit som mulig editorial accent — ikke spa eller luksusmagasin.",
    fontStack: 'Georgia / Iowan Old Style · system · Georgia, "Iowan Old Style", serif',
    cssVar: "--tlab-display-serif",
    isWorkingDecision: false,
  },
  {
    id: "precision",
    anchor: "dir-precision",
    number: "4",
    name: "Editorial Precision Display",
    testingFor: "Tester strammere redaksjonell presisjon — tyngde uten mykhet, produktpresisjon beholdt.",
    fontStack: 'Source Serif 4 700 · VIS-only · "Source Serif 4", Georgia, serif',
    cssVar: "--tlab-display-precision",
    isWorkingDecision: false,
  },
];
const tlabFontStylesheet =
  "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Epilogue:wght@600;700&family=Inter:wght@400;500;600&family=Roboto+Condensed:wght@700&family=Sora:wght@500;600;700&family=Source+Serif+4:wght@500;600;700&display=swap";
---

<PrototypeLayout title="Typography Lab — #123">
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" rel="stylesheet" href={tlabFontStylesheet} />
  <main class="tlab" data-typography-lab>
    <nav class="tlab__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <span>Typography</span>
    </nav>

    <!-- Header -->
    <header class="tlab__hero">
      <p class="tlab__kicker">VIS-only · #123</p>
      <h1>Typography Lab — #123</h1>
      <p class="tlab__subtitle">Viddel Display directions tested on article-start content</p>

      <dl class="tlab__meta">
        <div><dt>Sprint</dt><dd>2026-W21</dd></div>
        <div><dt>Parent</dt><dd>#120</dd></div>
        <div><dt>Preview</dt><dd>#126</dd></div>
        <div><dt>Issue</dt><dd>#123</dd></div>
        <div><dt>Status</dt><dd>Working decision</dd></div>
      </dl>

      <p class="tlab__decision">
        <strong>Working decision:</strong> continue with Existing Bold Display — moderated as the primary display hypothesis.
        Inter remains the system font for body, UI and action.
      </p>

      <ul class="tlab__usage" role="list">
        <li>Use display for H1, hero and key editorial entry points.</li>
        <li>Use Inter for body, UI, labels, navigation and action.</li>
        <li>Control max-width, line-height and responsive breaks.</li>
        <li>Avoid heavy display in small UI.</li>
      </ul>

      <p class="tlab__note">
        Viddel Sans = Inter. This lab is VIS-only — comparison references retained below.
      </p>
      <p class="tlab__debug-note">
        VIS-only webfonts loaded for review. If unavailable, browser falls back to listed stack.
        Check Network tab for fonts.googleapis.com / fonts.gstatic.com.
      </p>
    </header>

    <!-- Sticky nav -->
    <nav class="tlab__nav" aria-label="Typografiske retninger">
      <p class="tlab__nav-label">Directions</p>
      <ol class="tlab__nav-list">
        {directions.map((d) => (
          <li>
            <a href={`#${d.anchor}`} class:list={[d.isWorkingDecision && "tlab__nav-link--working"]}>
              {d.number}. {d.name}
              {d.isWorkingDecision ? <span class="tlab__badge tlab__badge--working">Working decision</span> : null}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <!-- Full-width stacked directions -->
    <div class="tlab__sections">
      {directions.map((direction) => (
        <section
          id={direction.anchor}
          class:list={["tlab__direction", direction.isWorkingDecision && "tlab__direction--working"]}
          data-direction={direction.id}
        >
          <header class="tlab__direction-head">
            <div class="tlab__direction-title-row">
              <h2>{direction.number}. {direction.name}</h2>
              {direction.isWorkingDecision ? (
                <span class="tlab__badge tlab__badge--working">Working decision</span>
              ) : (
                <span class="tlab__badge tlab__badge--reference">Comparison reference</span>
              )}
            </div>
            <p class="tlab__testing">
              <strong>Testing for:</strong> {direction.testingFor}
            </p>
            <p class="tlab__stack">
              <strong>Font / stack:</strong> {direction.fontStack}
            </p>
            <ul class="tlab__criteria" role="list" aria-label="Vurderingskriterier">
              {evalCriteria.map((c) => <li>{c}</li>)}
            </ul>
          </header>

          <article class="tlab__article-start">
            <p class="tlab__kicker-sample">{testContent.kicker}</p>
            <h3 class="tlab__h1">{testContent.h1}</h3>
            <p class="tlab__ingress">{testContent.ingress}</p>
            <p class="tlab__meta-line">{testContent.meta}</p>
            <h4 class="tlab__h2">{testContent.h2}</h4>
            <p class="tlab__body">{testContent.body}</p>

            <div class="tlab__ai-block">
              <p class="tlab__ai-label">{testContent.aiLabel}</p>
              <input
                type="text"
                class="tlab__input"
                placeholder={testContent.inputPlaceholder}
                aria-label={testContent.inputPlaceholder}
                readonly
              />
              <button type="button" class="tlab__button">{testContent.button}</button>
              <p class="tlab__ai-helper">{testContent.aiHelper}</p>
            </div>

            <p class="tlab__norwegian">{testContent.norwegian}</p>
            <pre class="tlab__charset" aria-label="Character set">{testContent.charset}</pre>
          </article>
        </section>
      ))}
    </div>

    <!-- Compact comparison strip -->
    <section class="tlab__strip" aria-labelledby="strip-heading">
      <h2 id="strip-heading">Compact comparison strip</h2>
      <p class="tlab__strip-note">Supplement only — full sections above are primary review surface.</p>
      <ul class="tlab__strip-list" role="list">
        {directions.map((direction) => (
          <li class="tlab__strip-item" data-direction={direction.id}>
            <p class="tlab__strip-name">{direction.number}. {direction.name}</p>
            <p class="tlab__strip-h1">{testContent.h1}</p>
          </li>
        ))}
      </ul>
    </section>

    <!-- Secondary alternates — lighter display studies -->
    <section class="tlab__secondary" id="secondary-alternates" aria-labelledby="secondary-heading">
      <header class="tlab__secondary-head">
        <p class="tlab__kicker">Exploration only</p>
        <h2 id="secondary-heading">Secondary alternates — lighter display studies</h2>
        <p class="tlab__secondary-intro">
          These are secondary, lighter display explorations inspired by earlier Viddel display studies.
          They do not replace the current working decision.
        </p>
        <ul class="tlab__secondary-notes" role="list">
          <li><strong>Working decision remains:</strong> Existing Bold Display — moderated</li>
          <li>These lighter variants are exploratory only</li>
          <li>Final display font is still not locked</li>
        </ul>
      </header>

      <div class="tlab__secondary-list">
        {secondaryAlternates.map((alt) => (
          <article id={alt.anchor} class="tlab__secondary-alt" data-secondary={alt.id}>
            <header class="tlab__secondary-alt-head">
              <div class="tlab__direction-title-row">
                <h3>{alt.name}</h3>
                <span class="tlab__badge tlab__badge--exploration">Secondary exploration</span>
              </div>
              <p class="tlab__testing">
                <strong>Testing for:</strong> {alt.testingFor}
              </p>
              <p class="tlab__stack">
                <strong>Font / stack:</strong> {alt.fontStack}
              </p>
            </header>

            <div class="tlab__hero-pair">
              <div class="tlab__hero-sample tlab__hero-sample--light">
                <p class="tlab__hero-label">Light hero</p>
                <p class="tlab__hero-headline">{heroContent.headline}</p>
                <p class="tlab__hero-subline">{heroContent.subline}</p>
              </div>
              <div class="tlab__hero-sample tlab__hero-sample--dark">
                <p class="tlab__hero-label">Dark hero</p>
                <p class="tlab__hero-headline">{heroContent.headline}</p>
                <p class="tlab__hero-subline">{heroContent.subline}</p>
              </div>
            </div>

            <article class="tlab__article-start tlab__article-start--compact">
              <p class="tlab__kicker-sample">{secondaryArticleContent.kicker}</p>
              <h4 class="tlab__h1">{secondaryArticleContent.h1}</h4>
              <p class="tlab__ingress">{secondaryArticleContent.ingress}</p>
              <h5 class="tlab__h2">{secondaryArticleContent.h2}</h5>
              <p class="tlab__body">{secondaryArticleContent.body}</p>
            </article>
          </article>
        ))}
      </div>
    </section>

    <footer class="tlab__footer">
      <p>
        Typography direction is under evaluation. Final font selection is not locked in #123.
        Fonts loaded on this page are VIS-only tests.
      </p>
      <p><a href={sprintPath}>← Back to Sprint Preview 2026-W21</a></p>
    </footer>
  </main>

  <style>
    [data-typography-lab] {
      --tlab-sans: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
      --tlab-display-existing: "Epilogue", "Inter", ui-sans-serif, sans-serif;
      --tlab-display-signal: "Sora", "Inter", ui-sans-serif, sans-serif;
      --tlab-display-tight: "Roboto Condensed", "Inter", ui-sans-serif, sans-serif;
      --tlab-display-serif: Georgia, "Iowan Old Style", "Times New Roman", serif;
      --tlab-display-precision: "Source Serif 4", Georgia, "Times New Roman", serif;

      min-height: 100vh;
      background: rgb(var(--article-page-canvas));
      color: rgb(var(--reading-ink));
      padding: 1.5rem 1rem 4rem;
      max-width: 52rem;
      margin: 0 auto;
      font-family: var(--tlab-sans);
    }

    .tlab__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.25rem;
      font-size: 0.72rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .tlab__breadcrumb a {
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .tlab__hero {
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgb(var(--border) / 0.24);
    }

    .tlab__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgb(var(--reading-accent-iris));
    }

    .tlab__hero > h1 {
      margin: 0.45rem 0 0;
      font-family: var(--tlab-sans);
      font-size: clamp(1.75rem, 4.5vw, 2.5rem);
      font-weight: 600;
      letter-spacing: -0.04em;
      line-height: 1.05;
    }

    .tlab__subtitle {
      margin: 0.6rem 0 0;
      font-size: 0.95rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .tlab__meta {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(7rem, 1fr));
      gap: 0.65rem 1rem;
      margin: 1.1rem 0 0;
      padding: 0.85rem 1rem;
      border: 1px solid rgb(var(--border) / 0.22);
      border-radius: var(--radius-md);
      background: rgb(var(--reading-paper));
    }

    .tlab__meta dt {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgb(var(--muted));
    }

    .tlab__meta dd {
      margin: 0.15rem 0 0;
      font-size: 0.84rem;
    }

    .tlab__decision {
      margin: 1rem 0 0;
      padding: 0.75rem 0.9rem;
      border-left: 3px solid rgb(var(--reading-accent-iris) / 0.55);
      font-size: 0.88rem;
      line-height: 1.65;
      color: rgb(var(--reading-ink));
      background: rgb(var(--surface-subtle) / 0.45);
    }

    .tlab__usage {
      margin: 0.75rem 0 0;
      padding-left: 1.15rem;
      max-width: 44rem;
      font-size: 0.82rem;
      line-height: 1.65;
      color: rgb(var(--reading-ink-secondary));
    }

    .tlab__note {
      margin: 0.85rem 0 0;
      padding: 0.65rem 0.85rem;
      border-left: 3px solid rgb(var(--reading-accent-iris) / 0.45);
      font-size: 0.86rem;
      line-height: 1.6;
      color: rgb(var(--reading-ink-secondary));
      background: rgb(var(--surface-subtle) / 0.35);
    }

    .tlab__debug-note {
      margin: 0.55rem 0 0;
      font-size: 0.75rem;
      line-height: 1.55;
      color: rgb(var(--muted));
    }

    /* Sticky nav */
    .tlab__nav {
      position: sticky;
      top: 0;
      z-index: 10;
      margin: 1.25rem 0;
      padding: 0.75rem 0.9rem;
      border: 1px solid rgb(var(--border) / 0.28);
      border-radius: var(--radius-md);
      background: rgb(var(--reading-paper) / 0.95);
      backdrop-filter: blur(8px);
    }

    .tlab__nav-label {
      margin: 0 0 0.45rem;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgb(var(--muted));
    }

    .tlab__nav-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .tlab__nav-list a {
      display: inline-flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.78rem;
      font-weight: 500;
      color: rgb(var(--reading-ink));
      text-decoration: none;
    }

    .tlab__nav-link--working {
      font-weight: 600;
    }

    .tlab__nav-list a:hover {
      color: rgb(var(--reading-accent-iris));
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    /* Direction sections */
    .tlab__sections {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .tlab__direction {
      scroll-margin-top: 5rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid rgb(var(--border) / 0.2);
    }

    .tlab__direction:last-child {
      border-bottom: 0;
    }

    .tlab__direction-head h2 {
      margin: 0;
      font-family: var(--tlab-sans);
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .tlab__direction-title-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
    }

    .tlab__badge {
      display: inline-flex;
      padding: 0.18rem 0.45rem;
      border-radius: 999px;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .tlab__badge--working {
      border: 1px solid rgb(var(--reading-accent-iris) / 0.45);
      color: rgb(var(--reading-accent-iris));
      background: rgb(var(--reading-accent-iris) / 0.08);
    }

    .tlab__badge--reference {
      border: 1px solid rgb(var(--border) / 0.4);
      color: rgb(var(--muted));
      background: rgb(var(--surface-subtle) / 0.35);
    }

    .tlab__direction--working .tlab__article-start {
      border-color: rgb(var(--reading-accent-iris) / 0.35);
    }

    .tlab__testing,
    .tlab__stack {
      margin: 0.5rem 0 0;
      font-size: 0.82rem;
      line-height: 1.6;
      color: rgb(var(--reading-ink-secondary));
    }

    .tlab__testing strong,
    .tlab__stack strong {
      color: rgb(var(--reading-ink));
    }

    .tlab__criteria {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin: 0.75rem 0 0;
      padding: 0;
      list-style: none;
    }

    .tlab__criteria li {
      padding: 0.22rem 0.5rem;
      border: 1px solid rgb(var(--border) / 0.35);
      border-radius: 999px;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      color: rgb(var(--reading-ink-secondary));
    }

    /* Article-start preview — shared UI layer */
    .tlab__article-start {
      margin-top: 1.25rem;
      padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1.25rem, 3vw, 2rem);
      border: 1px solid rgb(var(--border) / 0.22);
      border-radius: 10px;
      background: rgb(var(--reading-paper));
    }

    .tlab__kicker-sample,
    .tlab__ai-label {
      margin: 0;
      font-family: var(--tlab-sans);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgb(var(--reading-accent-iris));
    }

    .tlab__ingress,
    .tlab__body,
    .tlab__meta-line,
    .tlab__norwegian,
    .tlab__ai-helper {
      font-family: var(--tlab-sans);
    }

    .tlab__ingress {
      margin: clamp(0.85rem, 2vw, 1.15rem) 0 0;
      max-width: 38rem;
      font-size: clamp(1.05rem, 2.2vw, 1.25rem);
      line-height: 1.58;
      color: rgb(var(--reading-ink-secondary));
    }

    .tlab__meta-line {
      margin: 0.75rem 0 0;
      font-size: 0.72rem;
      letter-spacing: 0.03em;
      color: rgb(var(--muted));
    }

    .tlab__body {
      margin: 0.85rem 0 0;
      max-width: 38rem;
      font-size: 0.9375rem;
      line-height: 1.68;
      color: rgb(var(--reading-ink-secondary));
    }

    .tlab__ai-block {
      margin-top: 1.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgb(var(--border) / 0.18);
    }

    .tlab__ai-label {
      margin-bottom: 0.45rem;
      color: rgb(var(--muted));
    }

    .tlab__input {
      display: block;
      width: 100%;
      max-width: 24rem;
      padding: 0.55rem 0.85rem;
      border: 1px solid rgb(var(--border) / 0.4);
      border-radius: var(--radius-md);
