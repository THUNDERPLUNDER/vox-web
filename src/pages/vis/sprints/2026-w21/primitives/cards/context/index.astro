    .cardctx__mini-ai-seed {
      display: block;
      height: 0.55rem;
      border-radius: 999px;
      background: rgb(17 24 39 / 0.08);
    }

    .cardctx__mini-dark {
      display: block;
      width: 100%;
      padding: 0.45rem 0.55rem;
      border-radius: var(--p-radius);
