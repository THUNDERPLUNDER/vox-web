      color: inherit;
      text-underline-offset: 2px;
    }

    .cardctx__hero {
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgb(17 24 39 / 0.12);
    }

    .cardctx__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--p-deep);
    }

    .cardctx__hero h1,
    .cardctx__panel h2 {
      margin: 0.35rem 0 0;
      font-family: var(--font-display);
      letter-spacing: -0.045em;
      line-height: 1.05;
    }

    .cardctx__hero h1 {
      font-size: clamp(2rem, 5.5vw, 3.4rem);
    }

    .cardctx__subtitle,
    .cardctx__lead,
    .cardctx__panel > p:not(.cardctx__kicker),
    .cardctx__taxonomy-item p,
    .cardctx__notes p,
    .cardctx__dependencies p {
      color: var(--p-muted);
      line-height: 1.65;
    }

    .cardctx__subtitle {
      max-width: 46rem;
      margin: 0.8rem 0 0;
      font-size: 0.95rem;
    }

    .cardctx__hero-status {
      display: inline-flex;
      gap: 0.6rem;
      align-items: center;
      margin-top: 1rem;
      padding: 0.35rem 0.6rem;
      border: 1px solid rgb(14 165 233 / 0.28);
      border-radius: 999px;
      background: rgb(14 165 233 / 0.06);
      font-size: 0.76rem;
    }

    .cardctx__hero-status span {
      color: var(--p-muted);
    }

    .cardctx__callout {
      margin-top: 1.25rem;
      padding: 0.85rem 1rem;
      border: 1px solid rgb(19 77 106 / 0.24);
