---
/* CONTRACT: VIS-only applied card context review for #129.
   Tests clickable surfaces and card roles in realistic Viddel scenarios; no production components.
*/
import PrototypeLayout from "../../../../../../../layouts/PrototypeLayout.astro";
import "../../../../../../../styles/global.css";
import "../../../../../../../styles/r1-dialog-article.css";
import { navItems, statusLabels } from "../../_data";

const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;
const primitivesPath = `${sprintPath}/primitives`;
const cardsPath = `${primitivesPath}/cards`;

const cardTaxonomy = [
  {
    id: "hub-card",
    title: "Hub card / clickable surface",
    note: "Whole card is the target. Arrow or text cue — no internal CTA button.",
  },
  {
    id: "article-teaser",
    title: "Article teaser card",
    note: "Editorial entry: image area, title, ingress, meta. Quiet — not ad-like.",
  },
  {
    id: "helper-info",
    title: "Helper / info box",
    note: "Static guidance or reassurance. Must not look clickable unless it is.",
  },
  {
    id: "ai-action",
    title: "AI / action card",
    note: "Bridges editorial content to help. Seed questions are interaction pattern (#128).",
  },
  {
    id: "dark-identity",
    title: "Dark / identity surface card",
    note: "Deep Nordic Blue or ink — sparingly for hierarchy, identity or next-step.",
  },
];

const hubCards = [
  {
    eyebrow: "Live hub",
    title: "Bedre lyd i hverdagen",
    copy: "Praktiske råd for samtaler, støy og tilpasning i hverdagen.",
    live: true,
  },
  {
    eyebrow: "Kommende",
    title: "Relasjoner og samtale",
    copy: "Hvordan høreapparatet kan hjelpe i møter, familie og telefonsamtaler.",
    muted: true,
  },
  {
    eyebrow: "Ordbok",
    title: "Forstå begrepene",
    copy: "Korte forklaringer på ord du møter hos audiograf og i egne notater.",
  },
];

const articleTeasers = [
  {
    eyebrow: "Artikkel · 6 min",
    title: "Jeg får piping i høreapparatet",
    copy: "Piping kan komme plutselig. Ofte handler det om voks, fukt eller feil program.",
    meta: "Oppdatert mai 2026",
    mode: "whole-card",
  },
  {
    eyebrow: "Artikkel · 4 min",
    title: "De første ukene med høreapparat",
    copy: "Tilvenning tar tid. Små justeringer i hverdagen kan gjøre stor forskjell.",
    meta: "Oppdatert april 2026",
    mode: "title-link",
  },
];

const seedQuestions = [
  "Hva er forskjellen på pip fra apparatet og piping i øret?",
  "Kan jeg gjøre noe selv før jeg kontakter audiograf?",
];

const recommendedDirection = [
  "Hub cards should usually be whole-card clickable surfaces.",
  "Article cards should stay editorial and quiet.",
  "Helper/info boxes should not look clickable unless they are.",
  "AI/action cards should bridge content to help, not become detached widgets.",
  "Card affordance should come from layout, arrow/text cue, hover/focus and context — not from internal CTA buttons.",
  "Seed questions remain an article/AI interaction pattern (#128), not a button variant inside cards.",
  "Dark/identity cards only where hierarchy or next-step emphasis needs it.",
  "Magenta only as micro-signal — not card decoration.",
];

const qaChecklist = [
  "Do hub cards work without internal buttons?",
  "Is the whole-card click affordance clear enough?",
  "Are article cards editorial rather than CTA-heavy?",
  "Are static helper boxes visually distinct from clickable cards?",
  "Does AI/action feel connected to editorial content?",
  "Is elevation/stroke subtle enough?",
  "Is magenta only used as signal/detail?",
  "What states need a later interaction pass?",
];

const dependencyNotes = [
  { title: "Surfaces (#127)", note: "Cards must inherit surface hierarchy — light editorial default, elevated sparingly." },
  { title: "Buttons (#128)", note: "Cards should not use buttons to solve all navigation. Seed questions are interaction pattern, not button variants." },
  { title: "Elevation", note: "Card lift must remain subtle — light border and hover shadow only." },
  { title: "Layering", note: "Cards should not create overlay/depth confusion with chrome or modals." },
  { title: "Focus", note: "Whole-card focus must be handled later in interaction states pass." },
];
---

<PrototypeLayout title="Cards applied context - Primitives Lab #129">
  <main class="cardctx" data-card-context-page>
    <nav class="cardctx__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <a href={primitivesPath}>Primitives</a>
      <span aria-hidden="true">/</span>
      <a href={cardsPath}>Cards</a>
      <span aria-hidden="true">/</span>
      <span>Context</span>
    </nav>

    <header class="cardctx__hero">
      <p class="cardctx__kicker">VIS-only · #129 · Applied review</p>
      <h1>Clickable surfaces in product context</h1>
      <p class="cardctx__subtitle">
        Tests how Viddel cards behave in real scenarios — not as visual variants, but as distinct surface
        roles with affordance, hierarchy and context.
      </p>
      <div class="cardctx__hero-status">
        <span>Status</span>
        <strong>{statusLabels.needsReview}</strong>
      </div>
    </header>

    <aside class="cardctx__callout" role="note">
      <strong>This context page is the decision surface.</strong>
      <p>
        The main <a href={cardsPath}>Cards primitive catalog</a> remains the abstract reference.
        This page tests <em>card behavior</em> — hub surfaces, editorial teasers, helper boxes, AI bridge
        and dark identity — inside realistic product contexts.
      </p>
    </aside>

    <div class="cardctx__layout">
      <aside class="cardctx__nav" aria-label="Primitives Lab navigation">
        <p class="cardctx__nav-title">Primitives</p>
        <a class="cardctx__nav-link" href={primitivesPath}>Overview</a>
        {navItems.map((item) => (
          <a
            class:list={["cardctx__nav-link", item.slug === "cards" && "cardctx__nav-link--active"]}
            href={`${primitivesPath}/${item.slug}/`}
            aria-current={item.slug === "cards" ? "page" : undefined}
          >
            {item.title}
          </a>
        ))}
      </aside>

      <div class="cardctx__content">
        <section class="cardctx__panel" aria-labelledby="taxonomy-heading">
          <p class="cardctx__kicker">Card taxonomy</p>
          <h2 id="taxonomy-heading">Five card roles to evaluate</h2>
          <p class="cardctx__lead">
            Mental model: separate surface roles, not card color variants.
          </p>
          <div class="cardctx__taxonomy">
            {cardTaxonomy.map((item) => (
              <article class="cardctx__taxonomy-item" data-type={item.id}>
                <div class="cardctx__taxonomy-sample" aria-hidden="true">
                  {item.id === "hub-card" && (
                    <span class="cardctx__mini-hub">
                      <span class="cardctx__mini-hub-title">Hub</span>
                      <span class="cardctx__mini-hub-cue">→</span>
                    </span>
                  )}
                  {item.id === "article-teaser" && (
                    <span class="cardctx__mini-article">
                      <span class="cardctx__mini-article-thumb"></span>
                      <span class="cardctx__mini-article-text"></span>
                    </span>
                  )}
                  {item.id === "helper-info" && (
                    <span class="cardctx__mini-helper">Info</span>
                  )}
                  {item.id === "ai-action" && (
                    <span class="cardctx__mini-ai">
                      <span class="cardctx__mini-ai-seed"></span>
                    </span>
                  )}
                  {item.id === "dark-identity" && (
                    <span class="cardctx__mini-dark">Next step</span>
                  )}
                </div>
                <h3>{item.title}</h3>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="hub-heading">
          <p class="cardctx__kicker">Scenario 01</p>
          <h2 id="hub-heading">Hub card / clickable surface</h2>
          <p class="cardctx__surface-note">
            Whole card is the click target. Subtle arrow cue and hover lift — no internal CTA button.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__hub-grid">
              {hubCards.map((card) => (
                <a
                  href="#"
                  class:list={[
                    "cardctx__hub-card",
                    card.live && "cardctx__hub-card--live",
                    card.muted && "cardctx__hub-card--muted",
                  ]}
                  aria-disabled={card.muted ? "true" : undefined}
                >
                  <p class="cardctx__eyebrow">{card.eyebrow}</p>
                  <h3>{card.title}</h3>
                  <p>{card.copy}</p>
                  {card.muted ? (
                    <span class="cardctx__hub-cue cardctx__hub-cue--muted">Kommer snart</span>
                  ) : (
                    <span class="cardctx__hub-cue" aria-hidden="true">→</span>
                  )}
                </a>
              ))}
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Do whole-card targets help orientation without internal buttons? Is arrow/text cue enough
                affordance without CTA noise?
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Should hub cards ever contain internal buttons, or is surface-level click always preferred?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="article-heading">
          <p class="cardctx__kicker">Scenario 02</p>
          <h2 id="article-heading">Article teaser card</h2>
          <p class="cardctx__surface-note">
            Compare whole-card click vs title-only affordance. Both should feel editorial, not promotional.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__article-grid">
              {articleTeasers.map((article) =>
                article.mode === "whole-card" ? (
                  <a href="#" class="cardctx__article-card cardctx__article-card--whole">
                    <div class="cardctx__article-thumb" aria-hidden="true"></div>
                    <div class="cardctx__article-body">
                      <p class="cardctx__eyebrow">{article.eyebrow}</p>
                      <h3>{article.title}</h3>
                      <p>{article.copy}</p>
                      <span class="cardctx__article-meta">{article.meta}</span>
                      <span class="cardctx__article-cue" aria-hidden="true">Les artikkel →</span>
                    </div>
                  </a>
                ) : (
                  <article class="cardctx__article-card cardctx__article-card--static">
                    <div class="cardctx__article-thumb" aria-hidden="true"></div>
                    <div class="cardctx__article-body">
                      <p class="cardctx__eyebrow">{article.eyebrow}</p>
                      <h3>
                        <a href="#" class="cardctx__article-title-link">{article.title}</a>
                      </h3>
                      <p>{article.copy}</p>
                      <span class="cardctx__article-meta">{article.meta}</span>
                    </div>
                  </article>
                ),
              )}
            </div>
            <p class="cardctx__compare-note">
              Left: whole-card click candidate · Right: title-link affordance candidate
            </p>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Does the teaser feel like a reading invitation? Is image + title + ingress enough without
                a button?
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Whole-card click or title-only link as default editorial affordance?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="helper-heading">
          <p class="cardctx__kicker">Scenario 03</p>
          <h2 id="helper-heading">Helper / info box</h2>
          <p class="cardctx__surface-note">
            Static guidance — not clickable. Must visually separate from hub and article cards.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__helper-grid">
              <div class="cardctx__helper-box">
                <p class="cardctx__helper-label">Trygghet</p>
                <h3>Dette er vanlig i starten</h3>
                <p>
                  De fleste opplever mer lyd enn de er vant til de første ukene. Det betyr ikke at
                  apparatet er feil — kroppen trenger tid til å tilpasse seg.
                </p>
              </div>
              <div class="cardctx__helper-box cardctx__helper-box--tip">
                <p class="cardctx__helper-label">Tips</p>
                <h3>Rengjør domene regelmessig</h3>
                <p>
                  Voks og fukt er blant de vanligste årsakene til piping. Bruk riktig verktøy og
                  unngå vann direkte på apparatet.
                </p>
              </div>
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Is it obvious these boxes are not navigation targets? No hover lift, no arrow, muted
                surface treatment.
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>What visual language separates helper boxes from clickable cards?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="ai-heading">
          <p class="cardctx__kicker">Scenario 04</p>
          <h2 id="ai-heading">AI / action card</h2>
          <p class="cardctx__surface-note">
            Editorial-to-help transition. Seed questions (#128 pattern) — not a button collection.
          </p>

          <div class="cardctx__sample cardctx__sample--ai">
            <div class="cardctx__ai-bridge">
              <div class="cardctx__ai-copy">
                <p class="cardctx__eyebrow">Fra artikkel · piping</p>
                <p>
                  Du leser om piping i høreapparatet. Velg et spørsmål for å starte — eller fortsett
                  å lese på egen hånd.
                </p>
              </div>
              <div class="cardctx__ai-body" data-r1-editorial>
                <section class="r1-ai-bridge">
                  <section class="inline-chat-shell" data-inline-chat-mode="progressive">
                    <header class="inline-chat-shell__header">
                      <h2 class="inline-chat-shell__title">Spør Hørehjelpen:</h2>
                    </header>
                    <div class="inline-chat-shell__seed-suggestions">
                      <ul class="inline-chat-shell__seed-list inline-chat-shell__seed-list--rows" role="list">
                        {seedQuestions.map((question) => (
                          <li class="inline-chat-shell__seed-item">
                            <button type="button" class="inline-chat-shell__seed-btn inline-chat-shell__seed-row">
                              <span class="inline-chat-shell__seed-question">{question}</span>
                            </button>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </section>
                </section>
              </div>
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Does this feel like a continuation of the article — not a detached chatbot widget?
                Are seed questions clearly interaction pattern, not CTA buttons?
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Is AI transition primarily seed questions, a card wrapper, or both?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="dark-heading">
          <p class="cardctx__kicker">Scenario 05</p>
          <h2 id="dark-heading">Dark / identity surface card</h2>
          <p class="cardctx__surface-note">
            Deep Nordic Blue / ink for identity or next-step — sparingly, not as general decoration.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__dark-grid">
              <a href="#" class="cardctx__dark-card cardctx__dark-card--deep">
                <span class="cardctx__dark-signal" aria-hidden="true"></span>
                <p class="cardctx__eyebrow cardctx__eyebrow--inverse">Neste steg</p>
                <h3>Snakk med Hørehjelpen om tilpasning</h3>
                <p>
                  Få hjelp til å forstå hva som skjer i de første ukene — uten å måtte vite riktig
                  fagterm på forhånd.
                </p>
                <span class="cardctx__dark-cue">Start samtale →</span>
              </a>
              <div class="cardctx__dark-card cardctx__dark-card--ink cardctx__dark-card--static">
                <p class="cardctx__eyebrow cardctx__eyebrow--inverse">Identitet</p>
                <h3>Viddel hjelper deg i hverdagen</h3>
                <p>
                  Rolig veiledning for høreapparatbrukere — ikke klinisk, ikke teknisk for teknisk.
                </p>
              </div>
            </div>
            <p class="cardctx__compare-note">
              Left: clickable next-step (whole card) · Right: static identity panel — not navigation
            </p>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Is dark surface used only where hierarchy needs it? Is magenta dot a signal, not decoration?
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>When is a dark action card too heavy for editorial flow?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="direction-heading">
          <p class="cardctx__kicker">Recommended direction</p>
          <h2 id="direction-heading">Recommended direction after QA seed</h2>
          <ul class="cardctx__direction">
            {recommendedDirection.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="cardctx__panel" aria-labelledby="qa-heading">
          <p class="cardctx__kicker">QA checklist</p>
          <h2 id="qa-heading">What Thomas should verify</h2>
          <ul class="cardctx__checklist">
            {qaChecklist.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="cardctx__panel" aria-labelledby="deps-heading">
          <p class="cardctx__kicker">Dependencies</p>
          <h2 id="deps-heading">Before #125</h2>
          <div class="cardctx__dependencies">
            {dependencyNotes.map((dep) => (
              <article>
                <strong>{dep.title}</strong>
                <p>{dep.note}</p>
              </article>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>

  <style>
    [data-card-context-page] {
      --p-deep: #134d6a;
      --p-magenta: #ff55b0;
      --p-cyan: #0ea5e9;
      --p-ink: #111827;
      --p-dark: #020617;
      --p-dark-panel: #071827;
      --p-muted: #6b7280;
      --p-border: #e5e7eb;
      --p-light: #ffffff;
      --p-subtle: #f8fafc;
      --p-reading-paper: #ffffff;
      --p-card-radius: 12px;
      --p-card-border: rgb(17 24 39 / 0.1);

      min-height: 100vh;
      max-width: 76rem;
      margin: 0 auto;
      padding: 1.5rem 1rem 3rem;
      background: var(--p-light);
      color: var(--p-ink);
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    }

    .cardctx__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.1rem;
      font-size: 0.72rem;
      color: var(--p-muted);
    }

    .cardctx__breadcrumb a {
      color: inherit;
      text-underline-offset: 2px;
    }

    .cardctx__hero {
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgb(17 24 39 / 0.12);
    }

    .cardctx__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--p-deep);
    }

    .cardctx__hero h1,
    .cardctx__panel h2 {
      margin: 0.35rem 0 0;
      font-family: var(--font-display);
      letter-spacing: -0.045em;
      line-height: 1.05;
    }

    .cardctx__hero h1 {
      font-size: clamp(2rem, 5.5vw, 3.4rem);
    }

    .cardctx__subtitle,
    .cardctx__lead,
    .cardctx__panel > p:not(.cardctx__kicker),
    .cardctx__taxonomy-item p,
    .cardctx__notes p,
    .cardctx__dependencies p {
      color: var(--p-muted);
      line-height: 1.65;
    }

    .cardctx__subtitle {
      max-width: 46rem;
      margin: 0.8rem 0 0;
      font-size: 0.95rem;
    }

    .cardctx__hero-status {
      display: inline-flex;
      gap: 0.6rem;
      align-items: center;
      margin-top: 1rem;
      padding: 0.35rem 0.6rem;
      border: 1px solid rgb(14 165 233 / 0.28);
      border-radius: 999px;
      background: rgb(14 165 233 / 0.06);
      font-size: 0.76rem;
    }

    .cardctx__hero-status span {
      color: var(--p-muted);
    }

    .cardctx__callout {
      margin-top: 1.25rem;
      padding: 0.85rem 1rem;
      border: 1px solid rgb(19 77 106 / 0.24);
      border-radius: 12px;
      background: rgb(19 77 106 / 0.04);
      font-size: 0.82rem;
      line-height: 1.6;
    }

    .cardctx__callout strong {
      display: block;
      margin-bottom: 0.35rem;
      color: var(--p-ink);
    }

    .cardctx__callout a {
      color: var(--p-deep);
      font-weight: 700;
    }

    .cardctx__layout {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.5rem;
    }

    .cardctx__nav {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding: 0.75rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: var(--p-subtle);
    }

    .cardctx__nav-title {
      display: none;
    }

    .cardctx__nav-link {
      flex: 0 0 auto;
      padding: 0.42rem 0.65rem;
      border: 1px solid transparent;
      border-radius: 999px;
      color: var(--p-muted);
      font-size: 0.76rem;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .cardctx__nav-link--active {
      border-color: rgb(19 77 106 / 0.28);
      background: #fff;
      color: var(--p-deep);
    }

    .cardctx__content {
      display: grid;
      gap: 1.25rem;
    }

    .cardctx__panel {
      padding: 1.1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: #fff;
    }

    .cardctx__panel h2 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
    }

    .cardctx__surface-note,
    .cardctx__compare-note {
      margin: 0.55rem 0 0;
      font-size: 0.78rem;
      line-height: 1.55;
      color: var(--p-muted);
    }

    .cardctx__compare-note {
      margin-top: 0.85rem;
      padding-top: 0.75rem;
      border-top: 1px solid rgb(17 24 39 / 0.08);
      font-size: 0.72rem;
      font-style: italic;
    }

    /* Taxonomy */
    .cardctx__taxonomy {
      display: grid;
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .cardctx__taxonomy-item {
      padding: 0.85rem;
      border: 1px solid rgb(17 24 39 / 0.1);
      border-radius: 12px;
      background: var(--p-subtle);
    }

    .cardctx__taxonomy-item h3 {
      margin: 0.55rem 0 0;
      font-size: 0.88rem;
    }

    .cardctx__taxonomy-item p {
      margin: 0.35rem 0 0;
      font-size: 0.78rem;
    }

    .cardctx__taxonomy-sample {
      min-height: 3.5rem;
      display: flex;
      align-items: center;
    }

    .cardctx__mini-hub,
    .cardctx__mini-article,
    .cardctx__mini-helper,
    .cardctx__mini-ai,
    .cardctx__mini-dark {
      display: block;
      width: 100%;
      border-radius: 8px;
      border: 1px solid var(--p-card-border);
      background: #fff;
    }

    .cardctx__mini-hub {
      display: flex;
