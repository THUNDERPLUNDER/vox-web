    .cardctx__media-card-bg--image-warm {
      background: linear-gradient(160deg, rgb(180 120 80 / 0.55), rgb(255 237 213 / 0.85)),
        linear-gradient(145deg, rgb(19 77 106 / 0.2), rgb(248 250 252));
