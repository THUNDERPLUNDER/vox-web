---
/* CONTRACT: VIS-only applied card context review for #129.
   Tests grouped clickable/static surfaces in realistic Viddel scenarios; no production components.
*/
import PrototypeLayout from "../../../../../../../layouts/PrototypeLayout.astro";
import "../../../../../../../styles/global.css";
import "../../../../../../../styles/r1-dialog-article.css";
import { navItems, statusLabels } from "../../_data";

const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;
const primitivesPath = `${sprintPath}/primitives`;
const cardsPath = `${primitivesPath}/cards`;

const cardTaxonomy = [
  {
    id: "hub-card",
    title: "Hub card / clickable surface",
    note: "Media/background or grouped surface — fixed size in grids; text bottom-left; whole card clickable.",
  },
  {
    id: "article-teaser",
    title: "Article teaser card",
    note: "Editorial reading invitation. Whole-card click preferred; layout can vary (image inside, outside, or invisible group).",
  },
  {
    id: "feature-media-cta",
    title: "Feature / media CTA card",
    note: "Large visual card for featured content or hero/story surfaces with ghost CTA. Not default for hub navigation.",
  },
  {
    id: "helper-info",
    title: "Helper / info box",
    note: "Static note surface. Dashed border affordance only — must not look clickable.",
  },
  {
    id: "ai-action",
    title: "AI / action card",
    note: "Bridges editorial content to help. Seed questions are interaction pattern (#128).",
  },
  {
    id: "dark-identity",
    title: "Dark / identity surface card",
    note: "Deep Nordic Blue or ink — sparingly for hierarchy, identity or next-step.",
  },
];

const hubMediaImage = {
  eyebrow: "Live hub",
  title: "Bedre lyd i hverdagen",
  copy: "Praktiske råd for samtaler, støy og tilpasning.",
  cue: "Utforsk →",
};

const hubMediaColor = {
  eyebrow: "Ordbok",
  title: "Forstå begrepene",
  copy: "Korte forklaringer uten fagjargong.",
  cue: "Gå til ordbok →",
};

const hubSeparate = {
  eyebrow: "Live hub",
  title: "Høreapparat i hverdagen",
  copy: "Alt du trenger å vite om tilvenning, vedlikehold og vanlige utfordringer de første månedene — skrevet for deg som bruker apparatet hver dag.",
  cue: "Utforsk hubben",
};

const hubInvisible = {
  eyebrow: "Kommende",
  title: "Relasjoner og samtale",
  copy: "Hvordan høreapparatet kan hjelpe i møter, familie og telefonsamtaler.",
  cue: "Kommer snart →",
};

const articleMediaBg = {
  eyebrow: "Artikkel · 6 min",
  title: "Jeg får piping i høreapparatet",
  copy: "Ofte voks, fukt eller feil program.",
  meta: "Oppdatert mai 2026",
  cue: "Les artikkel",
};

const featureLarge = {
  eyebrow: "Featured guide",
  title: "Kom i gang med høreapparatet",
  copy: "En rolig guide til de første ukene — skrevet for deg, ikke audiografen.",
  cta: "Les guiden",
};

const featureCompact = {
  eyebrow: "Ny artikkel",
  title: "Piping i hverdagen",
  copy: "Hva du kan prøve selv.",
  cta: "Les mer",
};

const articleSeparate = {
  eyebrow: "Artikkel · 8 min",
  title: "De første ukene med høreapparat",
  copy: "Tilvenning tar tid. Kroppen må lære seg ny lyd, og det er helt normalt at alt føles litt overveldende i starten. Her er hva du kan forvente uke for uke.",
  meta: "Oppdatert april 2026",
};

const articleInvisible = {
  eyebrow: "Artikkel · 5 min",
  title: "Slik rengjør du høreapparatet riktig",
  copy: "Riktig rengjøring forebygger piping og forlenger levetiden. Du trenger ikke mange verktøy — bare riktig rutine og litt tålmodighet.",
  meta: "Oppdatert mars 2026",
};

const seedQuestions = [
  "Hva er forskjellen på pip fra apparatet og piping i øret?",
  "Kan jeg gjøre noe selv før jeg kontakter audiograf?",
];

const decisionSummary = [
  "Cards are grouped content surfaces — not default visible bordered boxes.",
  "Media/background cards are core patterns: image or color surface, fixed size in groups, text bottom-left with generous whitespace.",
  "Article media cards: wide fixed aspect, bottom-left text, generous whitespace — not text-driven or cramped.",
  "Feature/media CTA: borderless translucent CTA buttons; hover lightens CTA only.",
  "Feature/media CTA card is a special pattern for hero/story/promo — ghost CTA inside allowed; not default hub behavior.",
  "Default hub/article cards avoid internal CTA buttons; CTA-inside-card only for explicit feature/promo surfaces.",
  "Image+text-separated cards: shadow on media only; link underline on text cue.",
  "Invisible grouped, helper, AI bridge, dark identity: as reviewed.",
  "Hover/focus interaction states need a later pass after Cards decision.",
];

const openDecisions = [
  "Which media/background vs separated vs invisible layout fits hub overview vs article rails?",
  "Where should feature/media CTA cards appear vs standard hub cards?",
  "Is fixed card height correct for mobile (~390px) hub grids?",
  "How strong should bottom scrim be on image backgrounds?",
];

const verifyNext = [
  "Hub A: white/high-contrast cues on dark scrim — no dark «Utforsk» text.",
  "Article A: wide landscape media card, bottom-left anchor, whitespace above text.",
  "Scenario 06: borderless translucent CTA, lighter on hover, no card shadow.",
  "Hub B/C/D + Article B/C unchanged affordance.",
  "Mobile ~390px: contrast, spacing, fixed grid.",
];

const dependencyNotes = [
  { title: "Surfaces (#127)", note: "Cards inherit surface hierarchy — quiet editorial grouping, not boxed UI." },
  { title: "Buttons (#128)", note: "No internal navigation buttons. Seed questions are interaction pattern." },
  { title: "Elevation", note: "Hover shadow/lift validates clickability — no default visible border." },
  { title: "Layering", note: "Cards should not create overlay/depth confusion." },
  { title: "Focus", note: "Whole-card focus handled in later interaction states pass." },
];
---

<PrototypeLayout title="Cards applied context - Primitives Lab #129">
  <main class="cardctx" data-card-context-page>
    <nav class="cardctx__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <a href={primitivesPath}>Primitives</a>
      <span aria-hidden="true">/</span>
      <a href={cardsPath}>Cards</a>
      <span aria-hidden="true">/</span>
      <span>Context</span>
    </nav>

    <header class="cardctx__hero">
      <p class="cardctx__kicker">VIS-only · #129 · Applied review</p>
      <h1>Grouped surfaces in product context</h1>
      <p class="cardctx__subtitle">
        A card is a grouped content surface — not a visible bordered box. Affordance comes from
        grouping, whitespace, visual rhythm, image/text relation, subtle arrow/text cue and
        hover/focus — not from strokes or internal CTA buttons.
      </p>
      <div class="cardctx__hero-status">
        <span>Status</span>
        <strong>{statusLabels.candidate}</strong>
      </div>
    </header>

    <aside class="cardctx__callout" role="note">
      <strong>This context page is the decision surface.</strong>
      <p>
        The main <a href={cardsPath}>Cards primitive catalog</a> remains the abstract reference.
        Clickable surfaces may be almost invisible at rest — hover shadow/lift is the validation
        that a surface is interactive.
      </p>
    </aside>

    <div class="cardctx__layout">
      <aside class="cardctx__nav" aria-label="Primitives Lab navigation">
        <p class="cardctx__nav-title">Primitives</p>
        <a class="cardctx__nav-link" href={primitivesPath}>Overview</a>
        {navItems.map((item) => (
          <a
            class:list={["cardctx__nav-link", item.slug === "cards" && "cardctx__nav-link--active"]}
            href={`${primitivesPath}/${item.slug}/`}
            aria-current={item.slug === "cards" ? "page" : undefined}
          >
            {item.title}
          </a>
        ))}
      </aside>

      <div class="cardctx__content">
        <section class="cardctx__panel" aria-labelledby="taxonomy-heading">
          <p class="cardctx__kicker">Card taxonomy</p>
          <h2 id="taxonomy-heading">Six surface roles to evaluate</h2>
          <p class="cardctx__lead">
            Mental model: grouped content surfaces with distinct affordance — not bordered UI boxes.
          </p>
          <div class="cardctx__taxonomy">
            {cardTaxonomy.map((item) => (
              <article class="cardctx__taxonomy-item" data-type={item.id}>
                <div class="cardctx__taxonomy-sample" aria-hidden="true">
                  {item.id === "hub-card" && (
                    <span class="cardctx__mini-hub">
                      <span class="cardctx__mini-hub-thumb"></span>
                      <span class="cardctx__mini-hub-text"></span>
                    </span>
                  )}
                  {item.id === "article-teaser" && (
                    <span class="cardctx__mini-article">
                      <span class="cardctx__mini-article-thumb"></span>
                      <span class="cardctx__mini-article-text"></span>
                    </span>
                  )}
                  {item.id === "feature-media-cta" && (
                    <span class="cardctx__mini-feature">
                      <span class="cardctx__mini-feature-bg"></span>
                      <span class="cardctx__mini-feature-cta">CTA</span>
                    </span>
                  )}
                  {item.id === "helper-info" && (
                    <span class="cardctx__mini-helper">Note</span>
                  )}
                  {item.id === "ai-action" && (
                    <span class="cardctx__mini-ai">
                      <span class="cardctx__mini-ai-seed"></span>
                    </span>
                  )}
                  {item.id === "dark-identity" && (
                    <span class="cardctx__mini-dark">Next step</span>
                  )}
                </div>
                <h3>{item.title}</h3>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="hub-heading">
          <p class="cardctx__kicker">Scenario 01</p>
          <h2 id="hub-heading">Hub card / clickable surface</h2>
          <p class="cardctx__surface-note">
            Four card families — all whole-card clickable, no internal CTA, no visible border at rest.
            A/B use fixed size in grid; text sits bottom-left with whitespace above. C separates media
            shadow from text. D is invisible grouped surface.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__variants">
              <article class="cardctx__variant">
                <p class="cardctx__variant-label">A · Image background — text inside, bottom-left</p>
                <div class="cardctx__fixed-grid">
                  <a href="#" class="cardctx__media-card cardctx__media-card--image">
                    <div class="cardctx__media-card-surface">
                      <div class="cardctx__media-card-bg cardctx__media-card-bg--image-warm" aria-hidden="true"></div>
                      <div class="cardctx__media-card-scrim cardctx__media-card-scrim--dark" aria-hidden="true"></div>
                      <div class="cardctx__media-card-content">
                        <p class="cardctx__eyebrow cardctx__eyebrow--on-dark">{hubMediaImage.eyebrow}</p>
                        <h3>{hubMediaImage.title}</h3>
                        <p class="cardctx__media-card-copy">{hubMediaImage.copy}</p>
                        <span class="cardctx__ghost-cue cardctx__ghost-cue--on-dark">{hubMediaImage.cue}</span>
                      </div>
                    </div>
                  </a>
                  <a href="#" class="cardctx__media-card cardctx__media-card--image">
                    <div class="cardctx__media-card-surface">
                      <div class="cardctx__media-card-bg cardctx__media-card-bg--image-cool" aria-hidden="true"></div>
                      <div class="cardctx__media-card-scrim cardctx__media-card-scrim--dark" aria-hidden="true"></div>
                      <div class="cardctx__media-card-content">
                        <p class="cardctx__eyebrow cardctx__eyebrow--on-dark">Live hub</p>
                        <h3>Høreapparat i hverdagen</h3>
                        <p class="cardctx__media-card-copy">Tilvenning, vedlikehold og vanlige utfordringer.</p>
                        <span class="cardctx__ghost-cue cardctx__ghost-cue--on-dark">Utforsk →</span>
                      </div>
                    </div>
                  </a>
                </div>
                <p class="cardctx__variant-note">Fixed height in group — longer titles do not change card size.</p>
              </article>

              <article class="cardctx__variant">
                <p class="cardctx__variant-label">B · Color/surface background — text inside, bottom-left</p>
                <div class="cardctx__fixed-grid">
                  <a href="#" class="cardctx__media-card cardctx__media-card--color">
                    <div class="cardctx__media-card-surface">
                      <div class="cardctx__media-card-bg cardctx__media-card-bg--color-subtle" aria-hidden="true"></div>
                      <div class="cardctx__media-card-scrim cardctx__media-card-scrim--light" aria-hidden="true"></div>
                      <div class="cardctx__media-card-content">
                        <p class="cardctx__eyebrow">{hubMediaColor.eyebrow}</p>
                        <h3>{hubMediaColor.title}</h3>
                        <p class="cardctx__media-card-copy">{hubMediaColor.copy}</p>
                        <span class="cardctx__ghost-cue">{hubMediaColor.cue}</span>
                      </div>
                    </div>
                  </a>
                  <a href="#" class="cardctx__media-card cardctx__media-card--color">
                    <div class="cardctx__media-card-surface">
                      <div class="cardctx__media-card-bg cardctx__media-card-bg--color-page" aria-hidden="true"></div>
                      <div class="cardctx__media-card-content">
                        <p class="cardctx__eyebrow">Kommende</p>
                        <h3>Relasjoner og samtale</h3>
                        <p class="cardctx__media-card-copy">Møter, familie og telefonsamtaler.</p>
                        <span class="cardctx__ghost-cue cardctx__ghost-cue--muted">Kommer snart</span>
                      </div>
                    </div>
                  </a>
                </div>
                <p class="cardctx__variant-note">Surface may match page background — card defined by fixed size, spacing and hover.</p>
              </article>

              <article class="cardctx__variant">
                <p class="cardctx__variant-label">C · Image/media + text separate</p>
                <a href="#" class="cardctx__hub-c">
                  <div class="cardctx__hub-c-media cardctx__hub-c-media--cool" aria-hidden="true"></div>
                  <div class="cardctx__hub-c-body">
                    <p class="cardctx__eyebrow">{hubSeparate.eyebrow}</p>
                    <h3>{hubSeparate.title}</h3>
                    <p>{hubSeparate.copy}</p>
                    <span class="cardctx__link-cue">{hubSeparate.cue} →</span>
                  </div>
                </a>
              </article>

              <article class="cardctx__variant">
                <p class="cardctx__variant-label">D · Invisible / white grouped surface</p>
                <a href="#" class="cardctx__hub-d">
                  <div class="cardctx__hub-d-inner">
                    <p class="cardctx__eyebrow">{hubInvisible.eyebrow}</p>
                    <h3>{hubInvisible.title}</h3>
                    <p>{hubInvisible.copy}</p>
                    <span class="cardctx__ghost-cue cardctx__ghost-cue--muted">{hubInvisible.cue}</span>
                  </div>
                </a>
              </article>
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                A/B: fixed card size in grid; text bottom-left with whitespace above; whole-surface hover.
                C: media-only lift. D: gestalt grouping without visible background at rest.
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Which hub family fits hub overview grids vs in-flow navigation?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="article-heading">
          <p class="cardctx__kicker">Scenario 02</p>
          <h2 id="article-heading">Article teaser card</h2>
          <p class="cardctx__surface-note">
            <strong>Decision:</strong> whole-card click preferred. A uses media/background with fixed
            size and bottom-left text. B separates media shadow from text. C is invisible grouped surface.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__variants">
              <article class="cardctx__variant">
                <p class="cardctx__variant-label">A · Image/background + text inside (fixed size)</p>
                <div class="cardctx__fixed-grid cardctx__fixed-grid--article">
                  <a href="#" class="cardctx__media-card cardctx__media-card--image cardctx__media-card--article">
                    <div class="cardctx__media-card-surface cardctx__media-card-surface--article">
                      <div class="cardctx__media-card-bg cardctx__media-card-bg--image-editorial" aria-hidden="true"></div>
                      <div class="cardctx__media-card-scrim cardctx__media-card-scrim--article" aria-hidden="true"></div>
                      <div class="cardctx__media-card-content cardctx__media-card-content--anchored">
                        <p class="cardctx__eyebrow cardctx__eyebrow--on-dark">{articleMediaBg.eyebrow}</p>
                        <h3>{articleMediaBg.title}</h3>
                        <p class="cardctx__media-card-copy">{articleMediaBg.copy}</p>
                        <span class="cardctx__article-meta cardctx__article-meta--on-dark">{articleMediaBg.meta}</span>
                        <span class="cardctx__ghost-cue">{articleMediaBg.cue}</span>
                      </div>
                    </div>
                  </a>
                </div>
                <p class="cardctx__variant-note">Feature-like bottom-left text stack (no CTA button) — whole-card hover/shadow for click affordance.</p>
              </article>

              <article class="cardctx__variant">
                <p class="cardctx__variant-label">B · Image/media + text outside</p>
                <a href="#" class="cardctx__article-b">
                  <div class="cardctx__article-b-media" aria-hidden="true"></div>
                  <div class="cardctx__article-b-body">
                    <p class="cardctx__eyebrow">{articleSeparate.eyebrow}</p>
                    <h3>{articleSeparate.title}</h3>
                    <p>{articleSeparate.copy}</p>
                    <span class="cardctx__article-meta">{articleSeparate.meta}</span>
                    <span class="cardctx__link-cue">Les artikkel</span>
                  </div>
                </a>
              </article>

              <article class="cardctx__variant">
                <p class="cardctx__variant-label">C · No visible background — text/link inside</p>
                <a href="#" class="cardctx__article-c">
                  <div class="cardctx__article-c-inner">
                    <p class="cardctx__eyebrow">{articleInvisible.eyebrow}</p>
                    <h3>{articleInvisible.title}</h3>
                    <p>{articleInvisible.copy}</p>
                    <span class="cardctx__article-meta">{articleInvisible.meta}</span>
                    <span class="cardctx__ghost-cue">Les artikkel</span>
                  </div>
                </a>
              </article>
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                A: fixed-size media card with bottom-left text — editorial, not ad-like.
                B: media-only hover. C: invisible group with hover surface.
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Which article family fits article rails, related content and hub lists?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="helper-heading">
          <p class="cardctx__kicker">Scenario 03</p>
          <h2 id="helper-heading">Helper / info box</h2>
          <p class="cardctx__surface-note">
            Static helpers — dashed border as note affordance only. No fill, no hover, no arrow.
            Must not look clickable.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__helper-stack">
              <div class="cardctx__helper-box">
                <p class="cardctx__helper-label">Trygghet</p>
                <h3>Dette er vanlig i starten</h3>
                <p>
                  De fleste opplever mer lyd enn de er vant til de første ukene. Det betyr ikke at
                  apparatet er feil — kroppen trenger tid til å tilpasse seg nye lyder i hverdagen.
                </p>
              </div>
              <div class="cardctx__helper-box">
                <p class="cardctx__helper-label">Tips</p>
                <h3>Rengjør domene regelmessig</h3>
                <p>
                  Voks og fukt er blant de vanligste årsakene til piping. Bruk riktig verktøy og
                  unngå vann direkte på apparatet — en enkel rutine kan spare deg for mange
                  unødvendige turer til audiografen.
                </p>
              </div>
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Is dashed border enough to signal “note/helper” without looking like a navigation card?
                No hover state — clearly static.
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Does dashed-only treatment distinguish helpers from invisible clickable groups?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="ai-heading">
          <p class="cardctx__kicker">Scenario 04</p>
          <h2 id="ai-heading">AI / action card</h2>
          <p class="cardctx__surface-note">
            Editorial-to-help transition. Seed questions (#128 pattern) — not a button collection.
          </p>

          <div class="cardctx__sample cardctx__sample--ai">
            <div class="cardctx__ai-bridge">
              <div class="cardctx__ai-copy">
                <p class="cardctx__eyebrow">Fra artikkel · piping</p>
                <p>
                  Du leser om piping i høreapparatet. Mange opplever dette i starten, og det finnes
                  enkle ting du kan prøve selv. Velg et spørsmål for å starte — eller fortsett å lese
                  på egen hånd.
                </p>
              </div>
              <div class="cardctx__ai-body" data-r1-editorial>
                <section class="r1-ai-bridge">
                  <section class="inline-chat-shell" data-inline-chat-mode="progressive">
                    <header class="inline-chat-shell__header">
                      <h2 class="inline-chat-shell__title">Spør Hørehjelpen:</h2>
                    </header>
                    <div class="inline-chat-shell__seed-suggestions">
                      <ul class="inline-chat-shell__seed-list inline-chat-shell__seed-list--rows" role="list">
                        {seedQuestions.map((question) => (
                          <li class="inline-chat-shell__seed-item">
                            <button type="button" class="inline-chat-shell__seed-btn inline-chat-shell__seed-row">
                              <span class="inline-chat-shell__seed-question">{question}</span>
                            </button>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </section>
                </section>
              </div>
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Does this feel like a continuation of the article — not a detached chatbot widget?
              </p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="dark-heading">
          <p class="cardctx__kicker">Scenario 05</p>
          <h2 id="dark-heading">Dark / identity surface card</h2>
          <p class="cardctx__surface-note">
            Deep Nordic Blue / ink for identity or next-step — sparingly. Magenta dot is micro-signal
            only. Note: dot may later become a small Viddel signal symbol, sound bars or resonance
            mark — not designed here.
          </p>

          <div class="cardctx__sample cardctx__sample--surface">
            <div class="cardctx__dark-grid">
              <a href="#" class="cardctx__dark-card cardctx__dark-card--deep">
                <span class="cardctx__dark-signal" aria-hidden="true"></span>
                <p class="cardctx__eyebrow cardctx__eyebrow--inverse">Neste steg</p>
                <h3>Snakk med Hørehjelpen om tilpasning</h3>
                <p>
                  Få hjelp til å forstå hva som skjer i de første ukene — uten å måtte vite riktig
                  fagterm på forhånd. Hørehjelpen kjenner vanlige spørsmål fra hverdagen.
                </p>
                <span class="cardctx__dark-cue">Start samtale →</span>
              </a>
              <div class="cardctx__dark-card cardctx__dark-card--ink cardctx__dark-card--static">
                <p class="cardctx__eyebrow cardctx__eyebrow--inverse">Identitet</p>
                <h3>Viddel hjelper deg i hverdagen</h3>
                <p>
                  Rolig veiledning for høreapparatbrukere — ikke klinisk, ikke teknisk for teknisk.
                  Innhold du kan bruke i samtaler hjemme, på jobb og hos audiograf.
                </p>
              </div>
            </div>
          </div>

          <div class="cardctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>Is dark surface sparse enough? Is magenta dot signal-only?</p>
            </article>
          </div>
        </section>

        <section class="cardctx__panel" aria-labelledby="feature-heading">
          <p class="cardctx__kicker">Scenario 06</p>
          <h2 id="feature-heading">Feature / media CTA card</h2>
          <p class="cardctx__surface-note">
            Special pattern for hero/story/promo — not default hub navigation. Large visual surface,
            text bottom-left, transparent ghost CTA inside. No whole-card hover shadow — hover makes
            CTA lighter/clearer.
