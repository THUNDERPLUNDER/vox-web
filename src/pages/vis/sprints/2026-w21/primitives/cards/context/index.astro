    .cardctx__media-card-bg--image-cool {
      background: linear-gradient(160deg, rgb(19 77 106 / 0.45), rgb(224 242 254 / 0.75)),
        linear-gradient(145deg, rgb(71 85 105 / 0.15), rgb(248 250 252));
    }

    .cardctx__media-card-bg--image-editorial {
      background: linear-gradient(165deg, rgb(19 77 106 / 0.5), rgb(148 163 184 / 0.35)),
        linear-gradient(145deg, rgb(30 58 80 / 0.25), rgb(248 250 252));
    }

    .cardctx__media-card-bg--color-subtle {
      background: linear-gradient(160deg, rgb(19 77 106 / 0.06), rgb(248 250 252 / 0.95));
    }

    .cardctx__media-card-bg--color-page {
      background: var(--p-reading-paper);
    }

    .cardctx__media-card-scrim {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
    }

    .cardctx__media-card-scrim--dark {
      background: linear-gradient(
        to top,
        rgb(17 24 39 / 0.82) 0%,
        rgb(17 24 39 / 0.32) 36%,
        transparent 62%
      );
    }

    .cardctx__media-card-scrim--article {
      background: linear-gradient(
        to top,
        rgb(17 24 39 / 0.78) 0%,
        rgb(17 24 39 / 0.28) 34%,
        transparent 58%
      );
    }

    .cardctx__media-card-surface--article {
      display: block;
      width: 100%;
      height: auto;
      min-height: 0;
      max-height: none;
      aspect-ratio: 16 / 10;
    }

    .cardctx__media-card-scrim--light {
      background: linear-gradient(
        to top,
        rgb(248 250 252 / 0.95) 0%,
        rgb(248 250 252 / 0.45) 42%,
        transparent 72%
      );
