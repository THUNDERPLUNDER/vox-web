      height: 0.45rem;
      margin-top: 0.35rem;
      border-radius: 999px;
      background: rgb(17 24 39 / 0.08);
    }

    .cardctx__mini-helper {
      display: block;
      width: 100%;
      padding: 0.45rem 0.55rem;
      border: 1px dashed rgb(19 77 106 / 0.28);
      border-radius: var(--p-radius);
      background: transparent;
      font-size: 0.68rem;
      font-weight: 700;
      color: var(--p-muted);
      text-align: center;
    }

    .cardctx__mini-ai {
      width: 100%;
      padding: 0.45rem;
      border-top: 2px solid var(--p-deep);
