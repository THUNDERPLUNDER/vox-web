      color: #fff;
      font-size: 0.68rem;
      font-weight: 700;
      text-align: center;
    }

    /* Scenario samples */
    .cardctx__sample {
      margin-top: 1rem;
      padding: 1.25rem;
      border-radius: var(--p-radius);
      background: var(--p-reading-paper);
    }

    .cardctx__sample--surface {
      padding: 1.5rem 1rem;
    }

    .cardctx__sample--ai {
      padding: 0;
      overflow: hidden;
    }

    .cardctx__eyebrow {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--p-muted);
    }

    .cardctx__eyebrow--inverse {
      color: rgb(255 255 255 / 0.62);
    }

    .cardctx__variant-note {
      margin: 0.65rem 0 0;
      font-size: 0.72rem;
      font-style: italic;
      line-height: 1.5;
      color: var(--p-muted);
    }

    /* Fixed-size media/background cards */
    .cardctx__fixed-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: 1fr;
    }

    .cardctx__fixed-grid--single {
      max-width: 20rem;
    }

    .cardctx__fixed-grid--article {
      width: 100%;
      max-width: min(100%, 28rem);
      grid-template-columns: 1fr;
    }

    .cardctx__media-card--article {
      width: 100%;
    }

    .cardctx__media-card {
      display: block;
      color: inherit;
      text-decoration: none;
    }

    .cardctx__media-card-surface {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: stretch;
      height: 14.5rem;
      min-height: 14.5rem;
      max-height: 14.5rem;
      border-radius: var(--p-radius);
      overflow: hidden;
      transition: box-shadow 200ms ease, transform 200ms ease;
