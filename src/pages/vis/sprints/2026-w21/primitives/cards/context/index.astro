      font-size: 0.82rem;
      line-height: 1.6;
    }

    .cardctx__callout strong {
      display: block;
      margin-bottom: 0.35rem;
      color: var(--p-ink);
    }

    .cardctx__callout a {
      color: var(--p-deep);
      font-weight: 700;
    }

    .cardctx__layout {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.5rem;
    }

    .cardctx__nav {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding: 0.75rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: var(--p-subtle);
    }

    .cardctx__nav-title {
      display: none;
    }

    .cardctx__nav-link {
      flex: 0 0 auto;
      padding: 0.42rem 0.65rem;
      border: 1px solid transparent;
      border-radius: 999px;
