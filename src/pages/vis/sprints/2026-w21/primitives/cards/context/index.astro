    .cardctx__mini-hub-thumb {
      height: 2rem;
      border-radius: 6px;
      background: linear-gradient(135deg, rgb(19 77 106 / 0.12), rgb(248 250 252));
    }

    .cardctx__mini-hub-text {
      height: 0.4rem;
      border-radius: 999px;
      background: rgb(17 24 39 / 0.08);
    }

    .cardctx__mini-article {
      display: grid;
      grid-template-columns: 2.5rem 1fr;
