---
/* CONTRACT: VIS-only Primitives Lab overview for #124.
   Dashboard for the local primitives catalog; not production design or token implementation.
*/
import PrototypeLayout from "../../../../../layouts/PrototypeLayout.astro";
import "../../../../../styles/global.css";
import { guardrails, navItems, primitivePages, statusLabels } from "./_data";

const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;
const primitivesPath = `${sprintPath}/primitives`;

const meta = [
  ["Sprint", "2026-W21"],
  ["Parent", "#120 MVP Design Lock v0.1"],
  ["Issue", "#124 Primitives v0.1"],
  ["Scope", "VIS-only"],
];
---

<PrototypeLayout title="Primitives Lab IA v0.2 - #124">
  <main class="plab" data-primitives-overview>
    <nav class="plab__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <span>Primitives</span>
    </nav>

    <header class="plab__hero">
      <p class="plab__kicker">VIS-only · #124</p>
      <h1>Primitives Lab IA v0.2</h1>
      <p class="plab__subtitle">
        A small local catalog for reviewing Viddel primitive candidates before #125 MVP surface reskin.
      </p>
      <dl class="plab__meta">
        {meta.map(([label, value]) => (
          <div><dt>{label}</dt><dd>{value}</dd></div>
        ))}
      </dl>
    </header>

    <div class="plab__layout">
      <aside class="plab__nav" aria-label="Primitives Lab navigation">
        <p class="plab__nav-title">Primitives</p>
        <a class="plab__nav-link plab__nav-link--active" href={primitivesPath}>Overview</a>
        {navItems.map((item) => (
          <a class="plab__nav-link" href={`${primitivesPath}/${item.slug}/`}>{item.title}</a>
        ))}
      </aside>

      <div class="plab__content">
        <section class="plab__panel" aria-labelledby="purpose-heading">
          <p class="plab__kicker">Purpose</p>
          <h2 id="purpose-heading">From design direction to reviewable primitives</h2>
          <p>
            This overview keeps #124 scalable: each primitive now has its own page with P1-P4 iterations,
            favorites, decisions, open questions and local rules.
          </p>
        </section>

        <section class="plab__panel" aria-labelledby="interaction-states-heading">
          <p class="plab__kicker">#124D</p>
          <h2 id="interaction-states-heading">Interaction states pass</h2>
          <p>
            Validates hover, focus-visible, active, selected, disabled and loading across #128 action
            taxonomy and #129 clickable surfaces — decision surface before #125 MVP Surface Reskin.
          </p>
          <p class="plab__context-link">
            <a href={`${primitivesPath}/interaction-states/`}>Open interaction states pass →</a>
            <span>Builds on decision candidates #127 Surfaces, #128 Buttons and #129 Cards.</span>
          </p>
        </section>

        <section class="plab__panel" aria-labelledby="guardrails-heading">
          <p class="plab__kicker">Guardrails</p>
          <h2 id="guardrails-heading">Decision boundaries</h2>
          <ul class="plab__guardrails" role="list">
            {guardrails.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="plab__panel" aria-labelledby="catalog-heading">
          <p class="plab__kicker">Catalog</p>
          <h2 id="catalog-heading">Primitive categories</h2>
          <div class="plab__catalog">
            {primitivePages.map((page) => (
              <article class="plab__card" data-status={page.status}>
                <div class="plab__card-head">
                  <h3>{page.title}</h3>
                  <span class="plab__status">{statusLabels[page.status]}</span>
                </div>
                <p>{page.purpose}</p>
                <div class="plab__favorite">
                  <span>Current favorite</span>
                  <strong>{page.favorite?.name ?? "No favorite yet"}</strong>
                </div>
                <a href={`${primitivesPath}/${page.slug}/`}>Open {page.title} →</a>
              </article>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>

  <style>
    [data-primitives-overview] {
      --p-deep: #134d6a;
      --p-magenta: #ff55b0;
      --p-cyan: #0ea5e9;
      --p-ink: #111827;
      --p-dark: #020617;
      --p-muted: #6b7280;
      --p-border: #e5e7eb;
      --p-light: #ffffff;
      --p-subtle: #f8fafc;
      --p-elevated: #f3f4f6;

      min-height: 100vh;
      max-width: 76rem;
      margin: 0 auto;
      padding: 1.5rem 1rem 3rem;
      background: var(--p-light);
      color: var(--p-ink);
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    }

    .plab__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.1rem;
      font-size: 0.72rem;
      color: var(--p-muted);
    }

    .plab__breadcrumb a,
    .plab__card a {
      color: inherit;
      text-underline-offset: 2px;
    }

    .plab__hero {
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgb(17 24 39 / 0.12);
    }

    .plab__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--p-deep);
    }

    .plab__hero h1,
    .plab__panel h2 {
      margin: 0.35rem 0 0;
      font-family: var(--font-display);
      letter-spacing: -0.045em;
      line-height: 1.05;
    }

    .plab__hero h1 {
      max-width: 50rem;
      font-size: clamp(2rem, 5.5vw, 3.4rem);
    }

    .plab__subtitle,
    .plab__panel > p:not(.plab__kicker),
    .plab__card p {
      color: var(--p-muted);
      line-height: 1.65;
    }

    .plab__subtitle {
      max-width: 46rem;
      margin: 0.8rem 0 0;
      font-size: 0.95rem;
    }

    .plab__meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
      gap: 0.75rem;
      margin: 1.35rem 0 0;
      padding: 1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 12px;
      background: var(--p-subtle);
    }

    .plab__meta dt {
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--p-muted);
    }

    .plab__meta dd {
      margin: 0.2rem 0 0;
      font-size: 0.85rem;
    }

    .plab__context-link {
      max-width: 42rem;
      margin: 1rem 0 0;
      padding: 0.75rem 0.85rem;
      border: 1px solid rgb(19 77 106 / 0.24);
      border-radius: 10px;
      background: rgb(19 77 106 / 0.04);
      font-size: 0.8rem;
      line-height: 1.55;
    }

    .plab__context-link a {
      display: inline-block;
      margin-bottom: 0.25rem;
      color: var(--p-deep);
      font-weight: 800;
      text-decoration: none;
    }

    .plab__context-link span {
      display: block;
      color: var(--p-muted);
    }

    .plab__layout {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.5rem;
    }

    .plab__nav {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding: 0.75rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: var(--p-subtle);
    }

    .plab__nav-title {
      display: none;
    }

    .plab__nav-link {
      flex: 0 0 auto;
      padding: 0.42rem 0.65rem;
      border: 1px solid transparent;
      border-radius: 999px;
      color: var(--p-muted);
      font-size: 0.76rem;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .plab__nav-link--active {
      border-color: rgb(19 77 106 / 0.28);
      background: #fff;
      color: var(--p-deep);
    }

    .plab__content {
      display: grid;
      gap: 1.25rem;
    }

    .plab__panel {
      padding: 1.1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: #fff;
    }

    .plab__panel h2 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
    }

    .plab__guardrails {
      display: grid;
      gap: 0.35rem 1rem;
      margin: 1rem 0 0;
      padding-left: 1.15rem;
      color: var(--p-muted);
      font-size: 0.86rem;
      line-height: 1.65;
    }

    .plab__catalog {
      display: grid;
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .plab__card {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: 1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 12px;
      background: var(--p-subtle);
    }

    .plab__card-head {
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
      justify-content: space-between;
    }

    .plab__card h3,
    .plab__card p {
      margin: 0;
    }

    .plab__card h3 {
      font-size: 0.95rem;
    }

    .plab__status {
      flex: 0 0 auto;
      padding: 0.2rem 0.45rem;
      border-radius: 999px;
      background: #fff;
      color: var(--p-muted);
      font-size: 0.62rem;
      font-weight: 800;
    }

    .plab__card[data-status="favorite"] .plab__status {
      color: var(--p-deep);
      border: 1px solid rgb(19 77 106 / 0.24);
    }

    .plab__card[data-status="recommended"] .plab__status {
      color: var(--p-deep);
      border: 1px solid rgb(19 77 106 / 0.28);
      background: rgb(19 77 106 / 0.06);
    }

    .plab__card[data-status="needsReview"] .plab__status {
      color: #0369a1;
      border: 1px solid rgb(14 165 233 / 0.28);
    }

    .plab__favorite {
      padding-top: 0.75rem;
      border-top: 1px solid rgb(17 24 39 / 0.08);
    }

    .plab__favorite span {
      display: block;
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--p-muted);
    }

    .plab__favorite strong {
      display: block;
      margin-top: 0.2rem;
      font-size: 0.82rem;
    }

    @media (min-width: 640px) {
      [data-primitives-overview] {
        padding: 2rem 1.5rem 4rem;
      }

      .plab__guardrails,
      .plab__catalog {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 900px) {
      .plab__layout {
        grid-template-columns: 14rem minmax(0, 1fr);
        align-items: start;
      }

      .plab__nav {
        position: sticky;
        top: 1rem;
        display: grid;
        overflow: visible;
      }

      .plab__nav-title {
        display: block;
        margin: 0 0 0.35rem;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--p-muted);
      }

      .plab__nav-link {
        border-radius: 8px;
      }

      .plab__catalog {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</PrototypeLayout>
