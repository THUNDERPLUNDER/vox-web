---
/* CONTRACT: VIS-only applied button context review for #128.
   Tests action taxonomy in realistic Viddel scenarios; no production components.
*/
import PrototypeLayout from "../../../../../../../layouts/PrototypeLayout.astro";
import "../../../../../../../styles/global.css";
import { navItems, statusLabels } from "../../_data";

const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;
const primitivesPath = `${sprintPath}/primitives`;
const buttonsPath = `${primitivesPath}/buttons`;

const actionTaxonomy = [
  {
    id: "text-link",
    title: "Text link",
    note: "Quiet editorial reference inside reading flow. Not a CTA.",
  },
  {
    id: "question-pill",
    title: "Question pill / seed question",
    note: "Soft, clickable AI seed — large rounded pill, light surface, subtle border. Feels like a question.",
  },
  {
    id: "primary-pill",
    title: "Primary CTA pill",
    note: "Large pill-shaped, calm black/ink. Restrained type weight and optical vertical centering — not heavier than a ChatGPT-style CTA pill.",
  },
  {
    id: "secondary-pill",
    title: "Secondary pill",
    note: "Large pill-shaped support action. Light gray #EEEEEE, hover toward #DCDCDC.",
  },
  {
    id: "chrome-compact",
    title: "Chrome compact control",
    note: "Small nav/toolbar controls. Not mixed with editorial or action pills.",
  },
  {
    id: "ai-ghost-pill",
    title: "Standalone AI ghost pill",
    note: "Larger ghost pill to start standalone AI. Magenta as micro-signal only — not full fill.",
  },
];

const seedQuestions = [
  "Hva er forskjellen på pip fra apparatet og piping i øret?",
  "Kan jeg gjøre noe selv før jeg kontakter audiograf?",
  "Hvorfor piper høreapparatet mitt hele tiden?",
];

const recommendedDirection = [
  "Text links for editorial references.",
  "Question pills for AI seed questions — match production article pattern (ArticleInlineChatShell progressive seed-row).",
  "Primary CTA candidate: large pill-shaped, calm black/ink, 0.875rem / weight 500, optical vertical centering.",
  "Large light-gray pill for secondary action — not bolder or larger than primary CTA label.",
  "Hub cards should usually be clickable surfaces, not button containers.",
  "Chrome controls should stay compact.",
  "Standalone AI can use a larger ghost/pill button with magenta signal detail.",
  "Seed question pills should match the production article seed-question pattern. CTA and secondary pill labels should stay restrained, but not smaller or heavier than the primary CTA reference.",
];

const styleNotes = {
  production:
    "Production source: src/pages/no/artikkel/[slug].astro + ArticleInlineChatShell (mode=progressive) + src/styles/r1-dialog-article.css (.inline-chat-shell__seed-row / __seed-question).",
  surface:
    "Production light article surface: --article-page-canvas and --reading-paper are both rgb(255 255 255). Seed pill default background is transparent on white paper — not beige. Dark-mode seed treatment must be reviewed separately.",
  tokens:
    "Future semantic token candidates: questionPrompt.label, action.label, cta.label. Not implemented globally in #128.",
};

const surfaceContextNote =
  "Scenario uses production article surface context (reading-paper white). Dark-mode seed question treatment reviewed separately.";

const qaChecklist = [
  "Are seed questions visually distinct from CTA buttons?",
  "Do hub cards work without internal buttons?",
  "Does black/ink primary feel clear but calm — restrained weight, optically centered, not heavier than ChatGPT-style pill?",
  "Does light gray secondary feel useful enough?",
  "Does standalone AI ghost pill feel visible without becoming decorative?",
  "Is magenta only a signal/detail?",
  "Are button sizes and radius closer to the desired large pill direction?",
];
---

<PrototypeLayout title="Buttons applied context - Primitives Lab #128">
  <main class="btnctx" data-button-context-page>
    <nav class="btnctx__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <a href={primitivesPath}>Primitives</a>
      <span aria-hidden="true">/</span>
      <a href={buttonsPath}>Buttons</a>
      <span aria-hidden="true">/</span>
      <span>Context</span>
    </nav>

    <header class="btnctx__hero">
      <p class="btnctx__kicker">VIS-only · #128 · Applied review</p>
      <h1>Action taxonomy in product context</h1>
      <p class="btnctx__subtitle">
        Tests how Viddel actions behave in real scenarios — not as color variants, but as distinct action types
        with size, shape, radius and hierarchy.
      </p>
      <div class="btnctx__hero-status">
        <span>Status</span>
        <strong>{statusLabels.candidate}</strong>
      </div>
    </header>

    <aside class="btnctx__callout" role="note">
      <strong>This context page is the decision surface.</strong>
      <p>
        The main <a href={buttonsPath}>Buttons primitive catalog</a> remains the abstract reference.
        This page tests <em>action taxonomy</em> — text links, question pills, CTA pills, chrome controls
        and standalone AI — inside realistic product contexts.
      </p>
    </aside>

    <div class="btnctx__layout">
      <nav class="btnctx__nav" aria-label="Primitives Lab navigation">
        <a class="btnctx__nav-link" href={primitivesPath}>Overview</a>
        {navItems.map((item) => (
          <a
            class:list={["btnctx__nav-link", item.slug === "buttons" && "btnctx__nav-link--active"]}
            href={`${primitivesPath}/${item.slug}/`}
            aria-current={item.slug === "buttons" ? "page" : undefined}
          >
            {item.title}
          </a>
        ))}
      </nav>

      <div class="btnctx__content">
        <section class="btnctx__panel" aria-labelledby="taxonomy-heading">
          <p class="btnctx__kicker">Action taxonomy</p>
          <h2 id="taxonomy-heading">Six action types to evaluate</h2>
          <p class="btnctx__lead">
            Mental model: separate action roles, not button color variants.
          </p>
          <div class="btnctx__taxonomy">
            {actionTaxonomy.map((item) => (
              <article class="btnctx__taxonomy-item" data-type={item.id}>
                <div class="btnctx__taxonomy-sample" aria-hidden="true">
                  {item.id === "text-link" && <span class="btnctx__text-link">Text link</span>}
                  {item.id === "question-pill" && (
                    <button type="button" class="btnctx__question-pill">
                      <span class="btnctx__question-pill-text">Eksempelspørsmål?</span>
                    </button>
                  )}
                  {item.id === "primary-pill" && (
                    <button type="button" class="btnctx__pill btnctx__pill--primary">Try Viddel</button>
                  )}
                  {item.id === "secondary-pill" && (
                    <button type="button" class="btnctx__pill btnctx__pill--secondary">Secondary</button>
                  )}
                  {item.id === "chrome-compact" && (
                    <button type="button" class="btnctx__chrome-compact">Hubber</button>
                  )}
                  {item.id === "ai-ghost-pill" && (
                    <button type="button" class="btnctx__ai-ghost-pill">
                      <span class="btnctx__ai-ghost-signal" aria-hidden="true"></span>
                      Spør Viddel
                    </button>
                  )}
                </div>
                <h3>{item.title}</h3>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="btnctx__panel" aria-labelledby="editorial-heading">
          <p class="btnctx__kicker">Scenario 01</p>
          <h2 id="editorial-heading">Editorial article context</h2>
          <p class="btnctx__surface-note">{surfaceContextNote}</p>

          <div class="btnctx__sample btnctx__sample--editorial btnctx__sample--article-surface">
            <p class="btnctx__eyebrow">Artikkel · Høreapparat i hverdagen</p>
            <h3>Jeg får piping i høreapparatet</h3>
            <p>
              Piping kan komme plutselig og gjøre det vanskelig å konsentrere deg. Ofte handler det om
              voks, fukt eller feil program.{" "}
              <a href="#" class="btnctx__text-link btnctx__text-link--inline">Les mer om piping</a>{" "}
              i ordboken vår.
            </p>
            <h4>Dette kan du prøve først</h4>
            <ul>
              <li>Rengjør domene og høyttaler med riktig verktøy</li>
              <li>Bytt batteri eller lad opp og test på nytt</li>
              <li>Prøv et roligere program når du er inne</li>
            </ul>
            <div class="btnctx__action-row">
              <span class="btnctx__action-label">Secondary pill</span>
              <button type="button" class="btnctx__pill btnctx__pill--secondary">Lagre til senere</button>
            </div>
            <div class="btnctx__action-row btnctx__action-row--stack">
              <span class="btnctx__action-label">Question pill</span>
              <button type="button" class="btnctx__question-pill">
                <span class="btnctx__question-pill-text">
                  Hva er forskjellen på pip fra apparatet og piping i øret?
                </span>
              </button>
            </div>
          </div>

          <div class="btnctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Can you distinguish text link, secondary pill and question pill without the block feeling
                like a button showroom?
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Text link vs secondary pill vs question pill — which role fits each moment in editorial flow?</p>
            </article>
          </div>
        </section>

        <section class="btnctx__panel" aria-labelledby="ai-heading">
          <p class="btnctx__kicker">Scenario 02</p>
          <h2 id="ai-heading">AI / action transition context</h2>
          <p class="btnctx__surface-note">{surfaceContextNote}</p>

          <div class="btnctx__sample btnctx__sample--ai btnctx__sample--article-surface">
            <div class="btnctx__ai-bridge">
              <div class="btnctx__ai-copy">
                <p class="btnctx__eyebrow">Fra artikkel · piping</p>
                <p>Du leser om piping i høreapparatet. Velg et spørsmål for å starte, eller gå videre på egen hånd.</p>
              </div>
              <div class="btnctx__ai-seeds">
                <p class="btnctx__seed-label">Spør Hørehjelpen:</p>
                <ul class="btnctx__seed-list" role="list">
                  {seedQuestions.map((question) => (
                    <li>
                      <button type="button" class="btnctx__question-pill">
                        <span class="btnctx__question-pill-text">{question}</span>
                      </button>
                    </li>
                  ))}
                </ul>
                <div class="btnctx__ai-standalone">
                  <button type="button" class="btnctx__pill btnctx__pill--secondary btnctx__pill--quiet">
                    Spør videre
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="btnctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Do seed question pills feel like the published pattern — soft, clickable, question-first —
                rather than heavy CTAs on a colored panel?
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Is AI transition primarily seed questions, a CTA, or both? Should “Spør videre” exist at all here?</p>
            </article>
          </div>
        </section>

        <section class="btnctx__panel" aria-labelledby="hub-heading">
          <p class="btnctx__kicker">Scenario 03</p>
          <h2 id="hub-heading">Hub card / navigation context</h2>

          <div class="btnctx__sample btnctx__sample--hub">
            <div class="btnctx__hub-grid">
              <a href="#" class="btnctx__hub-card btnctx__hub-card--live">
                <p class="btnctx__eyebrow">Live hub</p>
                <h3>Bedre lyd i hverdagen</h3>
                <p>Praktiske råd for samtaler, støy og tilpasning i hverdagen.</p>
                <span class="btnctx__hub-cue" aria-hidden="true">→</span>
              </a>
              <a href="#" class="btnctx__hub-card btnctx__hub-card--muted" aria-disabled="true">
                <p class="btnctx__eyebrow">Kommende</p>
                <h3>Relasjoner og samtale</h3>
                <p>Hvordan høreapparatet kan hjelpe i møter, familie og telefonsamtaler.</p>
                <span class="btnctx__hub-cue btnctx__hub-cue--muted">Kommer snart</span>
              </a>
              <a href="#" class="btnctx__hub-card">
                <p class="btnctx__eyebrow">Ordbok</p>
                <h3>Forstå begrepene</h3>
                <p>Korte forklaringer på ord du møter hos audiograf og i egne notater.</p>
                <span class="btnctx__hub-cue" aria-hidden="true">→</span>
              </a>
            </div>
          </div>

          <div class="btnctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Do whole-card click targets help orientation without internal CTA buttons?
                OpenAI-style row/card affordance — subtle arrow or hover, not button soup.
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Card-level click vs explicit button — should hub cards ever contain internal buttons?</p>
            </article>
          </div>
        </section>

        <section class="btnctx__panel" aria-labelledby="chrome-heading">
          <p class="btnctx__kicker">Scenario 04</p>
          <h2 id="chrome-heading">Chrome / glass context</h2>

          <div class="btnctx__sample btnctx__sample--chrome">
            <div class="btnctx__chrome-bar">
              <span class="btnctx__brand">Viddel</span>
              <div class="btnctx__chrome-actions">
                <button type="button" class="btnctx__chrome-compact">Hubber</button>
                <button type="button" class="btnctx__chrome-icon" aria-label="Søk">
                  <span aria-hidden="true">⌕</span>
                </button>
                <button type="button" class="btnctx__chrome-glass">Meny</button>
              </div>
            </div>
            <div class="btnctx__chrome-body">
              <p class="btnctx__chrome-note">Chrome controls stay small and quiet — orient only.</p>
              <div class="btnctx__standalone-ai">
                <span class="btnctx__action-label">Standalone AI ghost pill</span>
                <button type="button" class="btnctx__ai-ghost-pill btnctx__ai-ghost-pill--large">
                  <span class="btnctx__ai-ghost-signal" aria-hidden="true"></span>
                  Åpne Hørehjelpen
                </button>
              </div>
            </div>
          </div>

          <div class="btnctx__notes">
            <article>
              <h4>What to evaluate</h4>
              <p>
                Are compact chrome controls distinct from editorial pills? Does the standalone AI ghost pill
                feel visible with magenta as signal — not decoration or full fill?
              </p>
            </article>
            <article>
              <h4>Decision needed</h4>
              <p>Standalone AI as chrome action vs action layer — where does the larger ghost pill live?</p>
            </article>
          </div>
        </section>

        <section class="btnctx__panel btnctx__panel--direction" aria-labelledby="direction-heading">
          <p class="btnctx__kicker">Recommended direction after QA</p>
          <h2 id="direction-heading">Working hypothesis from Thomas QA</h2>
          <ul class="btnctx__direction-list">
            {recommendedDirection.map((item) => <li>{item}</li>)}
          </ul>
          <div class="btnctx__style-notes">
            <p>{styleNotes.production}</p>
            <p>{styleNotes.surface}</p>
            <p class="btnctx__token-note">{styleNotes.tokens}</p>
          </div>
        </section>

        <section class="btnctx__panel btnctx__panel--checklist" aria-labelledby="qa-heading">
          <p class="btnctx__kicker">QA checklist</p>
          <h2 id="qa-heading">Before moving buttons toward decision candidate</h2>
          <ul class="btnctx__checklist">
            {qaChecklist.map((item) => <li>{item}</li>)}
          </ul>
          <p class="btnctx__back">
            <a href={buttonsPath}>← Back to Buttons primitive catalog</a>
          </p>
        </section>
      </div>
    </div>
  </main>

  <style>
    [data-button-context-page] {
      --p-deep: #134d6a;
      --p-magenta: #ff55b0;
      --p-ink: #111827;
      --p-muted: #6b7280;
      --p-border: #e5e7eb;
      --p-border-strong: #d1d5db;
      --p-light: #ffffff;
      --p-subtle: #f8fafc;
      --p-gray-secondary: #eeeeee;
      --p-gray-hover: #dcdcdc;
      --p-pill-radius: 999px;
      --p-pill-padding-y: 0.72rem;
      --p-pill-padding-x: 1.35rem;
      --p-cta-label-size: 0.875rem;
      --p-cta-label-weight: 500;
      /* Mapped from r1-dialog-article.css progressive seed-row (VIS-local, no global import) */
      /* Production article surfaces (tokens.css values, mapped locally — not imported) */
      --p-prod-article-canvas: #ffffff;
      --p-prod-reading-paper: #ffffff;
      --p-prod-border: 228 224 216;
      --p-prod-ink: 28 32 38;
      --p-prod-seed-radius: 1.15rem;
      --p-prod-seed-hover-surface: rgb(248 250 252 / 0.72);
      --p-prod-seed-measure: min(92%, 32rem);

      min-height: 100vh;
      max-width: 76rem;
      margin: 0 auto;
      padding: 1.5rem 1rem 3rem;
      background: var(--p-light);
      color: var(--p-ink);
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    }

    .btnctx__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.1rem;
      font-size: 0.72rem;
      color: var(--p-muted);
    }

    .btnctx__breadcrumb a {
      color: inherit;
      text-underline-offset: 2px;
    }

    .btnctx__hero {
      padding: 1.5rem 0 1.25rem;
      border-bottom: 1px solid rgb(17 24 39 / 0.12);
    }

    .btnctx__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--p-deep);
    }

    .btnctx__hero h1,
    .btnctx__panel h2 {
      margin: 0.35rem 0 0;
      font-family: var(--font-display);
      letter-spacing: -0.045em;
      line-height: 1.05;
    }

    .btnctx__hero h1 {
      font-size: clamp(2rem, 5.5vw, 3.2rem);
    }

    .btnctx__subtitle,
    .btnctx__lead {
      max-width: 46rem;
      margin: 0.8rem 0 0;
      color: var(--p-muted);
      font-size: 0.95rem;
      line-height: 1.65;
    }

    .btnctx__lead {
      font-size: 0.86rem;
    }

    .btnctx__hero-status {
      display: inline-flex;
      gap: 0.6rem;
      align-items: center;
      margin-top: 1rem;
      padding: 0.35rem 0.6rem;
      border: 1px solid rgb(19 77 106 / 0.24);
      border-radius: 999px;
      background: var(--p-subtle);
      font-size: 0.76rem;
    }

    .btnctx__hero-status span {
      color: var(--p-muted);
    }

    .btnctx__callout {
      margin-top: 1.25rem;
      padding: 0.9rem 1rem;
      border: 1px solid rgb(19 77 106 / 0.28);
      border-radius: 12px;
      background: rgb(19 77 106 / 0.05);
    }

    .btnctx__callout strong {
      display: block;
      font-size: 0.84rem;
    }

    .btnctx__callout p {
      margin: 0.45rem 0 0;
      color: var(--p-muted);
      font-size: 0.84rem;
      line-height: 1.6;
    }

    .btnctx__callout a {
      color: var(--p-deep);
      font-weight: 700;
    }

    .btnctx__layout {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.5rem;
    }

    .btnctx__nav {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding: 0.75rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: var(--p-subtle);
    }

    .btnctx__nav-link {
      flex: 0 0 auto;
      padding: 0.42rem 0.65rem;
      border: 1px solid transparent;
      border-radius: 999px;
      color: var(--p-muted);
      font-size: 0.76rem;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .btnctx__nav-link--active {
      border-color: rgb(19 77 106 / 0.28);
      background: #fff;
      color: var(--p-deep);
    }

    .btnctx__content {
      display: grid;
      gap: 1.25rem;
    }

    .btnctx__panel {
      padding: 1.1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: #fff;
    }

    .btnctx__panel h2 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
    }

    .btnctx__taxonomy {
      display: grid;
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .btnctx__taxonomy-item {
      padding: 0.85rem;
      border: 1px solid rgb(17 24 39 / 0.08);
      border-radius: 10px;
      background: var(--p-subtle);
    }

    .btnctx__taxonomy-item h3 {
      margin: 0.65rem 0 0;
      font-size: 0.88rem;
    }

    .btnctx__taxonomy-item p {
      margin: 0.35rem 0 0;
      color: var(--p-muted);
      font-size: 0.78rem;
      line-height: 1.55;
    }

    .btnctx__taxonomy-sample {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }

    /* Shared action types — CTA labels at 0.875rem / 500; seed pills match production progressive row */
    .btnctx__text-link {
      color: var(--p-deep);
      font-size: 0.875rem;
      font-weight: 500;
      text-decoration: underline;
      text-decoration-color: rgb(19 77 106 / 0.3);
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
    }

    .btnctx__text-link--inline {
      font-weight: 500;
    }

    .btnctx__question-pill {
      display: flex;
      width: var(--p-prod-seed-measure);
      max-width: 32rem;
      align-items: flex-start;
      justify-content: flex-start;
      padding: 0.7rem 0.84rem;
      border: 1px solid rgb(var(--p-prod-border) / 0.32);
      border-radius: var(--p-prod-seed-radius);
      background: transparent;
      color: rgb(var(--p-prod-ink));
      font: inherit;
      text-align: left;
      cursor: default;
      box-shadow: none;
      transition: background-color 140ms ease, border-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
    }

    .btnctx__question-pill-text {
      min-width: 0;
      flex: 1;
      font-size: 0.94rem;
      font-weight: 400;
      line-height: 1.42;
      letter-spacing: -0.006em;
    }

    .btnctx__question-pill:hover {
      border-color: rgb(var(--p-prod-border) / 0.52);
      background: var(--p-prod-seed-hover-surface);
      box-shadow: 0 12px 28px rgb(15 23 42 / 0.08);
      transform: translateY(-1px);
    }

    .btnctx__question-pill:focus-visible {
      outline: 2px solid rgb(14 165 233 / 0.34);
      outline-offset: 2px;
    }

    .btnctx__pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: var(--p-pill-padding-y) var(--p-pill-padding-x);
      border: none;
      border-radius: var(--p-pill-radius);
      font-family: inherit;
      font-size: var(--p-cta-label-size);
      font-weight: var(--p-cta-label-weight);
      line-height: 1;
      cursor: default;
      transition: background-color 140ms ease;
    }

    .btnctx__pill--primary {
      min-height: 2.375rem;
      padding: 0.62rem 1.2rem 0.58rem;
      background: var(--p-ink);
      color: #fff;
      font-size: var(--p-cta-label-size);
      font-weight: var(--p-cta-label-weight);
      letter-spacing: -0.012em;
    }

    .btnctx__pill--secondary {
      min-height: 2.375rem;
      padding: 0.62rem 1.2rem 0.58rem;
      background: var(--p-gray-secondary);
      color: var(--p-ink);
