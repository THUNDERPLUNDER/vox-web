---
/* CONTRACT: VIS-only primitive detail route for #124.
   Generates local catalog pages for primitive candidates; no production token implementation.
*/
import PrototypeLayout from "../../../../../layouts/PrototypeLayout.astro";
import "../../../../../styles/global.css";
import { navItems, primitivePages, statusLabels, type PrimitivePage } from "./_data";

export function getStaticPaths() {
  return primitivePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: PrimitivePage };
const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;
const primitivesPath = `${sprintPath}/primitives`;

const buttonLevels = [
  "Primary",
  "Secondary",
  "Tertiary / ghost",
  "Inline action",
  "AI primary",
  "AI secondary",
  "Icon button",
  "Compact button",
  "Disabled",
  "Loading",
  "Focus state",
  "Dark surface variant",
  "Glass chrome variant",
];
---

<PrototypeLayout title={`${page.title} - Primitives Lab #124`}>
  <main class="plab" data-primitive-page>
    <nav class="plab__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <a href={primitivesPath}>Primitives</a>
      <span aria-hidden="true">/</span>
      <span>{page.title}</span>
    </nav>

    <header class="plab__hero">
      <p class="plab__kicker">VIS-only · #124</p>
      <h1>{page.title}</h1>
      <p class="plab__subtitle">{page.purpose}</p>
      <div class="plab__hero-status">
        <span>Status</span>
        <strong>{statusLabels[page.status]}</strong>
      </div>
    </header>

    <div class="plab__layout">
      <aside class="plab__nav" aria-label="Primitives Lab navigation">
        <p class="plab__nav-title">Primitives</p>
        <a class="plab__nav-link" href={primitivesPath}>Overview</a>
        {navItems.map((item) => (
          <a
            class:list={["plab__nav-link", item.slug === page.slug && "plab__nav-link--active"]}
            href={`${primitivesPath}/${item.slug}/`}
            aria-current={item.slug === page.slug ? "page" : undefined}
          >
            {item.title}
          </a>
        ))}
      </aside>

      <div class="plab__content">
        <section class="plab__panel" aria-labelledby="does-heading">
          <p class="plab__kicker">01</p>
          <h2 id="does-heading">What this primitive does</h2>
          <p>{page.does}</p>
        </section>

        <section class="plab__panel" aria-labelledby="applies-heading">
          <p class="plab__kicker">02</p>
          <h2 id="applies-heading">Where it applies</h2>
          <div class="plab__applies">
            <article><strong>Chrome</strong><p>{page.applies.chrome}</p></article>
            <article><strong>Editorial</strong><p>{page.applies.editorial}</p></article>
            <article><strong>Action / AI</strong><p>{page.applies.action}</p></article>
          </div>
        </section>

        <section class="plab__panel" aria-labelledby="favorite-heading">
          <p class="plab__kicker">03</p>
          <h2 id="favorite-heading">Current favorite</h2>
          {page.favorite ? (
            <article class="plab__favorite-card">
              <div class:list={["plab__sample", `plab__sample--${page.favorite.sample}`]} aria-hidden="true"></div>
              <div>
                <h3>{page.favorite.name}</h3>
                <p>{page.favorite.note}</p>
              </div>
            </article>
          ) : (
            <p>No favorite yet.</p>
          )}
        </section>

        <section class="plab__panel" aria-labelledby="iterations-heading">
          <p class="plab__kicker">04</p>
          <h2 id="iterations-heading">Iterations</h2>
          <div class="plab__iteration-strip" aria-label="Iteration index">
            {page.iterations.map((iteration) => (
              <span data-status={iteration.status}>{iteration.id} · {iteration.status}</span>
            ))}
          </div>
          <div class="plab__iterations">
            {page.iterations.map((iteration) => (
              <article class="plab__iteration" data-status={iteration.status}>
                <header>
                  <span>{iteration.id}</span>
                  <strong>{iteration.status}</strong>
                </header>
                <div class:list={["plab__sample", `plab__sample--${iteration.sample}`]} aria-hidden="true"></div>
                <h3>{iteration.name}</h3>
                <p>{iteration.copy}</p>
                <p class="plab__rationale">{iteration.rationale}</p>
              </article>
            ))}
          </div>
        </section>

        {page.extra === "buttons" && (
          <section class="plab__panel" aria-labelledby="button-levels-heading">
            <p class="plab__kicker">Button structure</p>
            <h2 id="button-levels-heading">Levels to support</h2>
            <div class="plab__button-levels">
              {buttonLevels.map((level) => <span>{level}</span>)}
            </div>
          </section>
        )}

        <section class="plab__panel" aria-labelledby="rules-heading">
          <p class="plab__kicker">05</p>
          <h2 id="rules-heading">Do / Don't</h2>
          <div class="plab__rules">
            <article>
              <h3>Do</h3>
              <ul>{page.do.map((item) => <li>{item}</li>)}</ul>
            </article>
            <article>
              <h3>Don't</h3>
              <ul>{page.dont.map((item) => <li>{item}</li>)}</ul>
            </article>
          </div>
        </section>

        <section class="plab__panel" aria-labelledby="questions-heading">
          <p class="plab__kicker">06</p>
          <h2 id="questions-heading">Open questions</h2>
          <ul class="plab__questions">{page.questions.map((item) => <li>{item}</li>)}</ul>
        </section>
      </div>
    </div>
  </main>

  <style>
    [data-primitive-page] {
      --p-deep: #134d6a;
      --p-magenta: #ff55b0;
      --p-cyan: #0ea5e9;
      --p-ink: #111827;
      --p-dark: #020617;
      --p-dark-panel: #071827;
      --p-muted: #6b7280;
      --p-border: #e5e7eb;
      --p-border-strong: #d1d5db;
      --p-light: #ffffff;
      --p-subtle: #f8fafc;
      --p-elevated: #f3f4f6;

      min-height: 100vh;
      max-width: 76rem;
      margin: 0 auto;
      padding: 1.5rem 1rem 3rem;
      background: var(--p-light);
      color: var(--p-ink);
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    }

    .plab__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.1rem;
      font-size: 0.72rem;
      color: var(--p-muted);
    }

    .plab__breadcrumb a {
      color: inherit;
      text-underline-offset: 2px;
    }

    .plab__hero {
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgb(17 24 39 / 0.12);
    }

    .plab__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--p-deep);
    }

    .plab__hero h1,
    .plab__panel h2 {
      margin: 0.35rem 0 0;
      font-family: var(--font-display);
      letter-spacing: -0.045em;
      line-height: 1.05;
    }

    .plab__hero h1 {
      font-size: clamp(2rem, 5.5vw, 3.4rem);
    }

    .plab__subtitle,
    .plab__panel > p:not(.plab__kicker),
    .plab__applies p,
    .plab__favorite-card p,
    .plab__iteration p {
      color: var(--p-muted);
      line-height: 1.65;
    }

    .plab__subtitle {
      max-width: 46rem;
      margin: 0.8rem 0 0;
      font-size: 0.95rem;
    }

    .plab__hero-status {
      display: inline-flex;
      gap: 0.6rem;
      align-items: center;
      margin-top: 1rem;
      padding: 0.35rem 0.6rem;
      border: 1px solid rgb(19 77 106 / 0.24);
      border-radius: 999px;
      background: var(--p-subtle);
      font-size: 0.76rem;
    }

    .plab__hero-status span {
      color: var(--p-muted);
    }

    .plab__layout {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.5rem;
    }

    .plab__nav {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding: 0.75rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: var(--p-subtle);
    }

    .plab__nav-title {
      display: none;
    }

    .plab__nav-link {
      flex: 0 0 auto;
      padding: 0.42rem 0.65rem;
      border: 1px solid transparent;
      border-radius: 999px;
      color: var(--p-muted);
      font-size: 0.76rem;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .plab__nav-link--active {
      border-color: rgb(19 77 106 / 0.28);
      background: #fff;
      color: var(--p-deep);
    }

    .plab__content {
      display: grid;
      gap: 1.25rem;
    }

    .plab__panel {
      padding: 1.1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: #fff;
    }

    .plab__panel h2 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
    }

    .plab__applies,
    .plab__iterations,
    .plab__rules {
      display: grid;
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .plab__applies article,
    .plab__favorite-card,
    .plab__iteration,
    .plab__rules article {
      padding: 1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 12px;
      background: var(--p-subtle);
    }

    .plab__applies strong,
    .plab__rules h3,
    .plab__favorite-card h3,
    .plab__iteration h3 {
      margin: 0;
      font-size: 0.9rem;
    }

    .plab__favorite-card {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
    }

    .plab__iteration-strip {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      margin-top: 1rem;
      padding-bottom: 0.25rem;
    }

    .plab__iteration-strip span,
    .plab__iteration header strong,
    .plab__button-levels span {
      flex: 0 0 auto;
      padding: 0.25rem 0.5rem;
      border-radius: 999px;
      background: var(--p-elevated);
      color: var(--p-muted);
      font-size: 0.62rem;
      font-weight: 800;
    }

    .plab__iteration-strip span[data-status="Favorite"],
    .plab__iteration[data-status="Favorite"] header strong {
      color: var(--p-deep);
      background: rgb(19 77 106 / 0.08);
    }

    .plab__iteration-strip span[data-status="Rejected"],
    .plab__iteration[data-status="Rejected"] header strong {
      color: #9f1239;
      background: rgb(255 85 176 / 0.09);
    }

    .plab__iteration header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .plab__iteration header span {
      font-weight: 800;
      color: var(--p-deep);
    }

    .plab__rationale {
      margin-top: 0.65rem;
      padding-top: 0.65rem;
      border-top: 1px solid rgb(17 24 39 / 0.08);
      font-size: 0.78rem;
    }

    .plab__sample {
      min-height: 5.25rem;
      border-radius: 12px;
      border: 1px solid rgb(17 24 39 / 0.12);
      background: #fff;
    }

    .plab__sample--neutral-card,
    .plab__sample--card-favorite,
    .plab__sample--surface-light,
    .plab__sample--input-favorite {
      background: #fff;
    }

    .plab__sample--deep-card,
    .plab__sample--surface-deep,
    .plab__sample--surface-favorite,
    .plab__sample--ai-favorite,
    .plab__sample--ai-dark {
      background: linear-gradient(145deg, var(--p-deep), var(--p-dark));
    }

    .plab__sample--signal-card,
    .plab__sample--surface-signal,
    .plab__sample--signal-favorite,
    .plab__sample--signal-dot {
      background:
        radial-gradient(circle at 72% 32%, rgb(255 85 176 / 0.9) 0 5px, transparent 6px),
        linear-gradient(145deg, var(--p-deep), var(--p-dark-panel));
    }

    .plab__sample--rejected-card,
    .plab__sample--signal-rejected,
    .plab__sample--button-magenta,
    .plab__sample--glass-rejected,
    .plab__sample--focus-rejected {
      background: linear-gradient(90deg, var(--p-magenta), rgb(255 85 176 / 0.18));
    }

    .plab__sample--surface-ink {
      background: var(--p-dark);
    }

    .plab__sample--radius-favorite,
    .plab__sample--radius-medium {
      border-radius: 8px;
      background: var(--p-subtle);
    }

    .plab__sample--radius-sharp {
      border-radius: 0;
      background: var(--p-subtle);
    }

    .plab__sample--radius-large {
      border-radius: 18px;
      background: var(--p-subtle);
    }

    .plab__sample--radius-pill {
      min-height: 3rem;
      border-radius: 999px;
      background: var(--p-subtle);
    }

    .plab__sample--stroke-favorite,
    .plab__sample--stroke-subtle {
      border-color: var(--p-border-strong);
    }

    .plab__sample--stroke-deep {
      border: 2px solid var(--p-deep);
    }

    .plab__sample--stroke-focus,
    .plab__sample--focus-favorite,
    .plab__sample--focus-cyan {
      outline: 3px solid rgb(14 165 233 / 0.28);
      border-color: var(--p-cyan);
    }

    .plab__sample--stroke-signal,
    .plab__sample--signal-edge,
    .plab__sample--focus-magenta {
      box-shadow: inset 4px 0 0 var(--p-magenta);
    }

    .plab__sample--button-favorite,
    .plab__sample--button-primary {
      max-width: 10rem;
      min-height: 2.75rem;
      border-radius: 10px;
      background: var(--p-ink);
    }

    .plab__sample--button-ai {
      max-width: 10rem;
      min-height: 2.75rem;
      border-radius: 10px;
      background: var(--p-deep);
      box-shadow: 0 0 0 5px rgb(255 85 176 / 0.1);
    }

    .plab__sample--button-ghost {
      max-width: 10rem;
      min-height: 2.75rem;
      border: 1px solid rgb(19 77 106 / 0.3);
      border-radius: 10px;
      background: transparent;
    }

    .plab__sample--pill-favorite,
    .plab__sample--glass-solid {
      min-height: 3rem;
      border-radius: 999px;
      background: var(--p-subtle);
    }

    .plab__sample--glass-favorite,
    .plab__sample--glass-light {
      background: linear-gradient(135deg, rgb(255 255 255 / 0.72), rgb(248 250 252 / 0.35));
      box-shadow: 0 10px 28px rgb(2 6 23 / 0.1);
    }

    .plab__sample--glass-dark {
      background: linear-gradient(145deg, rgb(2 6 23 / 0.72), rgb(19 77 106 / 0.72));
    }

    .plab__sample--signal-bars {
      background:
        linear-gradient(90deg, transparent 42%, rgb(255 85 176 / 0.9) 42% 45%, transparent 45% 49%, rgb(255 85 176 / 0.75) 49% 53%, transparent 53%),
        linear-gradient(145deg, var(--p-deep), var(--p-dark));
    }

    .plab__sample--ai-transition,
    .plab__sample--ai-seed,
    .plab__sample--ai-helper {
      background: var(--p-subtle);
      border-top: 3px solid var(--p-deep);
    }

    .plab__button-levels {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .plab__rules ul,
    .plab__questions {
      margin: 0.6rem 0 0;
      padding-left: 1.15rem;
      color: var(--p-muted);
      font-size: 0.86rem;
      line-height: 1.65;
    }

    @media (min-width: 640px) {
      [data-primitive-page] {
        padding: 2rem 1.5rem 4rem;
      }

      .plab__applies,
      .plab__iterations,
      .plab__rules {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .plab__favorite-card {
        grid-template-columns: 12rem minmax(0, 1fr);
        align-items: center;
      }
    }

    @media (min-width: 900px) {
      .plab__layout {
        grid-template-columns: 14rem minmax(0, 1fr);
        align-items: start;
      }

      .plab__nav {
        position: sticky;
        top: 1rem;
        display: grid;
        overflow: visible;
      }

      .plab__nav-title {
        display: block;
        margin: 0 0 0.35rem;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--p-muted);
      }

      .plab__nav-link {
        border-radius: 8px;
      }

      .plab__applies {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .plab__iterations {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }
  </style>
</PrototypeLayout>
