---
/* CONTRACT: VIS-only primitive detail route for #124.
   Generates local catalog pages for primitive candidates; no production token implementation.
*/
import PrototypeLayout from "../../../../../layouts/PrototypeLayout.astro";
import "../../../../../styles/global.css";
import { navItems, primitivePages, statusLabels, type PrimitivePage } from "./_data";

export function getStaticPaths() {
  return primitivePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: PrimitivePage };
const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;
const primitivesPath = `${sprintPath}/primitives`;
---

<PrototypeLayout title={`${page.title} - Primitives Lab #124`}>
  <main class="plab" data-primitive-page>
    <nav class="plab__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <a href={primitivesPath}>Primitives</a>
      <span aria-hidden="true">/</span>
      <span>{page.title}</span>
    </nav>

    <header class="plab__hero">
      <p class="plab__kicker">VIS-only · #124</p>
      <h1>{page.title}</h1>
      <p class="plab__subtitle">{page.purpose}</p>
      <div class="plab__hero-status">
        <span>Status</span>
        <strong>{statusLabels[page.status]}</strong>
      </div>
      {page.slug === "buttons" && (
        <p class="plab__context-link">
          <a href={`${primitivesPath}/buttons/context/`}>Applied context review →</a>
          <span>Decision surface for action taxonomy — text links, question pills, CTA pills, chrome and standalone AI — in real Viddel scenarios.</span>
        </p>
      )}
      {page.slug === "cards" && (
        <p class="plab__context-link">
          <a href={`${primitivesPath}/cards/context/`}>Applied context review →</a>
          <span>Decision surface for clickable surfaces — hub cards, article teasers, helper boxes, AI bridge and dark identity — in real Viddel scenarios.</span>
        </p>
      )}
    </header>

    <div class="plab__layout">
      <aside class="plab__nav" aria-label="Primitives Lab navigation">
        <p class="plab__nav-title">Primitives</p>
        <a class="plab__nav-link" href={primitivesPath}>Overview</a>
        {navItems.map((item) => (
          <a
            class:list={["plab__nav-link", item.slug === page.slug && "plab__nav-link--active"]}
            href={`${primitivesPath}/${item.slug}/`}
            aria-current={item.slug === page.slug ? "page" : undefined}
          >
            {item.title}
          </a>
        ))}
      </aside>

      <div class="plab__content">
        <section class="plab__panel" aria-labelledby="does-heading">
          <p class="plab__kicker">01</p>
          <h2 id="does-heading">What this primitive does</h2>
          <p>{page.does}</p>
        </section>

        <section class="plab__panel" aria-labelledby="applies-heading">
          <p class="plab__kicker">02</p>
          <h2 id="applies-heading">Where it applies</h2>
          <div class="plab__applies">
            <article><strong>Chrome</strong><p>{page.applies.chrome}</p></article>
            <article><strong>Editorial</strong><p>{page.applies.editorial}</p></article>
            <article><strong>Action / AI</strong><p>{page.applies.action}</p></article>
          </div>
          {page.suggestedScale && (
            <div class="plab__scale-note" aria-label="Suggested scale">
              <strong>Suggested scale</strong>
              <div>
                {page.suggestedScale.map((item) => <span>{item}</span>)}
              </div>
            </div>
          )}
          {page.tokenNote && <p class="plab__token-note">{page.tokenNote}</p>}
        </section>

        <section class="plab__panel" aria-labelledby="favorite-heading">
          <p class="plab__kicker">03</p>
          <h2 id="favorite-heading">Current favorite</h2>
          {page.favorite ? (
            <article class="plab__favorite-card">
              <div class:list={["plab__sample", `plab__sample--${page.favorite.sample}`]} aria-hidden="true"></div>
              <div>
                <h3>{page.favorite.name}</h3>
                <p>{page.favorite.note}</p>
                {page.favoriteStack && (
                  <div class="plab__surface-stack" aria-label="Recommended surface stack">
                    {page.favoriteStack.map((item) => (
                      <span data-tone={item.tone}>
                        <strong>{item.label}</strong>
                        <code>{item.value}</code>
                      </span>
                    ))}
                  </div>
                )}
                {page.buttonStack && (
                  <div class="plab__button-stack" aria-label="Candidate button stack">
                    {page.buttonStack.map((item) => (
                      <span>
                        <i class:list={["plab__button-mini", `plab__button-mini--${item.sample}`]} aria-hidden="true"></i>
                        <strong>{item.label}</strong>
                        <code>{item.note}</code>
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ) : (
            <p>No favorite yet.</p>
          )}
        </section>

        {page.buttonHierarchy && (
          <section class="plab__panel" aria-labelledby="button-hierarchy-heading">
            <p class="plab__kicker">Button hierarchy</p>
            <h2 id="button-hierarchy-heading">Levels and roles</h2>
            <div class="plab__button-hierarchy">
              {page.buttonHierarchy.map((button) => (
                <article data-status={button.status}>
                  <div class:list={["plab__button-demo", `plab__button-demo--${button.sample}`]} aria-hidden="true">
                    <span></span>
                  </div>
                  <header>
                    <h3>{button.level}</h3>
                    <strong>{button.status}</strong>
                  </header>
                  <p>{button.role}</p>
                  <small>{button.context}</small>
                </article>
              ))}
            </div>
          </section>
        )}

        {page.surfaceRoles && (
          <section class="plab__panel" aria-labelledby="surface-roles-heading">
            <p class="plab__kicker">Surface system</p>
            <h2 id="surface-roles-heading">Surface roles</h2>
            <div class="plab__surface-roles">
              {page.surfaceRoles.map((role) => (
                <article data-tone={role.tone}>
                  <p>{role.title}</p>
                  <strong>{role.candidate}</strong>
                  <span>{role.role}</span>
                </article>
              ))}
            </div>
          </section>
        )}

        {page.surfaceCandidates && (
          <section class="plab__panel" aria-labelledby="surface-candidates-heading">
            <p class="plab__kicker">Comparison</p>
            <h2 id="surface-candidates-heading">Surface hierarchy candidates</h2>
            <div class="plab__surface-candidates">
              {page.surfaceCandidates.map((candidate) => (
                <article data-status={candidate.status}>
                  <header>
                    <span>{candidate.id}</span>
                    <strong>{candidate.status}</strong>
                  </header>
                  <div class:list={["plab__sample", `plab__sample--${candidate.sample}`]} aria-hidden="true"></div>
                  <h3>{candidate.title}</h3>
                  <p>{candidate.copy}</p>
                  <div class="plab__candidate-notes">
                    <div>
                      <h4>Pros</h4>
                      <ul>{candidate.pros.map((item) => <li>{item}</li>)}</ul>
                    </div>
                    <div>
                      <h4>Risk</h4>
                      <ul>{candidate.risks.map((item) => <li>{item}</li>)}</ul>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}

        {page.dependencies && (
          <section class="plab__panel" aria-labelledby="dependencies-heading">
            <p class="plab__kicker">Dependencies</p>
            <h2 id="dependencies-heading">Before #125</h2>
            <div class="plab__dependencies">
              {page.dependencies.map((dependency) => (
                <article>
                  <strong>{dependency.title}</strong>
                  <p>{dependency.note}</p>
                </article>
              ))}
            </div>
          </section>
        )}

        <section class="plab__panel" aria-labelledby="iterations-heading">
          <p class="plab__kicker">04</p>
          <h2 id="iterations-heading">{page.iterationsHeading ?? "Iterations"}</h2>
          {page.roundIntro && <p class="plab__round-note">{page.roundIntro}</p>}
          <div class="plab__iteration-strip" aria-label="Iteration index">
            {page.iterations.map((iteration) => (
              <span data-status={iteration.status}>{iteration.id} · {iteration.status}</span>
            ))}
          </div>
          <div class="plab__iterations">
            {page.iterations.map((iteration) => (
              <article class="plab__iteration" data-status={iteration.status}>
                <header>
                  <span>{iteration.id}</span>
                  <strong>{iteration.status}</strong>
                </header>
                <div class:list={["plab__sample", `plab__sample--${iteration.sample}`]} aria-hidden="true"></div>
                <h3>{iteration.name}</h3>
                <p>{iteration.copy}</p>
                <p class="plab__rationale">{iteration.rationale}</p>
              </article>
            ))}
          </div>
        </section>

        {page.buttonStates && (
          <section class="plab__panel" aria-labelledby="button-states-heading">
            <p class="plab__kicker">States</p>
            <h2 id="button-states-heading">Interaction states</h2>
            <div class="plab__button-states">
              {page.buttonStates.map((state) => (
                <article>
                  <div class:list={["plab__button-demo", `plab__button-demo--${state.sample}`]} aria-hidden="true">
                    <span></span>
                  </div>
                  <h3>{state.state}</h3>
                  <p>{state.note}</p>
                </article>
              ))}
            </div>
          </section>
        )}

        {page.buttonSurfaceBehavior && (
          <section class="plab__panel" aria-labelledby="button-surface-heading">
            <p class="plab__kicker">Surface behavior</p>
            <h2 id="button-surface-heading">Buttons inherit surface roles</h2>
            <div class="plab__button-surfaces">
              {page.buttonSurfaceBehavior.map((surface) => (
                <article>
                  <div class:list={["plab__button-surface-demo", `plab__button-surface-demo--${surface.sample}`]} aria-hidden="true">
                    <span></span>
                  </div>
                  <h3>{surface.surface}</h3>
                  <p>{surface.behavior}</p>
                </article>
              ))}
            </div>
          </section>
        )}

        {page.completionNotes && (
          <section class="plab__panel" aria-labelledby="completion-heading">
            <p class="plab__kicker">Completion note</p>
            <h2 id="completion-heading">{page.completionHeading ?? `What remains before ${page.title.toLowerCase()} are ready`}</h2>
            <ul class="plab__questions">{page.completionNotes.map((item) => <li>{item}</li>)}</ul>
          </section>
        )}

        <section class="plab__panel" aria-labelledby="rules-heading">
          <p class="plab__kicker">05</p>
          <h2 id="rules-heading">Do / Don't</h2>
          <div class="plab__rules">
            <article>
              <h3>Do</h3>
              <ul>{page.do.map((item) => <li>{item}</li>)}</ul>
            </article>
            <article>
              <h3>Don't</h3>
              <ul>{page.dont.map((item) => <li>{item}</li>)}</ul>
            </article>
          </div>
        </section>

        <section class="plab__panel" aria-labelledby="questions-heading">
          <p class="plab__kicker">06</p>
          <h2 id="questions-heading">Open questions</h2>
          <ul class="plab__questions">{page.questions.map((item) => <li>{item}</li>)}</ul>
        </section>
      </div>
    </div>
  </main>

  <style>
    [data-primitive-page] {
      --p-deep: #134d6a;
      --p-magenta: #ff55b0;
      --p-cyan: #0ea5e9;
      --p-ink: #111827;
      --p-dark: #020617;
      --p-dark-panel: #071827;
      --p-muted: #6b7280;
      --p-border: #e5e7eb;
      --p-border-strong: #d1d5db;
      --p-light: #ffffff;
      --p-subtle: #f8fafc;
      --p-elevated: #f3f4f6;

      min-height: 100vh;
      max-width: 76rem;
      margin: 0 auto;
      padding: 1.5rem 1rem 3rem;
      background: var(--p-light);
      color: var(--p-ink);
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    }

    .plab__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.1rem;
      font-size: 0.72rem;
      color: var(--p-muted);
    }

    .plab__breadcrumb a {
      color: inherit;
      text-underline-offset: 2px;
    }

    .plab__hero {
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgb(17 24 39 / 0.12);
    }

    .plab__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--p-deep);
    }

    .plab__hero h1,
    .plab__panel h2 {
      margin: 0.35rem 0 0;
      font-family: var(--font-display);
      letter-spacing: -0.045em;
      line-height: 1.05;
    }

    .plab__hero h1 {
      font-size: clamp(2rem, 5.5vw, 3.4rem);
    }

    .plab__subtitle,
    .plab__panel > p:not(.plab__kicker),
    .plab__applies p,
    .plab__favorite-card p,
    .plab__iteration p {
      color: var(--p-muted);
      line-height: 1.65;
    }

    .plab__subtitle {
      max-width: 46rem;
      margin: 0.8rem 0 0;
      font-size: 0.95rem;
    }

    .plab__hero-status {
      display: inline-flex;
      gap: 0.6rem;
      align-items: center;
      margin-top: 1rem;
      padding: 0.35rem 0.6rem;
      border: 1px solid rgb(19 77 106 / 0.24);
      border-radius: 999px;
      background: var(--p-subtle);
      font-size: 0.76rem;
    }

    .plab__hero-status span {
      color: var(--p-muted);
    }

    .plab__context-link {
      max-width: 42rem;
      margin: 1rem 0 0;
      padding: 0.75rem 0.85rem;
      border: 1px solid rgb(19 77 106 / 0.24);
      border-radius: 10px;
      background: rgb(19 77 106 / 0.04);
      font-size: 0.8rem;
      line-height: 1.55;
    }

    .plab__context-link a {
      display: inline-block;
      margin-bottom: 0.25rem;
      color: var(--p-deep);
      font-weight: 800;
      text-decoration: none;
    }

    .plab__context-link span {
      display: block;
      color: var(--p-muted);
    }

    .plab__layout {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.5rem;
    }

    .plab__nav {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding: 0.75rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: var(--p-subtle);
    }

    .plab__nav-title {
      display: none;
    }

    .plab__nav-link {
      flex: 0 0 auto;
      padding: 0.42rem 0.65rem;
      border: 1px solid transparent;
      border-radius: 999px;
      color: var(--p-muted);
      font-size: 0.76rem;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .plab__nav-link--active {
      border-color: rgb(19 77 106 / 0.28);
      background: #fff;
      color: var(--p-deep);
    }

    .plab__content {
      display: grid;
      gap: 1.25rem;
    }

    .plab__panel {
      padding: 1.1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 14px;
      background: #fff;
    }

    .plab__panel h2 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
    }

    .plab__applies,
    .plab__iterations,
    .plab__rules,
    .plab__surface-roles,
    .plab__surface-candidates,
    .plab__dependencies {
      display: grid;
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .plab__applies article,
    .plab__favorite-card,
    .plab__iteration,
    .plab__rules article,
    .plab__surface-roles article,
    .plab__surface-candidates article,
    .plab__dependencies article {
      padding: 1rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 12px;
      background: var(--p-subtle);
    }

    .plab__scale-note {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid rgb(17 24 39 / 0.08);
    }

    .plab__scale-note strong {
      display: block;
      margin-bottom: 0.55rem;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--p-muted);
    }

    .plab__scale-note div {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
    }

    .plab__scale-note span {
      padding: 0.25rem 0.55rem;
      border: 1px solid rgb(17 24 39 / 0.12);
      border-radius: 999px;
      background: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--p-ink);
    }

    .plab__token-note {
      margin: 1rem 0 0;
      padding: 0.7rem 0.8rem;
      border-left: 3px solid var(--p-deep);
      border-radius: 0 8px 8px 0;
      background: rgb(19 77 106 / 0.05);
      font-size: 0.8rem;
      line-height: 1.55;
      color: var(--p-muted);
    }

    .plab__applies strong,
    .plab__rules h3,
    .plab__favorite-card h3,
    .plab__iteration h3,
    .plab__surface-candidates h3,
    .plab__dependencies strong {
      margin: 0;
      font-size: 0.9rem;
    }

    .plab__surface-stack {
      display: grid;
      gap: 0.4rem;
      margin-top: 0.9rem;
    }

    .plab__surface-stack span {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.75rem;
      align-items: center;
      justify-content: space-between;
      padding: 0.45rem 0.55rem;
      border: 1px solid rgb(17 24 39 / 0.1);
      border-radius: 8px;
      background: #fff;
      font-size: 0.72rem;
    }

    .plab__surface-stack span[data-tone="deep"],
    .plab__surface-stack span[data-tone="ink"] {
      background: var(--p-deep);
      color: #fff;
    }

    .plab__surface-stack span[data-tone="ink"] {
      background: var(--p-dark);
    }

    .plab__surface-stack span[data-tone="signal"] {
      border-color: rgb(255 85 176 / 0.28);
      background: rgb(255 85 176 / 0.06);
    }

    .plab__surface-stack span[data-tone="glass"] {
      background: linear-gradient(135deg, rgb(255 255 255 / 0.72), rgb(248 250 252 / 0.45));
      box-shadow: 0 8px 20px rgb(2 6 23 / 0.06);
    }

    .plab__surface-stack code {
      color: inherit;
      opacity: 0.72;
      font-size: 0.68rem;
    }

    .plab__button-stack {
      display: grid;
      gap: 0.45rem;
      margin-top: 0.9rem;
    }

    .plab__button-stack span {
      display: grid;
      grid-template-columns: 5.75rem minmax(0, 1fr);
      gap: 0.35rem 0.75rem;
      align-items: center;
      padding: 0.45rem 0.55rem;
      border: 1px solid rgb(17 24 39 / 0.1);
      border-radius: 8px;
      background: #fff;
    }

    .plab__button-stack strong {
      margin: 0;
      font-size: 0.75rem;
    }

    .plab__button-stack code {
      grid-column: 2;
      color: var(--p-muted);
      font-size: 0.66rem;
    }

    .plab__button-mini,
    .plab__button-demo span,
    .plab__button-surface-demo span {
      display: inline-block;
      width: 4.75rem;
      height: 1.6rem;
      border-radius: 9px;
      background: var(--p-ink);
    }

    .plab__button-mini--button-secondary,
    .plab__button-demo--button-secondary span {
      border: 1px solid var(--p-border-strong);
      background: #fff;
    }

    .plab__button-mini--button-ghost,
    .plab__button-demo--button-ghost span {
      border: 1px solid rgb(19 77 106 / 0.28);
      background: transparent;
    }

    .plab__button-mini--button-inline,
    .plab__button-demo--button-inline span {
      width: 3.5rem;
      height: 0.9rem;
      border-radius: 0;
      border-bottom: 2px solid var(--p-deep);
      background: transparent;
    }

    .plab__button-mini--button-ai,
    .plab__button-demo--button-ai span,
    .plab__button-demo--button-ai-secondary span {
      background: var(--p-deep);
    }

    .plab__button-demo--button-ai-secondary span {
      border: 1px solid rgb(255 255 255 / 0.7);
      background: rgb(19 77 106 / 0.12);
    }

    .plab__button-demo--button-icon span {
      width: 1.75rem;
      border-radius: 50%;
    }

    .plab__button-demo--button-compact span {
      width: 3.25rem;
      height: 1.25rem;
      border-radius: 999px;
      background: var(--p-ink);
    }

    .plab__button-mini--button-loading,
    .plab__button-demo--button-loading span,
    .plab__button-demo--button-disabled span {
      background: var(--p-elevated);
      border: 1px solid var(--p-border);
    }

    .plab__button-demo--button-focus span {
      outline: 3px solid rgb(14 165 233 / 0.28);
      border: 1px solid var(--p-cyan);
    }

    .plab__button-demo--button-dark span {
      background: #fff;
    }

    .plab__button-demo--button-glass span {
      border: 1px solid rgb(255 255 255 / 0.45);
      background: rgb(255 255 255 / 0.62);
      box-shadow: 0 6px 18px rgb(2 6 23 / 0.08);
    }

    .plab__surface-roles article {
      min-height: 8rem;
    }

    .plab__surface-roles article[data-tone="light"] {
      background: #fff;
    }

    .plab__surface-roles article[data-tone="elevated"] {
      background: var(--p-elevated);
    }

    .plab__surface-roles article[data-tone="deep"] {
      background: var(--p-deep);
      color: #fff;
    }

    .plab__surface-roles article[data-tone="ink"] {
      background: var(--p-dark);
      color: #fff;
    }

    .plab__surface-roles article[data-tone="glass"] {
      background: linear-gradient(135deg, rgb(255 255 255 / 0.72), rgb(248 250 252 / 0.38));
      box-shadow: 0 10px 28px rgb(2 6 23 / 0.08);
    }

    .plab__surface-roles article[data-tone="signal"] {
      border-color: rgb(255 85 176 / 0.28);
      background: rgb(255 85 176 / 0.05);
    }

    .plab__surface-roles p,
    .plab__surface-roles strong,
    .plab__surface-roles span {
      display: block;
      margin: 0;
    }

    .plab__surface-roles p {
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity: 0.72;
    }

