---
/* CONTRACT: VIS-only Color Lab for #122 — restrained signal system review.
   Parent: #126 sprint preview / #120 Design Lock. Not production design.
   Typography premiss from #123: Epilogue display proxy + Inter body/UI (no new fonts).
*/
import PrototypeLayout from "../../../../../layouts/PrototypeLayout.astro";
import "../../../../../styles/global.css";

const base = import.meta.env.BASE_URL;
const sprintPath = `${base}vis/sprints/2026-w21`;

const evalCriteria = [
  "Lesbarhet",
  "Tillit",
  "Viddel-særpreg",
  "Hverdagsenergi",
  "Ikke-spa / ikke-wellness",
  "UI-kontroll",
  "Signal restraint",
];

const articleContent = {
  kicker: "BESLUTNINGSSTØTTE",
  h1: "Audiograf: når det haster, og hva du kan forberede",
  ingress:
    "Noen høreapparatproblemer kan du feilsøke rolig selv. Andre bør vurderes raskt.",
};

const aiTransition = {
  label: "ETTER LESING",
  title: "Hva bør jeg gjøre nå?",
  text: "Beskriv hva som ikke fungerer, så hjelper Viddel deg videre.",
  button: "Få hjelp nå",
};

const heroContent = {
  headline: "Få verden tydeligere tilbake.",
  subline:
    "Viddel hjelper deg å forstå, feilsøke og mestre høreapparatet i hverdagen.",
};

const colorSets = [
  {
    id: "a",
    anchor: "set-a",
    label: "SET A",
    name: "Dyp Nordisk",
    role: "Trygg, autoritær, nordisk og helsefaglig forankret uten å bli klinisk.",
    tokens: [
      { key: "background", label: "background", value: "#FFFFFF" },
      { key: "text", label: "text", value: "#111827" },
      { key: "surface", label: "surface", value: "#F3F4F6" },
      { key: "border", label: "border", value: "#E5E7EB" },
      { key: "primary", label: "primary signal", value: "#0F4C81" },
      { key: "secondary", label: "secondary/focus signal", value: "#0EA5E9" },
    ],
  },
  {
    id: "b",
    anchor: "set-b",
    label: "SET B",
    name: "Skarp Kontrast",
    role: "Høy kontrast, teknisk, presis, svært tydelig.",
    tokens: [
      { key: "background", label: "background", value: "#FFFFFF" },
      { key: "text", label: "text", value: "#000000" },
      { key: "surface", label: "surface", value: "#F4F5F7" },
      { key: "border", label: "border", value: "#D1D5DB" },
      { key: "primary", label: "primary signal", value: "#0055FF" },
      { key: "secondary", label: "secondary/success signal", value: "#10B981" },
    ],
  },
  {
    id: "c",
    anchor: "set-c",
    label: "SET C",
    name: "Monokrom + Varm Action",
    role: "Utfordrer helse-blå. Stram, monokrom base med varm aksent for handling.",
    tokens: [
      { key: "background", label: "background", value: "#FFFFFF" },
      { key: "text", label: "text", value: "#18181B" },
      { key: "surface", label: "surface", value: "#F4F4F5" },
      { key: "border", label: "border", value: "#E4E4E7" },
      { key: "primary", label: "primary signal", value: "#EA580C" },
    ],
  },
  {
    id: "d",
    anchor: "set-d",
    label: "SET D",
    name: "Deep Teal + Magenta Signal",
    role: "Magnific-inspirert utfordrer. Dyp blå/teal base og sterk magenta som energisk signal-linje — ikke creative AI platform.",
    tokens: [
      { key: "background", label: "background", value: "#FFFFFF" },
      { key: "text", label: "text", value: "#111827" },
      { key: "surface", label: "surface", value: "#F3F4F6" },
      { key: "border", label: "border", value: "#E5E7EB" },
      { key: "primary", label: "primary deep signal", value: "#0F4C5C" },
      { key: "secondary", label: "kinetic signal", value: "#EC4899" },
      { key: "tertiary", label: "warm energy (optional)", value: "#F97316" },
    ],
    signalNote: "Magenta used as line/marker only — not fill or gradient.",
  },
];
---

<PrototypeLayout title="Color Lab — #122">
  <main class="clab" data-color-lab>
    <nav class="clab__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <a href={sprintPath}>2026-W21</a>
      <span aria-hidden="true">/</span>
      <span>Color</span>
    </nav>

    <header class="clab__hero">
      <p class="clab__kicker">VIS-only · #122</p>
      <h1>Color Lab — #122</h1>
      <p class="clab__subtitle">Monochrome base + restrained signal systems</p>
      <p class="clab__note">
        Color is under evaluation. This lab tests restrained signal systems in the W21 VIS preview.
        No production tokens are changed.
      </p>

      <dl class="clab__meta">
        <div><dt>Sprint</dt><dd>2026-W21</dd></div>
        <div><dt>Parent</dt><dd>#120</dd></div>
        <div><dt>Preview</dt><dd>#126</dd></div>
        <div><dt>Issue</dt><dd>#122</dd></div>
        <div><dt>Status</dt><dd>Open evaluation</dd></div>
      </dl>

      <div class="clab__criteria">
        <p class="clab__criteria-label">Evaluation criteria</p>
        <ul class="clab__criteria-list" role="list">
          {evalCriteria.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </header>

    <div class="clab__sets">
      {colorSets.map((set) => (
        <article id={set.anchor} class="clab__set" data-set={set.id}>
          <header class="clab__set-head">
            <p class="clab__set-label">{set.label}</p>
            <h2>{set.name}</h2>
            <p class="clab__set-role">{set.role}</p>
            {set.signalNote && <p class="clab__set-note">{set.signalNote}</p>}
          </header>

          <!-- 1. Token swatches -->
          <section class="clab__panel" aria-label="Token swatches">
            <p class="clab__panel-label">Token swatches</p>
            <ul class="clab__swatches" role="list">
              {set.tokens.map((token) => (
                <li class="clab__swatch">
                  <div
                    class="clab__swatch-color"
                    style={`background: ${token.value}`}
                    aria-hidden="true"
                  />
                  <div class="clab__swatch-meta">
                    <strong>{token.label}</strong>
                    <code>{token.value}</code>
                  </div>
                </li>
              ))}
            </ul>
          </section>

          <div class="clab__samples">
            <!-- 2. Article intro -->
            <section class="clab__panel clab__article" aria-label="Article intro">
              <p class="clab__panel-label">Article intro</p>
              <p class="clab__kicker-sample">{articleContent.kicker}</p>
              <h3 class="clab__h1">{articleContent.h1}</h3>
              <p class="clab__ingress">{articleContent.ingress}</p>
            </section>

            <!-- 3. AI transition block -->
            <section class="clab__panel clab__ai" aria-label="AI transition block">
              <p class="clab__panel-label">AI transition block</p>
              <p class="clab__ai-label">{aiTransition.label}</p>
              <p class="clab__ai-title">{aiTransition.title}</p>
              <p class="clab__ai-text">{aiTransition.text}</p>
              <button type="button" class="clab__btn clab__btn--primary">
                {aiTransition.button}
              </button>
            </section>

            <!-- 4. UI primitives -->
            <section class="clab__panel clab__ui" aria-label="UI primitives">
              <p class="clab__panel-label">UI primitives</p>
              <div class="clab__ui-row">
                <button type="button" class="clab__btn clab__btn--primary">Primary button</button>
                <button type="button" class="clab__btn clab__btn--secondary">Secondary button</button>
              </div>
              <div class="clab__ui-row">
                <a href="#" class="clab__link" onclick="return false">Text link</a>
                <span class="clab__pill">Feilsøking</span>
              </div>
              <input
                type="text"
                class="clab__input"
                placeholder="Beskriv problemet kort …"
                aria-label="Input sample"
              />
            </section>

            <!-- 5. Signal marker -->
            <section class="clab__panel clab__marker" aria-label="Signal marker sample">
              <p class="clab__panel-label">Signal marker</p>
              <div class="clab__marker-demo">
                <span class="clab__marker-line" aria-hidden="true" />
                <div class="clab__marker-bars" aria-hidden="true">
                  <span /><span /><span /><span /><span />
                </div>
                <span class="clab__marker-dot" aria-hidden="true" />
              </div>
              <p class="clab__marker-caption">Signal used as line, bar or dot — not fill.</p>
            </section>

            <!-- 6. Mini hero light/dark -->
            <section class="clab__panel clab__hero-pair" aria-label="Mini hero preview">
              <p class="clab__panel-label">Mini hero light / dark</p>
              <div class="clab__hero-grid">
                <div class="clab__hero clab__hero--light">
                  <p class="clab__hero-tag">Light hero</p>
                  <p class="clab__hero-headline">{heroContent.headline}</p>
                  <p class="clab__hero-subline">{heroContent.subline}</p>
                </div>
                <div class="clab__hero clab__hero--dark">
                  <p class="clab__hero-tag">Dark hero</p>
                  <p class="clab__hero-headline">{heroContent.headline}</p>
                  <p class="clab__hero-subline">{heroContent.subline}</p>
                </div>
              </div>
            </section>
          </div>
        </article>
      ))}
    </div>

    <section class="clab__hybrid" aria-labelledby="hybrid-heading">
      <header class="clab__hybrid-head">
        <p class="clab__kicker">Recommended hybrid candidate</p>
        <h2 id="hybrid-heading">A+D — Dyp Nordisk + Kinetic Magenta</h2>
        <p>
          Combines the trust and Nordic authority of Set A with the kinetic signal energy of Set D.
          Magenta is used only as a restrained motion/sound marker, not as a decorative palette.
        </p>
      </header>

      <ul class="clab__hybrid-tokens" role="list" aria-label="Hybrid tokens">
        <li><strong>background</strong><code>#FFFFFF</code></li>
        <li><strong>text</strong><code>#111827</code></li>
        <li><strong>surface</strong><code>#F3F4F6</code></li>
        <li><strong>border</strong><code>#E5E7EB</code></li>
        <li><strong>primary deep</strong><code>#0F4C81 / #0F4C5C</code></li>
        <li><strong>signal magenta</strong><code>#EC4899</code></li>
        <li><strong>focus cyan</strong><code>#0EA5E9 optional</code></li>
        <li><strong>action button</strong><code>monochrome / near-black</code></li>
      </ul>

      <div class="clab__hybrid-rules">
        <div>
          <p class="clab__panel-label">Magenta allowed</p>
          <ul role="list">
            <li>signal line</li>
            <li>audio bars</li>
            <li>focus accent</li>
            <li>tiny dot/marker</li>
            <li>edge/transition indicator</li>
          </ul>
        </div>
        <div>
          <p class="clab__panel-label">Magenta not allowed</p>
          <ul role="list">
            <li>large filled button</li>
            <li>large background</li>
            <li>full gradient</li>
            <li>decorative pink wash</li>
          </ul>
        </div>
      </div>

      <div class="clab__hybrid-grid">
        <!-- 1. Chrome / navigation sample -->
        <section class="clab__hybrid-panel clab__hybrid-panel--wide" aria-label="Chrome navigation sample">
          <p class="clab__panel-label">Chrome / navigation sample</p>
          <div class="clab__mock-chrome">
            <a href="#" class="clab__wordmark" onclick="return false">VIDDEL</a>
            <nav class="clab__mock-nav" aria-label="Hybrid navigation sample">
              <a href="#" onclick="return false">Artikler</a>
              <a href="#" onclick="return false">Feilsøking</a>
              <a href="#" onclick="return false">Om Viddel</a>
            </nav>
            <button type="button" class="clab__mock-action">Få hjelp nå</button>
          </div>
        </section>

        <!-- 2. Editorial article start -->
        <section class="clab__hybrid-panel clab__hybrid-editorial" aria-label="Editorial article start">
          <p class="clab__panel-label">Editorial article start</p>
          <div class="clab__editorial-start">
            <span class="clab__edge-marker" aria-hidden="true"></span>
            <p class="clab__kicker-sample">{articleContent.kicker}</p>
            <h3 class="clab__h1">{articleContent.h1}</h3>
            <p class="clab__ingress">{articleContent.ingress}</p>
          </div>
        </section>

        <!-- 3. Article to AI transition block -->
        <section class="clab__hybrid-panel clab__hybrid-ai" aria-label="Article to AI transition block">
          <p class="clab__panel-label">Article → AI transition block</p>
          <div class="clab__transition-line" aria-hidden="true"></div>
          <p class="clab__ai-label">{aiTransition.label}</p>
          <p class="clab__ai-title">{aiTransition.title}</p>
          <p class="clab__ai-text">{aiTransition.text}</p>
          <div class="clab__ai-form">
            <input type="text" class="clab__input" placeholder="Beskriv problemet kort …" aria-label="Hybrid AI input sample" />
            <button type="button" class="clab__btn clab__btn--primary">Få hjelp nå</button>
          </div>
        </section>

        <!-- 4. Hub card cluster -->
        <section class="clab__hybrid-panel clab__hybrid-panel--wide" aria-label="Hub card cluster">
          <p class="clab__panel-label">Hub card cluster</p>
          <div class="clab__hub-cluster">
            <article class="clab__hub-card clab__hub-card--active">
              <span aria-hidden="true"></span>
              <h3>Få slutt på pipingen</h3>
              <p>Lyd som lekker tilbake kan ofte løses med enkle grep.</p>
            </article>
            <article class="clab__hub-card">
              <span aria-hidden="true"></span>
              <h3>Koble til mobilen</h3>
              <p>Sjekk app, Bluetooth og rekkefølge før du prøver på nytt.</p>
            </article>
            <article class="clab__hub-card">
              <span aria-hidden="true"></span>
              <h3>Bytte filter</h3>
              <p>Et tett filter kan gjøre lyden svakere eller uklar.</p>
            </article>
          </div>
        </section>

        <!-- 5. Photo / image placeholder card -->
        <section class="clab__hybrid-panel" aria-label="Photo energy placeholder">
          <p class="clab__panel-label">Photo / image placeholder card</p>
          <div class="clab__photo-card">
            <div class="clab__photo-placeholder" aria-hidden="true">
              <span></span>
            </div>
            <div class="clab__photo-copy">
              <p>photo energy placeholder</p>
              <strong>Everyday life carries warmth. Color stays controlled around it.</strong>
            </div>
          </div>
        </section>

        <!-- 6. Icon / signal system sample -->
        <section class="clab__hybrid-panel" aria-label="Icon and signal system sample">
          <p class="clab__panel-label">Icon / signal system sample</p>
          <div class="clab__signal-system">
            <div class="clab__hybrid-bars" aria-label="Audio bars">
              <span /><span /><span /><span /><span /><span />
            </div>
            <div class="clab__dot-sequence" aria-label="Dot sequence">
              <span /><span /><span /><span />
            </div>
            <span class="clab__short-line" aria-hidden="true"></span>
            <span class="clab__focus-ring" aria-label="Focus ring sample"></span>
            <span class="clab__ai-spark" aria-label="AI marker sample">AI</span>
          </div>
        </section>

        <!-- 7. Light / dark contrast strip -->
        <section class="clab__hybrid-panel clab__hybrid-panel--wide" aria-label="Light and dark contrast strip">
          <p class="clab__panel-label">Light / dark contrast strip</p>
          <div class="clab__contrast-strip">
            <div class="clab__contrast clab__contrast--light">
              <p class="clab__hero-tag">Light editorial base</p>
              <p class="clab__hero-headline">{heroContent.headline}</p>
              <p class="clab__hero-subline">{heroContent.subline}</p>
            </div>
            <div class="clab__contrast clab__contrast--dark">
              <p class="clab__hero-tag">Dark contrast test</p>
              <p class="clab__hero-headline">{heroContent.headline}</p>
              <p class="clab__hero-subline">{heroContent.subline}</p>
            </div>
          </div>
        </section>
      </div>
    </section>

    <footer class="clab__footer">
      <p>
        Color direction is under evaluation. No production tokens changed in #122.
        Typography premiss from #123: Existing Bold Display — moderated + Inter for body/UI.
      </p>
      <p><a href={sprintPath}>← Back to Sprint Preview 2026-W21</a></p>
    </footer>
  </main>

  <style>
    [data-color-lab] {
      --clab-sans: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
      --clab-display: var(--font-display);

      min-height: 100vh;
      background: rgb(var(--article-page-canvas));
      color: rgb(var(--reading-ink));
      padding: 1.5rem 1rem 3rem;
      max-width: 72rem;
      margin: 0 auto;
      font-family: var(--clab-sans);
    }

    .clab__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.1rem;
      font-size: 0.72rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .clab__breadcrumb a {
      text-decoration: underline;
      text-underline-offset: 2px;
      color: inherit;
    }

    .clab__hero {
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgb(var(--border) / 0.24);
    }

    .clab__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgb(var(--reading-accent-iris));
    }

    .clab__hero > h1 {
      margin: 0.4rem 0 0;
      max-width: 52rem;
      font-family: var(--clab-display);
      font-size: clamp(1.85rem, 5vw, 2.75rem);
      line-height: 1.05;
      letter-spacing: -0.045em;
    }

    .clab__subtitle {
      margin: 0.65rem 0 0;
      font-size: 1rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .clab__note {
      margin: 0.75rem 0 0;
      max-width: 44rem;
      font-size: 0.88rem;
      line-height: 1.65;
      color: rgb(var(--reading-ink-secondary));
    }

    .clab__meta {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(8rem, 1fr));
      gap: 0.65rem 1rem;
      margin: 1.15rem 0 0;
      padding: 0.85rem 1rem;
      border: 1px solid rgb(var(--border) / 0.22);
      border-radius: 8px;
      background: rgb(var(--reading-paper));
    }

    .clab__meta dt {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgb(var(--muted));
    }

    .clab__meta dd {
      margin: 0.15rem 0 0;
      font-size: 0.84rem;
    }

    .clab__criteria {
      margin-top: 1rem;
    }

    .clab__criteria-label {
      margin: 0;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgb(var(--muted));
    }

    .clab__criteria-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.65rem;
      margin: 0.45rem 0 0;
      padding: 0;
      list-style: none;
    }

    .clab__criteria-list li {
      padding: 0.25rem 0.55rem;
      border: 1px solid rgb(var(--border) / 0.35);
      border-radius: 999px;
      font-size: 0.72rem;
      color: rgb(var(--reading-ink-secondary));
      background: rgb(var(--reading-paper));
    }

    .clab__sets {
      display: flex;
      flex-direction: column;
      gap: 3rem;
      padding-top: 2rem;
    }

    .clab__set {
      scroll-margin-top: 4rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid rgb(var(--border) / 0.2);
    }

    .clab__set:last-child {
      border-bottom: 0;
    }

    .clab__set-head h2 {
      margin: 0.2rem 0 0;
      font-family: var(--clab-display);
      font-size: clamp(1.25rem, 3vw, 1.65rem);
      letter-spacing: -0.03em;
      line-height: 1.12;
    }

    .clab__set-label {
      margin: 0;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgb(var(--muted));
    }

    .clab__set-role {
      margin: 0.45rem 0 0;
      max-width: 44rem;
      font-size: 0.86rem;
      line-height: 1.6;
      color: rgb(var(--reading-ink-secondary));
    }

    .clab__set-note {
      margin: 0.5rem 0 0;
      max-width: 44rem;
      padding: 0.5rem 0.75rem;
      border-left: 3px solid rgb(var(--border) / 0.45);
      font-size: 0.78rem;
      font-style: italic;
      line-height: 1.55;
      color: rgb(var(--muted));
    }

    .clab__panel {
      margin-top: 1.15rem;
    }

    .clab__panel-label {
      margin: 0 0 0.55rem;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgb(var(--muted));
    }

    .clab__swatches {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(7.5rem, 1fr));
      gap: 0.55rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .clab__swatch {
      border: 1px solid rgb(var(--border) / 0.22);
      border-radius: 6px;
      overflow: hidden;
      background: rgb(var(--reading-paper));
    }

    .clab__swatch-color {
      height: 2.75rem;
      border-bottom: 1px solid rgb(0 0 0 / 0.06);
    }

    .clab__swatch-meta {
      padding: 0.45rem 0.55rem;
    }

    .clab__swatch-meta strong {
      display: block;
      font-size: 0.68rem;
      font-weight: 600;
    }

    .clab__swatch-meta code {
      display: block;
      margin-top: 0.15rem;
      font-size: 0.62rem;
      color: rgb(var(--muted));
    }

    .clab__samples {
      display: grid;
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .clab__kicker-sample {
      margin: 0 0 0.35rem;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .clab__h1 {
      margin: 0 0 0.45rem;
      font-family: var(--clab-display);
      font-size: clamp(1.35rem, 3.5vw, 1.85rem);
      font-weight: 650;
      letter-spacing: -0.04em;
      line-height: 1.1;
    }

    .clab__ingress {
      margin: 0;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .clab__ai {
      padding: 0.85rem 1rem;
      border-radius: 8px;
    }

    .clab__ai-label {
      margin: 0 0 0.3rem;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .clab__ai-title {
