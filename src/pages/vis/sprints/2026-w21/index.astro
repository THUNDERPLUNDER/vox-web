---
/* CONTRACT: Sprint-specific VIS preview shell for 2026-W21 (#126).
   Test bench for #122 Color tokens, #123 Typography, #124 Primitives.
   #123: Typography Lab at /typography/ — full-width direction review.
   #124: Primitives Lab at /primitives/ — VIS-only primitive candidates.
   #125C: Hub type split at /hub-types/ — closed; Hjelp A3 valgt for utility.
   #125D: Hjelp A3 applied on /no/hub/ — QA accepted, closed.
   #125E: Editorial hub prototype — QA accepted; E2 base for #125F.
   #125F: Lyd i hverdagen production slice at /no/lyd-i-hverdagen/ — QA accepted, closed.
   #125G: Forside/routing at /no/ — QA accepted, closed (#125G-R3 triage mandate).
   #125G-R2: Frontpage mandate decision surface — mandate accepted, applied R3.
   #125H: Navigation / top menu pass — QA accepted, closed (IA/nav-sync). Layout jump → #125I.
   #125I-B-R1: Shell simplification — static header, no content offset; needs review.
   #131B: Stakeholder review entry at /vis/review/.
   Parent sprint: #120 MVP Design Lock v0.1.
*/
import PrototypeLayout from "../../../../layouts/PrototypeLayout.astro";
import "../../../../styles/global.css";

const base = import.meta.env.BASE_URL;

const sprintMeta = {
  sprint: "2026-W21",
  date: "2026-05-19",
  type: "Work note / Preview shell",
  role: "@rigger / Cursor",
  issue: "#126",
  status: "Working preview",
  focus: "MVP Design Lock v0.1",
};

const guardrails = [
  "Viddel Sans = Inter",
  "Viddel Display er åpent",
  "Baseflate = hvit / helt lys ren grå",
  "Varme kommer fra foto og innhold, ikke baseflate",
  "Monokrome knapper fungerer som UI-retning",
  "Lydbuen som bredt UI-/behavior-språk er parkert",
  "Logo-retning er konseptuelt låst, vektor-master utsettes",
];

const anatomyZones = [
  {
    id: "chrome",
    label: "Chrome / navigasjon",
    items: ["header", "global navigasjon", "overordnet orientering"],
  },
  {
    id: "editorial",
    label: "Editorial / innholdsrom",
    items: ["hub", "artikkel", "fagstoff", "lesehierarki"],
  },
  {
    id: "action",
    label: "Action / AI-dialog",
    items: ["seed-spørsmål", "dialoginngang", "hjelpekort", "neste steg"],
  },
];

const colorLabSets = [
  "A. Dyp Nordisk",
  "B. Skarp Kontrast",
  "C. Monokrom + Varm Action",
  "D. Deep Teal + Magenta Signal",
];

const typographyLabDirections = [
  "0. Existing Bold Display — moderated · working decision",
  "1. Signal Sans",
  "2. Tight Sans",
  "3. Editorial Serif",
  "4. Editorial Precision Display",
];
---

<PrototypeLayout title="Sprint Preview — 2026-W21">
  <main class="sprint-preview" data-sprint-preview>
    <nav class="sprint-preview__breadcrumb" aria-label="Du er her">
      <a href={`${base}vis`}>VIS</a>
      <span aria-hidden="true">/</span>
      <span>Sprints</span>
      <span aria-hidden="true">/</span>
      <span>2026-W21</span>
    </nav>

    <!-- 1. Header / status -->
    <header class="sprint-preview__hero">
      <p class="sprint-preview__kicker">VIS / sprint preview</p>
      <p class="sprint-preview__review-link">
        Stakeholder review: <a href={`${base}vis/review/`}>Viddel Review →</a>
      </p>
      <h1>Viddel Sprint Preview — 2026-W21</h1>
      <p class="sprint-preview__subtitle">VIS reviewflate for #120 / #126</p>
      <p class="sprint-preview__focus">
        <span>Sprint focus:</span> {sprintMeta.focus}
      </p>

      <dl class="sprint-preview__meta">
        <div><dt>Sprint</dt><dd>{sprintMeta.sprint}</dd></div>
        <div><dt>Dato</dt><dd>{sprintMeta.date}</dd></div>
        <div><dt>Type</dt><dd>{sprintMeta.type}</dd></div>
        <div><dt>Rolle</dt><dd>{sprintMeta.role}</dd></div>
        <div><dt>Gjelder issue</dt><dd>{sprintMeta.issue}</dd></div>
        <div><dt>Status</dt><dd>{sprintMeta.status}</dd></div>
      </dl>

      <p class="sprint-preview__purpose">
        Teste typography, color tokens og primitives samlet før MVP-reskin.
      </p>
    </header>

    <!-- 2. Sprint scope -->
    <section class="sprint-preview__section" aria-labelledby="scope-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">01</p>
        <h2 id="scope-heading">Sprint scope</h2>
      </div>
      <ul class="sprint-preview__list">
        <li><strong>Parent issue:</strong> #120 MVP Design Lock v0.1</li>
        <li><strong>Preview issue:</strong> #126 VIS design preview</li>
        <li><strong>Testes i preview:</strong> #123 Typography v0.1 · #122 Color tokens v0.1 · #124 Primitives v0.1</li>
        <li><strong>Applied:</strong> #125D Hjelp A3 på <code>/no/hub/</code> — QA-godkjent, closed</li>
        <li><strong>Applied:</strong> #125F Editorial hub på <code>/no/lyd-i-hverdagen/</code> — QA-godkjent, closed</li>
        <li><strong>Applied:</strong> #125G Forside/routing på <code>/no/</code> — QA-godkjent, closed</li>
        <li><strong>Applied:</strong> #125H Nav/toppmeny — QA-godkjent, closed (IA/nav-sync)</li>
        <li><strong>Active:</strong> #125I-B-R1 Shell simplification — static header, needs review</li>
        <li><strong>Neste:</strong> #125I-B Thomas QA, deretter #125I-C Frontpage polish</li>
      </ul>
    </section>

    <!-- 3. Design lock guardrails -->
    <section class="sprint-preview__section" aria-labelledby="guardrails-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">02</p>
        <h2 id="guardrails-heading">Design lock guardrails</h2>
      </div>
      <ul class="sprint-preview__list sprint-preview__list--compact">
        {guardrails.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <!-- 4. Produktanatomi -->
    <section class="sprint-preview__section" aria-labelledby="anatomy-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">03</p>
        <h2 id="anatomy-heading">Produktanatomi</h2>
      </div>
      <div class="sprint-preview__anatomy">
        {anatomyZones.map((zone) => (
          <article class="sprint-preview__anatomy-zone" data-zone={zone.id}>
            <h3>{zone.label}</h3>
            <ul role="list">
              {zone.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
      <blockquote class="sprint-preview__quote">
        Chrome bærer orientering. Editorial layer bærer lesing. AI bærer handling videre fra lesing,
        og skal derfor visuelt slekte på editorial layer, ikke på chrome.
      </blockquote>
    </section>

    <!-- 5. Typography — #123 summary → Typography Lab -->
    <section class="sprint-preview__section" aria-labelledby="typography-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">04 · #123</p>
        <h2 id="typography-heading">Typography — #123</h2>
        <p>Typography direction test moved to full Typography Lab.</p>
      </div>

      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-decision">
          <strong>Working decision:</strong> Existing Bold Display — moderated
        </p>
        <p class="sprint-preview__typo-sans">
          Inter remains Viddel Sans for body, UI and action.
        </p>
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> Working decision recorded in Typography Lab
        </p>
        <ul class="sprint-preview__list sprint-preview__list--compact">
          {typographyLabDirections.map((dir) => (
            <li class:list={[dir.startsWith("0.") && "sprint-preview__typo-direction--working"]}>{dir}</li>
          ))}
        </ul>
        <a href={`${base}vis/sprints/2026-w21/typography/`} class="sprint-preview__typo-link">
          Open full Typography Lab →
        </a>
      </div>
    </section>

    <!-- 6. Color tokens — #122 summary → Color Lab -->
    <section class="sprint-preview__section" aria-labelledby="tokens-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">05 · #122</p>
        <h2 id="tokens-heading">Color tokens — #122</h2>
        <p>Restrained signal systems tested in full Color Lab.</p>
      </div>

      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> #122 Color Lab open
        </p>
        <ul class="sprint-preview__list sprint-preview__list--compact">
          {colorLabSets.map((set) => <li>{set}</li>)}
        </ul>
        <a href={`${base}vis/sprints/2026-w21/color/`} class="sprint-preview__typo-link">
          Open full Color Lab →
        </a>
      </div>
    </section>

    <!-- 7. Primitives preview -->
    <section class="sprint-preview__section" aria-labelledby="primitives-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">06 · #124</p>
        <h2 id="primitives-heading">Primitives preview</h2>
        <p>Primitive candidates now live in the full Primitives Lab.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> #124 Primitives Lab open
        </p>
        <a href={`${base}vis/sprints/2026-w21/primitives/`} class="sprint-preview__typo-link">
          Open full Primitives Lab →
        </a>
      </div>
      <div class="sprint-preview__primitives">
        <div class="sprint-preview__primitive-group">
          <p class="sprint-preview__primitive-label">Buttons</p>
          <div class="sprint-preview__primitive-row">
            <button type="button" class="sprint-preview__btn sprint-preview__btn--primary">Primary button</button>
            <button type="button" class="sprint-preview__btn sprint-preview__btn--secondary">Secondary button</button>
            <button type="button" class="sprint-preview__btn sprint-preview__btn--ghost">Ghost / text button</button>
          </div>
        </div>
        <div class="sprint-preview__primitive-group">
          <p class="sprint-preview__primitive-label">Tag / pill · link · chip</p>
          <div class="sprint-preview__primitive-row">
            <span class="sprint-preview__pill">Feilsøking</span>
            <a href="#" class="sprint-preview__link" onclick="return false">Les mer om piping</a>
            <span class="sprint-preview__chip">Hvorfor piper høreapparatet?</span>
          </div>
        </div>
        <div class="sprint-preview__primitive-group">
          <p class="sprint-preview__primitive-label">Card · input · info box</p>
          <div class="sprint-preview__primitive-stack">
            <div class="sprint-preview__card">
              <p class="sprint-preview__card-kicker">Guide</p>
              <p class="sprint-preview__card-title">Koble høreapparatet til mobilen</p>
            </div>
            <input type="search" class="sprint-preview__input" placeholder="Søk etter problem…" aria-label="Søk placeholder" />
            <div class="sprint-preview__infobox">
              Sjekk batterinivået før du starter feilsøking av Bluetooth.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hub type split (#125C) -->
    <section class="sprint-preview__section" aria-labelledby="hub-types-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">08 · #125C</p>
        <h2 id="hub-types-heading">Hub type split</h2>
        <p>Komplementære hubtyper: Hjelp og editorial — beslutningsflate etter #130 og #125C-R1.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-decision">
          <strong>Decision:</strong> Hjelp A3 valgt for utility-hub. Editorial hub kommer senere.
        </p>
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> Closed — beslutningsflate avsluttet
        </p>
        <a href={`${base}vis/sprints/2026-w21/hub-types/`} class="sprint-preview__typo-link">
          Open hub type comparison (reference) →
        </a>
      </div>
    </section>

    <!-- Hjelp A3 production (#125D) -->
    <section class="sprint-preview__section" aria-labelledby="hjelp-a3-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">09 · #125D</p>
        <h2 id="hjelp-a3-heading">Hjelp A3 production slice</h2>
        <p>Applied utility-hub på produksjon — AI-inngang, oppgavekort, korte guider og eskalering.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> QA accepted / closed
        </p>
        <p class="sprint-preview__typo-sans">
          Videre polish på <code>/no/hub/</code> venter til editorial hub og forside er på plass.
          Darkmode-svakheter observert — parkert til senere eget konsept/sweep, ikke del av #125D.
        </p>
        <a href={`${base}no/hub/`} class="sprint-preview__typo-link">
          Open production Hjelp hub →
        </a>
      </div>
    </section>

    <!-- Editorial hub prototype (#125E) -->
    <section class="sprint-preview__section" aria-labelledby="editorial-hub-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">10 · #125E</p>
        <h2 id="editorial-hub-heading">Editorial hub prototype</h2>
        <p>Lyd i hverdagen — redaksjonell motflate til Hjelp A3. Gjenkjennelse, mestring, situasjoner og videre samtale.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-decision">
          <strong>Decision:</strong> E2 situation-first anbefalt som base for production slice.
        </p>
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> QA accepted / decision candidate — applied som #125F
        </p>
        <p class="sprint-preview__typo-sans">
          To layoutvarianter testet (E1 story-first, E2 situation-first). Navn og rute fortsatt arbeidstittel.
        </p>
        <a href={`${base}vis/sprints/2026-w21/editorial-hub/`} class="sprint-preview__typo-link">
          Open editorial hub prototype (reference) →
        </a>
      </div>
    </section>

    <!-- Lyd i hverdagen production (#125F) -->
    <section class="sprint-preview__section" aria-labelledby="lyd-hverdagen-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">11 · #125F</p>
        <h2 id="lyd-hverdagen-heading">Lyd i hverdagen production slice</h2>
        <p>Første editorial production route — situation-first, artikler og videre samtale med Hørehjelpen.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> QA accepted / closed
        </p>
        <p class="sprint-preview__typo-sans">
          Editorial production slice på <code>/no/lyd-i-hverdagen/</code> er god nok for nå — ikke i toppmeny ennå.
          Videre polish venter til forside/routing og helhetsjustering.
        </p>
        <a href={`${base}no/lyd-i-hverdagen/`} class="sprint-preview__typo-link">
          Open production editorial hub →
        </a>
      </div>
    </section>

    <!-- Forside/routing (#125G) -->
    <section class="sprint-preview__section" aria-labelledby="forside-routing-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">12 · #125G</p>
        <h2 id="forside-routing-heading">Forside / routing</h2>
        <p>Produksjonsforside som ruter tydelig til Hjelp, Lyd i hverdagen og Hørehjelpen.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> QA accepted / closed
        </p>
        <p class="sprint-preview__typo-sans">
          Avklaringsflate / trafikkdirigent på <code>/no/</code> — Hjelp og Lyd i hverdagen som primære
          valg, Hørehjelpen som kompakt fast-track. #125H nav-sync QA-godkjent — layout jump parkert til #125I.
        </p>
        <a href={`${base}no/`} class="sprint-preview__typo-link">
          Open production forside →
        </a>
      </div>
    </section>

    <!-- Frontpage mandate (#125G-R2) -->
    <section class="sprint-preview__section" aria-labelledby="frontpage-mandate-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">13 · #125G-R2</p>
        <h2 id="frontpage-mandate-heading">Frontpage mandate</h2>
        <p>Beslutningsflate — hva skal forsiden være i MVP før videre produksjonspolish?</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> Decision candidate — mandate accepted, applied #125G-R3
        </p>
        <p class="sprint-preview__typo-sans">
          Mandat godkjent: avklaringsflate / triage. Implementert på produksjon — se{" "}
          <a href={`${base}no/`}>/no/</a>.
        </p>
        <a href={`${base}vis/sprints/2026-w21/frontpage-mandate/`} class="sprint-preview__typo-link">
          Open frontpage mandate decision →
        </a>
      </div>
    </section>

    <!-- Navigation / top menu (#125H) -->
    <section class="sprint-preview__section" aria-labelledby="nav-top-menu-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">14 · #125H</p>
        <h2 id="nav-top-menu-heading">Navigation / top menu</h2>
        <p>Toppmeny og footer synket til hubmodellen etter #125G.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> QA accepted / closed
        </p>
        <p class="sprint-preview__typo-sans">
          Primærnav: Forside, Hjelp, Lyd i hverdagen, Ordbok, Om. CTA: Start samtale →{" "}
          <code>/no/chat</code>. Footer synket. Hørehjelpen ikke duplisert som navpunkt og CTA.
        </p>
        <p class="sprint-preview__typo-sans">
          <strong>Known issue:</strong> Synlig layout jump / FOUC ved refresh og globalnav-klikk — ikke introdusert
          av #125H (bekreftet i pre-#125H baseline). Parkert til #125I Cross-surface layout/polish.
        </p>
        <a href={`${base}no/`} class="sprint-preview__typo-link">
          Verify navigation on production →
        </a>
      </div>
    </section>

    <!-- Layout stability / FOUC (#125I-B / R1) -->
    <section class="sprint-preview__section" aria-labelledby="layout-stability-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">15 · #125I-B-R1</p>
        <h2 id="layout-stability-heading">Layout stability / shell simplification</h2>
        <p>Test: header i normal dokumentflyt — ingen fixed header eller content offset padding.</p>
      </div>
      <div class="sprint-preview__typo-summary">
        <p class="sprint-preview__typo-status">
          <strong>Status:</strong> Applied — needs review
        </p>
        <p class="sprint-preview__typo-sans">
          #125I-B shell-first-paint.css revertet. Header <code>relative</code> (ikke fixed); content wrapper uten{" "}
          <code>pt-28</code>/<code>sm:pt-30</code>. Hypotese: fjern fixed+offset-modellen som årsak til synlig snap.
        </p>
        <a href={`${base}no/hub/`} class="sprint-preview__typo-link">
          Verify layout stability on production →
        </a>
      </div>
    </section>

    <!-- 8. Surface composition preview -->
    <section class="sprint-preview__section" aria-labelledby="composition-heading">
      <div class="sprint-preview__section-head">
        <p class="sprint-preview__kicker">07</p>
        <h2 id="composition-heading">Surface composition preview</h2>
        <p>Statiske komposisjoner — ikke produksjonsdesign.</p>
      </div>
      <div class="sprint-preview__compositions">
        <article class="sprint-preview__composition">
          <h3>Hub card cluster</h3>
          <div class="sprint-preview__hub-cluster">
            <div class="sprint-preview__hub-card sprint-preview__hub-card--featured">
              <p class="sprint-preview__hub-card-kicker">Feilsøking</p>
              <p class="sprint-preview__hub-card-title">Få slutt på pipingen</p>
            </div>
            <div class="sprint-preview__hub-card">
              <p class="sprint-preview__hub-card-title">Koble til mobilen</p>
            </div>
            <div class="sprint-preview__hub-card">
              <p class="sprint-preview__hub-card-title">Bytte filter</p>
            </div>
          </div>
        </article>
        <article class="sprint-preview__composition">
          <h3>Article intro block</h3>
          <div class="sprint-preview__article-intro">
            <p class="sprint-preview__article-kicker">Feilsøking</p>
            <p class="sprint-preview__article-h1">Få slutt på pipingen</p>
            <p class="sprint-preview__article-lead">Høreapparatet piper fordi lyd lekker tilbake til mikrofonen.</p>
          </div>
        </article>
        <article class="sprint-preview__composition">
          <h3>Article → AI transition block</h3>
          <div class="sprint-preview__ai-transition">
            <p class="sprint-preview__ai-transition-label">Etter lesing</p>
            <p class="sprint-preview__ai-transition-text">Har du fortsatt piping etter disse stegene?</p>
            <span class="sprint-preview__chip">Spør Hørehjelpen</span>
          </div>
        </article>
      </div>
    </section>

    <!-- 9. Future sprint scalability -->
    <footer class="sprint-preview__footer">
      <p class="sprint-preview__kicker">Note</p>
      <p>This page is a sprint-specific VIS preview.</p>
      <p>Future previews should follow the same pattern: <code>/vis/sprints/YYYY-wXX/</code></p>
      <p>Sprint focus can change from week to week.</p>
    </footer>
  </main>

  <style>
    [data-sprint-preview] {
      min-height: 100vh;
      background: rgb(var(--article-page-canvas));
      color: rgb(var(--reading-ink));
      padding: 1.5rem 1rem 3rem;
      max-width: 72rem;
      margin: 0 auto;
    }

    .sprint-preview__breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
      margin-bottom: 1.1rem;
      font-size: 0.72rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .sprint-preview__breadcrumb a {
      text-decoration: underline;
      text-underline-offset: 2px;
      color: inherit;
    }

    .sprint-preview__hero {
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgb(var(--border) / 0.24);
    }

    .sprint-preview__kicker {
      margin: 0;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgb(var(--reading-accent-iris));
    }

    .sprint-preview__review-link {
      margin: 0.55rem 0 0;
      font-size: 0.78rem;
      color: rgb(var(--reading-ink-secondary));
    }

    .sprint-preview__review-link a {
      font-weight: 600;
      color: rgb(var(--reading-ink));
      text-underline-offset: 2px;
    }

    .sprint-preview__hero h1 {
      margin: 0.4rem 0 0;
      max-width: 52rem;
